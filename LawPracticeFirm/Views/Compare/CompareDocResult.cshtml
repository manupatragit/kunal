@using QueryStringEDAES;
@{
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_ManuPanelPartialClient.cshtml";
    }
    string strurl = QueryAES.UrlDecode(Request.QueryString["u"]);
}
<section class="wrapper">
    <div class="container">
        <h2 class="title">Compare Document Result</h2>
        <input type="button" id="btncompare" value="New Ducuments Compare" onclick="NewFileCompare()" /><br />
        <div class="row">
            <div class="col-md-12">
                <iframe src="@strurl" frameborder="0" width="100%" height="100%" id="frmcompare"></iframe>
            </div>
        </div>
    </div>
    <script>
        function NewFileCompare() {
            window.location.href = "CompareNewDoc";
        }
    </script>
