@{
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
}
<style>
    ul li {
        display: inline;
    }
</style>
<script src="~/Scripts/CW/CaseSuggestion.js" type="text/javascript" language="javascript"></script>
<section class="wrapper">
    <div class="container">
        <div class="row">
            <div class="col-md-6" style="text-align:left;margin-left:-15px;"> <h2 class="title"> Case Suggestion </h2></div>
            <div class="row">
                <div class="search_panel">
                    <div class="col-md-12" style="text-align:left; height:40px;">
                        <input checked="checked" id="rdSC" name="rdcourt" type="radio" value="SC"> Supreme Court
                        &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<input id="rdHC" name="rdcourt" type="radio" value=""> High Court
                        &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                        <input id="rdDC" name="rdcourt" type="radio" value=""> District Court
                    </div>
                    <input type="hidden" value="1" id="hdnRadioType">
                    <input type="hidden" value="SC" id="vcode">
                    <input type="hidden" value="SC" id="scid">
                    <input type="hidden" value="" id="hcid">
                    <input type="hidden" value="" id="dcid">
                </div>
                <div class="col-md-12" align="center">
                    <section class="panel">
                        <div id="divsearchbypartyname" class="table-panel table-responsive" style="overflow-y:scroll;overflow-x:scroll;"></div>
                    </section>
                </div>
            </div>
            <div style="margin-top:10px;">
                <div id="divsearchbypartyname" class="table-panel table-responsive" style="overflow-x:auto"></div>
                <div class="row settingpanel">
                    <ul>
                        <li>
                            <div id="ptfooter" style="float:left;margin-top:5px;margin-left:5px;"></div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <div id="myModal" class="modal fade" role="dialog" data-backdrop="static" data-keyboard="false">
            <div class="modal-dialog " style="width:60%">
                <div class="modal-content">
                    <div class="modal-header btn-success">
                        <button type="button" class="close" data-dismiss="modal">&times;</button>
                        <h4 class="modal-title">
                            case details
                        </h4>
                    </div>
                    <!-- Modal content-->
                    <div class="modal-content mymodels" id="mymodels" style="margin-top:10px;">
                        <div class="table-panel table-responsive" style="overflow-x:scroll;">
                            <table style="overflow-x:auto;" class="table table-bordered table-striped">
                                <thead>
                                    <tr>
                                        <th>Appeal No</th>
                                        <th>Court Name</th>
                                        <th>Applent/Respondent</th>
                                        <th>Counsels</th>
                                        <th>District Name</th>
                                    </tr>
                                </thead>
                                <tbody id="bindappeal"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
