            <div class="modal-header btn-success">
                <button type="button" class="close" data-dismiss="modal">×</button>
                <div class="modaltitle" style="border-bottom:none;">
                    <h4>
                        Update the To Do Task Status
                    </h4>

                </div>
            </div>
            <div class="modal-body">
                @*<p style="color: #000; padding: 3px; border-radius: 5px; text-align: center; font-size: 24px; font-weight:bold; margin:0;">Update the To Do Task Status</p>*@
