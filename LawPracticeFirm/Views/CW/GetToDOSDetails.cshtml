
@{
    /**/
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_ManuPanelPartialClient.cshtml";
    }
}

<style>
    .modal-body {
        width: 100%;
        overflow-y: auto;
        padding: 1px;
    }

    .modal_a {
        position: fixed;
        z-index: 1;
        padding-top: 70px;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: auto;
        background-color: rgb(0,0,0);
        background-color: rgba(0,0,0,0.4);
    }

    .modal_a-content {
        background-color: #fefefe;
        margin: auto;
        padding: 10px 8px;
        border: 1px solid #000;
        border-radius: 5px;
        width: 50%;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 16px;
    }

    .close_a {
        color: #fff;
        font-size: 20px;
        font-weight: bold;
        background: #1860a3;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        text-align: center;
        padding: 3px 0 0 0px;
        position: relative !important;
        right: -11px !important;
        top: -13px !important;
        float: right !important;
    }

        .close_a:hover, .close_a:focus {
            color: #000;
            text-decoration: none;
            cursor: pointer;
        }

    .divnotes {
        margin: 10px auto 0;
        padding: 0;
        width: 100%;
    }

    .todo_txtbox {
        width: 100%;
        margin: 6px 0 0 0 !important;
        height: 300px !important;
        border: none;
        border-radius: 15px !important;
    }

    .sbtn {
        padding: 2px 14px;
        border: 2px solid #4d95dd;
        color: #ffffff;
        font-size: 13px;
        background: #4d95dd;
        border-radius: 20px;
        cursor: pointer;
    }

    .spacer_todo {
        min-height: 443px;
    }

    a {
        font-weight: unset !important;
    }
</style>

