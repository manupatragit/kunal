<script>
    $(document).ready(function () {
        $("#ColumnSelectionopen").click(function () {
            $("#myModalCustomizedcolumn").modal('show'); // Opens the modal
        });

        $(document).click(function (event) {
            if ($(event.target).is(".myModal")) {
                $("#myModalCustomizedcolumn").modal('hide'); // Closes the modal
            }
        });
    });

    $(document).ready(function () {
        $('.modal .close').click(function () {
            $('#myModalNotespopup').hide();
            $('body').removeClass('modal-open'); // Remove modal-open class from body
            $('.modal-backdrop').remove(); // Remove the backdrop if any
        });
    });

</script>
