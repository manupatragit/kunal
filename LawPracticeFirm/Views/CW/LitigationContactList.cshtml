                </div>
            </div>
            <div class="modal-body">

                <div class="row">
                    <div class="col-md-12" style="overflow-y:scroll; margin-top:15px; max-height:420px;">
                        <ul id="od">
                            <li><input type="checkbox" value="lName" class="chkChartsetting chkdhide" name="lName" checked><a href="#" class="dropdown-item">Name</a></li>
                            <li><input type="checkbox" value="lMobile" class="chkChartsetting chkdhide" name="lMobile" checked><a href="#" class="dropdown-item">Mobile</a></li>
                            <li><input type="checkbox" value="lEmail" class="chkChartsetting chkdhide" name="lEmail" checked><a href="#" class="dropdown-item">Email</a></li>
                            <li><input type="checkbox" value="lhomeaddress" class="chkChartsetting chkdhide" name="lhomeaddress"><a href="#" class="dropdown-item">Home Address</a></li>
                            <li><input type="checkbox" value="lofficename" class="chkChartsetting chkdhide" name="lofficename" checked><a href="#">Office Name</a></li>
                            <li><input type="checkbox" value="lofficeaddress" class="chkChartsetting chkdhide" name="lofficeaddress" checked><a href="#">Office Address</a></li>
                            <li><input type="checkbox" value="lalternatemob" class="chkChartsetting chkdhide" name="lalternatemob"><a href="#" class="dropdown-item">Alternate Mobile</a></li>
                            <li><input type="checkbox" value="lOrgnization" class="chkChartsetting chkdhide" name="lOrgnization"><a href="#" class="dropdown-item">Organization Name</a></li>


                        </ul>

                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<div id="myModalpopup" class="modal fade" role="dialog" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog " style="width:670px">
        <div class="modal-content">
            <div class="modal-header btn-success">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">
                    Add/Update Contact
                </h4>
            </div>
            <!-- Modal content-->
            <div class="modal-body" id="mymodels">
                <table cellspacing="0" cellpadding="0" width="100%" align="center">
                    <tbody>
                        <tr>
                            <td><label>Name</label><span class="required" aria-required="true"><b>*</b><input type="text" class="form-control inputFormatnav" placeholder="Enter Full Name" name="txtFullName" id="txtFullName" maxlength="20"></td>
                            <td width="30px">&nbsp;</td>
                            <td><label>Home Address</label><input type="text" class="form-control inputFormatnav" placeholder="Home Address" name="txthome" id="txthome" maxlength="200"></td>
                        </tr>
                        <tr>
                            <td><label>Mobile</label><span class="required" aria-required="true"><b>*</b><input type="text" class="form-control inputFormatnav" placeholder="Mobile No" pattern="[6789][0-9]{9}" name="txtMobile" id="txtMobile" maxlength="10"></td>
                            <td>&nbsp;</td>
                            <td><label>Office Name</label><input type="text" class="form-control inputFormatnav" placeholder="Office" name="txtoffice" id="txtoffice" maxlength="200"></td>
                        </tr>
                        <tr>
                            <td><label>Email</label><span class="required" aria-required="true"><b>*</b><input type="email" class="form-control inputFormatnav" placeholder="Email" name="txtEmail" id="txtEmail" maxlength="150"></td>
                            @*<td><label>Fax</label><input type="text" class="form-control inputFormat" placeholder="Fax No" name="txtFax" id="txtFax" maxlength="15"></td>*@
                            <td>&nbsp;</td>
                            <td><label>Alternate Mobile No</label><input type="text" class="form-control inputFormatnav" maxlength="10" placeholder="Alternate Mobile No" name="txthomephoneno" id="txthomephoneno" maxlength="21"></td>
                        </tr>
                        <tr>
                            <td><label>Office Address</label><input type="text" class="form-control inputFormatnav" placeholder="Office Address" name="txtAddress" id="txtAddress" maxlength="200"></td>
                            <td>&nbsp;</td>
                            <td><label>Orgnization</label><input type="text" class="form-control inputFormatnav" placeholder="Orgnization" name="txtOrgnization" id="txtOrgnization" maxlength="50"></td>
                        </tr>
                        @*<tr>
                                <td><label>Website</label><input type="text" class="form-control inputFormat" placeholder="Website" name="txtWebsite" id="txtWebsite" maxlength="30"></td>
                                <td>
                                </td>
                                <td><label>Orgnization</label><input type="text" class="form-control inputFormat" placeholder="Orgnization" name="txtOrgnization" id="txtOrgnization" maxlength="50"></td>
                            </tr>*@
                        <tr>

                            <td colspan="3" class="text-right" style="padding: 20px 0;">
                                <input type="hidden" id="hdniid" value="0" />
                                <button class="btn btn-primary" type="submit" name="submit" value="Submit" onclick="return validation();">Submit</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
                <div id="sbtn">
                </div>
            </div>
        </div>
    </div>
</div>

