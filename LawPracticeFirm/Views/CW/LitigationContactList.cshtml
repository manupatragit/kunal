                                <button class="btn btn-primary" id="btnAddUserModal">Add New Contact</button>
                            </div>
                            <div class="menuexport" style="position:relative; cursor:pointer;">
                                <div class="dropdown-toggle button9" id="menuexport" type="button" data-toggle="dropdown" title="Export">
                                    <img class="plus-icon" alt="" src="/newassets/img/upload-icon.png">
                                </div>
                                <ul class="dropdown-menu action-more" role="menu" aria-labelledby="menuexport">
                                    <li>
                                        <div id="exporttoexcel" title="Export to Excel"><span style="padding: 0 10px 0 0;"><img src="/newassets/img/exportexl-icon.png"></span> Export to Excel</div>
                                    </li>

                                </ul>

                            </div>
                            <div class="button13" id="CustSelectionopen" title="Column Selection">
                                <img class="plus-icon" alt="" src="/newassets/img/settings-icon.png">
                                <div class="text-padding">
                                    <div class="text1"><a href="javascript:void()"> Customize</a></div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
            <div class="tablearea">
                <div class="tablecontainer">
                    <div class="table-panel" id="allcasediv">
                        <table id="allcaselisttable" class="table-panel" role="grid" aria-describedby="example_info">
                            <thead width="100%">
                                <tr role="row">
                                    <th class="lName"><div class="thbg">Name</div></th>
                                    <th class="lMobile"><div class="thbg">Mobile</div></th>
                                    <th class="lEmail"><div class="thbg">Email</div></th>
                                    <th class="lhomeaddress"><div class="thbg">Home Address</div></th>
                                    <th class="lofficename"><div class="thbg">Office Name</div></th>
                                    <th class="lofficeaddress"><div class="thbg">Office Address</div></th>
                                    <th class="lalternatemob"><div class="thbg">Alternate Mobile</div></th>
                                    <th class="lOrgnization"><div class="thbg">Organization Name</div></th>
                                    @*<th class="lwebsite" width="10%">Website</th>*@
                                    <th width="100px"><div class="thbg">Action</div></th>
                                </tr>
                            </thead>
                            <tbody id="alldatabindcontactlist"></tbody>
                        </table>

                    </div>

                    <center>

                        <div class="notfound" id="pdatastatus" style="display:none;">
                            <img src="/newassets/img/not-found.png">
                            <h4>No Matter list found</h4>
                            <p>We found no matter list.</p>
                        </div>
                    </center>
                </div>

            </div>
            <div class="pagination" id="pagenatedArea">
                <div class="pagination-button-group">
                    <div id="prev" class="pagination-button-group-base">
                        <img class="arrow-left-icon" alt="" src="/newassets/img/pre-arrow.png" style="width:16px; height:16px;">
                        <div class="text" style="float:right; padding:0 0 0 8px;">Previous</div>
                    </div>
                    <div id="pageNumbers" class="pagination-button-group-base1">
                    </div>

                    <div id="next" class="pagination-button-group-base8">
                        <div class="text" style="float: left;padding: 0 8px 0 0px;">Next</div>
                        <img style="float: right; width: 16px; height: 16px;" class="arrow-left-icon" alt="" src="/newassets/img/next-arrow.png" />

                    </div>
                </div>
                <div class="text-and-supporting-text-parent">
                    <div class="input">
                        <div class="content">
                            <input type="text" id="txtgopage" name="query" placeholder="Page No.">
                        </div>
                        <div class="help-icon">
                        </div>
                    </div>
                    <div class="text-and-supporting-text-group">
                        <div class="text-and-supporting-text">
                            <div id="divGo" class="text9">Go</div>
                        </div>
                        <img class="chevron-down-icon" alt="" src="~/newassets/img/next-arrow.png" style="width:16px; height:16px;">

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


