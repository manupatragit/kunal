@*Fill NCDRC state by crt id and bench id*@
    function fillNCDRCState(crtid, benchid) {
        var idist = 0;
        if (benchid == "E") {
            $("#drpncdrcstate").html("");
            document.getElementById('divncdrcDistrict').style.display = "block";
            idist = 1;
        }
        else {
            document.getElementById('divncdrcDistrict').style.display = "none";
        }
        $("#drpncdrcstate").html("");
        $("#drpncdrcstate").empty;
        $.ajax({
            type: "POST",
            url: "/AddCase/AddFillTriDistrictState?courtid=" + crtid + "&courttype=" + document.getElementById("divSCHCDistrict").value + "&iDistrict=" + idist,
            dataType: "json",
            success: function (data) {
                $("#drpncdrcstate").append("<option value='0'>-Select the state.-</option>");
                for (var i = 0; i < data.length; i++) {
                    $("#drpncdrcstate").append("<option value='" + data[i].Stateid + "'>" + data[i].Statename + "</option>");
                }
            },
            error: function (data) {
            }
        });
    }
@*Bind NCDRC district by state id*@
