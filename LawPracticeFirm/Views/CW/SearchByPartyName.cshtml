<style>
    .courtlabel {
        font-size: 12px !important;
        font-weight: 500;
        border: 1px solid #D1D5DB;
        border-radius: 6px;
        padding: 1px;
        color: #4B5563;
        width: max-content;
        display: inline-block;
    }

    ul li {
        display: inline;
    }

    .action-btn {
        background-color: #fff;
        border: 1px solid #D1D5DB;
        padding: 5px 8px;
        cursor: pointer;
        font-weight: normal;
        font-size: 19px;
        line-height: 1;
        border-radius: 8px;
        color: #9CA3AF;
    }
        /* Optional hover effect for button */
        .action-btn:hover {
            background-color: #f0f0f0;
        }

    .ms-options-wrap button {
        width: 100% !important;
        padding:7px 3px !important;
        border: none !important;
        border-radius: 4px !important;
        font-size: 16px !important;
    }

    .search-button {
        border: 0;
        padding: 0;
        margin-right: 9px;
        background: none;
        margin-top: -28px;
        float: right;
    }
    .modal-content .form-group {
        height: 65px;
    }
    #info-wrapper-1 {
        position: relative;
        display: inline-block;
    }

    #info-icon-1 {
        cursor: pointer;
        margin-left: 5px;
    }

    #info-text-1 {
        display: none;
        position: absolute;
        top: 26px;
        left: 0;
        width: 360px;
        background: white;
        border: 1px solid rgb(143, 213, 0);
        padding: 4px;
        z-index: 1000;
    }

    /* Show text on hover of the wrapper */
    #info-wrapper-1:hover #info-text-1 {
        display: block;
    }

</style>
