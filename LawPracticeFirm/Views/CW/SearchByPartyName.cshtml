<script>
    $("#txtApplent").on("keypress", function (e) {

        var charCode = e.which;

        // Allow: A-Z, a-z, 0-9, space
        if (
            !(charCode >= 48 && charCode <= 57) && // 0-9
            !(charCode >= 65 && charCode <= 90) && // A-Z
            !(charCode >= 97 && charCode <= 122) && // a-z
            charCode !== 32 // space
        ) {
            e.preventDefault();
        }
    });
