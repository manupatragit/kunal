                }
            },
            error: function (data) {
            }
        });
    }
@*Get case type details*@
    function getCasetype(crtid, bench, side, vcourttitle) {
        if (crtid == 'TN' && bench == '') {
            document.getElementById('divTNBench').value = '';
            return;
        }
        if (crtid == 'RH' && bench == '') {
            document.getElementById('divRHBench').value = '';
            return;
        }
        if (crtid == 'JK' && bench == '') {
            document.getElementById('divJKBench').value = '';
            return;
        }
        if (crtid == 'NC' && bench == '') {
            document.getElementById('drpNCBench').value = '';
            return;
        }
        if (crtid == 'UP' && bench == '') {
            document.getElementById('divUPBench').value = '';
            return;
        }
        if (crtid == 'GH' && bench == '') {
            document.getElementById('divGHBench').value = '';
            return;
        }
        if (crtid == 'WB' && bench == '') {
            document.getElementById('divWBBench').value = '';
            return;
        }
        if (crtid == "NL") {
            setTimeout(function () {
                var benchs = document.getElementById("drpNCBench").value;
                GetNCCaseTyep(crtid, "", benchs)
            }, 3000);

        }
        if (crtid != "MH" && crtid != "TN" && crtid != "RH" && crtid != "UP" && crtid != "GH" && crtid != "JK" && crtid != "BH" && crtid != "MP" && crtid != "NC" && crtid != "CE" && crtid != "IT" && crtid != "DT"
            && crtid != "CT" && crtid != "CI" && crtid != "RC" && crtid != "WB" && crtid != "NL") {
            $("#drptype").empty();
            $.ajax({
                type: "POST",
                url: "/AddCase/Addcasetype?crtid=" + crtid + "&courttitle=" + vcourttitle + "&side=" + side,
                dataType: "json",
                success: function (data) {
                    $("#drptype").append("<option value='0'>Select Matter Type</option>");
                    for (var i = 0; i < data.length; i++) {
                        $("#drptype").append("<option value='" + data[i].casetype + "'>" + data[i].casetypename + "</option>");
                    }
                },
                error: function (data) {
                }
            });
        }
        else {
            if (vcourttitle != 'Goa' && bench == '') {
                document.getElementById('drpbench').innerHtml = "";
                $("#drpbench").empty;
                $.ajax({
                    type: "POST",
                    url: "/AddCase/GetBenchName?crtid=" + crtid,
                    dataType: "json",
                    success: function (data) {
                        $("#drpbench").empty;
                        $("#drpbench").append("<option value='0'>-Select Bench / Type-</option>");
                        for (var i = 0; i < data.length; i++) {
                            $("#drpbench").append("<option value='" + data[i].casetype + "'>" + data[i].casetypename + "</option>");
                        }
                    },
                    error: function (data) {
                    }
                });
            }
            else {
              //  $("#drpbench").empty;
                if (bench == "Goa") {
                    vcourttitle = bench;
                }
                $.ajax({
                    type: "POST",
                    url: "/AddCase/Addcasetype?crtid=" + crtid + "&courttitle=" + vcourttitle + "&bench=" + bench + "&side=" + side,
                    dataType: "json",
