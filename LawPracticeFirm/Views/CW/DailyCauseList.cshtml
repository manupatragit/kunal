<!DOCTYPE html>
@{
    /**/
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_ManuPanelPartialClient.cshtml";
    }
    var strcurdate = DateTime.Now.ToString("dd MMM yyyy");
    var firmcode121 = Session["FirmCode"];
}
@using NJDGDetail.Models;
@{
    var firmcode = Request.Url.Segments[1];
}
<style>
    ul li {
        display: inline;
    }
</style>
<script>
    var hsmklitigation = "@Session["hsmklitigation"]";
    var dashmatter ="@Session["dashmatter"]";
    var roleids = "@role";
    if (hsmklitigation == "display:unset" && dashmatter == "display:unset") {
        $(".litigationrera").show();
    }
    else if (hsmklitigation == "display:unset" && dashmatter == "display:none") {
        $('.litigationrera').hide();
    }
    else {
        $(".litigationrera").show();
    }
</script>
<link href="~/panelDesign/vendor/datatables-plugins/dataTables.bootstrap.css" rel="stylesheet">
