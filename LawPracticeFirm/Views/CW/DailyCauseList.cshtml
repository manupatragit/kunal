<section id="header">
    <div class="container-main">
        <div class="text-left">
            <p class="ctitle"> Cause List</p>
        </div>
    </div>
</section>
<section class="wrapper">
    <input type="hidden" id="hdnusercaseid" value="0" />
    <div class="container-main">
        <div class="formbg">

            <div class="row form-group">
                <div class="tab-pane active" id="a111">
                    <div class="row">
                        <div class="col-md-3">
                            <label>Select Court Type</label>
                            <select name="courtType1" id="ocasedata1" class="form-control selctInputFormat" style="background-color: white !important;">
                                <option value="0">Select Court</option>
                                <option value="1" selected="selected"> Supreme Court</option>
                                <option value="2"> High Court</option>
                                <option value="4">Tribunal</option>
                                <option value="3"> District Court</option>
                                <option value="7">Rera</option>
                                <option value="RERH">Revenue</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label>Date</label>
                            <input type="date" class="inputFormat" id="casedate" name="casedate">
                        </div>
                        <div class="col-md-2">

                            <button type="submit" class="btn btn-primary" id="getcauselist" name="getcauselist" style="margin:26px 0 0 0;">Search</button>
                        </div>
                        <div class="col-md-4">
                            <div class="actions3" style="margin:26px 0 0 0; position: relative; justify-content: flex-end;">
                                <div class="dropdown-toggle button13" id="menuexport" type="button" data-toggle="dropdown" title="Export">
                                    <img class="plus-icon" alt="" src="/newassets/img/upload-icon.png">

                                    <div class="text-padding">
                                        <div class="text1"><a href="javascript:void()"> Export</a></div>
                                    </div>
                                </div>
                                <ul class="dropdown-menu action-more" role="menu" aria-labelledby="menuexport">
                                    <li>
                                        <div id="exporttoexcel" title="Export to Excel"><span style="padding: 0 5px 0 0;"><img src="/newassets/img/exportexl-icon.png"></span> Export to Excel</div>
                                    </li>
                                    <li>
                                        <div title="Export to PDF" id="exporttopdf"><span style="padding: 0 5px 0 0;"><img src="/newassets/img/exportpdf-icon.png"></span> Export to PDF</div>
                                    </li>
                                    <li>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        </div>


                    </div>

            </div>

        </div>


    </div>
</section>
