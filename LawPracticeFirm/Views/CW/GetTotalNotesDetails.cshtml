@{
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
}
<script src="~/Scripts/CW/LitigationNotesDetails.js?1.1" type="text/javascript" language="javascript"></script>

<section class="wrapper">
    <div class="container-main">
        <section id="header">
            <div class="container-main" style="display:flex; align-items:center; justify-content:space-between;">
                <div class="text-left">
                    <h2 class="ctitle">Case Notes Details</h2>
                </div>
            </div>
        </section>
        <section class="CaseNoteDetails">
            <div id="allcasediv">
                <div style="overflow-x: auto; overflow-y: auto; min-height: 200px;" id="divcasenotesetails">
                    <table id="allcaseNotestable" class="table table-panel">
                        <thead width="100%">
                            <tr role="row">
                                <th>Case</th>
                                <th>Notes</th>
                                <th>Share</th>
                                <th>Delete</th>
                            </tr>
                        </thead>
                        <tbody id="alldatabindCaseNotes"></tbody>
                    </table>
                </div>
            </div>
        </section>



    </div>
    <div class="container-main">
        <section id="header">
            <div class="container-main" style="display:flex; align-items:center; justify-content:space-between;">
                <div class="text-left">
                    <h2 class="ctitle">Order Notes Details</h2>
                </div>
            </div>
        </section>
        <section class="CaseNoteDetails">
            <div id="allcasediv">
                <div style="overflow-x:auto; margin: 0 0 15px 0; overflow-y: auto;" id="ordernotes">
                    <table id="allcaseNotesOrdertable" class="table table-panel" aria-describedby="example_info" style="min-height: 100px;">
                        <thead width="100%">
                            <tr role="row">
                                <th>Case</th>
                                <th style="min-width:125px;">Order Date</th>
                                <th>Order Notes</th>
                                <th>Delete</th>
                            </tr>
                        </thead>
                        <tbody id="alldatabindOrderNotes"></tbody>
                    </table>
                </div>
            </div>
        </section>
    </div>
</section>
<div id="myModal" class="modal fade" role="dialog" data-backdrop="static" data-keyboard="false">
    
    <div class="modal-dialog " style="width:500px">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="ctitle">
                    Notes Details naveer
                </h4>
            </div>
            <!-- Modal content-->
            <div class="modal-body">
                <div id="mymodels">
                </div>
            </div>

        </div>
    </div>
</div>

<div id="removeCaseNoteConfModal" class="modal fade" role="dialog">
    <div class="modal-dialog " style="width:400px;">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header btn-success">
                <button type="button" class="close" data-dismiss="modal" id="createdocclose">×</button>
                <h4 class="modal-title">
                    <img src="/newassets/img/delete-notice.png" style="margin: -10px 0px 0 -12px">
                </h4>
            </div>
            <div class="modaltitle" style="margin: -33px 0 0 0; border-bottom: none;">
                <h4>
                    Remove Case Note
                </h4>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-12">
                        <p style="font-size: 14px; font-weight: 400; color: #535862;">Are you sure want to delete this notes!</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <div class="row">
                    <div class="col-md-6">
                        <button class="btn btn-secondary" style="width:100%;" data-dismiss="modal">Cancel</button>
                    </div>
                    <div class="col-md-6">
                        <button class="btn btn-primary" style="width:100%;" data-toggle="modal" id="removeCaseNoteCnf">Confirm</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="removeOrderNoteConfModal" class="modal fade" role="dialog">
    <div class="modal-dialog " style="width:400px;">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header btn-success">
                <button type="button" class="close" data-dismiss="modal">×</button>
                <h4 class="modal-title">
                    <img src="/newassets/img/delete-notice.png" style="margin: -10px 0px 0 -12px">
                </h4>
            </div>
            <div class="modaltitle" style="margin: -33px 0 0 0; border-bottom: none;">
                <h4>
                    Remove Order Note
                </h4>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-12">
                        <p style="font-size: 14px; font-weight: 400; color: #535862;">Are you sure want to delete order notes!</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <div class="row">
                    <div class="col-md-6">
                        <button class="btn btn-secondary" style="width:100%;" data-dismiss="modal">Cancel</button>
                    </div>
                    <div class="col-md-6">
                        <button class="btn btn-primary" style="width:100%;" data-toggle="modal" id="removeOrderNoteCnf">Confirm</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>