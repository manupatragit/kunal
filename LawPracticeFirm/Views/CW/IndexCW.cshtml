    <div style=" margin-left:50px;">
        <ul>
            <li><a href="/@firmcode/CW/ViewAlert">Alert List</a></li>
            <li><a href="/@firmcode/CW/SearchByPartyName">Search By Party Name</a></li>
            <li><a href="/@firmcode/CW/DailyCauseList">CauseList</a></li>
            <li><a href="/@firmcode/CW/LiveCaseList">CaseList</a></li>
            <li><a href="/@firmcode/CW/ArchiveLiveCaseList">Archive CaseList</a></li>
            @*<li><a href="/@firmcode/CW/casesuggestion">Case Suggestion </a></li>*@
        </ul>
