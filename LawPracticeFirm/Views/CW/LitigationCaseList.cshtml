<style>
    .tabs {
        display: flex;
        border-bottom: 2px solid #ddd;
        margin-bottom: 20px;
    }

    .tab {
        padding: 10px 20px;
        cursor: pointer;
        font-size: 16px;
        font-weight: 500;
        color: #333;
        border-bottom: 2px solid transparent;
    }

        .tab.active {
            border-bottom: 2px solid #007bff;
            color: #007bff;
        }

    .filters {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
    }

    .filter-btn {
        background: #fff;
        border: 1px solid #ccc;
        padding: 8px 15px;
        border-radius: 5px;
        cursor: pointer;
        font-size: 14px;
    }

        .filter-btn:hover {
            background-color: #f1f1f1;
        }

    .nav-pills > li > a {
        border-radius: 0;
        color: #000;
    }

    .nav-pills > li.active > a, .nav-pills > li.active > a:hover, .nav-pills > li.active > a:focus {
        color: #0369a1;
        background-color: transparent;
        border-bottom: 2px solid #0369a1;
    }

    .snav {
        margin: 0;
        padding: 0;
        list-style-type: none;
        border-bottom: 1px solid #ccc;
        overflow: hidden;
        display: inline-block;
    }

    .lcasecourtname .iconbox1 {
        display: flex;
        gap: 4px;
        width: max-content;
        border: 1px solid #ccc;
        padding: 3px 5px;
        font-size: 12px;
        border-radius: 6px;
        justify-content: center;
        background: #cccccc4d;
    }

    .button-group-base2 {
        background-color: #fff;
        /* border-right: 1px solid #d5d7da; */
        box-sizing: border-box;
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        padding: 8px 16px;
        min-height: 40px;
        color: #414651;
    }
    .button-group-base3 {
        background-color: #fff;
        /* border-right: 1px solid #d5d7da; */
        box-sizing: border-box;
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        padding: 8px 16px;
        min-height: 40px;
        color: #414651;
    }
    @*.snav {
        border-bottom: none !important;
    }
    .snav li.active {
        border-bottom: none !important;
    }

  .col-md-8 {
        width: 75% !important;
    } *@

    .alignNav {
        margin-left: -17px;
        width: 195px;
    }
</style>
