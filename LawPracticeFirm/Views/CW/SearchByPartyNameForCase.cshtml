@{
    var role = Session["sessionroleid"];
    Layout = null;
}
<script src="~/Scripts/CW/SearchByPartyNameForCase.js?1.9" type="text/javascript" language="javascript"></script>
<style>
    ul li {
        display: inline;
    }
</style>
<div class="ec_bg">
    <div class="row">
        <div class="col-md-12" style="text-align:left; height:40px;">
            <input checked="checked" id="rdSC" name="rdcourt" type="radio"> Supreme Court/High Court
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
            <input id="rdTC" name="rdcourt" type="radio"> Tribunal Court
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<input id="rdDC" name="rdcourt" type="radio"> District Court
        </div>
    </div>
    <div class="row">
        <div id="divSearchCriteria" style="display:block; margin:0; text-align:left;">
            <div id="div_SCHC" class="col-md-2" align="left" style="display:block;">
                <select name="divSCHC" id="divSCHC" class="form-control selctInputFormat" style="background-color: white !important;"><option value="0" selected="selected">ALL</option></select>
            </div>
            <div id="div_State" class="col-md-2" align="left" style="display:none;">
                <select name="divState" id="divState" class="form-control selctInputFormat" style="background-color: white !important;"></select>
            </div>
            <div id="div_District" class="col-md-2" align="left" style="display:none;">
                <select name="districtid" id="districtid" class="form-control selctInputFormat" style="background-color: white !important;"></select>
            </div>
            <div id="dr_pdistrictcourtname" class="col-md-2" align="left" style="display:none;">
                <select name="drpdistrictcourtname1" id="drpdistrictcourtname1" class="form-control selctInputFormat" style="background-color: white !important;"></select>
            </div>
            <div class="col-md-2"><input id="txtApplent" name="txtApplent" type="text" class="form-control inputFormat" value="" placeholder="Search Party name..."></div>
            <div class="col-md-2" align="center" id="divSearch" style="display:block;"><button class="sbtbtn" id="btnSearch" name="btnSearch" value="Search" type="button">Search</button></div>
        </div>
        <input type="hidden" value="2" id="hdnRadioType">
        <input type="hidden" value="1" id="Courttype">
    </div>
</div>
<div class="row">
    <div style="margin-top:30px;">
        <div id="divsearchbypartyname" class="table-panel table-responsive" style="overflow-x:auto"></div>
        <div class="row settingpanel">
            <ul>
                <li>
                    <div id="ptfooter" style="float:left;margin-top:5px;margin-left:5px;"></div>
                </li>
            </ul>
        </div>
    </div>
    <input type="hidden" value="2" id="hdnRadioType">
    <input type="hidden" value="1" id="Courttype">
</div>
<div style="margin-top:10px;">
    <div id="divsearchbypartyname" class="table-panel table-responsive" style="overflow-x:auto"></div>
    <div class="settingpanel">
        <ul>
            <li>
                <div id="ptfooter" style="float:left;margin-top:5px;margin-left:5px;"></div>
            </li>
        </ul>
    </div>
</div>
<div id="myModal23" class="modal fade" role="dialog" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog " style="width:70%">
        <div class="modal-content">
            <div class="modal-header btn-success">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">
                    case details
                </h4>
            </div>
            <!-- Modal content-->
            <div class="modal-content mymodels" id="mymodels" style="margin-top:10px;">
                <div style="overflow:scroll;height:530px;">
                    <table class="table">
                        <tbody id="bindappeal"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
