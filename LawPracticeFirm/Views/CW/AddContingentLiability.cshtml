<form id="conLiabilityDetail">

    <!-- ================= BASIC DETAILS ================= -->
    <div class="row" style="overflow: visible !important;margin-top:30px;">
        <div class="col-md-6">
            <input type="text" id="txtmatternamede1" name="txtmatternamede1" class="form-control inputFormat" autocomplete="new-text" placeholder="Matter Name" />
        </div>
        <input type="hidden" id="hdnMatterId" />
        <input type="hidden" id="hdnCourtName" />
    </div>
    <div class="row">

        <div class="col-md-3">
            <label>Case Id</label>
            <input type="text" id="caseId" class="form-control">
        </div>

        <div class="col-md-3">
            <label>Zone</label>
            <input type="text" id="zone" class="form-control">
        </div>

        <div class="col-md-3">
            <label>Branch</label>
            <input type="text" id="branch" class="form-control">
        </div>

        <div class="col-md-6">
            <label>Name of Account Holder / Borrower</label>
            <input type="text" id="accountHolderName" class="form-control">
        </div>

        <div class="col-md-6">
            <label>Name of Claimant</label>
            <input type="text" id="claimantName" class="form-control">
        </div>

        <div class="col-md-6">
            <label>Address of Claimant</label>
            <input type="text" id="claimantAddress" class="form-control">
        </div>

        <div class="col-md-3">
            <label>Date of Claim / Suit</label>
            <input type="date" id="dateOfClaim" class="form-control">
        </div>

        <div class="col-md-3">
            <label>Case No.</label>
            <input type="text" id="caseNo" class="form-control">
        </div>

    </div>

    <hr>

    <div class="row">

        <div class="col-md-2">
            <label>Bank Guarantee</label>
            <input type="number" id="bankGuarantee" class="form-control">
        </div>

        <div class="col-md-2">
            <label>Letter of Credit</label>
            <input type="number" id="letterOfCredit" class="form-control">
        </div>

        <div class="col-md-2">
            <label>Wrong Payment</label>
            <input type="number" id="wrongPayment" class="form-control">
        </div>

        <div class="col-md-2">
            <label>Fraud</label>
            <input type="number" id="fraud" class="form-control">
        </div>

        <div class="col-md-2">
            <label>Counter Claim</label>
            <input type="number" id="counterClaim" class="form-control">
        </div>

        <div class="col-md-2">
            <label>Others</label>
            <input type="number" id="othersClaim" class="form-control">
        </div>

    </div>

    <hr>

    <div class="row">

        <div class="col-md-4">
            <label>Nature of Security</label>
            <input type="text" id="natureOfSecurity" class="form-control">
        </div>

        <div class="col-md-4">
            <label>Realisable Value</label>
            <input type="number" id="realisableValue" class="form-control">
        </div>

        <div class="col-md-12">
            <label>Facts of the Case / Reasons for Claim</label>
            <input type="text" id="factsOfCase" class="form-control">
        </div>

    </div>

    <hr>

    <div class="row">

        <div class="col-md-8">
            <label>Purpose of Next Hearing / Stage of Suit</label>
            <input type="text" id="nextHearingPurpose" class="form-control">
        </div>

        <div class="col-md-4">
            <label>Next Hearing Date</label>
            <input type="date" id="nextHearingDate" class="form-control">
        </div>

    </div>

    <hr>

    <div class="row">

        <div class="col-md-3">
            <label>Provision Detail</label>
            <input type="text" id="provisionDetail" class="form-control">
        </div>

        <div class="col-md-3">
            <label>Year of Provision</label>
            <input type="text" id="yearOfProvision" class="form-control">
        </div>

        <div class="col-md-3">
            <label>Amount of Provision</label>
            <input type="number" id="amountProvision" class="form-control">
        </div>

        <div class="col-md-3">
            <label>Amount Deposited in Court</label>
            <input type="number" id="amountDepositedInCourt" class="form-control">
        </div>

    </div>

    <hr>

    <!-- ================= ACTION BUTTONS ================= -->
    <div class="text-end">
        <button type="button" id="clrLiabilitybtn" class="btn btn-secondary" onclick="$('#conLiabilityDetail')[0].reset();">
            Clear
        </button>

        <button type="button" id="btnSaveContingentLiability" class="btn btn-primary" onclick="saveContingentLiability()">
            Add Details
        </button>
    </div>

</form>

