
@{
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
}

<div>
    <iframe style="border: none; width: 100%;height: 100vh; margin: -20px 0 0 0; background:linear-gradient(to left, #dce35b, #45b649); position:relative; z-index:100000;" src="~/CW/CaseTrackingHelpVideo"></iframe>
</div>
