@{
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
}
<script src="~/Scripts/CW/ArchiveLiveCaselist.js?12.4" type="text/javascript" language="javascript"></script>
<style>
    ul li {
        display: inline;
    }
</style>
<section class="wrapper">
    <div class="container-main">
        <div>
            <h2 class="title"> archived list of matter for live update </h2>
            <div class="ec_bg">
                <div class="col-md-12" style="margin-left:-15px">
                    <div class="col-md-2">
                        <select name="divSCHCDistrict" id="divSCHCDistrict" class="form-control selctInputFormat" style="background-color: white !important;"></select>
                    </div>
                    <div class="col-md-2" id="HighCourt" style="display:none;">
                        <select name="drpcourtname" id="drpcourtname" class="form-control selctInputFormat" style="background-color: white !important;"></select>
                    </div>
                    <div class="col-md-2" id="DistrictCourt" style="display:none;">
                        <select name="drpcourtnameDC" id="drpcourtnameDC" class="form-control selctInputFormat" style="background-color: white !important;" onchange="divdrpcourtnameDC();"></select>
                    </div>
                    <div class="col-md-2" id="divDistrict">
                        <select name="drpdistrictcourtname" id="drpdistrictcourtname" class="form-control selctInputFormat" style="background-color: white !important; display:none;" onchange="divdistrictchange();"></select>
                    </div>
                    <div class="col-md-2" id="divcourtcomplexestb">
                        <select name="drpcourtcomplexestb" id="drpcourtcomplexestb" class="form-control selctInputFormat" style="background-color: white !important; display:none;" onchange="drpcourtcompestbchange();"></select>
                    </div>
                    <div class="col-md-2" id="divcompestbcourt">
                        <select name="drpcompestbcourt" id="drpcompestbcourt" class="form-control selctInputFormat" style="background-color: white !important; display:none;"></select>
                    </div>
                </div>
            </div>
            <div class="table-panel table-responsive" style="overflow-x:scroll;" id="allcasediv">
                <table id="allcaselisttable" class="table dataTable" cellspacing="0" width="100%" role="grid" aria-describedby="example_info">
                    <thead>
                        <tr role="row">
                            <th width="5%" style="font-size:12px;" class="sorting_disabled">
                                <div class="thbg">
                                    <input type="checkbox" id="select_all"> UnArchive
                                </div>
                            </th>
                            <th class="Case10 sorting " width="12%" style="font-size:12px;" tabindex="0" aria-controls="example"><div class="thbg"> Case / Diary</div></th>
                            <th class="Court10 sorting" width="10%" style="font-size:12px;" tabindex="0" aria-controls="example"><div class="thbg"> Court / District</div></th>
                            <th class="CaseName10 sorting" width="10%" style="font-size:12px;" tabindex="0" aria-controls="example"> <div class="thbg">Case Name</div></th>
                            <th class="AdvName10 sorting" width="10%" style="font-size:12px;" tabindex="0" aria-controls="example"><div class="thbg"> Advocate</div></th>
                            <th class="NextHearing10 sorting" width="10%" style="font-size:12px;" tabindex="0" aria-controls="example"> <div class="thbg">Next Hearing</div></th>
                            <th class="Disposed10 sorting" width="10%" style="font-size:12px;" tabindex="0" aria-controls="example"> <div class="thbg">Disposed Date</div></th>
                            <th class="Status10 sorting" width="8%" style="font-size:12px;" tabindex="0" aria-controls="example"><div class="thbg"> Status</div></th>
                        </tr>
                    </thead>
                    <tbody id="alldatabind"></tbody>
                </table>
            </div>
            <div class="table-panel table-responsive" style="overflow-x:scroll;display:none" id="casediv">
                <table id="tblDistrictCourt" class="table dataTable" cellspacing="0" width="100%" role="grid" aria-describedby="tblDistrictCourt_info" style="width: 100%;">
                    <thead>
                        <tr role="row">
                            <th width="5%" style="font-size: 12px; width: 55px;" class="sorting_disabled" rowspan="1" colspan="1" aria-label="
                                     Re-run / Archive / Delete / TagCase">
                                <div class="thbg">
                                    <input type="checkbox" id="select_all"> UnArchive
                                </div>
                            </th>
                            <th class="CaseDC10 sorting" width="12%" style="font-size: 12px; width: 104px;" tabindex="0" aria-controls="tblDistrictCourt" rowspan="1" colspan="1" aria-label=" Case: activate to sort column ascending"> <div class="thbg">Case</div></th>
                            <th class="State10 sorting" width="10%" style="font-size: 12px; width: 81px;" tabindex="0" aria-controls="tblDistrictCourt" rowspan="1" colspan="1" aria-label=" State: activate to sort column ascending"><div class="thbg"> State</div></th>
                            <th class="District10 sorting" width="10%" style="font-size: 12px; width: 86px;" tabindex="0" aria-controls="tblDistrictCourt" rowspan="1" colspan="1" aria-label=" District: activate to sort column ascending"> <div class="thbg">District</div></th>
                            <th class="Courttype10 sorting" width="10%" style="font-size: 12px; width: 100px;" tabindex="0" aria-controls="tblDistrictCourt" rowspan="1" colspan="1" aria-label=" Court Complex / Court Establishment Type: activate to sort column ascending"> <div class="thbg">Court Complex / Court Establishment Type</div></th>
                            <th class="Courttypecode10 sorting" width="10%" style="font-size: 12px; width: 100px;" tabindex="0" aria-controls="tblDistrictCourt" rowspan="1" colspan="1" aria-label=" Court Complex / Court Establishment: activate to sort column ascending"><div class="thbg"> Court Complex / Court Establishment</div></th>
                            <th class="CaseName10 sorting" width="10%" style="font-size: 12px; width: 83px;" tabindex="0" aria-controls="tblDistrictCourt" rowspan="1" colspan="1" aria-label=" Case Name: activate to sort column ascending"><div class="thbg"> Case Name</div></th>
                            <th class="AdvName10 sorting" width="10%" style="font-size: 12px; width: 90px;" tabindex="0" aria-controls="tblDistrictCourt" rowspan="1" colspan="1" aria-label=" Advocate: activate to sort column ascending"><div class="thbg"> Advocate</div></th>
                            <th class="NextHearing10 sorting" width="10%" style="font-size: 12px; width: 87px;" tabindex="0" aria-controls="tblDistrictCourt" rowspan="1" colspan="1" aria-label=" Next Hearing: activate to sort column ascending"><div class="thbg"> Next Hearing</div></th>
                            <th class="Disposed10 sorting" width="10%" style="font-size: 12px; width: 55px;" tabindex="0" aria-controls="tblDistrictCourt" rowspan="1" colspan="1" aria-label=" Disposed Date: activate to sort column ascending"><div class="thbg"> Disposed Date</div></th>
                            <th class="Status10 sorting" width="8%" style="font-size: 12px; width: 37px;" tabindex="0" aria-controls="tblDistrictCourt" rowspan="1" colspan="1" aria-label=" Status: activate to sort column ascending"><div class="thbg"> Status</div></th>
                        </tr>
                    </thead>
                    <tbody id="districtdatabind"></tbody>
                </table>
            </div>
            <div class="settingpanel">
                <ul>
                    <li>
                        <div class="col-md-6">
                            <div id="ptfooter" style="float:left;margin-top:5px;margin-left:5px;"></div>
                        </div>
                        <div class="col-md-6">
                            <ul class="pull-right">
                                <li>
                                    <div class="btn-group dropup">
                                        <a href="javascript:void()" class=" dropdown-toggle form-control selctInputFormat " style="background-color: #ebebeb !important; margin-top: -5px !important;" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                            Action Selected
                                        </a>
                                        <ul class="dropdown-menu settingaction">
                                            <li><a href="javascript:void()" id="archivecase" title="Unarchive Case">Unarchive case</a></li>
                                            <li><a href="/@Session["FirmCode"]/CW/LiveCaseList" style="clear:both !important" title="caselist">case list</a></li>
                                        </ul>
                                    </div>
                                </li>
                            </ul>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
        <div id="myModal" class="modal fade" role="dialog" data-backdrop="static" data-keyboard="false">
            <div class="modal-dialog " style="width:60%">
                <div class="modal-content">
                    <div class="modal-header btn-success">
                        <button type="button" class="close" data-dismiss="modal">&times;</button>
                        <h4 class="modal-title">
                            Details by Appeal No
                        </h4>
                    </div>
                    <!-- Modal content-->
                    <div class="modal-content mymodels" id="mymodels" style="margin-top:10px;">
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
