<script>
    document.addEventListener('DOMContentLoaded', function () {

        const tableWrappers = document.querySelectorAll('.table-scroll-wrapper');

        tableWrappers.forEach(function (tableScroll) {

            const table = tableScroll.querySelector('table');

            if (!table) return;

            // Create Top Scrollbar Dynamically
            const topScroll = document.createElement('div');
            topScroll.className = 'scroll-sync-top';

            const topScrollInner = document.createElement('div');
            topScrollInner.className = 'scroll-top-inner';

            topScroll.appendChild(topScrollInner);

            // Insert before table wrapper
            tableScroll.parentNode.insertBefore(topScroll, tableScroll);

            function updateScrollBarVisibility() {

                const scrollNeeded = table.scrollWidth > tableScroll.clientWidth;

                if (scrollNeeded) {

                    topScroll.style.display = 'block';
                    topScrollInner.style.width = table.scrollWidth + 'px';

                } else {

                    topScroll.style.display = 'none';

                }
            }

            // Top -> Bottom
            topScroll.addEventListener('scroll', function () {
                tableScroll.scrollLeft = topScroll.scrollLeft;
            });

            // Bottom -> Top
            tableScroll.addEventListener('scroll', function () {
                topScroll.scrollLeft = tableScroll.scrollLeft;
            });

            // Observe table resize
            const resizeObserver = new ResizeObserver(function () {
                updateScrollBarVisibility();
            });

            resizeObserver.observe(table);

            // Initial load
            setTimeout(function () {
                updateScrollBarVisibility();
            }, 300);

            // Window resize
            window.addEventListener('resize', function () {
                updateScrollBarVisibility();
            });

        });

    });
</script>