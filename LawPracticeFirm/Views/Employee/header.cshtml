     $("#chaticon").click(function () {
         var fcode678 = localStorage.getItem("FirmCode");
         window.location.href ="/"+ fcode678+"/Chat/InvitedChat";
        });
       // InvitedChatList();
        //setTimeout(function () { InvitedChatList(); }, 3000);
        function InvitedChatList() {
            $("#bindinvitedchatlist").empty();
            var formData = new FormData();
            formData.append("firmid", "@Session["sessionfirmid"].ToString()");
            formData.append("userid", "@Session["sessionuserid"].ToString()");
            $.ajax({
                async: true,
                url: '/api/ChatApi/InvitedChatList',
                data: formData,
                processData: false,
                contentType: false,
                type: 'POST',
                success: function (response) {
                    var html3 = '';

                    if (response.Data == "") {
                        $("#chaticon").hide();
						$("#chatnoti").hide();
                    }
                    else {
					try{
					$("#countnotify").text(parseInt($("#countnotify").text())+1);
					}
					catch
					{
					}
                        $("#chaticon").show();
						$("#chatnoti").show();
                    }

                    $.each(response.Data, function (i, val) {
                        if (val.iChatType == 2) {
                            html3 += '<tr><td>You have private chat invitation by <b>' + val.SenderName + '</b></td><td><a href="#" id="Channelid" data-val=' + val.ChannelGuid + '>JOIN</a></td></tr>';
                        }
                        else {
                            html3 += '<tr><td>You have group chat invitation by <b>' + val.SenderName + '</b></td><td><a href="#" id="ChannelidGroup" data-val=' + val.ChannelGuid + '>JOIN</a></td></tr>';
                        }
                    });
                    $("#bindinvitedchatlist").append(html3);
                },
                error: function (response) {
                    alert(response.responseText);
                }
        });
    }
    // Sidebar navigation active tile logic
