                        notification(1);
                    } else {
                        //alert("Something went wrong please try again later.");
                        new PNotify({
                            title: 'Info!',
                            text: 'Something went wrong please try again later.',
                            type: 'error',
                            delay: 3000
                        });
                    }
                },

                failure: function (response) {
                    //alert(data.responseText);
                },
                error: function (response) {
                    //alert(data.responseText);
                }

            });
        }
        //For Mark  Read Notification single
        $(document).on('click', '#Readnoti', function () {
            var ids = $(this).attr("idds");
            Readnotifi(ids, "");
        });
        //For Mark  Read Notification bulk
        $(document).on('click', '#Allreadnoti', function () {
            Readnotifi("", "1");
        });

        //For Mark Notification UnRead
        $(document).on('click', '#UnReadnoti', function () {
            var ids = $(this).attr("idds");
            Readnotifi(ids, "2");
        });

        //For Read single/bulk Notification
        function Readnotifi(ids, Isreadflag) {
            var formdata = new FormData();
            formdata.append("id", ids);
            formdata.append("Isreadflag", Isreadflag);
            $.ajax({
                async: true,
                url: "/api/callApi/UpdateNotificationStatus",
                data: formdata,
                processData: false,
                contentType: false,
                type: 'POST',
                success: function (response) {
                    headercount();
                    notification(1);
                    //  $("#bellcolor" + c).css("color", "#85d000");
                },

                failure: function (response) {
                    //alert(data.responseText);
                },
                error: function (response) {
                    //alert(data.responseText);
                }

            });
            // window.location = url1 + enctype(uid1);
        }
    });
    headercount();
    function headercount() {
        $.ajax({
            async: true,
            type: "POST",
            url: "/api/callApi/FirmHeaderData",
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (response) {
                if (response.Status == true) {
                    var datas = JSON.stringify(response);
                    //alert(datas);
                }
                else {
                    //alert("not found");
                }
                $.each(response.Data, function (i, a) {
                    $("#countmessage").text(a.countmessage);
                    $("#countnotify").text(a.countnotify);
                });
                //console.log(response);
            },

            failure: function (response) {
                alert(data.responseText);
            },
            error: function (response) {
                if (String(response.responseJSON.Message) == "SessionTimeOut") {
                    alert("Your session has expired, please log out and then login again");

                    window.location.href = location.protocol + '//' + location.host;
                }
                else {
                    alert(response.responseText);
                }
            }

        });
    }

    function loadnotifi(a, b, c, d) {
        var url1 = a;
        var uid1 = b;
        var formdata = new FormData();
        formdata.append("id", c);
        formdata.append("Isreadflag", "");
        $.ajax({
            async: true,
            url: "/api/callApi/UpdateNotificationStatus",
            data: formdata,
            processData: false,
            contentType: false,
            type: 'POST',
            success: function (response) {
                headercount();

                $("#bellcolor" + c).css("color", "#85d000");
                var fcode = localStorage.getItem("FirmCode");
                if (d == "DocDelete" || d == "UploadDoc" || d == "FileDescEdit" || d == "DocCheckin" || d == "DocCheckout") {
                    var urls = "/" + fcode + "/azure/directorylist/0";
                    url_redirect({
                        url: urls,
                        method: "post",
                        data: {}
                    });
                }
                else if (d == "SharedDoc") {
                    var urls = "/" + fcode + "/azure/AssignUserFileList";
                    url_redirect({
                        url: urls,
                        method: "post",
                        data: {}
                    });
                }
                else if (d == "AssignTask" || d == "RejectTask" || d == "ReAssignTask" || d == "TaskDue" || d == "OverdueRejectTask" || d == "AssignTeamMemberTaskCase") {
                    var urls = "/" + fcode + "/firm/UserTask";
                    url_redirect({
                        url: urls,
                        method: "post",
                        data: {}
                    });
                }

                else if (d == "TaskComplete") {
                    var urls = "/" + fcode + "/Firm/Personaldashboard";
                    url_redirect({
                        url: urls,
                        method: "post",
                        data: {}
                    });
                }

                else if (d == "MKEnabled" || d == "MKDisabled") {
                    var urls = "/" + fcode + "/Firm/Personaldashboard";
                    url_redirect({
                        url: urls,
                        method: "post",
                        data: {}
                    });
                }
                else if (d == "UserCreated" || d == "UserDetailsEdit" || d == "RightsEdit") {
                    var urls = "/" + fcode + "/Firm/UserProfile";
                    url_redirect({
                        url: urls,
                        method: "post",
                        data: {}
                    });
                }
                else if (d == "ContactEdit" || d == "ContactsList") {
                    var urls = "/" + fcode + "/Firm/UserProfile";
                    url_redirect({
                        url: urls,
                        method: "post",
                        data: {}
                    });
                }

                else if (d == "SentCommunication") {
                    var urls = "/" + fcode + "/Firm/NewCaseDashboard?type=SentCommunication";
                    url_redirect({
                        url: urls,
                        method: "post",
                        data: { token: b }
                    });
                }
                else if (d == "AddTeamMember" || d == "AddNewTeamMember") {
                    var urls = "/" + fcode + "/Firm/NewCaseDashboard?type=AddTeamMember";
                    url_redirect({
                        url: urls,
                        method: "post",
                        data: { token: b }
                    });
                }
                else if (d == "UploadDoc") {
                    var urls = "/" + fcode + "/Firm/NewCaseDashboard?type=UploadDoc";
                    url_redirect({
                        url: urls,
                        method: "post",
                        data: { token: b }
                    });
                }
                else if (d == "CreateTimeEntry") {
                    var urls = "/" + fcode + "/Firm/NewCaseDashboard?type=CreateTimeEntry";
                    url_redirect({
                        url: urls,
                        method: "post",
                        data: { token: b }
                    });
                }
                else if (d == "CaseEdit") {
                    var urls = "/" + fcode + "/Firm/NewCaseDashboard";
                    url_redirect({
                        url: urls,
                        method: "post",
                        data: { token: b }
                    });
                }
                else if (d == "DocDelete") {
                    var urls = "/" + fcode + "/Azure/RemoveFileRequest";
                    url_redirect({
                        url: urls,
                        method: "post",
                        data: {}
                    });
                }
                else if (d == "ChatNotification") {
                    var urls = "/" + fcode + "/Chat/InvitedChat";
                    url_redirect({
                        url: urls,
                        method: "post",
                        data: {}
                    });
                }
                else if (d == "ArchiveMatter") {
                    var urls = "/" + fcode + "/Firm/ArchiveMatterList";
                    url_redirect({
                        url: urls,
                        method: "post",
                        data: {}
                    });
                }
                else if (d == "UnArchiveMatter") {
                    var urls = "/" + fcode + "/Firm/caselist";
                    url_redirect({
                        url: urls,
                        method: "post",
                        data: {}
                    });
                }
            },

            failure: function (response) {
                alert(data.responseText);
            },
            error: function (response) {
                alert(data.responseText);
            }
        });
        // window.location = url1 + enctype(uid1);
    }

</script>

