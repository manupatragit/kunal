<script>

    function showConfirm(title, message) {
        return new Promise((resolve) => {
            $("#confirmTitle").text(title || "Confirmation");
            $("#confirmMessage").text(message || "Are you sure?");

            // remove old handlers
            $("#confirmYes").off("click");
            $("#myModalConfirm").off("hidden.bs.modal");

            // confirm clicked
            $("#confirmYes").on("click", function () {
                $("#myModalConfirm").modal("hide");
                resolve(true);
            });

            // closed without confirm
            $("#myModalConfirm").on("hidden.bs.modal", function () {
                resolve(false);
            });

            // show modal
            $("#myModalConfirm").modal("show");
        });
    }
</script>


