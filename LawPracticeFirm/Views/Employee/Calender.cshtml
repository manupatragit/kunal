<script type="text/javascript">
    //calendarsync();
    function calendarsync() {
        var urls3 = "/api/EmployeeApi/LoadEvent";
        var dataval = "";
        //    alert(urls3);
        $.ajax({
            async: true,
            type: "POST",
            url: urls3,
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (response) {
                if (response.Status == true) {
                    var datas = JSON.stringify(response);
                    var obj3 = JSON.parse(response.Data);
                    //alert(datas);
                    $.each(obj3, function (i, v) {
                        //  alert(v.sdate);
                        dataval = {
                            'summary': v.tsubject,
                            'location': v.elocation,
                            'description': v.tdetails,
                            'start': {
                                'dateTime': v.sdate + '-07:00'
                                //'dateTime': '2018-12-21T09:00:00-07:00'
                                //'timeZone': 'America/Los_Angeles'
                            },
                            'end': {
                                //'dateTime': v.edat,
                                'dateTime': v.edate + '-07:00'
                                //'timeZone': 'America/Los_Angeles'
                            }
                        };
                        localStorage.setItem("datacalendar", JSON.stringify(dataval));
                        handleCreateEvent();
                    });
                    new PNotify({
                        title: 'Success!',
                        text: ' Google Calendar Synchronize Successfully',
                        type: 'success',
                        delay: 2000
                    });
                }
                else {
                    alert("not found");
                }
            },
            error: function (error) {
                alert('failed');
            }
        });
    }
    // Client ID and API key from the Developer Console
    var CLIENT_ID = '347989676797-930nsffe6d2lqt19lea11mgujf8903un.apps.googleusercontent.com';
    // Array of API discovery doc URLs for APIs used by the quickstart
    var DISCOVERY_DOCS = ["https://www.googleapis.com/discovery/v1/apis/calendar/v3/rest"];
    // Authorization scopes required by the API; multiple scopes can be
    // included, separated by spaces.
    var SCOPES = "https://www.googleapis.com/auth/calendar";
    var createEventButton = document.getElementById('micsyn');
    function handleClientLoad() {
        // alert("hi");
        gapi.load('client:auth2', initClient);
    }
    function initClient() {
        // alert("hi");
        gapi.client.init({
            discoveryDocs: DISCOVERY_DOCS,
            clientId: CLIENT_ID,
            scope: SCOPES
        }).then(function () {
            // Call the handleCreateEvent function on the click on your desired button.
            createEventButton.onclick = calendarsync;
        });
    }
    function updateSigninStatus(isSignedIn) {
        if (isSignedIn) {
            createEvent();
        }
    }
    function handleCreateEvent() {
        gapi.auth2.getAuthInstance().signIn();
        updateSigninStatus(gapi.auth2.getAuthInstance().isSignedIn.get());
    }
    function createEvent() {
        var tempdata1 = localStorage.getItem("datacalendar");
        // alert(tempdata1);
        var event = tempdata1;
        var request = gapi.client.calendar.events.insert({
            'calendarId': 'primary',
            'resource': event
        });
        request.execute(function (event) {
            // window.location.href = event.htmlLink;
        });
    }
</script>
<script async defer src="https://apis.google.com/js/api.js"
        onload="handleClientLoad()"></script>
