<script type="text/javascript">
    var firmcodes = localStorage.getItem("FirmCode");
    $(document).ready(function () {
        var cfirst = true;
        var cfocus = true;
        $("#foo").on("focusout", function () {
            if (cfocus == true) {
                cfocus = false;
            }
        });
        $("#foo").on("click", function () {
            $("#bd").addClass("show").removeClass("show");
            if (cfirst == true && cfocus == true) {
                $("#bd").css("margin-top", "-41px");
                cfirst = false;
            }
            if (cfirst == false && cfocus == true) {
                $("#bd").css("margin-top", "-41px");
                cfirst = false;
            }
            else {
                $("#bd").css("margin-top", "3px");
            }
        });
        $('#modelEvent').click(function (e) {
            openload();
            var url = "/" + firmcodes + "/employee/ConfigEvent";
            $('.mymodels').load(url, function (result) {
                $('#myModal').modal();
                closeload();
            });
        });
        $('#modelTask').click(function (e) {
            openload();
            var url = "/" + firmcodes + "/employee/ConfigTask";
            $('.mymodels').load(url, function (result) {
                $('#myModal').modal();
                closeload();
            });
        });
    });
    $(document).on("click", "#modelEditEvent", function () {
        openload();
        var id = $(this).attr("value");
        var url = "/" + firmcodes + "/employee/ConfigEventEdit?data=true&token=" + id;
        localStorage.setItem("tempeventid", id);
        $('.mymodels').load(url, function (result) {
            $('#myModal').modal({ show: true });
            closeload();
        });
    });
    $(document).on("click", "#modelEditTask", function () {
        openload();
        var id = $(this).attr("value");
        var url = "/" + firmcodes + "/employee/ConfigTaskEdit?data=true&token=" + id;
        localStorage.setItem("temptaskid", id);
        $('.mymodels').load(url, function (result) {
            $('#myModal').modal({ show: true });
            closeload();
        });
    });
    var fcode = localStorage.getItem("FirmCode");
    $(document).on("click", "#mcalendar", function () {
        window.location = encodeURI("/" + fcode + "/employee/Calendarhybrid");
    });
    $(document).on("click", "#fullcalendar", function () {
        window.location = encodeURI("/" + fcode + "/Firm/MergeCalendar");
    });
</script>
