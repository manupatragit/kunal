    function drpcompestbcourtchange() {
        var courtype = "";
        var districttype = "";
        var compesttype = "";
        var compestcourt = "";
        $('#drptype').empty();
        document.getElementById("savebtn").style.display = "none";
        if (document.getElementById('drpcompestbcourt').value != "") {
            document.getElementById("savebtn").style.display = "block";
            courtype = encodeURIComponent(document.getElementById('drpcourtnameDC').value);
            districttype = encodeURIComponent(document.getElementById('drpdistrictcourtname').value);
            compesttype = encodeURIComponent(document.getElementById('drpcourtcomplexestb').value);
            compestcourt = encodeURIComponent(document.getElementById('drpcompestbcourt').value);
            $.ajax({
                type: "POST",
                url: "/AddCase/AddDistrictCaseType?crttype=" + courtype + "&dsttype=" + districttype + "&compesttype=" + compesttype + "&compestcourt=" + compestcourt,
                dataType: "json",
                success: function (data) {
                    $("#drptype").append("<option value=''>Please Select Case Type</option>");
                    for (var i = 0; i < data.length; i++) {
                        $("#drptype").append("<option value='" + data[i].courtid + "'>" + data[i].courtname + "</option>");
                    }
                },
                error: function (data) {
                }
            });
            $.ajax({
                type: "POST",
                url: "/firm/Addcaseyear?crtid=",
                dataType: "json",
                success: function (data) {
                    $("#drpYear").append("<option value='0'>Select Case Year</option>");
                    for (var i = 0; i < data.length; i++) {
                        var caseyearlength = data[i].caseyear;
                    }
                    startYear = new Date().getFullYear()
                    for (var i = parseInt(startYear); i >= parseInt(caseyearlength); i--) {
                        $("#drpYear").append("<option value='" + i + "'>" + i + "</option>");
                    }
                },
                error: function (data) {
                }
            });
        }
    }
