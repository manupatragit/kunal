                    <fieldset>
                        <legend>Personal Details</legend>
                        <div class="">
                            <div class="row">
                                <div class="col-lg-12">
                                    <div class="form-group">
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-lg-10 contact-details">
