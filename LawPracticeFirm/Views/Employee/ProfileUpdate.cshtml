                                                    <input autofocus="" class="form-control" maxlength="48" placeholder="Full Name" type="text" value="" name="name" id="name" required="">
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <span class="control-label col-md-4"> Email <span class="required" aria-required="true" style="color:red"><b>*</b> </span></span>
                                                <div class="col-md-8">
                                                    <input autofocus="" class="form-control" maxlength="49" placeholder="Email" required type="email" value="" name="email" id="email" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-lg-6">
                                            <div class="form-group">
                                                <span class="control-label col-md-4" for="Home"> Mobile <span class="required" aria-required="true" style="color:red"><b>*</b> </span></span>
                                                <div class="col-md-8">
                                                    <input class="form-control" onkeypress="return restrictAlphabets(event)" required maxlength="10" minlength="10" placeholder="Mobile Number" type="text" name="mobile" value="" id="mobile">
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-lg-6">
                                            <div class="form-group">
                                                <span class="control-label col-md-4" for="Mobile"> Land Line </span>
                                                <div class="col-md-8">
                                                    <input class="form-control" maxlength="49" onkeypress="return restrictAlphabetsfax(event)" placeholder="landline Number" name="landline" type="text" value="" id="landline">
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-lg-6">
                                            <div class="form-group">
                                                <span class="control-label col-md-4" for="Office"> Address </span>
                                                <div class="col-md-8">
                                                    <input class="form-control" maxlength="249" placeholder="Address" type="text" value="" id="address">
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-lg-6">
                                            <div class="form-group">
                                                <span class="control-label col-md-4"> Country <span class="required" aria-required="true" style="color:red"><b>*</b> </span> </span>
                                                <div class="col-md-8">
                                                    <select class="form-control" name="country" id="country" required></select>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-lg-6">
                                            <div class="form-group">
                                                <span class="control-label col-md-4"> State <span class="required" aria-required="true" style="color:red"><b>*</b> </span> </span>
                                                <div class="col-md-8">
                                                    <select nname="state" id="state" class="form-control"></select>
                                                    <input type="text" class="form-control" name="ostate" id="ostate" style="display:none" />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-lg-6">
                                            <div class="form-group">
                                                <span class="control-label col-md-4"> City  <span class="required" aria-required="true" style="color:red"><b>*</b> </span></span>
                                                <div class="col-md-8">
                                                    <select cname="city" id="city" class="form-control"></select>
                                                    <input type="text" class="form-control" name="ocity" id="ocity" style="display:none" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-lg-6">
                                            <div class="form-group">
                                                <span class="control-label col-md-4" for="Mobile"> Membership No. </span>
                                                <div class="col-md-8">
                                                    <input class="form-control" placeholder="Membership No." maxlength="49" name="barno" type="text" value="" id="barno">
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-lg-6">
                                            <div class="form-group">
                                                <span class="control-label col-md-4" for="Mobile"> Designation</span>
                                                <div class="col-md-8">
                                                    <input class="form-control" placeholder="Designation" name="barno" type="text" maxlength="48" value="" id="designation">
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-lg-6">
                                            <div class="form-group">
                                                <span class="control-label col-md-4" for="Department">Department</span>
                                                <div class="col-md-8">
                                                    <input class="form-control" placeholder="Department" name="Department" type="text" maxlength="48" value="" id="Department">
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-lg-12">
                                            <div class="form-group">
                                                <div class="col-md-10">
                                                    <div class="grid-container" style="display:none">
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-lg-6">
                                            <div class="form-group">
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-lg-6" id="content">
                                        </div>
                                    </div>
                                </div>
