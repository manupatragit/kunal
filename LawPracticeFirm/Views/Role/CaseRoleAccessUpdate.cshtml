    }
    .edit_matter_rights {
        display: flex;
        align-items: center;
        gap: 25px;
        margin-bottom: 10px;
        margin-top: 5px;
    }
        .edit_matter_rights label {
            /*font: 400 16px;*/
            margin-bottom: 0;
            font-size: 16px;
            font-weight: 400;
            color: #535862;
        }
    .reward_back {
        display: flex;
        /* align-items: center; */
        flex-direction: column;
        gap: 0px;
    }
    .reward_back h3{
        margin:0;
