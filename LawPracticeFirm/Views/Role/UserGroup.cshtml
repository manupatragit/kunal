                                        </li>




                                    }
                                    else
                                    {

                                        if (Convert.ToInt32(ViewBag.IsCreate) == 1)

                                        {



                                            <li>
                                                <a data-toggle="tab" href="#" id="addNewgroup" title="Create Team"> New Team</a>
                                            </li>



                                        }
                                    }

                                    @*<li><span>|</span></li>*@
                                    @*<li>
