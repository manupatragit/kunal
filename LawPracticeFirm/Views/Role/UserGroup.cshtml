    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }

}
<script src="~/Scripts/Firm/Pages/UserGroups.js?1.2" type="text/javascript" language="javascript"></script>
<script>
   var roleids = "@Session["sessionroleid"]";


    var isDelete = "@ViewBag.IsDelete";
