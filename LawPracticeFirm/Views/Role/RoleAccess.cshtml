</script>
<style>
    .glyphicon-pencil, .glyphicon-trash {
        color: black !important;
    }
    .button-group-label a {
        flex: 1;
        text-align: center;
        text-decoration: none;
        height: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        border-radius: 10px;
        color: #808080;
        padding: 0 6px;
    }
   
</style>
<section id="header">
    <div class="container-main">
        <div class="text-left">
            <p class="ctitle"><h2 id="dynamiciprheader"style="margin-top: -5px;margin-bottom: 10px;"></h2></p>
        </div>
        <div class="assign_wrapper_right">
            <div class="button-group-label">
                <a class="active" href="/@firmcode/Role/RoleAccess" title="Assign Rights" id="assignRights">Assigned Rights</a>

                <a href="/@firmcode/Role/CaseRoleAccess" title="Matter Rights" class="tabstyle" id="assignMatterRights">Matter Rights</a>
            </div>
            
            <div>
                @if (role.ToString() == "1")
                {

                <a data-toggle="tab" class="btn btn-primary" href="#" id="addNewRole" title="Create New Rights">  Create New Rights</a>

                }
                else
                {
                    if (Convert.ToInt32(ViewBag.IsCreate) == 1)
                    {

            <a data-toggle="tab" class="btn btn-primary" href="#" id="addNewRole" title="Create New Rights">  Create New Rights</a>

                    }
                }
            </div>
        </div>
            
    </div>
</section>
