    @*End Modal for Show User details on UserCount*@
    <div class="modal fade" id="modalUserCountView" tabindex="-1" role="dialog" aria-labelledby="myModalLabel">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header btn-primary">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true" style="font-size:unset !important">&times;</span></button>
                    <div id="divuserLabel"><h4 class="modal-title" id="myModalUserLabel">User(s) in Group</h4></div>
