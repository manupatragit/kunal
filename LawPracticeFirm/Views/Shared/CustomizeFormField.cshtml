@{
    var role = Session["sessionroleid"];
    var pagename = @ViewData["Pagename"];
    var pageid = @ViewData["PageId"];
}
<style>
    .switch {
        position: relative;
        display: inline-block;
        width: 47px;
        height: 20px;
        margin: 5px 0 0 0;
    }

    #content {
        padding: 0 0 10px 0;
    }
</style>
<script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
<link href="~/Manupanel/jquerydatetimepicker/jquery.datetimepicker.css" rel="stylesheet" />
<script src="~/Manupanel/jquerydatetimepicker/jquery.datetimepicker.js"></script>
<input type="hidden" value="@pageid" id="requestcamefrompageid" />
<div class="row" id="content">
</div>
<div class="row">
    <div class="col-md-12">
        <div class="" id="hidecf" style="display:block">
            @if (role.ToString() == "1")
            {
                <div class="row">
                    <div class="form-group col-md-12">
                        <a href="javascript:void(0);" data-toggle="modal" data-target="#myModal" title="Add New Custom Fields" style="color: #165a84; font-size: 13px; margin: 0 0 20px 0; display: inline-block;">
                            <img alt="" src="/newassets/img/plus-icon-blue.png">
                            <span>Add Custom Fields</span>
                        </a><br />
                        <btn class="selctInputFormat" id="publish" title="Click here to save Custom field settings"
                             style="cursor:pointer"><span><img src="/newassets/img/save-btn-icon.png" /></span> Save Custom Field</btn>
                        <span data-toggle="collapse" data-target="#demo">
                            <img src="/newassets/img/info-circle.png" style="cursor:pointer;margin-left: 5px;" />
                        </span>
                        <div id="demo" class="collapse"
                             style="border: 1px solid rgb(143, 213, 0); background:white; padding: 4px; width: 360px;top:-105px;z-index:1000;position: absolute">
                            <ul style="margin:0 0 0 20px;text-transform: none;">
                                <li>Add customized field's to the Notice form, if it does not appear in default myKase format. </li>
                                <li>The form with additional fields becomes the default form for your organization.</li>
                                <li>Reset to remove the additional fields.</li>
                            </ul>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
<br />
@if (role.ToString() == "1")
{
    <div id="myModal" class="modal fade" role="dialog">
        <div class="modal-dialog" style="width:400px;">
            <!-- Modal content-->
            <div class="modal-content">
                <div class="modal-header btn-primary">
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                    <h4 class="modal-title">
                        <img src="/newassets/img/date.png" style="margin:-15px 0px 0 -15px">
                    </h4>
                </div>
                <div class="modaltitle" style="margin: -33px 0 0 0; border-bottom: none;">
                    <h4>Custom Field</h4>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="alert alert-danger alert-dismissable validpanel">
                            </div>
                        </div>
                    </div>
                    <div class="row" id="addcustomf">
                        <form role="form" id="form2">
                            <div class="form-group col-md-12">
                                <label>Custom Field Name <span class="required" aria-required="true"><b>*</b></span></label>
                                <input class="inputFormat" type="text" value="" id="txtcustomFieldName">
                            </div>
                            <div class="form-group col-md-12">
                                <label>Custom Field Type <span class="required" aria-required="true"><b>*</b></span></label>
                                <select class="selctInputFormat" id="ctype" style="background-color: white !important;">
                                    <option value="0">Select Any</option>
                                </select>
                            </div>
                            <div class="form-group col-md-12" id="common" style="display:none">
                                <label id="listid">List options</label>
                                <input class="inputFormat" data-val="true" id="txtcustomFieldvalue" />
                                <p style="clear:both">(Add the options you would like to have in the drop down list list, separate values with a comma.)</p>
                            </div>
                            <div class="form-group" style="clear: both; height: auto;">
                                <div class="col-md-2">
                                    <label class="switch">
                                        <input type="checkbox" id="chkRequired" name="assign" value="1">
                                        <span class="slider round"></span>
                                    </label>
                                </div>
                                <div class="col-md-8">
                                    <label>Is Required :</label>
                                </div>
                            </div>
                        </form>
                    </div>        
                           
                    </div>
                
                <div class="modal-footer" style="border-top: none !important">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal" id="closemodal">Close</button>
                    <button type="button" class="btn btn-primary" id="addfield">Add Field</button>

                </div>
            </div>
        </div>
    </div>
}
<script src="~/Scripts/Notice/CustomizeFormField.js?1.0"></script>