                <li id="" class="active"><a href="javascript:void()">Send Notices</a></li>
                <li id="" style=""><a href="/@Session["firmcode"]/NoticeReceived/ReceivedNoticeList">Received Notices</a></li>
                <li id=""><a href="javascript:void()">Reminders</a></li>
            </ul>
        </div>
        <div class="text-center" id="fincesdiv" style="margin-bottom: 20px !important;">

            <div style="display: flex; align-items: center;">

                <div class="tabs-and-filters" style="width:100%;">
                    <div class="button-group">
                        @*<button class="button-group-base1" onclick="fnclearinput()" style="border-left: none; border-top: none; border-bottom: none; font-weight:600;">All <span id=""></span></button>*@
                        <a class="button-group-base1" href="/@Session["firmcode"]/NoticeNew/NewNoticeList">All<span id="AllNoticeCount"></span></a>
                        <a class="button-group-base2  active" href="/@Session["firmcode"]/NoticeNew/ArchiveNoticeList">Archived <span id="ArchNoticeCount"></span></a>
                        <a class="button-group-base1" href="/@Session["firmcode"]/NoticeNew/NoticeDeleteList">Delete <span id="DelNoticeCount"></span></a>
                        @if (Session["sessionroleid"].ToString() != "1")
                        {
                            <a class="button-group-base1" href="/@Session["firmcode"]/NoticeNew/DraftNotice">Share with me <span id="ShareNoticeCount"></span></a>
                        }
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>
<section>
    <div class="expense_total_card_wrapper">
        <div class="card" id="">
            <h5>Total Notice</h5>
            <span id="tonotice">0</span>
        </div>

        <div class="card" id="">
            <h5>Notice Settled</h5>
