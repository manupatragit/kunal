                                                <input type="text" id="NoticeeendersNametxt" placeholder="Senders Name" class="form-control pull-left" style="width:100px;">
                                            </div>
                                            <div style="float:left;width:20%">
                                                <span class="glyphicon glyphicon-search" id="searchdatas"></span>
                                                <span class="glyphicon glyphicon-remove" id="clearnewsearchforsender" title="Click here to reset search" style="display:none;"></span>
                                            </div>
                                        </div>

                                    </th>
                                    <th class="noticeto" data-column="AddressedTo"><div class="thbg">Receiver's Name</div></th>
                                    <th class="noticetitle" data-column="NoticeTitle">
                                        <div class="thbg">
                                            <div style="float:left;width:80%">
                                                <input type="text" id="Noticetitsrch" placeholder="Title" class="form-control pull-left" style="width:100px;">
                                            </div>
                                            <div style="float:left;width:20%">
                                                <span class="glyphicon glyphicon-search" id="searchdatatitl"></span>
