</section>
<section>
    <div class="card-header">
        <div class="content1" style="justify-content: space-between; padding:0;">
            <div id="prangediv" class="left_input" style="display: grid; gap: 10px; grid-template-columns: 150px 150px 120px 40px;">
                <input class="form-control inputFormat" id="rangefromdate" onkeypress="return false;" type="date" placeholder="yyyy-mm-dd" title="From" />
                <input class="form-control inputFormat" type="date" id="rangetodate" onkeypress="return false;" placeholder="yyyy-mm-dd" title="To" />
                <button class="btn btn-secondary" type="button" onclick="fnsearchbydate();" value="Go" style="padding: 8px 0;"><img src="/newassets/img/search-lg.png" style="width:18px;"> Search</button>
                <button class="btn btn-primary" type="button" id="btclear" style="display: none; padding: 8px 0px;" title="Click here to reset search" onclick="fnclearinput();" value="Reset"><img src="/newassets/img/btn-close.png"></button>

            </div>
            <div class="table-header">
                <div class="actions3">
                    <div id="ColumnSelectionopen" class="button13 dropup">
                        <a href="javascript:void()">
                            <img class="plus-icon" alt="" src="/newassets/img/settings-icon.png"> Customize
                        </a>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<section id="table">
    <div class="container-main">
        <div class="table">
            <div class="tablearea" style="margin:0;">
                <div class="scroll-sync-top" aria-hidden="true">
                    <div class="scroll-top-inner"></div>
                </div>
                <div class="tablecontainer table-scroll-wrapper">
                    <div class="table-scroll-inner">
