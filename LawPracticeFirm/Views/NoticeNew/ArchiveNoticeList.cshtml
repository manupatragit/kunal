                                            </div>
                                        </div>
                                    </th>
                                    <th class="attachment"><div class="thbg">Docs</div></th>

                                    <th class="noticesubject" data-column="NoticeSubject">
                                        <div class="thbg">
                                            <div style="float:left;width:80%">
                                                <input type="text" id="NoticeSubjectsrh" placeholder="Subject" class="form-control pull-left" style="width:100px;">
                                            </div>
                                            <div style="float:left;width:20%">
                                                <span class="glyphicon glyphicon-search" id="searchdatassub"></span>
                                                <span class="glyphicon glyphicon-remove" id="clearnewsearchforsendersub" title="Click here to reset search" style="display:none;"></span>
                                            </div>
                                        </div>

                                    </th>

                                    <th class="statutory" data-column="NoticeType"><div class="thbg">Type</div></th>
                                    <th class="dispatched" data-column="DateofDelivery"><div class="thbg">Date Of Delivery</div></th>
                                    <th class="modeofserviceordelivery" data-column="ModeofServiceorDelivery"><div class="thbg">Mode of Delivery</div></th>
                                    <th class="addressaddress" data-column="AddresseeAddress"><div class="thbg">Receiver's Address</div></th>
                                    <th class="otherdetailsofaddress" data-column="OtherDetailsofAddressee"><div class="thbg">Other Details of receiver</div></th>
                                    <th class="senderaddress" data-column="SendersAddress"><div class="thbg">Sender's Address</div></th>
                                    <th class="otherdetailsofaddressofsender" data-column="OtherDetailsofSender"><div class="thbg">Other Details of Sender</div></th>
                                    <th class="noticethrough" data-column="NoticeThrough"><div class="thbg">Notice Through/To</div></th>
                                    <th class="CreatedByName" data-column="CreatedByName"><div class="thbg">Created By</div></th>
                                    <th class="noticecreatedon" data-column="NoticeCreatedOn"><div class="thbg">Notice Created On</div></th>
                                    <th class="criticality"><div class="thbg">Priority</div></th>
                                    <th class="reasonforhighcriticality"><div class="thbg">Reason For High Priority</div></th>
                                    <th class="amountclaimed"><div class="thbg">Amount Claimed</div></th>
                                    <th class="noticeTrackingId"><div class="thbg">Consignment No</div></th>
                                    <th class="actualclosedate"><div class="thbg">Status Changed Date</div></th>

                                    <th class="Receiverdetails"><div class="thbg">Receiver Details</div></th>
                                    <th class="ReferenceNumber"><div class="thbg">Reference Number</div></th>
                                    <th class="InternalNumber"><div class="thbg">Internal  Number</div></th>
                                    <th class="deliveryDispatch"><div class="thbg">Date Of Dispatch</div></th>
                                    <th width="120px"><div class="thbg">Action</div></th>
                                </tr>
                            </thead>
                            <tbody id="tablevalue"></tbody>
                        </table>
                        <center> <div id="nonotice"> </div></center>
                    </div>
                </div>
                <div class="pagination" id="pagenatedArea">
                    <div class="pagination-button-group">
                        <div id="prev" class="pagination-button-group-base">
                            <img class="arrow-left-icon" alt="" src="/newassets/img/pre-arrow.png" style="width:16px; height:16px;">
                            <div class="text" style="float:right; padding:0 0 0 8px;">Previous</div>
                        </div>
                        <div id="pageNumbers" class="pagination-button-group-base1">
                        </div>

                        <div id="next" class="pagination-button-group-base8">
                            <div class="text" style="float: left;padding: 0 8px 0 0px;">Next</div>
                            <img style="float: right; width: 16px; height: 16px;" class="arrow-left-icon" alt="" src="/newassets/img/next-arrow.png" />

                        </div>
                    </div>
                    <div class="text-and-supporting-text-parent">
                        <div class="input">
                            <div class="content">
                                <input type="text" id="txtgopage" name="query" placeholder="Page No.">
                            </div>
                            <div class="help-icon">
                            </div>
                        </div>
                        <div class="text-and-supporting-text-group">
                            <div class="text-and-supporting-text">
                                <div id="divGo" class="text9">Go</div>
                            </div>
                            <img class="chevron-down-icon" alt="" src="~/newassets/img/next-arrow.png" style="width:16px; height:16px;">

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
