<div id="myModalCustomizedcolumn" class="modal right fade myModal " role="dialog" data-backdrop="static">
    <div class="modal-dialog" style="width:400px;height: 100vh; padding:2px 0;">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header btn-success">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <div class="modaltitle">
                    <h4><img src="~/newassets/img/customize-icon.png" /> Customise Field</h4>
                </div>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-12" style="margin:10px 0 0 0;">
                        <ul id="od">
                            <li data-subject="Amount Claimed"><input type="checkbox" class="shcheckbox1 chkdhide" name="amountclaimed"> Amount Claimed </li>
                            <li data-subject="Status changed date"><input type="checkbox" class="shcheckbox1 chkdhide" name="actualclosedate"> Status Changed Date </li>
                            <li data-subject="Priority"><input type="checkbox" class="shcheckbox1 chkdhide" name="criticality"> Priority </li>
                            <li data-subject="Reason For High Priority"><input type="checkbox" class="shcheckbox1 chkdhide" name="reasonforhighcriticality"> Reason For High Priority </li>
                            <li data-subject="Senders Name"><input type="checkbox" class="shcheckbox1 chkdhide" name="noticeby" checked> Senders Name </li>
                            <li data-subject="Receiver's Name"><input type="checkbox" class="shcheckbox1 chkdhide" name="noticeto" checked> Receiver's Name </li>
                            <li data-subject="Subject"><input type="checkbox" class="shcheckbox1 chkdhide" name="noticesubject"> Subject </li>
                            <li data-subject="Title"><input type="checkbox" class="shcheckbox1 chkdhide" name="noticetitle" checked> Title </li>
                            <li data-subject="Type"><input type="checkbox" class="shcheckbox1 chkdhide" name="statutory"> Type </li>
                            <li data-subject="Date of Notice"><input type="checkbox" class="shcheckbox1 chkdhide" name="noticedate" checked> Date of Notice </li>
                            <li data-subject="Due Date"><input type="checkbox" class="shcheckbox1 chkdhide" name="noticeduedate" checked> Due Date </li>
                            <li data-subject="Status"><input type="checkbox" class="shcheckbox1 chkdhide" name="pending" checked> Status </li>
                            <li data-subject="Notice Text"><input type="checkbox" class="shcheckbox1 chkdhide" name="remark" checked> Notice Text </li>
                            <li data-subject="Mode of Delivery"><input type="checkbox" class="shcheckbox1 chkdhide" name="modeofserviceordelivery"> Mode of Delivery </li>
                            <li data-subject="Receiver's Address"><input type="checkbox" class="shcheckbox1 chkdhide" name="addressaddress"> Receiver's Address </li>
                            <li data-subject="Other Details of Receiver"><input type="checkbox" class="shcheckbox1 chkdhide" name="otherdetailsofaddress"> Other Details of Receiver </li>
                            <li data-subject="Sender's Address"><input type="checkbox" class="shcheckbox1 chkdhide" name="senderaddress"> Sender's Address </li>
                            <li data-subject="Other Details of Sender"><input type="checkbox" class="shcheckbox1 chkdhide" name="otherdetailsofaddressofsender"> Other Details of Sender </li>
