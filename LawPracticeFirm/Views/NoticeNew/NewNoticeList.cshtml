@{
    /**/
    var role = Session["sessionroleid"];
    var userid = Session["sessionuserid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
    else if (role.ToString() == "3")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialClient.cshtml";
    }
}
<script>
    var userid = "@userid";
    var roleid = "@role";
    var NoticeId="@ViewBag.NoticeId";
</script>
<script src="~/Manupanel/ckeditor/ckeditor.js"></script>
<script src="~/Manupanel/ckeditor/samples/js/sample.js"></script>
<link href="~/Manupanel/css/jquery.datetimepicker.css" rel="stylesheet" />
<script src="~/Manupanel/js/daterangepicker.min.js"></script>
<style>
    .status_badge {
        max-width: fit-content;
        display: flex;
        align-items: center;
        gap: 4px;
        /* border: 1px solid #ccc; */
        padding: 3px;
        border-radius: 7px;
        background: #f5f5f5d4;
        font-size: 12px;
    }

        .status_badge span {
            display: block;
            height: 8px;
            width: 8px;
            border-radius: 50%;
        }

    .active1 {
        background: green;
    }

    .Settled {
        background: grey;
    }

    .Convertedmatter {
        background: red;
    }

    .InActive {
        background: orange;
    }

    .low {
        background: green;
    }

    .medium {
        background: grey;
    }

    .high {
        background: red;
    }

    .select2-container {
        box-sizing: border-box;
        display: inline-block;
        margin: 0;
        position: relative;
        vertical-align: middle;
        width: 300px !important;
    }

    #myInput {
        border-box: box-sizing !important;
        background-repeat: no-repeat !important;
        font-size: 11px !important;
        padding: 14px 15px 15px 11px !important;
        /* border: none !important; */
        border-bottom: 1px solid #ddd !important;
        width: 100%;
    }

    .settingshowhide li {
        margin-left: 10px !important;
    }

    .tblreplyclass thead tr th {
        background-color: #ffffff !important;
    }

    #tblincmingnotice {
        margin: 6px 0;
        padding: 10px;
        background: #ffffff;
        border: 1px solid #b1b1b1;
        border-radius: 10px;
    }

        #tblincmingnotice table {
            width: 100%;
        }

        #tblincmingnotice h2 {
            margin: 0 0 10px 0;
            padding: 2px 7px;
            font-size: 15px;
            border-bottom: 1px solid #e3e3e3;
            color: #145cbf;
        }

    .tblreplyclass tr {
        border-bottom: none;
    }

    .tblreplyclass tbody tr td {
        color: #020202;
        font-size: 13px;
        font-weight: 400;
        padding: 1px 8px !important;
    }

    #tblpoitem {
        background: #f1f3f4;
        overflow-x: scroll;
        padding: 10px;
        border-radius: 10px;
        border: 1px solid #ccc;
        width: 1150px;
    }

        #tblpoitem h2 {
            margin: 0 0 10px 0;
            padding: 2px 0px;
            font-size: 15px;
            border-bottom: 1px solid #a3a3a3;
        }

        #tblpoitem table {
            background-color: transparent;
        }

            #tblpoitem table th {
                background-color: #0c4a6e !important;
                border-radius: 0;
                font-size: 13px;
                color: #ffffff;
                padding: 8px 8px !important;
                white-space: nowrap;
                border: none !important;
                font-weight: normal;
                height: auto;
            }

            #tblpoitem table tbody tr td {
                color: #020202;
                font-size: 13px;
                font-weight: 400;
                padding: 3px 8px !important;
                border-top: none !important;
                background: #fff;
            }

    .glyphicon-chevron-down:before {
        font-size: 11px !important;
        padding: 0px 0 0 6px !important;
        color: #6d6d6d;
    }

    .pipesapcls {
        margin: 0;
        padding: 0 5px;
        color: #0059c1;
        font-weight: 500;
    }

    #childtbltr1 {
        background-color: #d0f0c0;
    }

    #trcolhighlighbydate {
        background: #d0f0c0 !important;
    }

        #trcolhighlighbydate td {
            background-color: transparent !important;
        }

    fieldset {
        background-color: transparent;
    }

    .modal-body fieldset {
        border: 1px solid #ccc !important;
        border-radius: 5px;
    }

    .modal-dialog {
        width: 700px;
        margin: 30px auto;
    }

    #footer-data ul {
        list-style-type: none;
    }

    .upload_btn {
        background: #fff;
        padding: 8px 12px;
        outline: 0 !important;
        border: 1px solid rgba(209, 213, 219, 1);
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        color: rgba(65, 70, 81, 1);
        display: inline-block;
        float: right;
        margin: -40px 0 0 0;
        cursor: pointer;
    }

    .scroll-sync-top {
        overflow-x: auto;
        overflow-y: hidden;
        height: 16px;
        background-color: transparent;
        display: none;
    }

    .scroll-top-inner {
        height: 1px;
    }

    .table-scroll-wrapper {
        overflow-x: auto;
        overflow-y: hidden;
        white-space: nowrap;
    }

        .table-scroll-wrapper::-webkit-scrollbar {
            display: none;
        }

    .scroll-sync-top::-webkit-scrollbar {
        height: 8px;
    }

    .table-panel th {
        position: sticky;
        top: 0;
        z-index: 91;

        background-color: #fafafa;
        border-bottom: 1px solid #e5e7eb;
        border-top: 1px solid #e5e7eb;
        box-sizing: border-box;
        height: 44px;
        align-items: center;
        padding: 0px;
        font-size: 12px;
        color: #717680;
        font-weight: 600;
        white-space: nowrap;
    }

        .table-panel th .thbg {
            position: sticky;
            top: 0;
            background-color: #fafafa;
            z-index: auto;
        }

    .tablecontainer {
        max-height: 600px;
        overflow-y: auto;
        position: relative;
        /*v*/
        z-index: 0;
    }
</style>

<link href="~/dist/select2/css/select2.min.css" rel="stylesheet" />
<div id="tooltip" class="custom-tooltip"></div>

<section id="header">
    <div class="container-main">
        <input type="hidden" value="@Session["hsnotice"]" id="hdnNoticePack" />
        <input type="hidden" value="@Session["dashmatter"]" id="hdnLMPack" />
        <input type="hidden" value="@ViewBag.noticefrom" id="fromreminder" />
        <input type="hidden" value="@ViewBag.iid" id="reminderid" />
        <div class="text-left">
            <p class="ctitle"><span id="dynamicnotiheader"></span></p>
        </div>
        <div style="margin: 10px 0 5px 0; overflow:hidden;">
            <ul class="snav">
                <li id="" class="active"><a href="javascript:void()">Send Notices</a></li>
                <li id="" style=""><a href="/@Session["firmcode"]/NoticeReceived/ReceivedNoticeList">Received Notices</a></li>
                <li id=""><a href="/@Session["firmcode"]/NoticeNew/NoticeReminder">Reminders</a></li>
            </ul>
        </div>
        <div class="text-center" id="fincesdiv" style="margin-bottom: 20px !important;">

            <div style="display: flex; align-items: center;">

                <div class="tabs-and-filters" style="width:100%;">
                    <div class="button-group">
                        <button class="button-group-base1 active" onclick="fnclearinput()" style="border-left: none; border-top: none; border-bottom: none; font-weight:600;">All <span id="AllNoticeCount"></span></button>
                        <a class="button-group-base2" href="/@Session["firmcode"]/NoticeNew/ArchiveNoticeList">Archived <span id="ArchNoticeCount"></span></a>
                        <a class="button-group-base1" href="/@Session["firmcode"]/NoticeNew/NoticeDeleteList">Delete <span id="DelNoticeCount"></span></a>
                        @if (Session["sessionroleid"].ToString() != "1")
                        {
                            <a class="button-group-base1" href="/@Session["firmcode"]/NoticeNew/DraftNotice">Share with me <span id="ShareNoticeCount"></span></a>
                        }

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<section>
    <div class="expense_total_card_wrapper">
        <div class="card" id="">
            <h6>Total Notice</h6>
            <span id="tonotice">0</span>
        </div>

        <div class="card" id="">
            <h6>Notice Settled</h6>
            <span id="setNotice">0</span>
        </div>

        <div class="card" id="">
            <h6>Converted Into Matter</h6>
            <span id="contomatNotice">0</span>
        </div>
    </div>
</section>
<section>
    <div class="card-header">
        <div class="content1" style="justify-content: space-between; padding:0;">
            <div id="prangediv" class="left_input" style="display: grid; gap: 10px; grid-template-columns: 150px 150px 120px 40px;">

                <input class="form-control inputFormat" id="rangefromdate" onkeypress="return false;" type="date" title="From" />

                <input class="form-control inputFormat" type="date" id="rangetodate" onkeypress="return false;" title="To" />
                <button type="button" onclick="fnsearchbydate();" value="Go" class="btn btn-secondary" style="padding: 8px 0;"><img src="/newassets/img/search-lg.png" style="width:18px;"> Search</button>
                <div class="btn btn-secondary" id="btclear" onclick="fnclearinput();" value="Reset" title="Click here to reset search" style="padding: 8px 0px; display: none;"><img src="/newassets/img/btn-close.png"></div>
            </div>
            <div class="table-header">
                <div class="actions3">
                    <button type="button" value="Send Multiple" class="button9" onclick="assignmodal()" title="Send Multiple"><img class="plus-icon" alt="" src="/newassets/img/share.svg" /></button>
                    <div class="menuexport" style="position:relative; cursor:pointer;">

                        <div class="dropdown-toggle button9" id="menuexport" type="button" data-toggle="dropdown" title="Export">
                            <img class="plus-icon" alt="" src="/newassets/img/upload-icon.png">
                        </div>
                        <ul class="dropdown-menu settingaction" role="menu" aria-labelledby="menuexport">
                            <li>
                                <div onclick="ExportToExcelNotice('NewNotice')" title="Export to excel"><span style="padding: 0 10px 0 0;"><img src="/newassets/img/exportexl-icon.png"></span>Export to excel</div>
                            </li>
                        </ul>
                    </div>
                    <div id="ColumnSelectionopen" class="button13 dropup">
                        <a href="javascript:void()">
                            <img class="plus-icon" alt="" src="/newassets/img/settings-icon.png"> Customize
                        </a>

                    </div>
                    @if (role.ToString() == "1")
                    {
                        <button type="button" class="button4" onclick="newNotice()" title="Add New Notice"><span><img src="/newassets/img/plus-icon.png"></span>Create New Notice</button>
                    }
                    else
                    {
                        if (Convert.ToInt32(ViewBag.IsCreate) == 1)
                        {
                            <button type="button" class="button4" onclick="newNotice()" title="Add New Notice"><span><img src="/newassets/img/plus-icon.png"></span>Create New Notice</button>
                        }
                    }



                </div>
            </div>
        </div>
    </div>
</section>
<section id="table">
    <div class="container-main">
        <div class="table">
            <div class="tablearea" style="margin:0;">
                <div class="scroll-sync-top" aria-hidden="true">
                    <div class="scroll-top-inner"></div>
                </div>
                <div class="tablecontainer table-scroll-wrapper">
                    <div class="table-scroll-inner">
                        <table id="example" class="table-panel">
                            <thead>
                                <tr id="newnoticeheadrow">
                                    <th><div class="thbg"><input type="checkbox" name="checkedAll" id="parentcheckboxid"></div></th>
                                    <th><div class="thbg">S.No</div></th>
                                    <th class="noticeby">
                                        <div class="thbg">
                                            <div style="float:left;width:80%">
                                                <input type="text" id="noticebyIds" placeholder="Senders Name" class="form-control pull-left" style="width:100px;">
                                            </div>
                                            <div style="float:left;width:20%">
                                                <span class="glyphicon glyphicon-search" id="searchdatas"></span>
                                                <span class="glyphicon glyphicon-remove" id="clearnewsearchforsender" title="Click here to reset search" style="display:none;"></span>
                                            </div>
                                        </div>
                                    </th>
                                    <th class="senderaddress"><div class="thbg">Sender's Address</div></th>
                                    <th class="otherdetailsofaddressofsender">
                                        <div class="thbg">
                                            <div style="float:left;width:80%">
                                                <input type="text" title="Other Details of Sender" id="othdetailsofsender" placeholder="Other Details of Sender" class="form-control pull-left" style="width:100px;">
                                            </div>
                                            <div style="float:left;width:20%">
                                                <span class="glyphicon glyphicon-search" id="searchothdetl"></span>
                                                <span class="glyphicon glyphicon-remove" id="clearnewsearthdetl" title="Click here to reset search" style="display:none;"></span>
                                            </div>
                                        </div>
                                    </th>
                                    <th class="noticeto"><div class="thbg">Receiver Name</div></th>
                                    <th class="addressaddress"><div class="thbg">Receiver's Address</div></th>
                                    <th class="otherdetailsofaddress"><div class="thbg">Other Details of Receiver</div></th>
                                    <th class="statutory">
                                        <div class="thbg">
                                            <select class="form-control form-control-sm" name="ddlnoticetypess" id="ddlnoticetypess">
                                                <option value="" selected>Type</option>
                                                <option value="Statutory">Statutory</option>
                                                <option value="Non-Statutory">Non-Statutory</option>
                                            </select>
                                        </div>
                                    </th>
                                    <th class="noticesubject">
                                        <div class="thbg">
                                            <div style="float:left;width:80%">
                                                <input type="text" id="noticeSubjects" placeholder="Subject" class="form-control pull-left" style="width:100px;">
                                            </div>
                                            <div style="float:left;width:20%">
                                                <span class="glyphicon glyphicon-search" id="searchdatassub"></span>
                                                <span class="glyphicon glyphicon-remove" id="clearnewsearchforsendersub" title="Click here to reset search" style="display:none;"></span>
                                            </div>
                                        </div>
                                    </th>
                                    <th class="noticetitle">
                                        <div class="thbg">
                                            <div style="float:left;width:80%">
                                                <input type="text" id="noticeTitless" placeholder="Title" class="form-control pull-left" style="width:100px;">
                                            </div>
                                            <div style="float:left;width:20%">
                                                <span class="glyphicon glyphicon-search" id="searchdatatitl"></span>
                                                <span class="glyphicon glyphicon-remove" id="clearnewsearchforsendertitl" title="Click here to reset search" style="display:none;"></span>
                                            </div>
                                        </div>
                                    </th>
                                    <th class="noticedate"><div class="thbg">Date Of Notice</div></th>
                                    <th class="modeofserviceordelivery"><div class="thbg">Mode of Delivery</div></th>
                                    <th class="noticethrough"><div class="thbg">Notice Through/To</div></th>
                                    <th class="criticality"><div class="thbg">Priority</div></th>
                                    <th class="reasonforhighcriticality"><div class="thbg">Reason For High Priority</div></th>
                                    <th class="remark"><div class="thbg">Notice Text</div></th>
                                    <th class="noticeduedate"><div class="thbg">Due Date</div></th>
                                    <th class="pending">
                                        <div class="thbg" style="width:180px;">
                                            <select class="form-control" id="txtStatusOfNotice" name="txtStatusOfNotice" required=""></select>
                                        </div>
                                    </th>
                                    <th class="amountclaimed"><div class="thbg">Amount Claimed</div></th>
                                    <th class="tags"><div class="thbg">Tags</div></th>
                                    <th class="noticeTrackingId"><div class="thbg">Consignment No</div></th>
                                    <th class="CreatedByName"><div class="thbg">Created By</div></th>
                                    <th class="actualclosedate"><div class="thbg">Status Changed Date</div></th>
                                    <th class="Receiverdetails"><div class="thbg">Receiver Details</div></th>
                                    <th class="ReferenceNumber"><div class="thbg">Reference Number</div></th>
                                    <th class="InternalNumber"><div class="thbg">Internal  Number</div></th>
                                    <th class="dispatched"><div class="thbg">Date Of Delivery</div></th>
                                    <th class="deliveryDispatch"><div class="thbg">Date Of Dispatch</div></th>
                                    <th class="attachment"><div class="thbg">Docs</div></th>
                                </tr>
                            </thead>
                            <tbody id="tablevalue"></tbody>
                        </table>

                        <center> <div id="nonotice"> </div></center>
                    </div>
                </div>
                <div class="pagination" id="pagenatedArea">
                    <div class="pagination-button-group">
                        <div id="prev" class="pagination-button-group-base">
                            <img class="arrow-left-icon" alt="" src="/newassets/img/pre-arrow.png" style="width:16px; height:16px;">
                            <div class="text" style="float:right; padding:0 0 0 8px;">Previous</div>
                        </div>
                        <div id="pageNumbers" class="pagination-button-group-base1">
                        </div>

                        <div id="next" class="pagination-button-group-base8">
                            <div class="text" style="float: left;padding: 0 8px 0 0px;">Next</div>
                            <img style="float: right; width: 16px; height: 16px;" class="arrow-left-icon" alt="" src="/newassets/img/next-arrow.png" />

                        </div>
                    </div>
                    <div class="text-and-supporting-text-parent">
                        <div class="input">
                            <div class="content">
                                <input type="text" id="txtgopage" name="query" placeholder="Page No.">
                            </div>
                            <div class="help-icon">
                            </div>
                        </div>
                        <div class="text-and-supporting-text-group">
                            <div class="text-and-supporting-text">
                                <div id="divGo" class="text9">Go</div>
                            </div>
                            <img class="chevron-down-icon" alt="" src="~/newassets/img/next-arrow.png" style="width:16px; height:16px;">

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

