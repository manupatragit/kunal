                        <ul>
                            <li>Matter Management</li>
                            <li>Document Management</li>
                            <li>Litigation Tracking</li>
                            <li>Expense Management</li>
                            <li>Invoice Management</li>
                            <li>Task Management</li>
                        </ul>
                    </div>

                </div>
                <div class="col-md-4">
                    <div class="h-bg">
                        <h1 style="padding: 4px 0;">Request & Matter Management Platform<br /><span style="font-weight:300;">for Corporate Legal Teams</span> </h1>
                    </div>
                    <div class="h-content" style="background: url(~/elp/p-bg2.png) no-repeat right bottom;">
                        <p>A single unified platform which gets requests, matters, people, clients, documents, communication, dates & external counsel together in one place.</p>
                        <ul>
                            <li>Request Management</li>
                            <li>Matter Management</li>
                            <li>Document Management</li>
                            <li>Expense Management</li>
                            <li>Task Management</li>

                        </ul>
                    </div>

                </div>
                <div class="col-md-4">
                    <div class="h-bg">
                        <h1 style="padding: 15px 0;">Notice Management Platform</h1>
                    </div>
                    <div class="h-content" style="background: url(~/elp/p-bg3.png) no-repeat right bottom;">
                        <p>Manages the notices throughout their lifecycle in a single streamlined workflow.</p>
                        <ul>
                            <li>Send & Receive Notices</li>
                            <li>Document Management</li>
                            <li>Smart Alerts</li>
                            <li>Workflow</li>
                            <li>Reports + Customized Dashboard</li>

                        </ul>
                    </div>

                </div>

            </div>
        </div>
    </section>
    <section class="footer">

        <div class="container">
            <div class="row">
