                        <iframe src="/schedule-demo?f=1&Source=@ViewBag.Source" width="100%" height="320px" frameborder="0" style="padding:10px 0 0 0;"></iframe>
                    </div>

                </div>

            </div>
        </div>

    </section>
    <section class="pmp">
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <h1>Practice Management Platform</h1>
                    <h2>A definitive tool for Lawyers, Law Firms & Corporate Legal Departments</h2>
                </div>
            </div>
        </div>
    </section>
    <section class="kb">
        <div class="col-md-6" style="background:#f2f2f2;">
            <div class="bg-w">
                <h2>Key Benefits</h2>
                <ul>
                    <li>Visibility and control over end to end process</li>
                    <li>Centralized repository of all files & information</li>
                    <li>Cross-Functional Collaboration</li>
                    <li>Become a DATA Informed Legal Team</li>
                    <li>Increase ROI- Do More with Less</li>
                    <li>Optimum Use of Resources</li>
                </ul>
            </div>
        </div>
        <div class="col-md-6" style="background:#585858;">
            <div class="bg-g">
                <ul>
                    <li>Centralized Information</li>
                    <li>Seamless Collaboration</li>
                    <li>Client Experience</li>
                </ul>
            </div>
        </div>
    </section>
    <section class="product">
        <div class="container">
            <div class="row">
                <div class="col-md-4">
                    <div class="h-bg">
                        <h1 style="padding: 15px 0;">Litigation Management Platform</h1>
                    </div>
                    <div class="h-content" style="background: url(~/elp/p-bg1.png) no-repeat right bottom;">
