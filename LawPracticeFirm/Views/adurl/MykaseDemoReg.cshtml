                        <li style="float:left; padding:0; color:#000000;">contact@mykase.in</li>
                        <li style="float:left; padding:0px 2px 0 10px"><img src="~/elp/phone_icon.png" width="20" height="19"></li>
                        <li style="float:left; padding:0; color:#000000;">0120-4014433</li>
                        <li style="float:left; padding:0px 2px 0 9px"><a href="https://api.whatsapp.com/send?phone=918800106683&amp;text=I%27m%20interested%20in%20myKase%20services.%20Please%20call%20me%20on%20this%20no" target="_blank"><img src="~/elp/whatapp_icon.png" width="22" height="22"></a></li>
                    </ul>
                </div>
                <div class="col-md-6 text-right">
                    <img src="~/elp/manu_logo.png">
                </div>
            </div>
        </div>

