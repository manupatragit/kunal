</head>

<body>
    <script>
        var Source = "@ViewBag.Source";

    </script>
    <header>
        <div class="container">
            <div class="row">
                <a href="https://www.mykase.in/" target="_blank" class="logo img-responsive"><img src="~/elp/logo_mykase.png" title="myKase" alt="myKase"></a>
                <div class="header-right">
                    <a href="https://www.linkedin.com/showcase/mykasemanupatra" target="_blank" class=""><i class="fa fa-linkedin" aria-hidden="true" style="font-size: 20px;"></i></a>
                    <a href="https://www.youtube.com/watch?v=cDvQfi4Qwuo" target="_blank" class=""><i class="fa fa-youtube-play" aria-hidden="true" style="font-size: 20px;"></i></a>
                </div>
            </div>
        </div>
    </header>
    <section class="banner">
        <div class="container">
            <div class="row">
                <div class="col-md-8"><img src="~/elp/banner1.png" class="img-responsive" title="myKase" alt="myKase"></div>
                <div class="col-md-4">
                    <div class="r-form-1-box wow fadeInLeft animated" style=" visibility: visible; animation-name: fadeInLeft; background:#ffffff; border: 1px solid #b9b9b9;padding: 2px;margin: 23px 0 30px 0;border-radius:0 0 10px 10px;">
