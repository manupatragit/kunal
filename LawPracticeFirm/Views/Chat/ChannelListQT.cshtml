<link rel="stylesheet" href="https:/resources/demos/style.css">
<script src="https://code.jquery.com/jquery-1.12.4.js"></script>
<script src="https://code.jquery.com/ui/1.12.1/jquery-ui.js"></script>
<script>
    $(function () {
        $("#tabs").tabs();
    });
</script>
<style>
    table th, td {
        font-size: 12px !important;
    }
</style>
<section class="wrapper">
    <input type="hidden" id="userid" value="@Session["sessionuserid"].ToString()" />
    <div class="container" style="width:100%!important">
        <div class="row">
            <div id="tabs">
                <ul>
                    <li><a href="#tabs-3">Join Chat</a></li>
                    <li><a href="#tabs-1">Matter Channel</a></li>
                    <li><a href="#tabs-2">Private Channel</a></li>
                    <li><a href="#tabs-4">Chat Setting</a></li>
                </ul>
                <div id="tabs-1" style="padding: 0px 5px 0 5px !important;">
                    <p><iframe id="frmnew" src="/@firmcode121/chat/ChannelListQTDetail" height="500px" width="98%" style="border:none;padding:10px 0 0 0;overflow-y:scroll"></iframe></p>
                </div>
                <div id="tabs-2" style="padding: 0px 5px 0 5px !important;">
                    <p><iframe id="frmnew1" src="/@firmcode121/chat/PrivateChannelListQTDetail" height="500px" width="98%" style="border:none;padding:10px 0 0 0;overflow-y:scroll"></iframe></p>
                </div>
                <div id="tabs-3" style="padding: 0px 5px 0 5px !important;">
                    <p><iframe id="frmnew1" src="/@firmcode121/chat/InvitedchatQT" height="450px" width="98%" style="border:none;padding:10px 0 0 0;overflow-y:scroll"></iframe></p>
                </div>
                <div id="tabs-4" style="padding: 0px 5px 0 5px !important;">
                    <p><iframe id="frmnew1" src="/@firmcode121/chat/ChatSetting" height="450px" width="98%" style="border:none;padding:10px 0 0 0;overflow-y:scroll"></iframe></p>
                </div>
            </div>
    </div>
</section>
