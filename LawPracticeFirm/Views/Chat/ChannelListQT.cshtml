@{
    ViewBag.Title = "ChannelListQT";
    Layout = null;// "~/Views/Shared/_ManuPanelPartial.cshtml";
    var strenyfirmid = Convert.ToBase64String(QueryStringEDAES.QueryAES.EncryptAes(Session["sessionfirmid"].ToString().Replace("_", " ")));
    var strenyuserid = Convert.ToBase64String(QueryStringEDAES.QueryAES.EncryptAes(Session["sessionuserid"].ToString().Replace("_", " ")));
    var strenyusername = Convert.ToBase64String(QueryStringEDAES.QueryAES.EncryptAes(ViewBag.UseName.Replace("_", " ")));
    var firmcode121 = Session["FirmCode"];
}
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
<link href="/Manupanel/css/bootstrap.min.css" rel="stylesheet" type="text/css" />
