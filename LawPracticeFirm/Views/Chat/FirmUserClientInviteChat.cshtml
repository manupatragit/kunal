@{
    ViewBag.Title = "FirmUserClientInviteChat";
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
    else if (role.ToString() == "3")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialClient.cshtml";
    }
    Guid obj = new Guid();
    var strdate = DateTime.Now.ToString("dd-MMM-yyyy");
    var ChannelGuid = obj.ToString();
}
<script src="~/Scripts/Firm/Pages/Chat.js?2.5"></script>
<h2>FirmUserClientInviteChat</h2>
<table id="example" class="table table-striped table-bordered" style="width:50%;">
    <thead>
        <tr><td>Firm User</td><td><a href="#" onclick="InsertInviteUser(1)">Invite</a></td></tr>
    </thead>
    <tbody id="binddata"></tbody>
</table>
<table id="example1" class="table table-striped table-bordered" style="width:50%;">
    <thead>
        <tr><td>Client</td><td><a href="#" onclick="InsertInviteUser(2)">Invite</a></td></tr>
    </thead>
    <tbody id="binddata1"></tbody>
</table>
<input type="text" value="@strdate" id="curdate" />
<input type="text" value="@strdate" id="ChannelGuid" />
<script>
    FirmUserList(2);
    FirmClientList(3);
</script>