    $(document).ready(function () {    
        $(document).on('click', '#reminderClose', function () {
            $("#divChatReminder").hide();
        });
        CheckChatJoinedByUser();
        setInterval(function () { if ($("#hidtempchatdisable").val() == "0") { CheckChatJoinedByUser(); }}, 100000);
        function CheckChatJoinedByUser() {
            $.ajax({
                async: true,
                url: '/api/ChatApi/CheckChatJoinedByUser',              
                processData: false,
                contentType: false,
                type: 'POST',
                success: function (response) {                   
                    if (response.Data.length > 0 && $("#hidtempchatdisable").val()=="0") {
                        $("#divChatReminder").show();
                    }
                    else {
                        $("#divChatReminder").hide();
                    }
                },
                error: function (response) {
                    alert(response.responseText);
                }
            });
        }
        $(document).on('click', '#chatjoin', function () {
            $("#hidtempchatdisable").val("1");
            $("#divChatReminder").hide();           
        });
        $(document).on('click', '#chatdisable', function () {
            $("#hidtempchatdisable").val("1");
            $("#divChatReminder").hide();
        });
    });
</script>*@