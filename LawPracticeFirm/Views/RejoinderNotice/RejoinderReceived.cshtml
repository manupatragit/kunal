</div>
<div class="modal fade" id="ViewLogModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <a href="#" class="close" data-dismiss="modal">&times;</a>
                <h3 class="modal-title">Notice Logs</h3>
            </div>
            <div class="modal-body">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Sender Name</th>
                            <th>Receiver Name</th>
                            <th>Type</th>
                            <th>Notice Sent On</th>
                            <th>Status</th>
                            <th>Feedback</th>
                        </tr>
                    </thead>
                    <tbody id="modlbody"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="FinalStatusModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <a href="#" class="close" data-dismiss="modal">&times;</a>
                <h3 class="modal-title">Final Status</h3>
            </div>
            <div class="modal-body">
                <div class="container">
                    <form>
                        <div class="row">
                            <div class="col-sm-3">
                                <span style="color:red">*</span><label>Date of Delivery</label>
                                <input type="date" class="form-control" id="dateofddel" />
                            </div>
                            <div class="col-sm-3">
                                <span style="color:red">*</span><label>Date of Receipt (Proof)</label>
                                <input type="date" class="form-control" id="txtdateofreceipt" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-sm-3">
                                <span style="color:red">*</span><label>Current Status</label>
                                <textarea type="text" id="currentstatus" class="form-control"></textarea>
                            </div>
                            <div class="col-sm-3">
                                <label>Upload Files</label>
                                <input type="file" class="form-control" id="postedFile" multiple />
                            </div>
                        </div>
                        <br />
                        <button type="button" id="savefinalstatus" class="sbtbtn">Save</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="NoticeDraftModal">
    <div class="modal-dialog">
        <div class="modal-content" style="width: 780px !important">
            <div class="modal-header">
                <a href="#" class="close" data-dismiss="modal">&times;</a>
                <h3 class="modal-title">Notice</h3>
            </div>
            <div class="modal-body">
                <div class="row" style="height:40vh;overflow-y:scroll">
                    <div class="col-md-12">
                        <div class="ec_bg">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Sr no.</th>
                                        <th>File</th>
                                        <th>Created By</th>
                                        <th>Created Date</th>
                                    </tr>
                                </thead>
                                <tbody id="draftnoticemodlbody"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="row" style="height:40vh; overflow-y:scroll;padding-left:15px;">
                    <h4 style="text-align:center">Send notice on email</h4>
                    <div class="row" style="margin-top:30px">
                        <div class="col-sm-10" style="padding-bottom:10px;margin:0px">
                            <span style="color:red">*</span><label>Receiver Email</label>
                            <input type="email" id="receiverEmailidd" class="inputFormat" style="background-color: #ebebeb !important;" />
                        </div>
                        <div class="col-sm-2">
                            <button type="button" id="sendmailbtn" class="sbtbtn" value="Save" style="margin: 25px 0 0 0;">Send</button>
                        </div>
                        <div class="col-sm-6">
                        </div>
                        <br />
                        <span style="color:red;display:none" id="spanEmailId">Alert ! please enter valid email address.</span>
                    </div>
                    <div class="ec_bg">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>File</th>
                                    <th>Sender</th>
                                    <th>Receiver</th>
                                    <th>Status</th>
                                    <th>Sent Date</th>
                                </tr>
                            </thead>
                            <tbody id="noticemailaudit"></tbody>
                        </table>
                        <center> <div id="nonoticemailaudit"> </div></center>
                    </div>
                </div>
                <center> <div id="nodraftnotice"> </div></center>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="dateOfDeliveryModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <a href="javascript:void(0)" class="close" data-dismiss="modal">&times;</a>
                <h3 class="modal-title">Save date of delivery of Notice</h3>
            </div>
            <div class="modal-body">
                <div class="container">
                    <form>
                        <div class="row">
                            <div class="col-sm-3">
                                <span style="color:red">*</span><label>Date of Delivered</label>
                                <input type="date" class="form-control" id="dateofdelivered" />
                            </div>
                        </div>
                        <br />
                        <button type="button" id="btnsavedod" class="sbtbtn">Save</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
