<style>
    ul li {
        list-style: none;
    }

    .accessbility {
        position: absolute !IMPORTANT;
    }

    .glyphicon-download-alt, .glyphicon-trash {
        color: black !important;
        font-size: 12px !important;
    }

    output {
        text-align: left;
    }

    .upload {
        width: 0.1px;
        height: 0.1px;
        opacity: 0;
    }

        .upload + label {
            width: 200px;
            height: 40px;
            font-size: 1em;
            font-weight: 500;
            color: black;
            line-height: 2.6em;
            text-transform: uppercase;
            text-align: center;
            background-color: #ccc;
            display: inline-block;
            border-radius: 10px;
            box-shadow: 0px 3px 0px #ccc;
            transition: 150ms;
        }

            .upload:focus + label,
            .upload + label:hover {
                background-color: #ccc;
                box-shadow: 0px 5px 0px #ccc;
                cursor: pointer;
            }

        .upload:focus + label {
            outline: 1px dotted #000;
            outline: -webkit-focus-ring-color auto 5px;
        }
</style>
