@{
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
}
<script>
    var roleid = "@role";
</script>
<script src="~/Scripts/ReportBuilder/ReportBuilderList.js?1.3" type="text/javascript"></script>
<style>
    .glyphicon-pencil, .glyphicon-trash, .fa-download {
        color: black !important;
    }
</style>
<section class="wrapper" style="margin:unset !important">
    <div class="container-main showcontent" id="showcontent">
        <div>
            <h2 class="title">Saved Report Builder</h2>
            <section class="content">
                <form id="savedatastructure" enctype="multipart/form-data" name="savedata">
                    <div class="row ">
                        <div class="col-md-2">
                            <div class="form-group">
                                <label class="formLabel colorDark "><span> Select Module <span class="required" aria-required="true">*</span></span></label>
                                <select id="Modules" class="form-control selctInputFormat" style="background-color: #ebebeb !important; margin-left: -5px !important;"></select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group" style="margin-top: 25px;">
                                <input type="text" id="SearchData" class="form-control inputbg" placeholder="Enter Report Name">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group" style="margin-top: 15px;">
                                <button type="button" class="sbtbtn" id="getreport" style="float:left;margin-top:13px;"><span class="glyphicon glyphicon-search" style="margin-left:-3px;"></span></button>
                            </div>
                        </div>
                    </div>
                </form>
            </section>
            <input type="hidden" id="reportidhiddden">
            <div class="table-panel table-responsive" id="activityreport" style="margin-top:5px !important">
                <table id="loadactivity" class="dataTable table ">
                    <thead>
                        <tr>
                            <th width="15px;"><div class="thbg">Sl.No</div></th>
                            <th width="100px;"><div class="thbg">Report Name</div></th>
                            <th width="100px;"><div class="thbg">Module Name</div></th>
                            <th width="140px;"><div class="thbg">Created On</div></th>
                            <th width="20%"><div class="thbg">Action</div></th>
                        </tr>
                    </thead>
                    <tbody id="loadactivitydata"></tbody>
                </table>
                <div class="table-panel">
                    <div class="settingpanel">
                        <div class="col-md-6">
                            <div id="tfooter">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <ul class="pull-right"></ul>
                        </div>
                    </div>
                </div>
            </div>
            <div id="noresultdivFinal" style="text-align:center;display:none">No result found...</div>
        </div>
    </div>
</section>
<div class="modal fade" id="ReportBuilderPreview" role="dialog" data-backdrop="static">
    <div class="modal-dialog" style="width:90%">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">
                    Saved Report Builder
                </h4>
                <div style="float:right;margin-right:25px;margin-top:-10px"><img src="~/assets/img/exportexcel.png" id="oexcel" title="export to excel" style="cursor:pointer" />&nbsp;&nbsp;<img src="~/assets/img/exportpdf.png" id="opdf" style="cursor:pointer" title="export to pdf"> </div>
            </div>
            <div class="modal-body ">
                <div id="noresultdiv" style="text-align:center;display:none">No result found...</div>
                <div class="table-panel table-responsive" style="overflow:auto">
                    <table style="width: 100%;overflow: scroll;border-spacing: 40px;" cellspacing="20px" #CustomReport
                           id="CustomReport">
                        <thead>
                            <tr id="rpcolumn"></tr>
                        </thead>
                        <tbody id="rptbody"></tbody>
                    </table>
                </div>
                <div class="table-panel">
                    <div class="settingpanel">
                        <div class="col-md-6">
                            <div id="Prevfooter"></div>
                        </div>
                        <div class="col-md-6"></div>
                    </div>
                </div>
            </div>
        </div>
        <button id="PreviewFormPaging" style="display:none">&amp</button>
    </div>
</div>
<div id="myOverlay" class="overlay">
    <div class="overlay-content">
        <div class="spinner2">
            <div><img src="~/newassets/images/MyKase_Loader.gif" height="59" width="150"></div>
        </div>
    </div>
</div>
<style>
    .overlay {
        height: 100%;
        width: 100%;
        display: none;
        position: fixed;
        z-index: 1;
        top: 0;
        left: 0;
        background-color: rgb(0,0,0);
        background-color: rgba(0,0,0, 0.4);
    }

    .overlay-content {
        position: relative;
        top: 46%;
        width: 80%;
        text-align: center;
        margin-top: 30px;
        margin: auto;
        color: white;
    }

    .overlay .closebtn {
        position: absolute;
        top: 20px;
        right: 45px;
        font-size: 60px;
        cursor: pointer;
        color: white;
    }

        .overlay .closebtn:hover {
            color: #ccc;
        }
</style>