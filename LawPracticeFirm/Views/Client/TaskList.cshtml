@{
    Layout = "~/Views/Shared/_ManuPanelPartialclient.cshtml";
}
<script src="~/Manupanel/pnotify/pnotify.custom.min.js"></script>
<link href="~/Manupanel/pnotify/pnotify.custom.min.css" rel="stylesheet" />
<link href="~/Manupanel/validation/screen.css" rel="stylesheet" />
<script src="~/Manupanel/validation/jquery.validate.js"></script>
<script src="~/Scripts/Firm/Pages/TaskList.js" type="text/javascript"></script>
<script>
    function UpdateStatus(strid) {
        var fcode = localStorage.getItem("FirmCode");
        var url = '/' + fcode + '/Firm/TaskStatusUpdate/' + strid;
        $('.mymodels').load(url, function () {
            $('#myModal1').modal('show');
        });
    }
</script>
<aside class="right-side">
    <section class="content-header">
        <!-- Content Header (Page header) -->
        <ol class="breadcrumb">
            <li><a href="/@Session["firmcode"]/client/dashboard"><i class="fa fa-dashboard"></i> Home</a></li>
            <li class="active">Task List</li>
        </ol>
        <h1><span class="fa fa-user"></span> Task List</h1>
        <ul class="pagination-sm  pull-right" style="margin-top:5px;">
            <input type="button" class="btn btn-primary" onclick="tableToExcel('example', 'W3C Example Table')" value=" Excel">
            <input type="button" class="btn btn-primary" id="btnExport" value="PDF" />
        </ul>
    </section>
    <section class="content">
        <form id="frmtsklist">
            <div class="col-xs-12 col-sm-12 col-md-12">
                <section class="content-header">
                    <div id="wfdata"></div>
                </section>
                <!-- Modal -->
                <div id="myModal1" class="modal fade myModal" role="dialog" data-backdrop="static">
                    <div class="modal-dialog modal-lg">
                        <!-- Modal content-->
                        <div class="modal-content mymodels" id="mymodels">
                        </div>
                    </div>
                </div>
        </form>
</aside>
<script src="~/CssJsfiles/js/pdfmake.min.js"></script>
<script src="~/CssJsfiles/js/html2canvas.min.js"></script>
<script type="text/javascript">
    $("body").on("click", "#btnExport", function () {
        html2canvas($('#example')[0], {
            onrendered: function (canvas) {
                var data = canvas.toDataURL();
                var docDefinition = {
                    content: [{
                        image: data,
                        width: 500
                    }]
                };
                pdfMake.createPdf(docDefinition).download("Table.pdf");
            }
        });
    });
    function searchTable() {
        var input, filter, found, table, tr, td, i, j;
        input = document.getElementById("searchdata");
        filter = input.value.toUpperCase();
        table = document.getElementById("example");
        tr = table.getElementsByTagName("tr");
        for (i = 0; i < tr.length; i++) {
            td = tr[i].getElementsByTagName("td");
            for (j = 0; j < td.length; j++) {
                if (td[j].innerHTML.toUpperCase().indexOf(filter) > -1) {
                    found = true;
                }
            }
            if (found) {
                tr[i].style.display = "";
                found = false;
            } else {
                tr[i].style.display = "none";
            }
        }
    }
</script>
<script type="text/javascript">
    var tableToExcel = (function () {
        var uri = 'data:application/vnd.ms-excel;base64,'
            , template = '<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="https://www.w3.org/TR/REC-html40"><head><!--[if gte mso 9]><xml><x:ExcelWorkbook><x:ExcelWorksheets><x:ExcelWorksheet><x:Name>{worksheet}</x:Name><x:WorksheetOptions><x:DisplayGridlines/></x:WorksheetOptions></x:ExcelWorksheet></x:ExcelWorksheets></x:ExcelWorkbook></xml><![endif]--></head><body><table>{table}</table></body></html>'
            , base64 = function (s) { return window.btoa(unescape(encodeURIComponent(s))) }
            , format = function (s, c) { return s.replace(/{(\w+)}/g, function (m, p) { return c[p]; }) }
        return function (table, name) {
            if (!table.nodeType) table = document.getElementById(table)
            var ctx = { worksheet: name || 'Worksheet', table: table.innerHTML }
            window.location.href = uri + base64(format(template, ctx))
        }
    })()
</script>