@{
    ViewBag.Title = "ChangePassword";
    Layout = null;
}
<script src="~/Manupanel/pnotify/pnotify.custom.min.js"></script>
<link href="~/Manupanel/pnotify/pnotify.custom.min.css" rel="stylesheet" />
<link href="~/Manupanel/validation/screen.css" rel="stylesheet" />
<script src="~/Manupanel/validation/jquery.validate.js"></script>
<script src="~/Scripts/Firm/Pages/ChangePassword.js?2.3" type="text/javascript"></script>
<div class="modal-header btn-success">
    <button type="button" id="closemodel" class="close" data-dismiss="modal">&times;</button>
    <h4 class="modal-title">
        Change Password
    </h4>
</div>
<div class="modal-body ">
    <!-- Main content -->
    <form method="post" class="ec_bg" id="frmpass" enctype="multipart/form-data">
        <!-- Start About boxes -->
        <div class="row">
            <div class="col-md-12">
                <div class="row" style="margin: 0 0 10px 0;">
                    <div class="form-group ">
                        <label class="control-label col-md-12 ">Old Password <span class="required" aria-required="true">*</span></label>
                        <div class="col-md-12">
                            <div style="float:left;width:95%">
                                <input class="form-control  form-control-sm inputFormat" minlength="8" maxlength="30" name="oldpass" type="password" id="oldpass" autocomplete="off" required="" onfocus="$(this).removeAttr('readonly');" readonly>
                            </div>
                            @if (HttpContext.Current.Request.UserAgent.ToLower().Contains("MSIE") || HttpContext.Current.Request.UserAgent.ToLower().Contains("edge")) //IF IE > 10
                            {
                            }
                            else
                            {
                                <div style="float:right;position:relative;right:15px;">
                                    <span id="hideeye" toggle="#oldpass" class="fa fa-fw fa-eye-slash field-icon toggle-password1" style="color:#676767;position:relative;z-index:1000; margin-top: 5px !important;">  </span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="row" style="margin: 0 0 10px 0;">
                    <div class="form-group ">
                        <label class="control-label col-md-12">New Password <span class="required" aria-required="true">*</span></label>
                        <div class="col-md-12">
                            <div style="float:left;width:95%">
                                <input class="form-control  form-control-sm inputFormat" minlength="8" maxlength="30" name="newpass" type="password" id="newpass" autocomplete="off" required="" onfocus="$(this).removeAttr('readonly');" readonly>
                            </div>
                            @if (HttpContext.Current.Request.UserAgent.ToLower().Contains("MSIE") || HttpContext.Current.Request.UserAgent.ToLower().Contains("edge")) //IF IE > 10
                            {
                            }
                            else
                            {
                                <div style="float:right;position:relative;right:15px;">
                                    <span id="hideeye" toggle="#newpass" class="fa fa-fw fa-eye-slash field-icon toggle-password1" style="color:#676767;position:relative;z-index:1000; margin-top: 5px !important;"></span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="row" style="margin: 0 0 10px 0;">
                    <div class="form-group ">
                        <label class="control-label col-md-12 ">Confirm Password <span class="required" aria-required="true">*</span></label>
                        <div class="col-md-12">
                            <div style="float:left;width:95%">
                                <input class="form-control form-control-sm inputFormat" minlength="8" maxlength="30" name="conpass" type="password" id="conpass" autocomplete="off" required="" onfocus="$(this).removeAttr('readonly');" readonly>
                            </div>
                            @if (HttpContext.Current.Request.UserAgent.ToLower().Contains("MSIE") || HttpContext.Current.Request.UserAgent.ToLower().Contains("edge")) //IF IE > 10
                            {
                            }
                            else
                            {
                                <div style="float:right;position:relative;right:15px;">
                                    <span id="hideeye" toggle="#conpass" class="fa fa-fw fa-eye-slash field-icon toggle-password1" style="color:#676767;position:relative;z-index:1000; margin-top: 5px !important;"></span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="form-actions">
                    <div class="modal-footer" style="border-top: none !important;">
                        <button type="submit" id="btnsave" class="sbtbtn save" value="Save">Save</button>
                    </div>
                </div>
            </div>
        </div>
        <!-- /.content -->
    </form>
</div>