<script>
    var str = "@ViewBag.id";
    var newstfile = "";
    loaddata();
    function loaddata() {
        var strheader1 = '';
        var stritem1 = '';
        var strtable1 = '';
        var strid = str;
        strtable1 = $('<table style="overflow-x:auto;width:95%;" align="center" /><tr><th>').addClass('table');
        $.ajax(
            {
                async: true,
                url: "/Client/CaseDetails/" + strid, // Controller/View
                dataType: 'json',
                contentType: "application/json; charset=utf-8",
                success: function (data) {
                    if (data == "") {
                        $(".stsdata").css("display", "block");
                        $(".loader1").css("display", "none");
                    }
                    else {
                        $(".stsdata").css("display", "none");
                    }
                    strheader1 = $('<thead><tr><th class="name" bgcolor="DIMGRAY"><div class="thbg">Case No.</div></th><th class="name" bgcolor="DIMGRAY"><div class="thbg">Party Name</div></th><th class="desc" width="20%" bgcolor="DIMGRAY"><div class="thbg">Advocate Name</div></th><th class="task" bgcolor="DIMGRAY"><div class="thbg">Court</div></th><th class="desc" width="20%" bgcolor="DIMGRAY"><div class="thbg">Order Date</div></th><th class="desc" bgcolor="DIMGRAY"><div class="thbg">Order</div></th></tr></thead>');
                    strtable1.append(strheader1);
                    stritem1 = "<tbody>";
                    $.each(data, function (i, val) {
                        var strcasename = val.Casetype + " " + val.CaseNo + "/" + val.Caseyear;
                        if (val.strfile == "") {
                        stritem1 += '<tr><td>' + strcasename +'</td><td>' + val.Casename + "" + '</td><td>' + val.Advname + '</td><td>' + val.Court + '</td><td>' + val.Disposeddt + '</td><td></td></tr>';
                        }
                        else if (val.strfile == null) {
                            stritem1 += '<tr><td>' + strcasename + '</td><td>' + val.Casename + "" + '</td><td>' + val.Advname + '</td><td>' + val.Court + '</td><td>' + val.Disposeddt + '</td><td></td></tr>';
                        }
                        else {
                               var filepath = "/DownloadFile.ashx?module=caseorderunlink&ftoken=";
                            strfile = filepath + enctypesingle(val.strfile);
                         stritem1 += '<tr><td>' + strcasename + '</td><td>' + val.Casename + '</td><td>' + val.Advname + '</td><td>' + val.Court + '</td><td>' + val.Disposeddt + '</td><td><a href='+strfile + '  target="_blank">Order</a></td></tr>';
                        }
                    });
                    stritem1 += "</tbody>";
                    strtable1.append(stritem1);
                    $(".divdata").html(strtable1);
                    $(".loader1").css("display", "none");
                },
                failure: function (data) {
                    //alert(data.responseText);
                },
                error: function (data) {
                    // alert(data.responseText);
                }
            });
    }
</script>
<div class="modal-header btn-primary">
    <button type="button" id="closemodel" class="close" data-dismiss="modal">&times;</button>
    <h4 class="modal-title">
        Case Detail
    </h4>
</div>
<div class="loader1"></div>
<div class="modal-body " style="height:500px; overflow-y:scroll;">
    <!-- Main content -->
    <div id="content">
        <div class="row">
            <div id="divdata" class="divdata" style="overflow:auto"></div>
        </div>
        <center><div id="stsdata" class="stsdata" style="display:none">No data found.</div></center>
    </div>
</div>
