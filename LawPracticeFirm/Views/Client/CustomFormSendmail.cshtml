@{
    ViewBag.Title = "CustomFormSendmail";
    Layout = "~/Views/Shared/_ManuPanelPartialClient.cshtml";
}
<script src="~/Manupanel/pnotify/pnotify.custom.min.js"></script>
<link href="~/Manupanel/pnotify/pnotify.custom.min.css" rel="stylesheet" />
<link href="~/Manupanel/validation/screen.css" rel="stylesheet" />
<link href="~/panelDesign/vendor/datatables-plugins/dataTables.bootstrap.css" rel="stylesheet">
<!-- DataTables Responsive CSS -->
<link href="~/panelDesign/vendor/datatables-responsive/dataTables.responsive.css" rel="stylesheet">
<script src="~/Scripts/Client/Pages/CustomFormSendmail.js" type="text/javascript"></script>
<aside class="right-side">
    <section class="content">
        <div id="page-wrapper">
            <section class="content-header">
                <h3>Workflow Stage - Send Email</h3>
                <br><br>
                <div id="wfdata1">
                    <div class="panel panel-default">
                        <div class="panel-body" id="wfdata"><b>All Stage of this task has completed, to inform send email. </b></div>
                    </div>
                    <section class="content">
                        <form id="savematterform" enctype="multipart/form-data">
                            <!-- Start About boxes -->
                            <div class="row">
                                <div class="col-md-12">
                                    <fieldset>
                                        <legend>Send Email</legend>
                                        <div class="form-group form-horizontal">
                                            <label class="control-label col-md-2">To <span class="required" aria-required="true">*</span> </label>
                                            <div class="col-md-6">
                                                <input class="form-control" name="mname" type="text" id="emailto" placeholder="To : Enter Emails separated by  (,)" required />
                                            </div>
                                        </div>
                                        <div class="form-group form-horizontal">
                                            <label class="control-label col-md-2">Cc </label>
                                            <div class="col-md-6">
                                                <input class="form-control" name="mname" type="text" id="emailcc" placeholder="Cc : Enter Emails separated by  (,)" required />
                                            </div>
                                        </div>
                                        <div class="form-group form-horizontal">
                                            <label class="control-label col-md-2">Subject </label>
                                            <div class="col-md-6">
                                                <input class="form-control" name="cnrno" type="text" id="emailsub" placeholder="Enter Subject" required />
                                            </div>
                                        </div>
                                        <div class="form-group form-horizontal">
                                            <label class="control-label col-md-2">Body</label>
                                            <div class="col-md-4">
                                                <textarea ID="emailbody" value="sdsdfd" style="margin: 0px; height: 105px; width: 457px;"></textarea>
                                                <div class="grid-container" style="display:none">
                                                    <div id="editor">
                                                    </div>
                                                    <script>
                                                        initSample();
                                                        CKEDITOR.replace('mnotes', {
                                                            toolbar:
                                                                [
                                                                    { name: 'basicstyles', items: ['Bold', 'Italic'] },
                                                                    { name: 'paragraph', items: ['NumberedList', 'BulletedList'] },
                                                                    { name: 'tools', items: ['Maximize',] }
                                                                ],
                                                            height: 100,
                                                            width: 305
                                                        });
                                                    </script>
                                                </div>
                                            </div>
                                            <div class="row">
                                                <div class="col-md-12">
                                                    <div class="">
                                                        <div class="form-actions hidden-print">
                                                            <div class="btn-group">
                                                                <btn style="margin:0 0 0 5px " class="btn btn-info pull-right" id="sendemail"><span class="glyphicon glyphicon-envelope"></span> Send Mail</btn>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                    </fieldset>
                                </div>
                            </div>
                </div>
            </section>
            <!-- Modal -->
        </div>
    </section>
</aside>
