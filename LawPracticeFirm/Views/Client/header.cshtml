            url: "/api/callApi/LogoPath",
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (response) {



                if (response.Data != "") {
                    $("#firmlogosrc").attr("src", response.Data)
                    $("#firmlogolink").show();
                    $("#sidebarnav").css("margin-top", "0px");
                    $("#navheaderpostion").css("float", "unset");

                }
                else {
                    $("#firmlogolink").hide();
                    $("#sidebarnav").css("margin-top", "38px");
                    $("#navheaderpostion").css("float", "left");
                }



                //console.log(response);
            },

            failure: function (response) {
                alert(data.responseText);
            },
            error: function (response) {


                if (String(response.responseJSON.Message) == "SessionTimeOut") {
                    alert("Your session has expired, please log out and then login again");

                    window.location.href = location.protocol + '//' + location.host;
                }
                else {
                    alert(response.responseText);
                }
            }

        });
    }
</script>
