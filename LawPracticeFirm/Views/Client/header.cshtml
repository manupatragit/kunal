<script>
     //Navigation By Navin
    function OpenActive(obj) {

        if (!$(obj).find(".nav-content").hasClass("collapse")) {
            $(obj).find(".nav-content").addClass("collapse");
            $(obj).find("p").removeClass("active");
        } else {
            $("#sidebar .nav-content").addClass("collapse")
            $(".nav-link p").removeClass("active")
            $(obj).find(".nav-content").removeClass("collapse");
            $(obj).find("p").addClass("active");
        }
    }
    function openload() {
        $('#myOverlay').css("display", "block");
    }

    function closeload() {
        $('#myOverlay').css("display", "none");
    }
    $(document).ready(function () {
        $(document).on("click", "#openuserlist", function () {
            $('#companyuserlistmodal').modal({ show: true });
        });
        $("#signoutconfirm").click(function () {
               if (confirm('Thank you for using myKase.\r\nAre your sure you want to Sign Off?')) {
                location.href = "/@firmcode121/Account/LogOut";
            }

        });
        function openload3() {
            $('#myOverlay').css("display", "block");
        }
        function closeload3() {
            $('#myOverlay').css("display", "none");
        }
        $("#password1").click(function (e) {
            try {
                openload3();
                var url = "/Client/ChangePassword";
                $('.mymodelscpd').load(url, function (result) {
                    closeload3();
                    $('#myModalcpd').modal({ show: true });
                });
                //window.location = "/" + fcode + url;
            }
            catch (err) {
                alert(err.message);
            }
        });
    });
</script>
