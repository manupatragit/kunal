        //Notification delete single/bulk
        function deletenotifications(Notificationid, deleteflag) {
            var formdata = new FormData();
            formdata.append("id", Notificationid);
            formdata.append("deleteflag", deleteflag);
            var result = confirm("Are you sure to remove notification?");
            if (result) {
                $.ajax({
                    async: true,
                    url: "/api/callApi/RemoveNotificationStatus",
                    data: formdata,
                    processData: false,
                    contentType: false,
                    type: 'POST',
                    success: function (response) {
                        if (response.Data >= 1) {
                            alert("Notification deleted successfully.");
                            notification(1);
                        } else {
                            alert("Something went wrong please try again later.");
                        }
                    },

                    failure: function (response) {
