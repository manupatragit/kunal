    <!-- Content Header (Page header) -->
    <section class="content-header">
        <input type="hidden" id="hidid" />
        <ul class="dropdown-menu" id="bd" style="width:116px !important; top:0 !important;">
            <li><a href="#" class="small" data-value="option1" tabIndex="-1"><input type="checkbox" id="event" name="event" checked>Show Event</a></li>
