@{
    Layout = null;
}
<script>
    var filesize=@ViewBag.filesize
</script>
<link href="~/Manupanel/validation/screen.css" rel="stylesheet" />
<script src="~/Manupanel/validation/jquery.validate.js"></script>
<script src="~/Scripts/Client/Pages/ConfigMessage.js"></script>
<script src="~/Manupanel/ckeditor/ckeditor.js"></script>
<script src="~/Manupanel/ckeditor/samples/js/sample.js"></script>
<script src="~/Content/multipleselect/selectize.js"></script>
<link href="~/Content/multipleselect/dist/css/selectize.bootstrap2.css" rel="stylesheet" />
<link href="~/Content/multipleselect/dist/css/jquery.magicsearch.min.css" rel="stylesheet" />
<style>
    .selectize-control {
        margin: 0 -30px 6px 0 !important;
    }

    .selectize-input {
        width: 95% !important;
        MARGIN: 0 0 0 5px;
        border-radius: 0;
    }
</style>
<div class="modal-header btn-primary">
    <button type="button" class="close" data-dismiss="modal">&times;</button>
    <h4 class="modal-title">
        Forward Message
    </h4>
</div>
<div class="modal-body ">
    <section class="content-header"></section>
    <section class="content">
        <div id="page-wrapper">
            <!-- Main content -->
            <form id="savemessageform" enctype="multipart/form-data">
                <div class=" form-horizontal" style="width:100%;display:block">
                    <label class="control-label col-md-3" style="margin:0 0 0 -10px;">To: <span class="required" aria-required="true">*</span> </label>
                    <div class="col-md-8">
                        @Html.DropDownList("select-user", new SelectList(ViewBag.Fruits, "val", "label"), "Please select", new { @id = "select-user", @class = "demodefault ", @multiple = "multiple" })
                    </div>
                </div>
                <div class="form-group form-horizontal" style="clear:both;">
                    <label class="control-label col-xs-3">Matter: </label>
                    <div class="col-xs-8">
                        <select name="matter" class="form-control" id="matter">
                            <option value=""> Select </option>
                        </select>
                    </div>
                </div>
                <div class="form-group form-horizontal">
                    <label class="control-label col-md-3">Subject: <span class="required" aria-required="true">*</span></label>
                    <div class="col-md-8">
                        <input class="form-control" name="subject" type="text" id="subject" placeholder="Add Subject" required />
                    </div>
                </div>
                <div class="form-group form-horizontal">
                    <label class="control-label col-md-3">Message:</label>
                    <div class="col-md-8">
                        <textarea ID="details" cols="15" style="width:330px;"></textarea>
                        <div class="grid-container" style="display:none">
                            <div id="editor">
                            </div>
                            <script>
                                CKEDITOR.replace('details', {
                                    toolbar:
                                        [
                                            { name: 'basicstyles', ['Bold', 'Italic', 'Underline', 'justify', 'JustifyLeft', 'JustifyCenter', 'JustifyRight'] },
                                            { name: 'paragraph', items: ['NumberedList', 'BulletedList'] },
                                            { name: 'tools', items: ['Maximize'] },
                                            { name: 'styles', items: ['Styles', 'format', 'Font', 'FontSize'] },
                                            { name: 'colors', items: ['TextColor', 'BGColor'] },
                                            { name: 'links', items: ['Link', 'Unlink', 'Anchor'] }
                                        ],
                                    height: 80,
                                });
                            </script>
                        </div>
                    </div>
                </div>
                <div class="form-group form-horizontal">
                    <label class="control-label col-md-3">Attachment:</label>
                    <div class="col-md-8">
                        <input class="form-control" name="postedFile" id="postedFile" type="file" multiple placeholder="Add description..." />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <div class="modal-footer">
                            <input type="submit" id="savecall" class="btn save" value="Send">
                            <button type="button" id="closemodels" class="btn btn-default" data-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </form>
            <!-- /.content -->
        </div>
    </section>
</div>
<script>
    $('#select-user').selectize({
        //maxItems: 3
    });
</script>
<script>
    CKEDITOR.instances['details'].setData(localStorage.getItem("details"));
    $("#subject").val("Fwd: " + localStorage.getItem("subject"));
</script>
