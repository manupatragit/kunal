@{
    Layout = null;
}
<style>
    table {
        background: none !important;
    }
</style>
<script>
    var iid = "@ViewBag.inid";
    if (iid != "") {

        if (iid == "1") {
            $("#invoicecontent").load("/Documents/Invoicetemplate/invoice1.html");
        }
        else if (iid == "2") {
            $("#invoicecontent").load("/Documents/Invoicetemplate/invoice2.html");
        }
        else if (iid == "3") {
            $("#invoicecontent").load("/Documents/Invoicetemplate/invoice3.html");
        }
        else if (iid == "4") {
            $("#invoicecontent").load("/Documents/Invoicetemplate/invoice4.html");
        }
        else if (iid == "5") {
            $("#invoicecontent").load("/Documents/Invoicetemplate/invoice5.html");
        }
        //For Auto checked
        $("input[name=rbt][value=" + iid + "]").prop('checked', true);
    }
    $(document).on("click", "#viewtemplate", function () {
        var selected = $("input[type='radio'][name='rbt']:checked");
        var selectedvalues = 1;
        if (selected.length > 0) {
            selectedvalues=selected.val();
        }
        if (selectedvalues == "1") {
            $("#invoicecontent").load("/Documents/Invoicetemplate/invoice1.html");
        }
        else if (selectedvalues == "2") {
            $("#invoicecontent").load("/Documents/Invoicetemplate/invoice2.html");
        }
        else if (selectedvalues == "3") {
            $("#invoicecontent").load("/Documents/Invoicetemplate/invoice3.html");
        }
        else if (selectedvalues == "4") {
            $("#invoicecontent").load("/Documents/Invoicetemplate/invoice4.html");
        }
        else if (selectedvalues == "5") {
            $("#invoicecontent").load("/Documents/Invoicetemplate/invoice5.html");
        }
    });
</script>
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>viewinvoicetemplate</title>
</head>


<body>
    <div class="modal-header btn-primary">
        <button type="button" class="close" id="closemodel" data-dismiss="modal">&times;</button>
        <h4 class="modal-title">
            <img src="/newassets/img/receipt-check.png" style="margin:-15px 0px 0 -15px">
        </h4>
    </div>
    <div class="modaltitle" style="border-bottom: none; margin: -30px 0 0 0;">
        <h4>View Inovice</h4>
    </div>
    <div class="modal-body">
        <div style="overflow: hidden;margin: 0 0 10px 0;">
            <ul style="margin:0;padding:0;list-style-type:none">
                <li style="float:left"><input id="viewtemplate" type="radio" value="1" checked name="rbt" style="cursor:pointer;" />Template 1 &nbsp;&nbsp;&nbsp;</li>
                <li style="float:left;padding:0 0 0 5px;"><input id="viewtemplate" type="radio" value="2" name="rbt" style="cursor:pointer;" />Template 2 &nbsp;&nbsp;&nbsp;</li>
                <li style="float:left;padding:0 0 0 5px;"><input id="viewtemplate" type="radio" value="3" name="rbt" style="cursor:pointer;" />Template 3 &nbsp;&nbsp;&nbsp;</li>
                <li style="float:left;padding:0 0 0 5px;"><input id="viewtemplate" type="radio" value="4" name="rbt" style="cursor:pointer;" />Template 4 &nbsp;&nbsp;&nbsp;</li>
                <li style="float:left;padding:0 0 0 5px;"><input id="viewtemplate" type="radio" value="5" name="rbt" style="cursor:pointer;" />Template 5 &nbsp;&nbsp;&nbsp;</li>


                @*<li style="float: left; padding: 0 10px 0 0;"><input id="radio1" type="radio" value="1" checked="" name="rbt"> <a href="javascript:void()" id="" value="1" style="color: #717680;">Template 1</a></li>
                    <li style="float: left; padding: 0 10px 0 0;"><input id="radio2" type="radio" value="2" name="rbt"> <a href="javascript:void()" id="" value="2" style="color: #717680;">Template 2</a></li>
                    <li style="float: left; padding: 0 10px 0 0;"><input id="radio3" type="radio" value="3" name="rbt"> <a href="javascript:void()" id="" value="3" style="color: #717680;">Template 3</a></li>
                    <li style="float: left; padding: 0 10px 0 0;"><input id="radio4" type="radio" value="4" name="rbt"> <a href="javascript:void()" id="" value="4" style="color: #717680;">Template 4</a></li>
                    <li style="float: left; padding: 0 10px 0 0"><input id="radio5" type="radio" value="5" name="rbt"> <a href="javascript:void()" id="" value="4" style="color: #717680;">Template 5</a></li>*@
            </ul>
        </div>
        <div class="table" style="border:1px solid #000000; padding:10px 0;">
            <div id="invoicecontent"></div>
        </div>
    </div>
    <div class="modal-footer">
        <div class="form-group pull-right">
            <button type="button" id="closemodels" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
            @*<button type="button" id="" class="btn btn-primary">Select Invoice</button>*@
        </div>
    </div>
</body>
</html>
