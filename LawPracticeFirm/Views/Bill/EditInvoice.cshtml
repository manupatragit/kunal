<script>
    $(document).ready(function () {
         var invdate = "@ViewBag.invdate.ToString("yyyy-MM-dd")";
        $("#duedate").attr("min", invdate);
        bindstate();
        function bindstate() {
            var ddlState = $('#state');
            var bddlState = $('#billerstate');
            var sddlState = $('#sstate');
            $.ajax({
                async: true,
                url: '/api/EmployeeApi/BindStateDetails',
                type: 'POST',
                dataType: 'json',
                headers: { CountryName: 'India' },
                success: function (d) {
                    $.each(d.Data, function (i, states) {
                        ddlState.append($("<option></option>").val(states.StateName).html(states.StateName));
                        sddlState.append($("<option></option>").val(states.StateName).html(states.StateName));
                    });
                },
                error: function (d) {
                    alert(d.responseText);
                }
            });
        }
            function openload() {
                $("#myOverlay").css("display", "block");
            }
            function closeload() {
                $("#myOverlay").css("display", "none");
            }
            openload();
            var address1 = "@ViewBag.billaddress";
            var state1 = "@ViewBag.state";
              var sstate1 = "@ViewBag.sstate";
            var isdefault1 = "@ViewBag.isdefault";
            var clientid = $("#hclientids").val();
            var clientstate = $("#clientstate").val();
        var sclientstate = $("#sclientstate").val();
        var istax = "@ViewBag.istax";
        var matteridnew = "@ViewBag.matterid";
        var subtotatalcheckfortax = "@ViewBag.subtotal";
        var billeraddress = "@ViewBag.billeraddress";
        $("#invcid").val("@ViewBag.invid");
        var a = ['', 'ONE ', 'TWO ', 'THREE ', 'FOUR ', 'FIVE ', 'SIX ', 'SEVEN ', 'EIGHT ', 'NINE ', 'TEN ', 'ELEVEN ', 'TWELVE ', 'THIRTEEN ', 'FOURTEEN ', 'FIFTEEN ', 'SIXTEEN ', 'SEVENTEEN ', 'EIGHTEEN ', 'NINETEEN '];
        var b = ['', '', 'TWENTY', 'THIRTY', 'FORTY', 'FIFTY', 'SIXTY', 'SEVENTY', 'EIGHTY', 'NINETY'];
        function inWords(num) {
            num = Math.round(num);
            if ((num = num.toString()).length > 9) return 'overflow';
            n = ('000000000' + num).substr(-9).match(/^(\d{2})(\d{2})(\d{2})(\d{1})(\d{2})$/);
            if (!n) return; var str = '';
            str += (n[1] != 0) ? (a[Number(n[1])] || b[n[1][0]] + ' ' + a[n[1][1]]) + 'CRORE ' : '';
            str += (n[2] != 0) ? (a[Number(n[2])] || b[n[2][0]] + ' ' + a[n[2][1]]) + 'LAKH ' : '';
            str += (n[3] != 0) ? (a[Number(n[3])] || b[n[3][0]] + ' ' + a[n[3][1]]) + 'THOUSAND ' : '';
            str += (n[4] != 0) ? (a[Number(n[4])] || b[n[4][0]] + ' ' + a[n[4][1]]) + 'HUNDRED ' : '';
            str += (n[5] != 0) ? ((str != '') ? 'AND ' : '') + (a[Number(n[5])] || b[n[5][0]] + ' ' + a[n[5][1]]) + 'ONLY ' : '';
            return str;
        }
          setTimeout(function () {
            if (istax == 1) {
                $('input:radio[name="tax"]').filter('[value="2"]').attr('checked', true);
                $("#subtotals").hide();
                $("#igst").hide();
                $("#cgst").hide();
                $("#sgst").hide();
            }
            else {
                $("#subtotals").show();
                $("#igst").show();
                $("#cgst").show();
                $("#sgst").show();
                $('input:radio[name="tax"]').filter('[value="1"]').attr('checked', true);
              }
              if (subtotatalcheckfortax != 0) {
                  $('#totinwords').text(inWords(Math.round(subtotatalcheckfortax)));
              }
              else
              {
              }
                  $('#billerstate').val(state1);
                   $('#billeraddress').append($("<option></option>").prop("value", address1).text(address1).attr("state", state1).attr("tokenid", "00000000-0000-0000-0000-000000000000"));
                $('#client option[value="' + clientid.toLowerCase() + '"]').prop("selected", true);
                $('#client option[value="' + clientid.toUpperCase() + '"]').prop("selected", true);
                loadmatter1(clientid);
                $('#state option[value="' + clientstate + '"]').prop("selected", true);
                $('#sstate option[value="' + sclientstate + '"]').prop("selected", true);
                $('#billeraddress option[tokenid="' + billeraddress + '"]').prop("selected", true);
                $("#subtotal").text("@ViewBag.subtotal");
                $("#finaltotal").text("@ViewBag.totamt");
                $("#igsttot").text("@ViewBag.igst");
                $("#cgsttot").text("@ViewBag.cgst");
                $("#sgsttot").text("@ViewBag.sgst");
                $("#igstpername").text("("+"@ViewBag.igstper"+"%)");
                $("#cgstpername").text("(" +"@ViewBag.cgstper"+ "%)");
                $("#sgstpername").text("(" + "@ViewBag.sgstper" + "%)");
                $("#subtotaltemp").val("@ViewBag.subtotal");
                $("#finaltotaltemp").val("@ViewBag.totamt");
                $("#igsttempval").val("@ViewBag.igst");
                $("#cgsttempval").val("@ViewBag.cgst");
                $("#sgsttempval").val("@ViewBag.sgst");
                $("#igsttemp").val("@ViewBag.igstper");
                $("#cgsttemp").val("@ViewBag.cgstper");
                $("#sgsttemp").val("@ViewBag.sgstper");
              $("#sgsttemp").val("@ViewBag.sgstper");
                closeload();
            }, 10000);
            function loadmatter1(clientid) {
                $('#MatterName').empty().append('<option value="">Select Matter</option>').find('option:first').prop("selected", "selected");
                $.ajax({
                    async: true,
                    type: "POST",
                    url: "/api/callApi/LoadMatterforclient",
                    headers: {
                        "clientid": clientid
                    },
                    contentType: "application/json; charset=utf-8",
                    dataType: "json",
                    success: function (response) {
                        if (response.Status == true) {
                            var datas = JSON.stringify(response);
                        }
                        else {
                            alert("not found");
                        }
                        $.each(JSON.parse(response.Data), function (i, a) {
                            var mattername = a.mname;
                            var mid = a.Id;
                            if (mattername == null) {
                                mattername = "";
                                mid = "";
                            }
                            else {
                                var option = '<option value="' + mid + '"  tempname="' + mattername + '"> ' + mattername + '</option>';
                                $("#MatterName").append(option);
                                $('#MatterName option[value="' + matteridnew + '"]').prop("selected", true);
                            }
                        });
                    },
                    failure: function (response) {
                        alert(data.responseText);
                    },
                    error: function (response) {
                        alert(data.responseText);
                    }
                });
            }
        });
</script>
