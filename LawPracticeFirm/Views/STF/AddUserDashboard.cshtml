        <form class="ec_bg" enctype="multipart/form-data" autocomplete="off" id="UserSubmitForm">

            <div class="row">

                <div class="col-md-3">
                    <div class="form-group ">

                        <label class="formLabel colorDark"><span class="control-label"> Name<span class="required" aria-required="true" style="color:red"><b>*</b> </span></span></label>
                        <input type="text" id="userName" maxlength="50" placeholder="Enter the  name" class="inputFormat" autofocus>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group ">

                        <label class="formLabel colorDark"><span class="control-label"> Email<span class="required" aria-required="true" style="color:red"><b>*</b> </span></span></label>
                        <input type="text" id="emailId" maxlength="50" placeholder="Enter the  email id" class="inputFormat" autofocus>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">

                        <label class="formLabel colorDark"><span class="control-label"> Mobile <span class="required" aria-required="true" style="color:red"><b>*</b> </span></span></label>
                        <input type="text" id="mobileNo" maxlength="10" placeholder="Enter the  mobile no." class="inputFormat" onkeypress="return isNumberKey(event)" autofocus>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group ">

                        <label class="formLabel colorDark"><span class="control-label">  Designation <span class="required" aria-required="true" style="color:red"><b>*</b> </span></span></label>
                        <input type="text" id="Designation" maxlength="50" placeholder="Enter the designation" class="inputFormat" autofocus>
                    </div>
                </div>


            </div>
