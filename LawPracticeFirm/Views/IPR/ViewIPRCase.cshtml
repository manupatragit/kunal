<div id="myModalCustomizedcolumn" class="modal in right fade myModal ipr_filter_feild" role="dialog" data-backdrop="static">
    <div class="modal-dialog" style="width: 450px; max-height: 100vh;">
        <div class="modal-content modal-drawer" style="border: 1px solid #ccc; padding: 20px; max-width: 500px; margin: auto;">

            <!-- Header -->
            <div class="modal-header btn-success" style="border-bottom: none;">
                <button type="button" class="close" data-dismiss="modal" style="float: right;">×</button>
                <div class="modaltitle" style="display: flex; align-items: center; gap: 10px;">
                    <img src="/newassets/img/customize-icon.png" alt="icon">
                    <h4 style="margin: 0;">Customise Field</h4>
                </div>
            </div>

            <!-- Body -->
            <div class="modal-body" >
                <form id="customColumnForm" autocomplete="off">
                    <div class="wrapper_form_feild" id="CustIPRcreatefield" style="padding-right: 15px;">
                        <ul id="myDropdown">
                            <li class="checkbox-item">
                                <input type="checkbox" id="applicanttype" name="applicanttype" onchange="toggleBorder(this)">
                                <label for="applicanttype">Applicant Type</label>
                            </li>
                            <li class="checkbox-item">
                                <input type="checkbox" id="applicantname" name="applicantname" checked onchange="toggleBorder(this)">
                                <label for="applicantname">Applicant Name</label>
                            </li>
                            <li class="checkbox-item">
                                <input type="checkbox" id="applicantadd" name="applicantadd" onchange="toggleBorder(this)">
                                <label for="applicantadd">Applicant Address</label>
                            </li>
                            <li class="checkbox-item">
                                <input type="checkbox" id="applicantcountry" name="applicantcountry" onchange="toggleBorder(this)">
                                <label for="applicantcountry">Applicant Country</label>
                            </li>
                            <li class="checkbox-item">
                                <input type="checkbox" id="useofmark" name="useofmark" checked onchange="toggleBorder(this)">
                                <label for="useofmark">Use Of Mark</label>
                            </li>
                        </ul>
                    </div>
                </form>
            </div>

        </div>

    </div>
</div>

<script>
    function toggleBorder(checkbox) {
        const li = checkbox.closest('li');
        if (checkbox.checked) {
            li.classList.add('checked');
        } else {
            li.classList.remove('checked');
        }
    }

    // Highlight already checked checkboxes on load
    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll("#myDropdown input[type='checkbox']").forEach(cb => {
            toggleBorder(cb);
        });
    });
</script>
<script>
  function toggleBorder(checkbox) {
    const li = checkbox.closest('li');
    if (checkbox.checked) {
      li.classList.add('checked');
    } else {
      li.classList.remove('checked');
    }
  }

  function toggleCheck(event) {
    const checkbox = document.getElementById('filingDate');
    if (event.target.tagName !== 'INPUT') {
      checkbox.checked = !checkbox.checked;
      checkbox.dispatchEvent(new Event('change'));
    }
  }

  // Initialize on page load
  window.addEventListener('DOMContentLoaded', () => {
    const cb = document.getElementById('filingDate');
    toggleBorder(cb);
  });
</script>

