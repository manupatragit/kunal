@{
    /**/

    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
}
<head>
    <script src="~/Scripts/IPR/AgentSearch.js?2.1" type="text/javascript" language="javascript"></script>
    <link href="~/Manupanel/css/IPRSearchStyle.css" rel="stylesheet" />
</head>

<style>
    .modal-footer {
        border-top: 0 !important;
        padding-top: 8px !important;
    }

      
        .modal-footer .btn {
            float: right !important;
        }

    #opentrademarkdetails {
        cursor: pointer;
    }
