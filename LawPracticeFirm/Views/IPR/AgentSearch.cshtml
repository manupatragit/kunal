                                            </div>
                                            <img class="chevron-down-icon" alt="" src="~/newassets/img/next-arrow.png" style="width:16px; height:16px;">

                                        </div>
                                    </div>
                                </div>

                            </div>

                        </div>
                        @*<div class="modal-footer">
                                <div id="ptfooter1">
                                </div>
                            </div>*@
                    </div>
                </div>
            </div>

        </div>

    </div>

    <!-- Modal View Start -->
    <div class="modal fade vertical-centered" id="emailmodal" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false">
        <div class="modal-dialog manuModal1" role="document" style="width:480px;">
            <!-- Modal content -->
            <div class="modal-content" id="emasexc" style="background:#fff;">

                <div class="modal-header btn-success">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close" id="emailClose">
                        <span aria-hidden="true" style="font-size:unset !important">×</span>
                    </button>
                    <div class="modal-title">
                        <div class="icon_header_pulse">
                            <span class="pulse_div">
                                <img src="/newassets/img/mail-01.png" alt="mail">
                            </span>
                        </div>
                        <h4 class="modal-title" id="mdChange">Send Information Details To</h4>
                    </div>
                </div>

                <div class="modal-body">
                    <div class="form-group">
                        <label class="formLabel colorDark" for="emailtxt">Email Id.</label>
                        <input type="email"
                               id="emailtxt"
                               name="sendemail"
                               class="form-control inputFormat"
                               placeholder="Enter Mail id"
                               title="Please enter the receiver's mail address"
                               required />
                    </div>
                </div>

                <div class="modal-footer footer_buttons" style="margin-top:20px; border-top: none !important;">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal" aria-label="Close">Cancel</button>
                    <button type="button" id="btnEmail" class="btn btn-primary">Share</button>
                </div>

            </div>
        </div>
    </div>

    <!-- Modal View End -->
