<section id="header">
    <div class="container-main">
        <div class="text-left">
            <p class="ctitle"><h2 style="margin-top:0px;" id="dynamicnotiheader">Add Trademark</h2></p>
        </div>
        <div class="tabs-and-filters" style="margin:0;">
            <div class="button-group">
                <a href="#" title="Trademark Search" id="searchIP" class="button-group-base">Trademark</a>
                <a href="#" class="button-group-base1" title="Proprietor Search" id="propSearch">Proprietor</a>
                <a href="#" title="Agent Result" class="button-group-base2 active" id="searchAgent" style="display:none">Agent<span id="AgentCount"></span></a>
                <span id="spPhoneticSearch" style="display:none"><a href="#" title="Phonetic Search" class="button-group-base2" id="searchPhonetictab">Phonetic Search<span id="PhoSearchCount"></span></a></span>
            </div>
        </div>
    </div>

</section>

<section class="wrapper" style="margin:unset !important">
    <input type="hidden" value="0" id="hdnsort" />
    <input type="hidden" value="0" id="hdncounter" />
    <input type="hidden" value="@ViewBag.ImagePath" id="imgpath" />
    <div class="container-main">
        @*<div class="card-header">
