                    <div class="col-md-4" id="hidename">
                        <div class="form-group">
                            <label class="formLabel colorDark" id="changelbl">
                                <span class="control-label">Name<span class="required" aria-required="true"><b> *</b> </span></span>
                            </label>
                            <input type="text" id="agentName" placeholder="Enter the Agent Name" class="form-control inputFormat" onkeydown="fn_search(event)" autofocus>
                        </div>
                    </div>
                    <div class="col-md-4" id="hide">
                        <div class="form-group col-md-12">
                            <label class="formLabel colorDark" id="changelbls">
                                <span class="control-label">Address</span>
                            </label>
                            <input type="text" id="agentAddress" placeholder="Enter the Agent Address" class="form-control inputFormat" autofocus>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="formLabel colorDark"><span class="control-label">&nbsp;</span></label>
                        <div class="form-group" style="display:flex; gap:12px;" id="btns">
                            <button type="button" id="btnsearch" class="btn btn-primary pull-right" value="SEARCH">Search</button>
                            <button type="button" id="btnclear" class="btn btn-secondary" onclick="fn_btnclear()" value="CLEAR">Reset</button>
                        </div>
                    </div>
                </div>
            </form>
            <div class="table-panel table-responsive">
                <div style="overflow-x:scroll;">
                    <table class="table-panel">
                        <thead>
                            <tr>
                                <th>
                                    <div class="thbg">
                                        S.NO
                                    </div>
                                </th>

                                <th>
                                    <div class="thbg">
                                        Name
                                    </div>
                                </th>
                                <th>
                                    <div class="thbg">
                                        Address
                                    </div>
                                </th>

                                <th>
                                    <div class="thbg" style="display:flex; justify-content:center;">
                                        Action
                                    </div>
                                </th>

                            </tr>
                        </thead>
                        <tbody id="bindIPRSearchData"></tbody>
                    </table>
                    <center>
                        <div class="notfound" id="pdatastatus">
                            <img src="~/newassets/img/not-found.png" />
