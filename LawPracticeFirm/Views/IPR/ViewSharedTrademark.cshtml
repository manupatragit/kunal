                        </div>

                    </div>

                </div>
                <div class="modal-footer flex-end" style="margin-top:20px;">
                    <button type="button" id="searchByApplDate" class="btn btn-primary">Search</button>
                    <button type="button" id="Applicationcleardate" class="btn btn-secondary">Reset</button>
                    @*<button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>*@
                </div>
            </div>
        </div>
    </div>


