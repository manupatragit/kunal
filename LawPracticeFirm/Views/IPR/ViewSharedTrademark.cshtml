<script type="text/javascript">
    var exportfilter = false;

    $('#spnDateOfApp').on('click', function (e) {
        $("#dropdown-menu1").show();
        $("#dropdown-hear-menu").hide();
    });
    $('#spnHearingDate').on('click', function (e) {
        $("#dropdown-hear-menu").show();
        $("#dropdown-menu1").hide();
    });
    $(document).click(function (e) {
        if (!$(e.target).closest("#dropdown-menu1, #toggleCalendar").length) {
            $("#dropdown-menu1").hide();
        }

        if (!$(e.target).closest("#dropdown-hear-menu, #toggleCalendar").length) {
            $("#dropdown-hear-menu").hide();
        }

    });

    $("#opdf").click(function () {
        $("#myModalexport").modal({ show: true });
        var totalRecord = $("#exportrecords").val();
        var pagesize = 10;
        var recordsection = totalRecord / pagesize;
        recordsection = recordsection + 1;

        var res = totalRecord % 10;
        if (res != 0) {
            recordsection = parseInt(recordsection) + 1;
        }
        else {
            recordsection = parseInt(recordsection);
        }
        var html = '';
        for (var i = 1; i < recordsection; i++) {
            html += '<tr>';
            html += '<td>Page No:' + i + ' </td>';
            html += '<td><span style="cursor:pointer;color:#069;" id="exporttopdffile" pageno="' + i + '" type="pdf">Download File</span></td>';
            html += '</tr>';
        }
        $("#printexport").html(html);
    });
    $(document).on("click", "#exporttopdffile", function () {
        var pageno = $(this).attr('pageno');
        var IPList = $("#IPList").val();
        var filtertradmark = $("#filtertradmark").val();
        var txtapplicationno = $("#txtapplicationno").val();
        var searchclass = $("#searchclass").val();
        var searchtype = $("#searchtype").val();
        var searchstatus = $("#searchstatus").val();
        var txtdateapplicationfrom = $("#txtdateapplicationfrom").val();
        var txtdateapplicationto = $("#txtdateapplicationto").val();
        var searchuserdetetail = $("#searchuserdetetail").val();
        var txtProprietor = $("#txtProprietor").val();
        var JurisdictionList = $("#JurisdictionList").val();
        var usedsincefrom = $("#usedsincefrom").val();
        var usedsinceto = $("#usedsinceto").val();

        window.location = encodeURI("/IPR/ViewSharedTrademarkExporttoPDF?IPList=" + IPList + "&filtertradmark=" + filtertradmark + "&applicationno=" + txtapplicationno
            + "&searchclass=" + searchclass + "&searchtype=" + searchtype + "&searchstatus=" + searchstatus + "&txtdateapplicationfrom=" + txtdateapplicationfrom
            + "&searchuserdetetail=" + searchuserdetetail + "&txtProprietor=" + txtProprietor + "&JurisdictionList=" + JurisdictionList
            + "&txtdateapplicationto=" + txtdateapplicationto + "&usedsincefrom=" + usedsincefrom + "&usedsinceto=" + usedsinceto + "&hearingFrmDate=" + hearingFrmDate + "&hearingToDate=" + hearingToDate + "&pagenum=" + pageno + "&pagesize1=500");
    })
    $(document).on("click", "#tmdetailsdownload", function () {
        var IPname = urlParams.get("IP");
        var downTradeId = downloadTradeId;
        window.location = encodeURI("/IPR/DownloadIPRDetails?IPList=" + IPname + "&filtertradmark=" + downTradeId);
    });
</script>

