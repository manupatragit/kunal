    @* calender modal started --- Date of application *@
    <div class="modal fade" id="spnDateOfApp" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header" style="display: flex !important; justify-content: space-between;">
                    <h5 class="modal-title" id="exampleModalLabel">&nbsp;</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label class="form-check-label" for="rdusers">
                            Select Date Of Application
                        </label>

                        <div style="display:flex; gap:15px;">
                            <input type="date" title="From date" id="applfrmdate" class="form-control" onkeypress="return false" />
