@{
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }

    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
}

<style>
    .btnManual {
        padding: 10px;
        display: flex;
        gap: 5px;
        border: 2px solid gray;
        border-radius: 7px;
        margin-right: 5px;
        text-decoration: none;
        color: gray;
    }
    .modal-footerip {
        border-top: 1px solid #E9EAEB !important;
        margin-top: 8px;
        text-align: left;
        padding: 16px 0 0 0;
    }
</style>
<link href="~/Manupanel/css/IPRSearchStyle.css" rel="stylesheet" />
<script src="~/Scripts/IPR/ViewDeletedTrademarks.js?2.1" type="text/javascript" language="javascript"></script>


<section id="header">
    <div class="container-main">
        <div class="text-left">
            <p class="ctitle"><h2 id="dynamiciprheader"></h2></p> <input type="text" id="searchdata" style="display:none">
        </div>
        <div class="tabs-and-filters">
            <div class="button-group">
                <a href="#" title="Tracker List" id="trackertab" class="button-group-base">Tracker <span id="trademarkcount"></span></a>
                <a href="#" class="button-group-base1" title="My List" id="mylisttab">My List <span id="MyListCount"></span></a>
                <a href="#" title="Search Result" class="button-group-base2" id="searchtab">Search History <span id="SearchCount"></span></a>
                @if (ViewBag.RoleId == "1")
                {
                    <a href="#" title="Delete" class="button-group-base2 active" id="deletemattertab">Delete Request<span id="DeleteTradeCount"></span></a>
                    <a href="#" title="alert history" class="button-group-base2" style="@Session["IPRJournalAlertSub"]" id="jAlertHistorytab">Journal Alert History <span id="JournalAlertCount"></span></a>
                }
                else
                {
                    <a href="#" title="Shared Trademark" class="button-group-base2" id="SharedTradetab">Shared <span id="SharedTradeCount"></span></a>
                }
                @*<span id="spPhoneticSearch" style="display:none"><a href="#" title="Phonetic Search" class="button-group-base2" id="searchPhonetictab">Phonetic Search<span id="PhoSearchCount"></span></a></span>*@
            </div>
            <div style="display:inline-flex">
                <a href="#" title="Add new Manually" id="AddmanuallyTrade" class="btnManual"><span><img class="plus-icon" alt="" src="/newassets/img/Icon.svg"></span>Add Manually</a>
                <a href="#" title="Add new Matter" id="AddTradeAfterSearch" class="button4"><span><img src="~/newassets/img/plus-icon.png" /></span><span id="btnNameDetail"></span></a>
            </div>
        </div>
    </div>
</section>

<section class="wrapper" style="margin:unset !important">
    <div class="container-main">
        <h2 class="title" id="dynamiciprheader"></h2>
        <div id="page-wrapper">
            <div class="showcontent" id="showcontent">
                <div class="box">
                    <div class="box-header" style="padding:5px;">
                        <ul class="btn_panel no-margin pull-right" style="padding:0;" id="sectiontemp"></ul>
                    </div>
                </div>
            </div>
            <!-- Main content -->

            <div class="table-panel table-responsive">
                <div style="overflow-x:auto;">
                    <div class="card-header">
                        <div class="content1" style="padding-bottom:20px;">
                            <div class="text-and-supporting-text1">
                                <div class="filter" id="idcustomcommonFilter" style="cursor:pointer;">
                                    <img src="/newassets/img/search-lg.png" alt="">
                                    Filters
                                </div>
                            </div>
                            @*<div class="table-header">
                                    <div class="fs3">
                                        <div class="menuexport" style="position:relative; cursor:pointer;">
                                            <div class="dropdown-toggle button9" id="menuexport" type="button" data-toggle="dropdown" title="Export">
                                                <img class="plus-icon" alt="" src="~/newassets/img/upload-icon.png">
                                            </div>
                                            <ul class="dropdown-menu settingaction" style="margin-left: -50px;" id="dynaction">
                                                <li><a id="oexcel" title="Export to Excel"><span style="padding: 0 10px 0 0;"><img src="/newassets/img/exportexl-icon.png"></span>Export to Excel</a></li>
                                                <li><a id="opdf" title="Export to PDF"><span style="padding: 0 10px 0 0;"><img src="/newassets/img/exportpdf-icon.png"></span>Export to PDF</a></li>
                                            </ul>
                                        </div>

                                    </div>
                                </div>*@
                        </div>
                    </div>


                    <table class="table-panel fixed_table_head">
                        <thead>
                            <tr id="thval"></tr>
                        </thead>
                        <tbody id="ddlbindIPRSearchData"></tbody>
                    </table>
                    <center>
                        <div class="notfound" id="pdatastatus" style="display:none;">
                            <img src="~/newassets/img/not-found.png" />
                            <h4><span id="dtNotFound"></span></h4>

                        </div>
                    </center>
                </div>
                <div class="pagination" id="tradePagination">
                    <div class="pagination-button-group">
                        <div id="prev" class="pagination-button-group-base">
                            <img class="arrow-left-icon" alt="" src="/newassets/img/pre-arrow.png" style="width:16px; height:16px;">
                            <div class="text" style="float:right; padding:0 0 0 8px;">Previous</div>
                        </div>
                        <div id="pageNumbers" class="pagination-button-group-base1">
                        </div>
                        <div id="next" class="pagination-button-group-base8">
                            <div class="text" style="float: left;padding: 0 8px 0 0px;">Next</div>
                            <img style="float: right; width: 16px; height: 16px;" class="arrow-left-icon" alt="" src="/newassets/img/next-arrow.png" />

                        </div>
                    </div>
                    <div class="text-and-supporting-text-parent">
                        <div class="input">
                            <div class="content">
                                <input type="text" id="txtgopage" name="query" placeholder="Page No.">
                            </div>
                            <div class="help-icon">
                            </div>
                        </div>
                        <div class="text-and-supporting-text-group">
                            <div class="text-and-supporting-text">
                                <div id="divGo" class="text9">Go</div>
                            </div>
                            <img class="chevron-down-icon" alt="" src="~/newassets/img/next-arrow.png" style="width:16px; height:16px;">

                        </div>
                    </div>
                </div>
                @*<div class="table-panel">
                        <div class="settingpanel">
                            <div class="col-md-6">
                                <div style="float: left;padding: 0 10px 0 0;">
                                </div>
                                <div id="ptfooter">

                                </div>
                            </div>
                        </div>
                    </div>*@
            </div>
        </div>
    </div>

    @*Common Custom Filter*@
    <div id="myModalCustomCommonFilter" class="modal right fade myModal" role="dialog" data-backdrop="static">
        <div class="modal-dialog" style="width:400px;height: 100vh; padding:2px 0;">
            <!-- Modal content-->
            <div class="modal-content">
                <div class="modal-header btn-success">
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                    <h4 class="modal-title">
                        <img src="~/newassets/img/mfilter-icon.png" />
                    </h4>
                </div>
                <div class="modaltitle">
                    <h4>Apply Filter</h4>
                    <p>Select fields to apply your filter</p>
                </div>
                <div class="modal-body">
                    <form class="ec_bg" enctype="multipart/form-data" autocomplete="off" id="ddliprform" onsubmit="return false">
                        <!-- Start About boxes -->
                        <input type="hidden" value="" id="hiddenid" />
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label class="formLabel colorDark"><span class="control-label">Search</span></label>
                                    <input type="text" id="filtertradmark" placeholder="Search" class="inputFormat" autofocus>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label class="formLabel colorDark"><span class="control-label">Application No</span></label>
                                    <input type="text" class="inputFormat" id="txtapplicationno" />
                                </div>
                            </div>
                        </div>
                        @*<div class="row" id="divHide3" style="width: 280px; margin-left: 100px;">
                            <div class="col-md-12">
                                <div class="form-group" style="margin-top: 34px;" id="btns">
                                    <div class="col-md-6">
                                        <button type="submit" id="ddlbtnclear" class="btn btn-secondary pull-left" value="CLEAR" style="width:100%">Reset</button>

                                    </div>
                                    <div class="col-md-6">
                                        <button type="submit" id="ddlbtnsearch" class="btn btn-primary pull-left" value="SEARCH" onclick="" style="width:100%">Confirm</button>
                                    </div>
                                </div>
                            </div>
                        </div>*@
                    </form>
                </div>
                <div class="modal-footerip">
                    <button type="submit" value="CLEAR" class="btn btn-secondary" id="ddlbtnclear">Reset</button>
                    <button type="submit" value="SEARCH" class="btn btn-primary pull-right" id="ddlbtnsearch">Confirm</button>
                </div>
            </div>
        </div>
    </div>
</section>

@* Delete popup started *@
<div id="myModalmarkdeleteTradeconfirmation" class="modal fade" role="dialog" data-backdrop="static" data-keyboard="false" aria-hidden="true" style="display: none;">
    <div class="modal-dialog" style="width:480px;">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header btn-success">
                <button type="button" class="close" data-dismiss="modal">×</button>
                <h4 class="modal-title">
                    <img src="/newassets/img/icon1.png" style="margin:-15px 0px 0 -15px">
                </h4>
            </div>
            <div class="modaltitle" style="margin: -33px 0 0 0; border-bottom: none;">
                <h4 id="ids_deleteTraderequesr"></h4>
            </div>
            <div class="modal-body">
                <p id="msgRUSure"></p>
            </div>
            <div class="footer_buttons modal-footer">
                <button class="btn btn-secondary" id="" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary" id="deleteTrademarkDetails">Confirm</button>
            </div>
        </div>
    </div>
</div>
@* Delete popup ended *@

