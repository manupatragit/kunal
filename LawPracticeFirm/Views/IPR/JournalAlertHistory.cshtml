<style>
    #opentrademarkdetails {
        cursor: pointer;
    }

    #removetrademarkdetails {
        cursor: pointer;
    }

    #emasexc1 {
        background: #ebebeb;
    }

    .btnManual {
        padding: 10px;
        display: flex;
        gap: 5px;
        border: 2px solid gray;
        border-radius: 7px;
        margin-right: 5px;
        text-decoration: none;
        color: gray;
    }
    .popup-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.6);
        z-index: 1000;
    }

    .popup-content {
        position: fixed;
        top: 35%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: #fff;
        border-radius: 8px;
        width: 850px;
        max-height: 600px;
        overflow-y: auto;
        box-shadow: 0 4px 10px rgba(0,0,0,0.3);
    }

    .popup-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #f0f0f0;
        padding: 10px 15px;
        border-bottom: 1px solid #ddd;
    }

        .popup-header h3 {
            margin: 0;
            font-size: 18px;
        }

    .close-btn {
        cursor: pointer;
        font-size: 20px;
        font-weight: bold;
        color: #d00;
    }

    .popup-body {
        padding: 15px;
    }
    .download-actionBtn {
        display: block;
        padding: 0;
        border: 1px solid #cccccc !important;
        box-shadow: rgba(0, 0, 0, 0.1) 0px 0px 5px 0px, rgba(0, 0, 0, 0.1) 0px 0px 1px 0px;
        border-radius: 5px;
    }
</style>
