    }

    .border-0 {
        border: 0px;
    }

    .setalerticon-border {
        display: flex;
        padding: 3px;
        border: 1px solid #cccccc !important;
        box-shadow: rgba(0, 0, 0, 0.1) 0px 0px 5px 0px, rgba(0, 0, 0, 0.1) 0px 0px 1px 0px;
        border-radius: 5px;
        justify-content: center;
