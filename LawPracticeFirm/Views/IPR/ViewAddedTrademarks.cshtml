            float: right !important;
        }

    table.fixed_table_head tr {
        position: relative;
    }

    table.fixed_table_head thead tr th.head_fix {
        position: sticky;
        top: 0;
        left: 0;
        background: #fafafa;
    }

    table.fixed_table_head tbody tr td.head_fix {
        position: sticky;
        top: 0;
        left: 0;
