            highlight: true,
            minLength: 3,
            source: function (request, response) {
                request = request.replace(/"/g, "").replace(/\\/g, "");
                $.ajax({
                    async: true,
                    url: '/Firm/ClientFilter',
                    data: "{ 'prefix': '" + request + "'}",
                    dataType: "json",
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    success: function (data) {
                        items = [];
                        map = {};
                        $.each(data, function (i, item) {
                            var id = item.val;
                            var name = item.label;
                            var utype = item.utype;
                            var isclient = item.isclient;
                            var CompanyID = item.CompanyID;
                            var ProfileType = item.ProfileType;
                            var LabelName = item.LabelName;
                            map[name] = {
                                id: id,
                                name: name,
                                utype: utype,
                                isclient: isclient,
                                CompanyID: CompanyID,
                                ProfileType: ProfileType,
                                LabelName: LabelName
                            };
                            items.push(name);
                        });
                        response(items);
                        $(".dropdown-menu").css("height", "auto");
                        $(".typeahead li").removeClass("active");
                    },
                    error: function (response) {
                        alert(response.responseText);
                    },
                    failure: function (response) {
                        alert(response.responseText);
                    }
                });
            },
            updater: function (item) {
                var clientds = map[item].id;
                $("#tasktimecontactvalue").val(clientds);
                if (clientds != "") {
                    $('#taskmatter').empty();
                    loadmatter12(clientds, "taskmatter");
                } else {
                    //$('#alertmember').empty().append('
                   // <option value="ALL" > Select All User < /option>').find('option:first').attr("selected", "selected");
                  }
                  return item;
                }
              });
            });
</script>
