@{
    ViewBag.Title = "PDFMergeView";
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_ManuPanelPartialClient.cshtml";
    }
    string strp = Request.Form["p"];
    strp = HttpUtility.UrlDecode(QueryStringEDAES.QueryAES.DecryptAes(QueryAES.FromBase64StringWithReplace(Request.Form["p"].Replace(" ", "+"))));
}
<iframe src="" id="frmcompare" width="100%" height="650px" frameborder="0"></iframe>
<script>
    url = strp.replace(/\\\\/g, "/").replace(/\\/g, "/");
    $("#frmcompare").attr("src", url);
</script>