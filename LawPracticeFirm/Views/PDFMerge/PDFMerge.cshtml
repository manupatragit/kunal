                            return false;
                        }
                        else {
                            //alert("err !!");
                            closeload();
                        }
                    },
                    error: function (data) {
                        closeload();
                    }
                });
            }
            else {
                alert("Please upload file!!")
                return false;
            }
    }
        function MergePDFSaveChanges() {
            var strfiles = $('#hidfilename').val();
            var strtxt = CKEDITOR.instances.txt.getData();  //$('#txt').val();
            var formData = new FormData();
            formData.append("id", EncodeText(strfiles));
            formData.append("txt", EncodeText(strtxt));
            var strfilename = $('#txtfilename').val();
            var filesizemerge = $('#filesizemerge').val();
            formData.append("filesize", EncodeText(filesizemerge));
            formData.append("filename", EncodeText(strfilename));
            openload();
            $.ajax({
                async: true,
                type: "POST",
                url: "/pdfmerge/GeneratePDFAfterEditIndex",
                dataType: 'json',
                data: formData,
                contentType: false,
                processData: false,
                success: function (data) {
                    if (data.Result == "SUCCESS") {
                        $('#txt').val(data.Message);
                        //alert(data.FileName);
                        $('#Finalpdf,#detailssection2').show();
                        $('#Finalpdf').attr("linkdata", window.location.origin + "/" + data.FileName.toString().replace(/\\\\/g,"/"));
                        $("#selected").hide();
                        $("#priority").hide();
                        alert("Index updated successfully");
                        closeload();
                    }
                    else {
                        //alert("err !!");
                        closeload();
                    }
                },
                error: function (data) {
                    closeload();
                }
            });
        }
        document.getElementById('txt').style.display = "none";
</script>
<script>
    $(document).ready(function () {
        $('#selected-items-select').empty();
        $('#move-up').click(moveUp);
        $('#move-down').click(moveDown);
    });
    function moveUp() {
        $('#selected-items select :selected').each(function (i, selected) {
            if (!$(this).prev().length) return false;
            $(this).insertBefore($(this).prev());
        });
        $('#selected-items select').focus().blur();
    }
    function moveDown() {
        $($('#selected-items select :selected').get().reverse()).each(function (i, selected) {
            if (!$(this).next().length) return false;
            $(this).insertAfter($(this).next());
        });
        $('#selected-items select').focus().blur();
    }
    function RemoveItem() {
        $("#selected-items-select option:selected").each(function () {
            //alert($(this).val());
            $(this).remove();
        });
    }
    function openload() {
        $('#myOverlay').css("display", "block");
    }
    function closeload() {
        $('#myOverlay').css("display", "none");
    }
</script>
