    function removeLastComma(strng) {
        var n = strng.lastIndexOf(",");
        var a = strng.substring(0, n)
        return a;
    }
    function downloadfile(data,fname) {
        var a = document.createElement('a');
        a.target = "_blank";
        a.href = data;
        a.download = fname;
        a.click();
        window.location.href = "PDFMergeList";
    }
            function MergePDF() {
            var finalesequencefile = "";
