                }
                var myarraylength = String(finalesequencefile).split(',');
                if (parseInt(myarraylength.length) > 25) {
                    alert("Sorry! You have added more than 25 file. Pls remove some file(s)");
                    return false;
                }
                ///check file size
                @*var tempsize = 0;
            var tottempsize = 0;
            var totalFiles = document.getElementById(attachmenttask).files.length;
            if (totalFiles == "0") {
                alert("Please select the attachment.");
                $("#attachmenttask" + srno).focus();
