<script>
    var ecpageindex = 1;
    var ecpagesize = 10;
    $(document).ready(function () {
        $(document).on('click', '#clearnewseach', function () {
            /* your code here */
            // ecpageindex = $(this).attr("index");
            $("#clearnewseach").hide();
            $("#name,#datefrom,#dateto").val("");
            PdfMergeList(ecpageindex);
        });
        $(document).on('click', '#btnsearch', function () {
            $("#clearnewseach").show();
            PdfMergeList(ecpageindex);
        });
        PdfMergeList(ecpageindex);
        $(document).on('click', '#btnpdfmerge', function () {
            window.location.href = "pdfmerge";
        });
        $(document).on('click', '#GOpagnumvalue', function () {
            ppageindex = $("#maxpagnumvalue").val();
            if (ppageindex != "undefined") {
                if (Math.sign(ppageindex) == 1) {
                    var ppageindesx = $("#totalresult").text();
                    if (ppageindex <= parseInt(ppageindesx)) {
                        openload();
                        loadflag = true;
                        PdfMergeList(ppageindex);
                        //closeload();
                    }
                    else {
                        alert("Please enter a valid page number.");
                        closeload();
                    }
                }
                else {
                    alert("Please enter a valid page number.");
                }
            }
        });
        $(document).on('click', '#nxtprebtn', function () {
            ppageindex = $(this).attr("index");
            PdfMergeList(ppageindex);
        });
        $(document).on('click', '#deletepdf', function () {
            if (confirm("Are you sure want to delete this file!")) {
                var uCGuid = $(this).attr("data-val");
                var formData = new FormData();
                formData.append("uCGuid", EncodeText(uCGuid));
                $.ajax({
                    async: true,
                    type: "POST",
                    url: "/PDFMerge/RemoveBundleDoc",
                    dataType: 'text',
                    data: formData,
                    contentType: false,
                    processData: false,
                    success: function (response1) {
                        if (response1 == "Success") {
                            alert("Successfully deleted");
                            PdfMergeList(ecpageindex);
                            return false;
                        }
                        else if (response1 == "error") {
                            alert("Oops! Something went wrong..");
                        }
                    }
                });
            }
        });
        $(document).on('click', '#view', function () {
            var token = $(this).attr("datap");
            var url = token;
            url = url.replace(/\\\\/g, "/").replace(/\\/g, "/");
            $("#frmcompare").attr("src", url);
            $("#comparemodal").show();
        });
        $(document).on('click', '#download', function () {
            var token = $(this).attr("datap");
            var url = token;
            url = url.replace(/\\\\/g, "/").replace(/\\/g, "/");
            var a = document.createElement('a');
            a.href = url;
            a.download = url.split("/").pop();
            a.click();
        });
        $(document).on('click', '#mclose', function () {
            $("#comparemodal").hide();
        });
    });
    function PdfMergeList(ecpageindex) {
