                                if (pnext == 0) pnext = 1;
                                pprev = parseInt(pageno) - 1;
                                if (pprev == 0) pprev = 1;
                                totpage = parseInt(totdata) / parseInt(ecpagesize);
                                if (parseInt(totdata) % parseInt(ecpagesize) != 0) {
                                    totpage = parseInt(totpage) + 1;
                                }
                                $("#maxpagnumvalue").attr("max", totpage);
                            }
                            tfot += '<li>results <span>' + totdata + '</span>  <span id="totalresult" style="display:none">' + totpage + '</span></li>'
                            tfot += '<li><span>|</span></li>'
                            tfot += '<li>pages ' + ecpageindex + '/ ' + parseInt(totpage) + '</li>'
                            tfot += '<li><span>|</span></li>'
                            tfot += '<li ><input type="number" id="maxpagnumvalue" min="1"  class="footerInput"><a class="gobtn" type="button" id="GOpagnumvalue" style="margin-left:10px;cursor:pointer">Go</button> </li>'
                            tfot += '<li>'
                            if (a.totRow <= length) { }
                            else if (pageno == 1) { }
                            else if (pageno == totpage) {
                                //tfot += '<span> <a id="ecpaginate" title="Previous Page" href="javascript:void()" index="' + pprev + '"><span class="glyphicon glyphicon-arrow-left" style="padding:0 !important"></span></a></span>'
                                tfot += '<li><span><a id="nxtprebtn"  title="Previous Page" href="javascript:void()" index="' + pprev + '"><img src="/newassets/images/arrow_left.png" ></a></span>  ' + firstvalue + '-' + a.rownum + '  <span>'
                            }
                            else {
                                //tfot += '<span> <a id="ecpaginate" title="Previous Page" href="javascript:void()" index="' + pprev + '"><span class="glyphicon glyphicon-arrow-left" style="padding:0 !important"></span></a></span>'
                                tfot += '<li><span><a id="nxtprebtn"  title="Previous Page" href="javascript:void()" index="' + pprev + '"><img src="/newassets/images/arrow_left.png" > </a></span>  ' + firstvalue + '-' + a.rownum + '  <span>'
                            }
                            if (pageno < totpage) {
                                tfot += '<a id="nxtprebtn" title="Next Page" href="javascript:void()" index="' + pnext + '"><img src="/newassets/images/arrow_right.png" style="padding:3px 0 0 0;"></a></span>'
                            }
                            // tfot += '</li>'
                            $("#ecfootercompare").append(tfot);
                        }
                        var Date = a.ddate;
                        var vName = a.vName;
                        var TotalPage = a.TotalPage;
                        var vFileName = a.vFileName;
                        var vPath = a.vPath;
                        var PageType = a.PageType;
                        html3 += '<tr>'
                        html3 += '<td class="ddate">'
                        html3 += '' + Date + ' '
                        html3 += '</td>'
                        html3 += '<td class="Name">'
                        html3 += '<span id="Name" >' + vName + '</span>'
                        html3 += '</td>'
                        html3 += '<td class="File" >'
                        html3 += '<span id="File" title="View document"><a href="#" id="view"  datap="' + vPath + '" data-val="' + a.iid + '"><i class="glyphicon glyphicon-eye-open"></i></a></span>'
                        html3 += ' &nbsp;|&nbsp; <span id="File" title="Download document"><a href="javaxscirpt:void();"  datap="' + vPath + '" id="download"><i class="fa fa-download"></i></a></span>'
                        html3 += ' &nbsp;|&nbsp; <span id="File" title="Delete document"><a href="javaxscirpt:void();"   data-val="' + a.iid + '" id="deletepdf" style="color:red;"><i class="glyphicon glyphicon-trash"></i></a></span>'
                        html3 += '</td>'
                        html3 += '<td class="TotalPage">'
                        html3 += '<span name="TotalPage" id="TotalPage" >' + TotalPage + '</span></i>'
                        html3 += '</td>'
                        html3 += '</tr>'
                    });
                    if (strrecord1 > 0) {
                        $("#doclist").html(html3);
                    }
                    else {
                        $("#doclist").html("<tr><td align=center colspan=4>No record found</td></tr>");
