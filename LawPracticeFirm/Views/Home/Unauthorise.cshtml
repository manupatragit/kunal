<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body {
            margin: 0;
            padding: 0;
            background-image: url(data:image/png;base64,);
        }

        .error-template {
            padding: 30px 0;
            text-align: center;
        }

        .error-actions {
            margin-top: 15px;
            margin-bottom: 15px;
        }

            .error-actions .btn {
                margin-right: 10px;
            }

        .btncls {
            background-color: #4CAF50;
            border: none;
            color: white;
            padding: 15px 32px;
            text-align: center;
            text-decoration: none;
            display: inline-block;
            font-size: 16px;
            margin: 4px 2px;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <div class="container1">
        <div class="row">
            <div class="col-md-12">
                <div class="error-template">
                    <p><img src="/newassets/images/logo.png" /></p><br>
                    <div class="error-details">
                        <a href="javascript:void()" onclick="goBack()">
                            <img src="/newassets/images/authorized_img.png" />
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script>
        function goBack() {
            var fcodes = localStorage.getItem("FirmCode");
            window.location = encodeURI("/" + fcodes + "/client/matterlist");
        }
    </script>
</body>
</html>
