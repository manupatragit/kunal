@{
    Layout = "~/Views/Shared/_NewHomePartialHomeInner.cshtml";
}
<script>
    $(document).ready(function () {
        $('.trigger').click(function () {
            var clsd = $(this).attr("coltype");
            var dtt = $(this).attr("ttllbl");
            $(clsd).toggle();
            if ($(this).hasClass('collapsed')) {
                $(this).html('<span class="pmicon1">-</span> ' + dtt);
                $(this).removeClass('collapsed');
            } else {
                $(this).html('<span class="pmicon">+</span> ' + dtt);
                $(this).addClass('collapsed');
            }
        });
    });
</script>
