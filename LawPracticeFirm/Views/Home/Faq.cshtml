    .trigger {
        width: 100%;
        text-align: left;
        border-bottom: 1px solid #d2d2d2;
    }

    .headtxt {
        color: #0067b8;
        margin: 0;
        padding: 10px 2px;
        font-size: 16px;
    }

        .headtxt:hover {
            background: #eaeaea;
            cursor: pointer;
        }

    .pmicon {
        height: 27px;
        width: 27px;
        border: 2px solid #636363;
        color: #636363;
        border-radius: 50%;
        padding: 3px 8px 3px 8px;
        font-weight: bold;
        font-size: 20px;
        font-family: arial;
    }

    .pmicon1 {
