@{
    Layout = null;
    var strfilename = TempData["filename"];
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>MyKaseEnquiryThankyou</title>
    <link href="~/NewDesign/css/bootstrap.css?1" rel="stylesheet">
    <link href="~/NewDesign/css/fontawesome-all.css?1" rel="stylesheet">
    <link href="~/NewDesign/css/home.css?2.2" rel="stylesheet">
    <link href="~/NewDesign/css/home.css?2.2" rel="stylesheet">
</head>
<body>
    <div style="margin: 80px auto 0; width: 100%; border: 1px solid #8fd500; padding: 27px; font-size: 14px; color: #0059c1; text-align: center;">
        <p><img src="/NewDesign/images/logo_enquiry.png" alt="MyKase"></p><br />
        <p>
            Thank you for your interest in myKase.<br />
            Our representative will contact you shortly.<br /><br />
            @if (strfilename != null && Convert.ToString(strfilename) != "")
            {
                strfilename = strfilename.ToString() + ".ics";
            <p style="font-size:12px"><a href="@System.Web.Configuration.WebConfigurationManager.AppSettings["SiteUrl"].ToString()@System.Web.Configuration.WebConfigurationManager.AppSettings["Demoicspath"].ToString()/@strfilename.ToString()">Save to Calendar &nbsp; <img src="~/Content/images/calendar_icon.png" title="Save to Calendar" width="20px" height="20px" /></a></p>
        }  </p>
        </div>
    </body>
</html>
