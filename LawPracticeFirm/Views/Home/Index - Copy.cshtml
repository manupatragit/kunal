<section class="demorequest" id="demorequest">
    <div class="demorequest-head">
        <div class="container">
            <h2>request for demo </h2>
        </div>
    </div>
    <div class="container">
        <div class="demorequestform">
            <form id="democontact">
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label for="">name</label>
                            <input type="text" class="form-control" id="demoname" placeholder="" required maxlength="30">
                        </div>
                    </div>
                    <div class="col-md-5">
                        <div class="form-group">
                            <label for="">email</label>
                            <input type="email" class="form-control" id="demoemail" placeholder="" required maxlength="50">
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label for="">phone</label>
                            <input type="text" class="form-control" id="demophone" placeholder="" required maxlength="10">
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <button type="button" class="sbtbtn" id="SaveDemocontact">SUBMIT</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>


    <div class="modal fade" id="myModal" role="dialog">
        <div class="modal-dialog">

            <!-- Modal content-->
            <div class="modal-content">

                <div class="modal-body">
                    <P>
                        <button type="button" class="close" data-dismiss="modal" style="margin-top: -19px;
    margin-right: -14px;">
                            &times;
                        </button>
                    </P>
                    <p style="text-align: center;
    color: #5a5a5c;
    font-size: 12px;
    border: 1px solid #9fd29f;
    border-radius: 5px;
    padding: 8px 3px 7px 1px;
    margin-top: 30px;">
                        Thank you for your interest in myKase.
                        <br> Our representative will contact your shortly.
                    </p>
                </div>
                <br>
            </div>

        </div>
    </div>

</section>
