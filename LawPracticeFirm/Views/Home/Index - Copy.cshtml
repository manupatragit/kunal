<script>
    $(document).ready(function () {
        $("button").click(function () {
            $("#btnnn").toggle();
        });

        $('.trigger-more').click(function () {
            if ($(this).hasClass('collapsed')) {
                $(this).text('- less');
                $(this).removeClass('collapsed');
            } else {
                $(this).text('more features +');
                $(this).addClass('collapsed');
            }
        });
    });
</script>
<script>
    function ModalClose() {
        document.getElementById("showMe").style.display = "none";
    }
</script>
<style>

    .trigger-more {
        border: none;
        background: transparent;
        font-size: 18px;
        color: #337ab7;
        margin: 10px 0 0 0;
    }

    #showMe1 {
        width: 200px;
        height: 100px;
        border: solid 1px black;
        /* margin-bottom: 5px; */
        margin: 0 auto;
        position: absolute;
        z-index: 1000;
        background: #fff;
        left: 40%;
    }

    .modal_a {
        position: fixed;
        z-index: 9999999999;
        padding-top: 90px;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: auto;
        background-color: rgb(0,0,0);
        background-color: rgba(0,0,0,0.8);
    }

    .modal_a-content {
        background-color: #fefefe;
        margin: -10px auto 0;
        padding: 10px 10px;
        border: 1px solid #000;
        border-radius: 5px;
        width: 650px;
        height: 500px;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 16px;
    }

    .close_a {
        position: relative;
        right: -20px;
        top: -22px;
        float: right;
    }

        .close_a:hover, .close_a:focus {
            color: #000;
            text-decoration: none;
            cursor: pointer;
        }
</style>
<script type="">
    $(document).ready(function () {
        var hiddenDiv = $("#showMe");
        var show = function () {
            hiddenDiv.fadeIn();
        };

        hiddenDiv.hide();
        setTimeout(show, 0000);

        $("#bannerdiv").click(function () {
            $("#bannerdivpanel").hide();
            $("#enquireydiv").show();



        });
    });
</script>

