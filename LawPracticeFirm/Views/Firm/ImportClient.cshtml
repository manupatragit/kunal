                                                    <div class="col-md-8">
                                                        <input type="file" onchange="preview_image(this)" name="postedFile" id="postedFile" class="form-control inputbg" required style="width:56%; display:inline; height:38px; padding:0 5px;" />
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-6" style="margin-top:-5px;margin-left:-110px;">
                                                <div class="form-group">
                                                    <button type="button" id="uploadleaddata" class="sbtbtn" value="Upload File" title="Upload File">Upload File</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-lg-12 contact-details">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <input type="hidden" id="hidid" />
                                                    <span class="control-label col-md-8"> <b>Download Client template sample: </b> <a title="download Sample Template for Imoprt Contact Data " href="/Documents/ImportTemplate/ImportClientTemplate.xlsx">Click here</a></span>
                                                    <div class="col-md-4">
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <br>
                                    <br>
                                    <br>
                                    <div class="col-lg-12 contact-details">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="form-group">
                                                    <span class="control-label col-md-12" style="color:red;margin-top:30px;" id="errorresult"></span>
