@{
    /**/
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
}
<link href="~/panelDesign/vendor/datatables-plugins/dataTables.bootstrap.css" rel="stylesheet">
<link href="~/panelDesign/vendor/datatables-responsive/dataTables.responsive.css" rel="stylesheet">
<script src="~/Manupanel/pnotify/pnotify.custom.min.js"></script>
<link href="~/Manupanel/pnotify/pnotify.custom.min.css" rel="stylesheet" />
<script>
    function preview_image(event) {
        var validExts = new Array(".xlsx", ".xls");
        var fileExt = event.value;
        fileExt = fileExt.substring(fileExt.lastIndexOf('.'));
        if (validExts.indexOf(fileExt) < 0) {
            alert("Invalid file selected, valid files are of " +
                validExts.toString() + " types.");
            event.value = '';
            return false;
        }
        else {
            return true;
        }
    }
    $(document).ready(function () {
        function openload() {
            $('#myOverlay').css("display", "block");
        }
        function closeload() {
            $('#myOverlay').css("display", "none");
        }
        $(document).on("click", "#uploadleaddata", function () {
            ImportLeaddata();
        });
        function ImportLeaddata() {
            var formData = new FormData();
            var totalFiles = document.getElementById("postedFile").files.length;
            if (totalFiles == "0") {
                alert("Please Select Excel File");
                return false;
            }
            for (var i = 0; i < totalFiles; i++) {
                var file = document.getElementById("postedFile").files[i];
                formData.append("FileUpload", file);
            }
            openload();
            $.ajax({
                async: true,
                type: 'POST',
                url: '/firm/ImportClientData',
                data: formData,
                contentType: false,
                processData: false,
                success: function (response) {
                    document.getElementById("postedFile").value = "";
                    if (response == "Record imported successfully, please check Contact Details.") {
                        $("#errorresult").text("");
                        alert("Record imported successfully, please check Contact Details.");
                        closeload();
                    }
                    else {
                        $("#errorresult").text(response);
                        closeload();
                    }
                },
                error: function () {
                    alert('Please Contact Your Administrator !');
                    closeload();
                }
            });
        }
    });
</script>
<section class="wrapper">
    <div class="container-main showcontent" id="showcontent">
        <div class="row">
            <h2 class="title" style="margin-left:13px;">Import Client</h2>
            <div class="content">
