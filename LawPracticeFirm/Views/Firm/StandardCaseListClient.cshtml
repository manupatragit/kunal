<style>
    #opencasewatchusermodal {
        cursor: pointer;
    }

    .glyphicon-book, .glyphicon-trash, .glyphicon-pencil {
        color: black !important;
    }

    .trcolor {
        background: #f5c9c9 !important;
    }

        .trcolor td {
            background-color: transparent !important;
        }
</style>
<style>

    .caseinfo {
        border: 1px solid rgb(143, 213, 0);
        padding: 4px;
        width: 360px;
        height: auto;
        font-size: 12px;
        position: absolute;
        z-index: 9000;
        background: white;
        word-break: break-all;
    }

    #opencasewatchusermodal {
        cursor: pointer;
    }

    .glyphicon-book, .glyphicon-trash, .glyphicon-pencil {
        color: black !important;
    }

    .trcolor {
        background: #f5c9c9 !important;
    }

        .trcolor td {
            background-color: transparent !important;
        }

    .Border_Modal {
        position: relative;
        border: 1px solid #71768073;
        padding: 20px;
        margin: 22px auto 12px auto;
        border-radius: 7px;
    }

    .top-Modal-border-text {
        position: absolute;
        top: -15px; /* Adjust to move text above the border */
        left: 20px; /* Adjust text position */
        padding: 0 10px;
        font-weight: bold;
        background-color: white;
        color: gray;
    }

    .notfound {
        text-align: center;
        width: 320px;
        margin: 0 auto;
    }

        .notfound h4 {
            font-size: 16px;
            font-weight: 600;
            color: #1F2937;
            margin: 0;
        }

        .notfound p {
            font-size: 13px;
            font-weight: 400;
            color: #1F2937;
            padding: 0;
            margin: 0;
        }

    .Divlabourmatter,
    .Divcommercialmatter {
        display: grid;
        align-items: center;
        grid-template-columns: 1fr 1fr;
        column-gap: 20px;
    }

    /* 6/8/2025 new changes*/

    .modal-content p {
        font-size: 14px;
        font-weight: 400;
    }

    .modal-content .modaltitle h4 {
        font-size: 18px;
        font-weight: 600;
    }
</style>
