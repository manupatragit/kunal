@{
    Layout = null;
}
<i class="pp-icon-user"></i>
<!-- Page Content -->
<link href="/panelDesign/vendor/datatables-plugins/dataTables.bootstrap.css" rel="stylesheet">
<!-- DataTables Responsive CSS -->
<link href="/panelDesign/vendor/datatables-responsive/dataTables.responsive.css" rel="stylesheet">
<style>
    <style >
    table {
        font-family: arial, sans-serif;
        border-collapse: collapse;
        width: 100%;
    }

    td, th {
        border: 1px solid #dddddd;
        text-align: left;
        padding: 8px;
    }

    tr:nth-child(even) {
        background-color: #dddddd;
    }
</style>
<script>
    $(document).ready(function () {
        var filetype = "@ViewBag.type";
         var fid = "@ViewBag.data";
        var filedata = localStorage.getItem("filedata-val");
        var url = window.location.href;
        var segments = url.split('/');
        var typeid = '';
        var id = segments[6];
        if (id == "undefined") {
            typeid = 0;
        }
        else {
            typeid = id;
        }
        $table = '';
        $table = $('<table id="example1" class="table"  style="overflow-x:auto;" /><tr><th>').addClass('dataTable table table-bordered table-striped');
        $header = $('<thead  >').html('');
        $head1 = $('<tr><th width="12%" class="Activity"  style="text-align: left; ">Sl. No.</th><th class="Status" style="text-align: center; ">File Name</th><th style="text-align: center; padding-top: 12px;" class="Date">Download</th></tr> ');
        $header.append($head1);
        $table.append($header);
        var str_array = filedata.split('|');
        var html = '';
        var q = 0;
        if (filedata != "null") {
            for (var i = 0; i < str_array.length; i++) {
                q = q + 1;
                str_array[i] = str_array[i].replace(/^\s*/, "").replace(/\s*$/, "");
                dfilename = String(str_array[i]).substring(str_array[i].lastIndexOf("/") + 1);
                var idx = dfilename.lastIndexOf('.');
                if (idx != -1)
                string1 = dfilename.substring(0, idx);
                string1 = String(string1).substring(0, String(string1).length - 10);
                string2 = dfilename.substring(idx + 1);
                dfilename = string1 + "." + string2;
                var ftoken = "/DownloadFile.ashx?module=multiple&ftype=" + filetype + "&fid=" + fid + "&ftoken=" + str_array[i].replace(/ /g, '%20');
                html += str_array[i];
                // Add additional code here, such as:
                var $row = $('<tr />');
                $row.append($('<td class="s" />').html("<span>" + q + ""));
                $row.append($('<td class="s" />').html("<span>" + dfilename + ""));
                $row.append($('<td class="s" />').html("<center><span><a href=" + ftoken + " class='glyphicon glyphicon-download-alt' title='Download File' download='" + dfilename + "'> </a></center> "));
                $table.append($row);
            }
        }
        $('#contentdata').append($table);
    });
</script>
<div class="modal-header btn-primary">
    <button type="button" class="close" id="closemodel" data-dismiss="modal">&times;</button>
    <h4 class="modal-title">
        Document List
    </h4>
</div>
<div class="modal-body " style="height:500px; overflow-y:scroll;">
    <aside class="">
        <section class="content">
            <div id="page-wrapper">
                <div class="container-fluid showcontent" id="showcontent">
                    <div class="">
                        <div class="box-header">
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!-- /.box-header -->
        <!-- /.panel-heading -->
        <!-- Main content -->
        <!-- Main content -->
        <section class="content" style="height:450px; overflow-x:auto">
            <div id="contentdata"></div>
        </section>
        <!-- /.content -->
        <!-- /.content -->
    </aside>
    <div class="row">
        <div class="col-md-12">
            <div class="form-actions ">
                <div class="btn-group">
                    <div class="modal-footer">
                        <button type="button" id="closemodels" class="btn btn-default" data-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- /.container-fluid -->
</div>
