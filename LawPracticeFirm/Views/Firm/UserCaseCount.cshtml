@{
    /**/
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
}

<script>
    var roleids = "@Session["sessionroleid"]";
    var FirmIdss = "@Session["sessionfirmid"]";
</script>
<script src="~/Scripts/Firm/Pages/UserCaseCount.js?0.1"></script>
<style>
    #opencasewatchusermodal {
        cursor: pointer;
    }

    .glyphicon-book, .glyphicon-trash, .glyphicon-pencil {
        color: black !important;
    }

    .trcolor {
        background: #f5c9c9 !important;
    }

        .trcolor td {
            background-color: transparent !important;
        }

    .Border_Modal {
        position: relative;
        border: 2px solid black;
        padding: 20px;
        margin: 20px auto;
    }

    .top-Modal-border-text {
        position: absolute;
        top: -15px; /* Adjust to move text above the border */
        left: 20px; /* Adjust text position */
        padding: 0 10px;
        font-weight: bold;
        background-color: white;
        color: black;
    }
</style>
<section id="header">
    <div class="container-main">
        <div class="row">
            <div class="col-md-12">
                <div class="text-left">
                    <p class="ctitle">User-Wise Case List</p>
                </div>
            </div>

        </div>
    </div>
</section>
<section id="table">
    <div class="container-main">
        <div class="table">
            <div class="card-header">
                <div class="content1">
                    <div class="text-and-supporting-text1">

                    </div>
                    <div class="table-header">
                        <div class="actions3">
                            <div class="menuexport" style="position:relative; cursor:pointer;">
                                <div class="dropdown-toggle button9" id="menuexport" type="button" data-toggle="dropdown" title="Export">
                                    <img class="plus-icon" alt="" src="~/newassets/img/upload-icon.png">
                                </div>
                                <ul class="dropdown-menu action-more" role="menu" aria-labelledby="menuexport">
                                    <li><a href="javascript:void()" id="exporttoexcellogin" title="Export to Excel"><span style="padding: 0 10px 0 0;"><img src="/newassets/img/exportexl-icon.png"></span> Export to Excel</a></li>
                                    <li><a href="javascript:void()" id="exporttopdflogin" title="Export to PDF"><span style="padding: 0 10px 0 0;"><img src="/newassets/img/exportpdf-icon.png"></span> Export to PDF</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="tablearea">

                <div class="tablecontainer">
                    <div class="table-panel">
                        <div style="overflow-x:scroll;margin:0 0 15px 0;">
                            <table class="table-panel">
                                <thead>
                                    <tr>
                                        <th class="srno">
                                            <div class="thbg">
                                                S.No
                                            </div>
                                        </th>

                                        <th class="username">
                                            <div class="thbg">
                                                User name
                                            </div>
                                        </th>
                                        <th class="UserId">
                                            <div class="thbg" style="min-width: 120px;">
                                                <div style="float:left;width:80%">
                                                    <input type="text" id="luserId" title="Login UserId" placeholder="Login UserId" class="form-control pull-left">
                                                </div>
                                                <div style="float:left;width:20%">
                                                    <span class="glyphicon glyphicon-search" id="lloginuserid" style="margin:5px 0 0 -14px;float:right"></span>
                                                    <span class="" id="loginuseridclearnewsearch" title="Click here to reset search" style="display:none;font-size:15px;color:black:font-weight:350;cursor:pointer;">x</span>
                                                </div>
                                            </div>
                                        </th>

                                        <th class="mattercount">
                                            <div class="thbg">
                                                Matter Count
                                            </div>
                                        </th>
                                    </tr>
                                </thead>
                                <tbody id="bindMatterData"></tbody>

                            </table>
                            <center>
                                <div class="notfound" id="pdatastatus" style="display:none;">
                                    <img src="~/newassets/img/not-found.png" />
                                    <h4>Data Not Found</h4>
                                </div>
                            </center>
                        </div>
                    </div>
                </div>
            </div>
            <div class="pagination" id="mtrPagination">
                <div class="pagination-button-group">
                    <div id="prev" class="pagination-button-group-base">
                        <img class="arrow-left-icon" alt="" src="/newassets/img/pre-arrow.png" style="width:16px; height:16px;">
                        <div class="text" style="float:right; padding:0 0 0 8px;">Previous</div>
                    </div>
                    <div id="pageNumbers" class="pagination-button-group-base1">
                    </div>

                    <div id="next" class="pagination-button-group-base8">
                        <div class="text" style="float: left;padding: 0 8px 0 0px;">Next</div>
                        <img style="float: right; width: 16px; height: 16px;" class="arrow-left-icon" alt="" src="/newassets/img/next-arrow.png" />

                    </div>
                </div>
                <div class="text-and-supporting-text-parent">
                    <div class="input">
                        <div class="content">
                            <input type="text" id="txtgopage" name="query" placeholder="Page No.">
                        </div>
                        <div class="help-icon">
                        </div>
                    </div>
                    <div class="text-and-supporting-text-group">
                        <div class="text-and-supporting-text">
                            <div id="divGo" class="text9">Go</div>
                        </div>
                        <img class="chevron-down-icon" alt="" src="~/newassets/img/next-arrow.png" style="width:16px; height:16px;">

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div id="myModalexport" class="modal fade myModal " role="dialog" data-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <input type="hidden" id="exportrecords">
            <div class="modal-header btn-primary">
                <button type="button" class="close" id="closemodels22" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">
                    Export Cases
                </h4>
            </div>
            <div class="modal-body  partynamebody " id="">
                <div style="height: 400px; overflow-y: auto;">
                    <table class="table-panel">
                        <thead>
                            <tr>
                                <th><div class="thbg">Page No.</div></th>
                                <th><div class="thbg">FileName</div></th>
                            </tr>
                        </thead>
                        <tbody id="printexport"></tbody>

                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

