<script>
    $(document).ready(function () {
        var fcode = localStorage.getItem("FirmCode");
        $(document).on("click", "#transferpageevent", function () {
            var modelid = $(this).attr("type");
            var transferid = $(this).attr("data-val");
            if (String(modelid) == "modelEditEvent") {
                var urls = "/" + fcode + "/Firm/EventSingleView";
                url_redirect({
                    url: urls,
                    method: "post",
                    data: { "token": transferid }
                });
            }
            else if (String(modelid) == "modelEditTask") {
                var urls = "/" + fcode + "/Firm/TaskSingleView";
                url_redirect({
                    url: urls,
                    method: "post",
                    data: { "token": transferid }
                });
            }
        });
        $(document).on("click", "#transferpagemore", function () {
            var modelid = $(this).attr("data-val");
            openload3();
            var url = "/firm/CalendarMoreEvent?status=true&token=" + encodeURI(modelid);
            $('.mymodels').load(url, function (result) {
                closeload3();
                $('#myModal').modal({ show: true });
            });
        });
    });
</script>
