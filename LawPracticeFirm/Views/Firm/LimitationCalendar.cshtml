<script src="~/Manupanel/icsfile/FileSaver.js"></script>
<form id="form1" runat="server">
    <div>
        <script>
            function download() {
                var urls31 = "/firm/LoadMergeNextHearing";
                var cal = ics();
                $.ajax({
                    async: true,
                    type: "POST",
                    url: urls31,
                    contentType: "application/json; charset=utf-8",
                    dataType: "json",
                    success: function (data) {
                        var datas = JSON.stringify(data);
                        if (data.length > 0) {
                            for (var i = 0; i < data.length; i++) {
                                if (data[i].Caseyear == "NA") {
                                    appealno = data[i].Casename;
                                    cdescription = data[i].CourseName;
                                }
                                else if (data[i].Caseyear != "") {
                                    appealno = data[i].CourseName + " " + data[i].CaseNo + "/" + data[i].Caseyear;
                                    cdescription = data[i].CourseName + ", Advocate:" + data[i].Advname;
                                }
                                else {
                                    appealno = data[i].Casetype;
                                    cdescription = "";
                                }
                                cal.addEvent(appealno, cdescription, "", data[i].Disposeddt, "");
                            }
                            cal.download();
                        }
                        else {
                            alert("No data available for calendar.");
                        }
                    }
                });
            }
        </script>
    </div>
</form>
