<div id="myOverlay" class="overlay">
    <div class="overlay-content">
        <div class="spinner2">
            <div><img src="~/newassets/images/MyKase_Loader.gif" height="59" width="150"></div>
        </div>
    </div>
</div>
<div id="MatterAssigned" class="modal fade" role="dialog" data-backdrop="static">
    <div class="modal-dialog" style="width:400px;">
        <div class="modal-content">
            <div class="modal-header btn-primary">
                <button type="button" id="closemodel" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">
                    <img src="/newassets/img/icon1.png" style="margin:-10px 0px 0 -11px">
                </h4>

            </div>
            <div class="modaltitle" style="border-bottom:none;margin:-30px 0 0 0;">
                <h4 id="">Matter Assigned</h4>
            </div>
            <div class="modal-body ">
                <div class="row">
                    <div class="col-md-12">
                        Matter has been assigned.
                    </div>
                </div>
            </div>
            <div class="modal-footer" style="border-top: none !important;">
                <div class="row">
                    <div class="col-md-6"></div>
                    <div class="col-md-6">
                        <button type="button" class="btn btn-primary" data-dismiss="modal" style="width:100%;">OK</button>
                    </div>
                    @*<div class="col-md-6">
                            <button type="button" id="" class="btn btn-primary" value="Save" style="width:100%;">Confirm</button>
                        </div>*@
                </div>
            </div>
        </div>
    </div>
</div>