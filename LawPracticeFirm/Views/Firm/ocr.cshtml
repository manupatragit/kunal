<script>
    function toggleHistoryGroup(header) {
        const files = header.nextElementSibling;
        if (files.style.display === "none") {
            files.style.display = "block";
        } else {
            files.style.display = "none";
        }
    }

    function filterOCRHistory() {
        const input = document.getElementById('ocrSearch');
        const filter = input.value.toLowerCase();
        const groups = document.querySelectorAll('#ocrHistory .date-group');

        groups.forEach(group => {
            let match = false;
            const files = group.querySelectorAll('.history-item');
            files.forEach(item => {
                const text = item.textContent.toLowerCase();
                const isVisible = text.includes(filter);
                item.style.display = isVisible ? 'block' : 'none';
                if (isVisible) match = true;
            });

            // Show or hide the whole group depending on matches
            group.style.display = match ? 'block' : 'none';
        });
    }
</script>
