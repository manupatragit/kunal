<!-- Loader for OCR generation  -->
<div id="myOverlay" style="
    display: none;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 360px;
    height: 180px;
    background: #fff;
    z-index: 9999;
    text-align: center;
    padding: 30px 20px;
    font-size: 18px;
    color: #333;
    font-family: sans-serif;
    border-radius: 8px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    border: 1px solid #ddd;
">
    <div class="spinner2" style="margin-bottom: 15px;">
        <img src="~/newassets/images/MyKase_Loader.gif" height="59" width="150" alt="Loading..." />
    </div>
    <strong>Please wait while we upload your file...</strong>
</div>

<div id="overlayBackdrop" style="
    display: none;
    position: fixed;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0,0,0,0.4);
    z-index: 9998;
"></div>

<div id="myOverlayOCR" class="overlay" style="z-index: 9999;">
    <div class="overlay-content">
        <div class="spinner2">
            <div><img src="~/newassets/images/MyKase_Loader.gif" height="59" width="150"></div>
        </div>
    </div>
</div>
<!-- Email Modal -->
<div id="emailModalCustom" style="display: none;">
    <div id="emailModalOverlay">
        <div id="emailModalBox">

            <!-- Modal Header -->
            <div id="emailModalHeader">
                <h5 id="emailModalTitle" style="font-size: 16px;">
                    <i class="bi bi-envelope-fill me-2"></i> Send OCR via Email
                </h5>
                <button id="emailModalCloseBtn" onclick="closeEmailModal()" aria-label="Close">×</button>
            </div>

            <!-- Modal Body -->
            <div id="emailModalBody">
                <form id="emailFormCustom" novalidate>
                    <div style="margin-bottom: 15px;">
                        <label for="recipientEmail" style="font-weight: 600;">Recipient Email <span style="color: red;">*</span></label>
                        <input type="email" id="recipientEmail" placeholder="example@domain.com" required style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
                    </div>
                    <div style="margin-bottom: 15px;">
                        <label for="emailMessage" style="font-weight: 600;">Message</label>
                        <textarea id="emailMessage" rows="4" placeholder="Add a short message (optional)..." style="height: 100px !important;width: 100%;padding: 8px !important;border: 1px solid #ccc !important;border-radius: 4px !important;"></textarea>
                    </div>
                </form>
            </div>

            <!-- Modal Footer -->
            <div id="emailModalFooter">
                <button id="emailCancelBtn" onclick="closeEmailModal()">
                    <i class="bi bi-x-circle me-1"></i> Cancel
                </button>
                <button id="emailSendBtn" onclick="sendEmailModal()">
                    <i class="bi bi-send-fill me-1"></i> Send
                </button>
            </div>

        </div>
    </div>
</div>
<input type="hidden" id="OCRBaseUrl" value="@ViewBag.OCRUrl" />
<!-- OCR Result Modal -->
<div class="modal fade" id="ocrModal" tabindex="-1" role="dialog" aria-labelledby="ocrModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="ocrModalLabel">OCR Output Preview</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body" id="ocrModalContent" style="max-height:80vh; overflow-y:auto;">
