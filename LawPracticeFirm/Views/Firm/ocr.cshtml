<script>
    $(document).ready(function () {
        function openload() {
            $("#myOverlay").css("display", "block");
        }
        function closeload() {
            $("#myOverlay").css("display", "none");
        }

        const TOTALLIMIT1 = 5120; // 5MB in KB
        const TOTALLIMITMSG1 = "Total file size cannot exceed 5 MB.";

        // Simulated extension check (you can customize it)
        function browsecomparedoc(filename) {
            const allowedExtensions = ["pdf", "jpg", "jpeg", "png"];
            const ext = filename.split('.').pop().toLowerCase();
            return allowedExtensions.includes(ext);
        }

        $("#attachment").change(function () {
            var formData = new FormData();
            var fileInput = document.getElementById("attachment");
            var files = fileInput.files;
            if (files.length === 0) {
                alert("Please select the file to be uploaded.");
                return false;
            }

            var totalSizeKB = 0;
            let filext1 = "";
            for (let i = 0; i < files.length; i++) {
                var file = files[i];
                var filename = file.name;
                filext1 = filename.split('.').pop();

                if (filename.length > 100) {
                    alert("The name of the file cannot exceed 100 characters. Please check file: " + filename);
                    $("#attachment").val("");
                    return false;
                }

                if (!browsecomparedoc(filename)) {
                    alert("Unsupported file extension: " + filext1);
                    return false;
                }

                formData.append("FileUpload", file);
                var sizeKB = file.size / 1024;
                totalSizeKB += sizeKB;
            }

            if (totalSizeKB > TOTALLIMIT1) {
                alert(TOTALLIMITMSG1);
                $("#attachment").val('');
                return false;
            }

            openload();

            $.ajax({
                async: true,
                type: "POST",
                url: "/Compare/UploadFile1",
                dataType: 'json',
                data: formData,
                contentType: false,
                processData: false,
                success: function (data) {
                    if (data.Result) {
                        var path = data.Result;
                        if (path === "FileAttachExceed") {
                            alert("You have added more than 1 file. Please remove some file(s).");
                        } else if (path === "NoFileAttach") {
                            alert("Please select the file to be uploaded.");
                        } else {
                            // Optional: handle different types of file preview
                            if (filext1.toLowerCase() === "doc" || filext1.toLowerCase() === "docx") {
                                $('#frmFileone').attr('src', "https://view.officeapps.live.com/op/view.aspx?src=" + path);
                            } else {
                                $('#frmFileone').attr('src', path);
                            }
                        }
                    }
                    closeload();
                },
                error: function () {
                    closeload();
                    alert("Error uploading file.");
                }
            });
        });
    });

</script>

<script>
    document.getElementById("attachmentDriveTab1").addEventListener("change", function (e) {
        document.getElementById("ocrPreviewContainerTab1").style.display = "block";
        const files = e.target.files;
        const fileNameField = document.getElementById("selectedFileNameTab1");
        const previewContainer = document.getElementById("ocrPreviewContainerTab1");
        const iframe = document.getElementById("ocrPreviewFrameTab1");

        previewContainer.innerHTML = "";

        if (!files || files.length === 0) {
            fileNameField.value = "No file chosen";
            iframe.style.display = "none";
            iframe.src = "";
            return;
        }
        fileNameField.value = Array.from(files).map(f => f.name).join(", ");

        Array.from(files).forEach((file, index) => {
            const fileURL = URL.createObjectURL(file);

            if (index === 0 && (file.type === "application/pdf" || file.type.startsWith("image/"))) {
                iframe.src = fileURL;
                iframe.style.display = "block";
                return;
            }

            let previewElement;

            if (file.type === "application/pdf") {
                previewElement = document.createElement("iframe");
                previewElement.src = fileURL;
                previewElement.width = "100%";
                previewElement.height = "400px";
                previewElement.style.border = "1px solid #ccc";
                previewElement.className = "mb-3";
            } else if (file.type.startsWith("image/")) {
                previewElement = document.createElement("img");
                previewElement.src = fileURL;
                previewElement.style.maxWidth = "100%";
                previewElement.style.maxHeight = "300px";
                previewElement.style.marginBottom = "15px";
                previewElement.style.display = "block";
            } else {
                previewElement = document.createElement("p");
                previewElement.textContent = "Preview not available for: " + file.name;
            }

            const wrapper = document.createElement("div");
            wrapper.className = "file-preview mb-4";
            wrapper.appendChild(previewElement);
            previewContainer.appendChild(wrapper);
        });
    });

    document.addEventListener("DOMContentLoaded", function () {
        const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        tooltipTriggerList.forEach(function (tooltipTriggerEl) {
            //
        });
    });
</script>



<script>
    // Download iframe content
    document.getElementById("aiGeneratedOCRDownload").addEventListener("click", function () {
        const iframe = document.getElementById("previewIframeTab1");
        if (iframe && iframe.contentDocument) {
            const doc = iframe.contentDocument;
            const html = doc.documentElement.outerHTML;
            const blob = new Blob([html], { type: "text/html" });
            const url = URL.createObjectURL(blob);

            const a = document.createElement("a");
            a.href = url;
            a.download = "ocr_preview.html";
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        } else {
            alert("Preview content not available for download.");
        }
    });

    // Trigger print from iframe
    document.getElementById("aiGeneratedOCRPrint").addEventListener("click", function () {
        const iframe = document.getElementById("previewIframeTab1");
        if (iframe && iframe.contentWindow) {
            iframe.contentWindow.focus();
            iframe.contentWindow.print();
        } else {
            alert("Preview content not available for printing.");
        }
    });

    document.getElementById("aiGeneratedWordFile").addEventListener("click", function () {

        const iframe = document.getElementById("previewIframeTab1");

        // Get iframe HTML content
        let htmlContent = iframe.contentDocument || iframe.contentWindow.document;
        htmlContent = htmlContent.documentElement.outerHTML;

        // Word compatible HTML wrapper
        let wordHTML =
            '<html xmlns:o="urn:schemas-microsoft-com:office:office" ' +
            'xmlns:w="urn:schemas-microsoft-com:office:word" ' +
            'xmlns="http://www.w3.org/TR/REC-html40">' +
            '<head><meta charset="utf-8"></head><body>' +
            htmlContent +
            '</body></html>';

        var blob = new Blob(['\ufeff', wordHTML], {
            type: 'application/msword'
        });

        var url = URL.createObjectURL(blob);

        var a = document.createElement("a");
        a.href = url;
        a.download = "OCR.doc";
        document.body.appendChild(a);
        a.click();

        document.body.removeChild(a);
    });
</script>
