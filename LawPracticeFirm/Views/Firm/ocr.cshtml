@{
    /**/
    ViewBag.Title = "AddContent";
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_ManuPanelPartialClient.cshtml";
    }
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

<script src="~/Scripts/html2pdf.bundle.min.js"></script>
<script src="~/Scripts/jszip.min.js"></script>
<script src="~/Scripts/Firm/Pages/ocr.js?2.6"></script>
<script type="text/javascript" src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
<script src="~/Scripts/pdf.min.js"></script>
<script pdfjsLib.GlobalWorkerOptions.workerSrc="~/Scripts/pdf.worker.min.js"></script>
<script type="text/javascript">
    //var newfilesize = 20480;
    var newfilesize = 5120;
    function googleTranslateElementInit() {
        new google.translate.TranslateElement({ pageLanguage: 'en', includedLanguages: 'bn,en,gu,hi,kn,ml,mr,pa,ta,te,ur,ne', layout: google.translate.TranslateElement.InlineLayout.HORIZONTAL }, 'google_translate_element');
    }
</script>
<section id="header">
    <div class="container-main">
        <div class="text-left">
            <h2 class="ctitle" style="margin-top:0;">OCR Converter </h2>
        </div>
    </div>
</section>
<style>
    .progress-container {
        width: 100%;
        height: 10px;
        background-color: #E9EAEB;
        border-radius: 6px;
        margin-top: 5px;
        position: relative;
    }

    /* The colored portion of the progress bar */
    .progress-bar {
        height: 100%;
        background-color: #0369A1; /* Adjust color as needed */
        border-radius: 6px;
        width: 0; /* Start at 0% width */
        transition: width 0.3s ease-in-out;
    }

    /* Optional text styling */
    #quotaText {
        font-family: Arial, sans-serif;
        font-size: 14px;
    }

    .progressbarcontainer {
        list-style-type: none;
        border: 1px solid #E9EAEB;
        border-radius: 8px;
        padding: 4px;
        overflow: hidden;
        width: 450px;
    }

        .progressbarcontainer li {
            float: left;
            width: 100%;
        }

    .btn-with-progress {
        display: flex;
        justify-content: space-between;
        align-items: center;
        column-gap: 16px;
    }

        .btn-with-progress .progressbarcontainer.pull-right {
            width: 100%;
        }
</style>
<section style="margin:20px 0;">
    <div class="container-main" style="display: flex; gap: 20px;">

        <!-- LEFT: OCR History Sidebar -->
        <aside style="width: 220px; border: 1px solid #E9EAEB; background-color: #FAFAFA; height: 100vh; overflow-y: auto; padding: 15px; box-sizing: border-box;">
            <h4 style="font-weight: 800; margin-bottom: 15px; display: flex; align-items: center; gap: 8px; color: #0369A1;">
                <i class="bi bi-clock-history"></i> OCR History
            </h4>

            <!-- Search Input -->
            <input type="text" id="ocrSearch" placeholder="Search by filename..." style="width: 100%; padding: 6px 10px; margin-bottom: 15px; border: 1px solid #ccc; border-radius: 4px;" onkeyup="filterOCRHistory()" />

            <!-- History Items Grouped by Date -->
            <div id="ocrHistory" style="font-size: 12px;">
                <!-- JS will populate it -->
            </div>
            <p id="noOcrMessage" style="color: #999; font-style: italic; display: none;; font-size: 18px;">No OCR generated...</p>
        </aside>

        <!-- RIGHT: Upload & OCR Document -->
        <main style="flex-grow: 1; display: flex; flex-direction: column; gap: 20px;">

            <!-- Upload Controls -->
            <div class="row align-items-center" style="margin-bottom: 20px;">
                <h4 style="font-weight: 800; margin-bottom: 15px; margin-left: 25px; display: flex; align-items: center; gap: 8px; color: #0369A1;">
                    <i class="bi bi-file-earmark-text me-2 fs-5"></i> Upload & OCR Document
                </h4>
                <div class="col-md col-lg-6">
                    <div class="input-group d-flex align-items-center">
                        <div class="upload-buttons" style="padding-top:7px; display: flex; gap: 10px;">
                            <label title="No file chosen" class="upload-btn browsetaskfile browsetaskfile1" id="browsefileocrTab1" module="ocr" style="width: 145px; cursor: pointer; border: 1px solid #ccc; padding: 6px 10px; border-radius: 4px;" onclick="onMyKasePickedTab1(event)">
                                <i class="fa fa-upload me-1"></i> <span> MyKase Drive</span>
                            </label>
                            <input type="file" id="attachmentDriveTab1" class="postedFile" accept=".pdf,.jpeg,.jpg,.png,.gif,.bmp,.webp,.tiff,.tif" style="display:none;" onchange="fileValidationTab1()" />
                        </div>

                        <input type="text" class="form-control" id="selectedFileNameTab1" placeholder="No file chosen" readonly style="width: 520px; border-radius: 4px; margin-left: 10px;" />

                    </div>
                    <div id="mkFileListTab1" style="margin-top:8px;"></div>
                </div>

                <div class="col-md col-lg-6">
                    <div class="btn-with-progress">

                        <div class="btn-group-ocr d-flex justify-content-end" style="gap: 15px;">
                            <button type="button" class="btn btn-primary" id="savecasefilenew">Convert Document</button>
                        </div>



                        <ul class="progressbarcontainer pull-right w-100">
                            <li><div id="quotaText"></div></li>
                            <li>
                                <div class="progress-container">
                                    <div id="progressBar1" class="progress-bar"></div>
                                </div>
                            </li>
                        </ul>

                    </div>
                </div>

            </div>
            <!-- Preview Sections side-by-side -->
            <div class="compareDoc">
                <div class="col-md-6">

                    <!-- Upload Preview -->
                    <div class="card-header bg-light fw-semibold border-r" style="padding: 10px 15px; background: lightgrey; font-weight: 800;">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-file-earmark-text me-2 fs-5" style="font-size: 16px;"></i>
                            <span style="font-size: 16px;">File Preview</span>
                        </div>
                    </div>

                    <div class="compare_screen" id="uploadSectionTab1" style="position: relative; height: 636px; border: 1px solid #E9EAEB; background-color: #FAFAFA;">
                        <div id="uploadUIBlockTab1" style="height:636px; overflow-y:auto;">
                            <div class="nofound_inner" style="text-align: center; margin: 50px auto 0; margin-top: 247px;">
                                <img src="/newassets/img/cloud_no.svg" />
                                <h3 style="font-size: 16px; font-weight: 600; color: #181D27; margin:0;">No Documents Added</h3>
                                <p style="font-size: 14px; font-weight: 400; color: #535862; margin:0;">
                                    Upload documents to start the OCR process and<br />extract text.
                                </p>
                            </div>
                        </div>

                        <iframe id="ocrPreviewFrameTab1" style="
            display: none;
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            border: none;
            background: #fff;
            z-index: 5;">
                        </iframe>
                        <div id="ocrPreviewContainerTab1" class="mt-3"></div>
                    </div>
                </div>

                <!-- OCR Result Preview -->
                <div class="col-md-6">
                    <div class="card-header d-flex justify-content-between align-items-left" style="padding: 10px 15px; background: #0369A1; font-weight: 800; color: white; flex-wrap: nowrap;">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-robot me-2 fs-5"></i>
                            <span style="font-size: 16px;">AI Generated OCR</span>
                            <div class="d-flex align-items-center" style="gap: 15px;">
                                <i title="Print" id="aiGeneratedOCRPrint" data-bs-toggle="modal" data-bs-target="#printModal" class="bi bi-printer cursor-pointer" style="cursor: pointer; font-size: 16px;"></i>
                                <i id="aiGeneratedWordFile" class="bi bi-file-word cursor-pointer" aria-hidden="true" style="font-size:16px;cursor: pointer;" title="Download as Word"></i>
                                <i title="Email" id="aiGeneratedOCREmail" data-bs-toggle="modal" data-bs-target="#emailModal" class="bi bi-envelope cursor-pointer" style="cursor: pointer; font-size: 16px;"></i>
                                <i title="Download" id="aiGeneratedOCRDownload" class="bi bi-download cursor-pointer" style="cursor: pointer; font-size: 16px;"></i>
                            </div>
                        </div>
                    </div>

                    <div class="compare_screen" style="position: relative; height: 636px; overflow-y: auto;">
                        <div id="notFoundSectionTab1" style="height:634px; overflow-y:auto;">
                            <div class="nofound_inner" style="text-align: center; margin: 50px auto 0; margin-top: 247px;">
                                <img src="~/newassets/img/cloud_no.svg" />
                                <h3 style="font-size: 16px; font-weight: 600; color: #181D27; margin:0;">No Documents Added</h3>
                                <p style="font-size: 14px; font-weight: 400; color: #535862; margin:0;">
                                    Upload documents to start the OCR process and<br />extract text.
                                </p>
                            </div>
                        </div>

                        <iframe id="previewIframeTab1" style="
                        display: none;
                        position: absolute;
                        top: 0; left: 0;
                        width: 100%; height: 100%;
                        border: none;
                        background: #fff;
                        z-index: 0;">
                        </iframe>

                    </div>                        <div id="divOCRContentTab1" class="divOCRContent"></div>

                </div>

            </div>
        </main>

    </div>
</section>

