                    </div>
                </fieldset>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="form-section-bordered">
                    <div class="form-group form-horizontal">
                        <label class="control-label col-md-2"><b>Description</b></label>
                        <div class="col-md-8">
                            <label class="control-label" id="details"></label>
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-md-2"><b>Location</b></label>
                        <div class="col-md-4">
                            <label class="control-label" id="location"></label>
                        </div>
                    </div>
                    <div class="form-group form-horizontal" style="display:none">
                        <label class="control-label col-md-2"><b>Color</b></label>
                        <div class="col-md-4">
                            <label class="control-label" id="color"></label>
                        </div>
                    </div>
                    <div class="form-group form-horizontal" style="display:none">
                        <label class="control-label col-md-2"><b>Priority</b></label>
                        <div class="col-md-4">
