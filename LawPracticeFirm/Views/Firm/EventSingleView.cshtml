                        <label class="control-label col-md-2"><b>Status</b></label>
                        <div class="col-md-4">
                            <label class="control-label" id="status"></label>
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-md-2"><b>Start</b></label>
                        <div class="col-md-4">
                            <label class="control-label" id="start"></label>
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-md-2"><b>End</b></label>
