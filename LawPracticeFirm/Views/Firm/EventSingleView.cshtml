        </div>
    </section>
    <!-- /.content -->
</aside>
<!-- Modal -->
<div id="myModaldocs" class="modal fade myModal " role="dialog" data-backdrop="static">
    <div class="modal-dialog modal-lg">
        <!-- Modal content-->
        <div class="modal-content mymodels12" id="mymodels">
        </div>
    </div>
</div>
<div id="myOverlay" class="overlay">
    <div class="overlay-content">
        <div class="spinner2">
            <div><img src="~/newassets/images/MyKase_Loader.gif" height="59" width="150"></div>
        </div>
    </div>
</div>
<script src='https://cdnjs.cloudflare.com/ajax/libs/jquery/2.1.3/jquery.min.js'></script>
<script>
    function openload1() {
        $('#myOverlay').css("display", "block");
    }
    function closeload1() {
        $('#myOverlay').css("display", "none");
    }
    $('#modelNote').click(function (e) {
        openload1();
        var url = "/firm/ConfigEventEdit?data=true&token=" + id;
        localStorage.setItem("tempeventid", id);
        $('.mymodels').load(url, function (result) {
            closeload1();
            $('#myModal').modal({ show: true });
        });
    });
</script>