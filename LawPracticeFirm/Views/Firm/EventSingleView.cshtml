@{
    ViewBag.Title = "EventSingleView";
    Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
}
@{
    var id = ViewBag.token;
}
<script>
    var id="@id";
</script>
<script type='text/javascript'>
    if (String(id) != "") {
        localStorage.setItem("contacttoken", id);
    }
    if (String(id) == "") {
        var urls = window.location.href;
        url_redirect({
            url: urls,
            method: "post",
            data: { "token": localStorage.getItem("contacttoken") }
        });
    }
    function goodbye(e) {
        localStorage.setItem("contacttoken", id);
        if (!e) e = window.event;
        //e.cancelBubble is supported by IE - this will kill the bubbling process.
        e.cancelBubble = true;
        //  e.returnValue = 'You sure you want to leave?'; //This is displayed on the dialog
        //e.stopPropagation works in Firefox.
        if (e.stopPropagation) {
            e.stopPropagation();
            e.preventDefault();
        }
    }
    window.onbeforeunload = goodbye;
</script>
<style>
    .form-horizontal .control-label {
        max-width: 100%;
    }
</style>
<script src="~/Scripts/Firm/Pages/EventSingleView.js"></script>
<script>
    $(document).on("click", "#print1", function () {
        window.print();
    });
</script>
<aside class="right-side">
    <!-- Content Header (Page header) -->
    <section class="note">
        @{
            var firmcode = Request.Url.Segments[1];
            firmcode = firmcode.Replace("/", "");
        }
        <div class="col-md-12">
            <ol class="breadcrumb" id="sectionbrud">
                <li><i class="fa fa-calendar" aria-hidden="true"></i></li>
                <li><span>Event</span> - <span id="taskname"></span></li>
                <li><a href="/@firmcode/Firm/activities/">Activities List</a></li>
                <li> <a class="dropdown-item " href="#" data-toggle="modal" data-target="#myModal" id="modelNote">  <i class="fa fa-pencil"></i> Edit</a></li>
                <li>
                    <btn class=" " id="print1" title="Print" style="margin-left:15px; cursor:pointer"><span class="glyphicon glyphicon-print" style="color:darkorange"></span> </btn>
                </li>
            </ol>
        </div>
    </section>
    <section class="status">
        <div class="col-md-12">
            <div class="row">
                <div class="col-md-4">
                    <div class="get-started-action action-complete bg-blue">
                        <div class="icon"><i class="fa fa-clock-o" style="color:#ffffff;"></i></div>
                        <div class="text">START - <span id="starth"></span></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="get-started-action action-complete bg-blue">
