                    </div>
                    <div class="form-group form-horizontal" style="display:none">
                        <label class="control-label col-md-2"><b>Contact</b></label>
                        <div class="col-md-4">
                            <label class="control-label" id="assigncontact"></label>
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-md-2"><b>Tags</b></label>
                        <div class="col-md-4">
                            <label class="control-label" id="tags"></label>
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-md-2"><b>Attachments</b></label>
                        <div class="col-md-4">
                            <a href="#" id="alink">Attached File</a>
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-md-2"><b>Email  Assignees</b></label>
                        <div class="col-md-4">
