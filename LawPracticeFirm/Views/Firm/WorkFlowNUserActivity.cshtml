@{
    ViewBag.Title = "WorkFlowNUserActivity";
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_ManuPanelPartialclient.cshtml";
    }
}
<script src="~/Manupanel/pnotify/pnotify.custom.min.js"></script>
<link href="~/Manupanel/pnotify/pnotify.custom.min.css" rel="stylesheet" />
<link href="~/Manupanel/validation/screen.css" rel="stylesheet" />
<style>
    .Collapseheader {
        font-size: 12px;
        padding: 4px !important;
        background-color: #204d74;
    }

    table {
        font-family: arial, sans-serif;
        border-collapse: collapse;
        width: 100%;
        background: #5c5c5c !important;
        border: 1px solid #5c5c5c;
    }

    td, th {
        border: 1px solid #dddddd;
        text-align: left;
        padding: 8px;
    }

    tr:nth-child(even) {
        background-color: #dddddd;
    }
</style>
<!-- DataTables Responsive CSS -->
<link href="~/panelDesign/vendor/datatables-responsive/dataTables.responsive.css" rel="stylesheet">
<script src="~/Scripts/Firm/Pages/WorkFlowNUserActivity.js" type="text/javascript"></script>
<script>
    $(document).on("click", "#Updatestatus", function () {
        var strid = $(this).attr("updatestatid");
        var tskid = $(this).attr("updatetaskid");
        localStorage.setItem("taskid", tskid);
        localStorage.setItem("stgid", strid);
        var fcode = localStorage.getItem("FirmCode");
        var url = '/' + fcode + '/Firm/WorkFlowNStatus/' + strid;
        $('.mymodels').load(url, function () {
            $('#myModal1').modal('show');
        });
    });
    function openfrmswin(strfrmid, strstage, strtskid, stageid, formid, wfid) {
        var fcode = localStorage.getItem("FirmCode");
        localStorage.setItem("taskid", strtskid);
        localStorage.setItem("stgid", stageid);
        if (strstage == "1") {
            var urls = "/" + fcode + "/Firm/LivePagePreview";
            url_redirect({
                url: urls,
                method: "post",
                data: { "wftoken": wfid, "ftoken": formid }
            });
        }
        else if (strstage == "2") {
            var urls = "/" + fcode + "/Firm/CustomForm";
            url_redirect({
                url: urls,
                method: "post",
                data: { "wftoken": wfid, "ftoken": formid }
            });
        }
        else if (strstage == "3") {
            var urls = "/" + fcode + "/Firm/CustomFormdownload";
            url_redirect({
                url: urls,
                method: "post",
                data: { "wftoken": wfid, "ftoken": formid }
            });
        }
        else if (strstage == "4") {
            var urls = "/" + fcode + "/Firm/CustomFormSendmail";
            url_redirect({
                url: urls,
                method: "post",
                data: {}
            });
        }
    }
</script>
<aside class="right-side">
    <section class="content-header">
        <!-- Content Header (Page header) -->
        <ol class="breadcrumb">
            @if (role.ToString() == "1")
            {
                <li><a href="/@Session["firmcode"]/firm/dashboard"><i class="fa fa-dashboard"></i> Home</a></li>
            }
            else if (role.ToString() == "2")
            {
                <li><a href="/@Session["firmcode"]/employee/dashboard"><i class="fa fa-dashboard"></i> Home</a></li>
            }
            else
            {
                <li><a href="/@Session["firmcode"]/client/dashboard"><i class="fa fa-dashboard"></i> Home</a></li>
            }
            <li class="active">WorkFlow Task</li>
        </ol>
        <h1><span class="fa fa-cubes"></span> WorkFlow Task</h1>
    </section>
    <section class="content">
        <form id="frmtsklist">
            <section class="content-header">
                <div id="wfdata" style="overflow-x:auto"></div>
            </section>
            <!-- Modal -->
            <div id="myModal1" class="modal fade myModal" role="dialog" data-backdrop="static">
                <div class="modal-dialog modal-lg">
                    <!-- Modal content-->
                    <div class="modal-content mymodels" id="mymodels">
                    </div>
                </div>
            </div>
        </form>
</aside>
