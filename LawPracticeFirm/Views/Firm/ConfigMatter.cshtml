<script src="/CssJsfiles/js/bootstrap3-typeahead.min.js"></script>
<script type="text/javascript">
    var nusername = "";
    var npassword = "";
    $('.hspass').hide();
    $('#lduser').on('keypress', function () {
        //code to be executed
    }).on('keydown', function (e) {
        $("#clientname").val("");
        if (e.keyCode == 8)
            $("#username").removeAttr("disabled").val("");
        $("#npassword").removeAttr("disabled").val("");
        $("#cpassword").removeAttr("disabled").val("");
        $('#leadid').val("");
        $('.hspass').hide();
    });
    $(function () {
        $("#lduser").typeahead({
            hint: true,
            highlight: true,
            minLength: 1,
            source: function (request, response) {
                $.ajax({
                    async: true,
                    url: '/Firm/Leaduser',
                    data: "{ 'prefix': '" + request + "'}",
                    dataType: "json",
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    success: function (data) {
                        items = [];
                        map = {};
                        $.each(data, function (i, item) {
                            var id = item.val;
                            var name = item.label;
                            map[name] = { id: id, name: name };
                            items.push(name);
                        });
                        response(items);
                        $(".dropdown-menu").css("height", "auto");
                    },
                    error: function (response) {
                        alert(response.responseText);
                    },
                    failure: function (response) {
                        alert(response.responseText);
                    }
                });
            },
            updater: function (item) {
                if (map[item].id != null) {
                    $('#leadid').val(map[item].id);
                    $('.hspass').show();
                }
                else {
                    $('.hspass').hide();
                    $('#leadid').val("");
                }
                request = map[item].id;
                $.ajax({
                    async: true,
                    url: '/Firm/LeadUserListlogin',
                    data: "{ 'prefix': '" + request + "'}",
                    dataType: "json",
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    success: function (data) {
                        if (data != "null") {
                            $.each(data, function (i, item) {
                                nusername = item.username;
                                npassword = item.password;
                            });
                            $("#username").val(nusername).prop("disabled", true);
                            $("#npassword").val(npassword).prop("disabled", true);
                            $("#cpassword").val(npassword).prop("disabled", true);
                        }
                        else {
                            $("#username").removeAttr("disabled").val("");
                            $("#npassword").removeAttr("disabled").val("");
                            $("#cpassword").removeAttr("disabled").val("");
                        }
                    },
                    error: function (response) {
                        alert(response.responseText);
                    },
                    failure: function (response) {
                        alert(response.responseText);
                    }
                });
                return item;
            }
        });
    });
</script>
