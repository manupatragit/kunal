<style>

    .caseinfo {
        border: 1px solid rgb(143, 213, 0);
        padding: 4px;
        width: 360px;
        height: auto;
        font-size: 12px;
        position: absolute;
        z-index: 9000;
        background: white;
        word-break: break-all;
    }

    #opencasewatchusermodal {
        cursor: pointer;
    }

    .glyphicon-book, .glyphicon-trash, .glyphicon-pencil {
        color: black !important;
    }

    .trcolor {
        background: #f5c9c9 !important;
    }

        .trcolor td {
            background-color: transparent !important;
        }

    .Border_Modal {
        position: relative;
        border: 1px solid #71768073;
        padding: 20px;
        margin: 22px auto 12px auto;
        border-radius: 7px;
    }

    .top-Modal-border-text {
        position: absolute;
        top: -15px; /* Adjust to move text above the border */
        left: 20px; /* Adjust text position */
        padding: 0 10px;
        font-weight: bold;
        background-color: white;
        color: gray;
    }

    .notfound {
        text-align: center;
        width: 320px;
        margin: 0 auto;
    }

        .notfound h4 {
            font-size: 16px;
            font-weight: 600;
            color: #1F2937;
            margin: 0;
        }

        .notfound p {
            font-size: 13px;
            font-weight: 400;
            color: #1F2937;
            padding: 0;
            margin: 0;
        }

    .Divlabourmatter,
    .Divcommercialmatter {
        display: grid;
        align-items: center;
        grid-template-columns: 1fr 1fr;
        column-gap: 20px;
    }

    /* 6/8/2025 new changes*/

    .modal-content p {
        font-size: 14px;
        font-weight: 400;
    }

    .modal-content .modaltitle h4 {
        font-size: 18px;
        font-weight: 600;
    }

    .scroll-sync-top {
        overflow-x: auto;
        overflow-y: hidden;
        height: 16px;
        background-color: transparent;
        display: none;
    }

    .scroll-top-inner {
        height: 1px;
    }

    .table-scroll-wrapper {
        overflow-x: auto;
        overflow-y: hidden;
        white-space: nowrap;
    }

        .table-scroll-wrapper::-webkit-scrollbar {
            display: none;
        }

    .scroll-sync-top::-webkit-scrollbar {
        height: 8px;
    }

    .table-panel th {
        position: sticky;
        top: 0;
        z-index: auto;
        background-color: #fafafa;
        border-bottom: 1px solid #e5e7eb;
        border-top: 1px solid #e5e7eb;
        box-sizing: border-box;
        height: 44px;
        align-items: center;
        padding: 0px;
        font-size: 12px;
        color: #717680;
        font-weight: 600;
        white-space: nowrap;
    }

        .table-panel th .thbg {
            position: sticky;
            top: 0;
            background-color: #fafafa;
            z-index: auto;
        }

    .tablecontainer {
        max-height: 600px;
        overflow-y: auto;
        position: relative;
    }
