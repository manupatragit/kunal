    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
}
<script>
    var roleids = "@Session["sessionroleid"]";
    var isDelete = "@ViewBag.IsDelete";
    var IsCreate = "@ViewBag.IsCreate";
    var type = 8;
    var ChoiceField = "@ViewBag.ChoiceField";
    var FirmIdss = "@Session["sessionfirmid"]";
    var userid = "@Session["sessionuserid"]";
    var TASLFirmId = '@(System.Configuration.ConfigurationManager.AppSettings["TASL"].ToString())';
    var ShreeClient = '@(System.Configuration.ConfigurationManager.AppSettings["ShreeViewOnly"].ToString())';
    var ShreeClient3nd = '@(System.Configuration.ConfigurationManager.AppSettings["ShreeViewOnly3nd"].ToString())';
    var ShreeClient4nd = '@(System.Configuration.ConfigurationManager.AppSettings["ShreeViewOnly4nd"].ToString())';
    var bridgePermissionView = "@ViewBag.typeClientView";
    var caserediectId = "@ViewBag.CaseRedirect";
    var auserredirect = "@ViewBag.CaseAuser";
    var isRBICustomization = "@ViewBag.RBICustomtype";
    var rbiCaseListApiUrl = (isRBICustomization === "RBICustomtype" && (roleids === "2" || roleids === "3"))
        ? '/api/MatterApi/LoadNewCaseList_RBIAll'
        : '/api/MatterApi/LoadNewCaseList';
