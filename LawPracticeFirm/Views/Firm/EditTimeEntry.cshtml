@{
    Layout = null;
}
<!-- Page Content -->
<script>
    var timeid = "@ViewBag.timeid";
</script>
<link href="~/Manupanel/validation/screen.css" rel="stylesheet" />
<script src="~/Manupanel/validation/jquery.validate.js"></script>
<script src="~/Scripts/Firm/Pages/EditTimeEntry.js"></script>
<script src="~/Manupanel/ckeditor/ckeditor.js"></script>
<script src="~/Manupanel/ckeditor/samples/js/sample.js"></script>
<link href="~/Manupanel/ckeditor/samples/css/sampltes.css" rel="stylesheet" />
<link href="~/Manupanel/ckeditor/samples/toolbarconfigurator/lib/codemirror/neod.css" rel="stylesheet" />
<div class="modal-header btn-primary">
    <button type="button" class="close" id="closemodel" data-dismiss="modal">&times;</button>
    <h4 class="modal-title">
        Edit Entry
    </h4>
</div>
<div class="modal-body " style="height:500px; overflow-y:scroll;">
    <!-- Main content -->
    <form id="savecallform2" enctype="multipart/form-data">
        <!-- Start About boxes -->
        <div class="row">
            <div class="col-md-12">
                <fieldset>
                    <legend>New Time Entry</legend>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-md-3">Subject </label>
                        <div class="col-md-9">
                            <input class="form-control" name="subject" type="text" placeholder="Subject" id="subject" required />
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-md-3">Date <span class="required" aria-required="true">*</span></label>
                        <div class="col-md-9">
                            <input class="form-control" name="dt" type="date" placeholder="Date" id="dt2" required />
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-md-3">Call Duration <span class="required" aria-required="true">*</span></label>
                        <div class="col-md-9">
                            <input class="form-control" name="duration" type="text" required id="duration3" placeholder="Format: 1h 10m 1s" value="0h:0m:0s" />
                        </div>
                    </div>
                    <div class="form-group form-horizontal" style="clear:both;margin-top:10px;">
                        <label class="control-label col-md-3">Description</label>
                        <div class="col-md-8">
                            <textarea id="details1" cols="15" class="valid" aria-invalid="false" style="margin: 0px; width: 484px; height: 93px;"></textarea>
                            <div class="grid-container" style="display:none">
                                <div id="editor">
                                </div>
                                <script>
                                    CKEDITOR.replace('details1', {
                                        toolbar:
                                            [
                                                { name: 'basicstyles', items: ['Bold', 'Italic'] },
                                                { name: 'paragraph', items: ['NumberedList', 'BulletedList'] },
                                                { name: 'tools', items: ['Maximize',] }
                                            ],
                                        height: 80,
                                        width: 350
                                    });
                                </script>
                            </div>
                        </div>
                    </div>
                </fieldset>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <fieldset>
                    <legend>Linked to</legend>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-md-3">Client </label>
                        <div class="col-md-9">
                            <select name="contact" class="form-control" id="contact2">
                                <option value="" selected>Select Client...</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-md-3">Case </label>
                        <div class="col-md-9">
                            <select name="matter" class="form-control" id="matter2">
                                <option value="" selected>Select Case...</option>
                            </select>
                        </div>
                    </div>
                </fieldset>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="modal-footer">
                    <input type="submit" id="savecall" class="btn save" value="save">
                    <button type="button" id="closemodels" class="btn btn-default" data-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
        <!-- /.content -->
    </form>
</div>
<div id="myOverlay21" class="overlay">
    <div class="overlay-content">
        <div class="spinner2">
            <div><img src="~/newassets/images/MyKase_Loader.gif" height="59" width="150"></div>
        </div>
    </div>
</div>