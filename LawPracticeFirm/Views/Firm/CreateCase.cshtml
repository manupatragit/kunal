<script src="/CssJsfiles/js/bootstrap3-typeahead.min.js"></script>
<script type="text/javascript">
    var nusername = "";
    var npassword = "";
    var usertype = "";
    $('.hspass').hide();
    $('#fsidebindcaseclient').on('keyup', function () {
        /* your code here */
        var txtlength = $("#fsidebindcaseclient").val().length;
        if (txtlength > 0) {
            $('#mandtorylead').show();
            $('#nonmandtorylead').hide();
        }
        else {
            $('#nonmandtorylead').show();
            $('#mandtorylead').hide();
            $("#fshortcasemap").val("");
            $("#fcheckclient").val("");
            $("#fcommoncaseloginpanel").hide();
            $("#fcasesideuserid").val("");
            $("#fcasesidepassword").val("");
            $("#fcasesidecpassword").val("");
            $("#fcaseclientcontact").find('option').remove().end().append('<option value="">Select</option>');
            var $select = $("#clientto").selectize();
            var selectize = $select[0].selectize;
            selectize.clear();
            selectize.clearOptions();
        }
    });
    $(".fselectusertype").change(function () {
        $("#fshortcasemap").val("");
        $("#fcheckclient").val("");
        $('#fsidebindcaseclient').val("");
        $("#fcommoncaseloginpanel").hide();
        $("#fcasesideuserid").val("");
        $("#fcasesidepassword").val("");
        $("#fcasesidecpassword").val("");
        $("#fcaseclientcontact").find('option').remove().end().append('<option value="">Select</option>');
        var $select = $("#clientto").selectize();
        var selectize = $select[0].selectize;
        selectize.clear();
        selectize.clearOptions();
    });
    $('#fsidebindcaseclient').on('keyup', function () {
        $("#fcommoncaseloginpanel").hide();
        usertype = $("input[name='fselectusertype']:checked").val();
    }).on('keydown', function (e) {
        $("#fclientname").val("");
        if (e.keyCode == 8)
            $("#fcasesideuserid").val("");
        $("#fcasesidepassword").val("");
        $("#fcasesidecpassword").val("");
    });
    $(function () {
        $("#fsidebindcaseclient").typeahead({
            hint: true,
            highlight: true,
            minLength: 3,
            source: function (request, response) {
                request = request.replace(/"/g, "").replace(/\\/g, "");
                $.ajax({
                    async: true,
                    url: '/Firm/CaseClientCompanyFilterUser',
                    data: "{ 'prefix': '" + request + "','type': '" + usertype + "'}",
                    dataType: "json",
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    success: function (data) {
                        items = [];
                        map = {};
                        $.each(data, function (i, item) {
                            var id = item.val;
                            var name = item.label;
                            var fname = item.fnamelabel;
                            var mname = item.mnamelabel;
                            var lname = item.lnamelabel;
                            var utype = item.utype;
                            var isclient = item.isclient;
                            var CompanyID = item.CompanyID;
                            map[name] = { id: id, name: name, fname: fname, mname: mname, lname: lname, utype: utype, isclient: isclient, CompanyID: CompanyID };
                            items.push(name);
                        });
                        response(items);
                        $(".dropdown-menu").css("height", "auto");
                        $(".typeahead li").removeClass("active");
                    },
                    error: function (response) {
                        alert(response.responseText);
                    },
                    failure: function (response) {
                        alert(response.responseText);
                    }
                });
            },
            updater: function (item) {
                $("#msidebindcaseclient").val(map[item].mname);
                $("#lsidebindcaseclient").val(map[item].lname);
                $("#fshortcasemap").val(map[item].id);
                $("#fcheckclient").val(map[item].isclient);
                if (String(map[item].isclient) == "0") {
                    usertypes = $("input[name='fselectusertype']:checked").val();
                    if (usertype == "user") {
                        if (packmodules == "2" || packmodules == "3") {
                            $("#fcommoncaseloginpanel").show();
                        }
                        else {
                            $("#fcommoncaseloginpanel").hide();
                        }
                    }
                    else {
                        $("#fcommoncaseloginpanel").hide();
                    }
                }
                else {
                    $("#fcommoncaseloginpanel").hide();
                }
                if (map[item].utype == "Company") {
                    requestid = map[item].CompanyID;
                    var formData = new FormData();
                    formData.append("prefix", requestid)
                    $("#fcaseclientcontact").find('option').remove().end().append('<option value="">Select</option>');
                    $.ajax({
                        url: '/api/CallApi/loadcompanycontacts',
                        data: formData,
                        contentType: false,
                        processData: false,
                        type: 'POST',
                        success: function (response) {
                            var $select = $("#clientto").selectize();
                            var selectize = $select[0].selectize;
                            selectize.clear();
                            selectize.clearOptions();
                            var obj = JSON.parse(response.Data);
                            $.each(obj, function (i, a) {
                                var option = '<option value="' + a.val + '" >  ' + a["label"] + '</option>';
                                $("#fcaseclientcontact").append(option);
                                selectize.addOption({ value: a.val, text: a["label"] });
                            }); //End of foreach Loop
                        },
                        error: function (response) {
                            alert(response.responseText);
                        },
                        failure: function (response) {
                            alert(response.responseText);
                        }
                    });
                }
                return map[item].fname;
            }
        });
    });
    $("#clearmember").click(function () {
        var $select = $("#assignto").selectize();
        var selectize = $select[0].selectize;
        selectize.clear();
        selectize.clearOptions();
    });
    $("#teamtype").change(function () {
        var $select = $("#assignto").selectize();
        var selectize = $select[0].selectize;
        selectize.clearOptions();
        var useridytpe = $("#teamtype").val();
        $.ajax({
            async: true,
            url: '/Firm/CaseFilterUser',
            data: "{ 'useridytpe': '" + useridytpe + "'}",
            dataType: "json",
            type: "POST",
            contentType: "application/json; charset=utf-8",
            success: function (response) {
                $.each(response, function (i, a) {
                    if (response.length > 1) {
                        if (a.role != "Partner") {
                            var $select = $("#assignto").selectize();
                            var selectize = $select[0].selectize;
                            selectize.addOption({ value: a.val, text: a["label"] });
                        }
                    }
                    else {
                        var $select = $("#assignto").selectize();
                        var selectize = $select[0].selectize;
                        selectize.addOption({ value: a.val, text: a["label"] });
                    }

                }); //End of foreach Loop
            },
            error: function (response) {
                alert(response.responseText);
            },
            failure: function (response) {
                alert(response.responseText);
            }
        });
    });
</script>
