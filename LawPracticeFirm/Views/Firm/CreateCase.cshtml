<script>
    $(document).on('keypress', '#OppositePartyCounselphone,#fCourtfee,#fPhone', function (event) {
        var regex = new RegExp("^[0-9]+$");
        var key = String.fromCharCode(!event.charCode ? event.which : event.charCode);
        if (!regex.test(key)) {
            event.preventDefault();
            return false;
        }
    });
</script>
