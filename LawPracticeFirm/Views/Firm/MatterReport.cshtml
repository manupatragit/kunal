
@{
    Layout = null;
    var role = Session["sessionroleid"];
}
<script src="~/Scripts/Firm/Pages/MatterReport.js?10.2"></script>
<script>
    var roleids = "@Session["sessionroleid"]";
</script>
<style>


    a.morelink {
        text-decoration: none;
        outline: none;
    }

    .morecontent span {
        display: none;
    }

    a.morelink, a.imorelink, a.dmorelink, a.omorelink {
        text-decoration: none;
        outline: none;
    }

    .morecontent span, .imorecontent span, .dmorecontent span, .omorecontent span {
        display: none;
    }
</style>
<section class="wrapper">
    <div class="row" style="margin-bottom:15px;">
        <div class="col-md-4"></div>

        <div class="col-md-2">
            <input checked type="radio" id="rdadded" name="rdadded" onclick="fn_IsAddedMatter(1);"> &nbsp;&nbsp;Added

        </div>
        <div class="col-md-2">
            <input type="radio" id="rdassigned" name="rdadded" onclick="fn_IsAddedMatter(0);"> &nbsp;&nbsp;Assigned
        </div>
        <div class="col-md-4"></div>
    </div>
  
  <div class="ec_bg">
    <div class="row">


        <input type="hidden" id="hdnisaddedval" value="1" />
        <div class="col-md-3">
            <label class="formLabel colorDark">User</label>
            @if (role.ToString() == "1")
            {
                <select class="form-control selctInputFormat" style="background-color: white !important;" id="ddlExpUser" name="ddlExpUser"></select>
            }
            else
            {
                <span style="display:none" id="ddlExpUser" name="ddlExpUser"></span>
            }
        </div>
        <div class="col-md-3" style="display:none">
            <label class="formLabel colorDark">Matter Type</label>
            <select class="form-control col_b selctInputFormat" style="background-color: white !important;" id="rptmfmattertype"></select>
        </div>
        <div class="col-md-3">
            <label class="formLabel colorDark">Matter Name</label>
            <input type="text" id="casefiltercasename" placeholder="Matter Name" class="form-control inputFormat">


        </div>
        <div class="col-md-3" style="display:none">
           
            <label class="formLabel colorDark">Case Type</label>
            <select id="ddlCasetype" class="form-control col_b selctInputFormat" style="background-color: white !important;">
                <option value="" selected="">Select</option>
                <option value="Original">Original</option>
                <option value="Appeal">Appeal</option>
                <option value="Application">Application</option>
            </select>
        </div>
        <div class="col-md-3" style="display:none">
            <label class="formLabel colorDark">Subject Type</label>
            <select class="form-control selctInputFormat" style="background-color: white !important;" id="rptmfcasecasetype"></select>
        </div>
        <div class="col-md-3">
            <label class="formLabel colorDark">Status</label>
            <select class="form-control selctInputFormat" style="background-color: white !important;" id="rptmfcasestatus"></select>
        </div>
        <div class="col-md-3">
            <label class="formLabel colorDark">Court</label>
            <select class="form-control col_b selctInputFormat" style="background-color: white !important;" id="rptmcasefiltercourt">
                <option value="" selected="">Select</option>
                <option value="Supreme Court">Supreme Court</option>
                <option value="High Court">High Court</option>
                <option value="District Court">District Court</option>
                <option value="Tribunals">Tribunals</option>
            </select>
        </div>
    </div>
        <div class="row" style="padding:10px 0 0 0;">
            
          
            <div class="col-md-3">
                <label class="formLabel colorDark">Start</label>
                <input class="form-control inputFormat" id="datefrom" onkeypress="return false;" type="date">
            </div>
            <div class="col-md-3">
                <label class="formLabel colorDark">End</label>
                <input class="form-control inputFormat" id="dateto" onkeypress="return false;" type="date">
            </div>
            <div class="col-md-2">
                <button type="button" id="searchdatas" class="sbtbtn" style="margin:27px 0 0 0;">Search</button>
            </div>


        </div>
        </div>

</section>


<div class="table-panel table-responsive">
    <div style="overflow-x:scroll;">
        <table id="example" class="table ">
            <thead>
                <tr>
                    <th class="casestartdate">
                        <div class="thbg">
                        Date
                        <div>
                    </th>
                    <th class="casecasename">
                        <div class="thbg">
                       Matter Name
                        @*<span class="glyphicon glyphicon-search" id="searchdatas"></span>*@
                        <div>
                    </th>

                    <th class="caseclientname">
                        <div class="thbg">
                        Client Name
                        <div>
                    </th>
                    <th class="companyname"><div class="thbg">Company<div></th>
                    <th class="casecourtname"><div class="thbg">
                        Court
                        <div>
                    </th>
                    <th class="casecasedetails"><div class="thbg">
                        Court Hearing
                        <div>
                    </th>
                    <th class="casestatus"><div class="thbg">
                        Status
                        <div>

                    </th>
                    <th class="casecreatedby"><div class="thbg">
                        Created By
                        <div>
                    </th>
                    <th class="caseteammembers"><div class="thbg">
                        Team Members
                         <div></div>
                    </th>

                    <th class="caseclientcontact"><div class="thbg">
                        ClientContact
                        <div>
                    </th>

                    <th class="MatterType"><div class="thbg">
                        Matter Type
                        <div>
                    </th>
                    <th class="CertifiedCopyAppliedon"><div class="thbg">
                        Copy Applied On
                        <div>
                    </th>
                    <th class="CertifiedCopyReceivedon"><div class="thbg">
                        Copy Received On
                        <div>
                    </th>
                    <th class="ValuationofSuit"><div class="thbg">
                        Valuation of Suit
                        <div>
                    </th>
                    <th class="Courtfee"><div class="thbg">
