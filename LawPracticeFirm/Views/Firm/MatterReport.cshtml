                                    <li><input type="checkbox" class="shcheckbox1 chkdhide" name="casecourtname" checked><a href="#" class="dropdown-item">Court</a></li>
                                    <li class="casecasedetails1"><input type="checkbox" class="shcheckbox1 chkdhide" name="casecasedetails" checked><a href="#" class="dropdown-item">Court Hearing</a></liclass="casecasedetails">
