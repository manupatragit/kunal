                                    <li><input type="checkbox" class="shcheckbox1 chkdhide" name="caseclientcontact"><a href="#" class="dropdown-item">ClientContact</a></li>

                                    <li><input type="checkbox" class="shcheckbox1 chkdhide" name="MatterType"><a href="#" class="dropdown-item">Matter Type</a></li>
                                    <li><input type="checkbox" class="shcheckbox1 chkdhide" name="CertifiedCopyAppliedon"><a href="#" class="dropdown-item">Copy Applied On</a></li>
                                    <li><input type="checkbox" class="shcheckbox1 chkdhide" name="CertifiedCopyReceivedon"><a href="#" class="dropdown-item">Copy Received On</a></li>
                                    <li><input type="checkbox" class="shcheckbox1 chkdhide" name="ValuationofSuit"><a href="#" class="dropdown-item">Valuation of Suit</a></li>
                                    <li><input type="checkbox" class="shcheckbox1 chkdhide" name="Courtfee"><a href="#" class="dropdown-item">Court Fee</a></li>
                                    <li><input type="checkbox" class="shcheckbox1 chkdhide" name="OppositePartyCounselname"><a href="#" class="dropdown-item">PartyCounsel Name</a></li>
                                    <li><input type="checkbox" class="shcheckbox1 chkdhide" name="OppositePartyCounselemail"><a href="#" class="dropdown-item">PartyCounsel Email</a></li>
                                    <li><input type="checkbox" class="shcheckbox1 chkdhide" name="OppositePartyCounselphone"><a href="#" class="dropdown-item">PartyCounsel Phone</a></li>
                                    <li><input type="checkbox" class="shcheckbox1 chkdhide" name="CasenumberInternal"><a href="#" class="dropdown-item">Matter Number Internal</a></li>
                                    @* <li><input type="checkbox" class="shcheckbox1 chkdhide" name="IsCourtFeePaid"><a href="#" class="dropdown-item">IsCourtFeePaid</a></li>*@
                                    <li><input type="checkbox" class="shcheckbox1 chkdhide" name="PoliceStation"><a href="#" class="dropdown-item">Police Station</a></li>
                                    <li><input type="checkbox" class="shcheckbox1 chkdhide" name="FIRNo"><a href="#" class="dropdown-item">FIR No</a></li>


