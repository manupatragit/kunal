                                </ul>
                            </div>
                        </li>
                    </ul>
                </div>
                <div id="casetfooter"></div>
            </div>
            <div class="col-md-6">
                <ul class="pull-right">


                    @if (role.ToString() == "1")
                    {

                        <li>
                            <select id="filtercaseuser" class="form-control" style=" display:none; border-bottom: 1px solid #ccc !important;">
                                <option value="" selected>Select User </option>
                            </select>
                        </li>

                    }
                    else
                    {
                        <input type="text" id="filtercaseuser" style="display:none">

                    }


                    <li>
                        <div class="btn-group dropup">
                            <a href="javascript:void()" class=" dropdown-toggle form-control selctInputFormat " style="background-color: #ebebeb !important;" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                Action Selected
                            </a>
                            <ul class="dropdown-menu settingaction">
                                <li><a href="javascript:void()" id="oexcel" title="export to excel"> export to excel</a></li>
