                        <div>
                    </th>

                    <th class="caseclosedate"><div class="thbg">
                        Close Date
                        <div>
                    </th>

                    <th class="linkedcase"><div class="thbg">
                        Linked Matter
                        <div>
                    </th>
                </tr>
            </thead>
            <tbody id="bindcasedata"></tbody>
        </table>
    </div>
    <div id="pdatastatus"></div>
    <div class="table-panel">
        <div class="settingpanel">
