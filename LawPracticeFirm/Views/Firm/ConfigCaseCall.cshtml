@{
    Layout = null;
    var role = Session["sessionroleid"];
}
<!-- Page Content -->
<link href="~/Manupanel/validation/screen.css" rel="stylesheet" />
<script src="~/Manupanel/validation/jquery.validate.js"></script>
<script src="~/Content/multipleselect/selectize.js"></script>
<script src="~/Content/multipleselect/index.js"></script>
<link href="~/Content/multipleselect/dist/css/selectize.bootstrap2.css" rel="stylesheet" />
<link href="~/Content/multipleselect/dist/css/jquery.magicsearch.min.css" rel="stylesheet" />
<script src="~/Scripts/Firm/Pages/ConfigCaseCall.js"></script>
<script src="~/Manupanel/ckeditor/ckeditor.js"></script>
<script src="~/Manupanel/ckeditor/samples/js/sample.js"></script>
<script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
<link href="~/Manupanel/jquerydatetimepicker/jquery.datetimepicker.css" rel="stylesheet" />
<script src="~/Manupanel/jquerydatetimepicker/jquery.datetimepicker.js"></script>
<script type="text/javascript">
    $(document).ready(function () {
        $('#dt').datetimepicker();
    });
     var filesize =@ViewBag.filesize;
    var roleid = "@role";
</script>
<style>
    .selectize-dropdown {
        position: unset !important;
    }
</style>

<div class="modal-body ">
    <!-- Main content -->
    <form id="savecallform" enctype="multipart/form-data">
        <!-- Start About boxes -->
        <div class="row">
            <div class="col-md-12">
                <fieldset>
                    <legend>Call</legend>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-md-3">Subject <span class="required" aria-required="true">*</span></label>
                        <div class="col-md-9">
                            <input class="form-control" type="text" required id="subject" placeholder="Add Subject..." />
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-md-3">Call Type</label>
                        <div class="col-md-9">
                            <select name="" class="form-control" id="calltype">
                                <option value="Inbound">Inbound</option>
                                <option value="OutBound">OutBound</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-md-3">Date/Time <span class="required" aria-required="true">*</span></label>
                        <div class="col-md-9">
                            <input class="form-control" name="dt" type="text" placeholder="Date/Time" id="dt" required />
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-md-3">Call Duration <span class="required" aria-required="true">*</span></label>
                        <div class="col-md-9">
                            <input class="form-control" name="duration" type="text" required id="duration" placeholder="Format: 1h 10m 1s" value="0h:0m:0s" />
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-md-3"> </label>
                        <div class="col-md-6">
                            <button id="starttimer" type="button" class="btn save" style="float:left; margin:0 10px 5px 0px;"><span class="glyphicon glyphicon-time"></span>&nbsp;&nbsp;Start Timer</button>
                            <button id="stoptimer" type="button" class="btn save" style="float:left; margin:0 10px 5px 0px;display:none"><span class="glyphicon glyphicon-pause"></span>&nbsp;&nbsp;Stop Timer</button>
                            <div class="timer " id="countdown2">0h:0m:0s</div>
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-md-3">Description</label>
                        <div class="col-md-9">
                            @*<input class="form-control" type="text" id="details" placeholder="Add description..." />*@
                            <textarea ID="details" cols="15"></textarea>
                            <div class="grid-container" style="display:none">
                                <div id="editor">
                                </div>
                                <script>
                                    initSample();
                                    CKEDITOR.replace('details', {
                                        toolbar:
                                            [
                                                { name: 'basicstyles', items: ['Bold', 'Italic'] },
                                                { name: 'paragraph', items: ['NumberedList', 'BulletedList'] },
                                                { name: 'tools', items: ['Maximize',] }
                                            ],
                                        height: 80
                                        // width: 360
                                    });
                                </script>
                            </div>
                        </div>
                    </div>
                </fieldset>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <fieldset>
                    <legend>Participants</legend>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-md-3">User <span class="required" aria-required="true">*</span></label>
                        <div class="col-md-9">
                            @Html.DropDownList("puser", new SelectList(ViewBag.Fruits, "val", "label"), "Select", new { @id = "puser", @class = "demodefault ", @multiple = "multiple" })
                        </div>
                    </div>
                    <div class="form-group form-horizontal" style="display:none">
                        <label class="control-label col-md-3">Contacts <span class="required" aria-required="true">*</span></label>
                        <div class="col-md-9">
                            <select name="" class="form-control" id="pcontact">
                                <option value="">Select Contact...</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-md-3">Tags</label>
                        <div class="col-md-9">
                            <input class="form-control" type="text" id="tags" placeholder="Tags..." />
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-md-3">Attachments</label>
                        <div class="col-md-9">
                            <input class="form-control" name="postedFile" id="postedFile" type="file" multiple placeholder="Add description..." />
                        </div>
                    </div>
                </fieldset>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="modal-footer" style="border-top:0px !important">
                    <input type="submit" id="savecall" class="btn save" value="save">
                </div>
            </div>
        </div>
        <!-- /.content -->
    </form>
</div>
<script>
    $('#puser').selectize({
        //maxItems: 3
    });
</script>
