@{
    /**/
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
}
<i class="pp-icon-user"></i>
<script src="~/CssJsfiles/js/2.02/jquery.min.js"></script>
<!-- Page Content -->
<script src="~/Manupanel/pnotify/pnotify.custom.min.js"></script>
<link href="~/Manupanel/pnotify/pnotify.custom.min.css" rel="stylesheet" />
<script src="~/Scripts/Firm/Pages/EditMailboxsetting.js"></script>
<style>
    table {
        font-family: arial, sans-serif;
        border-collapse: collapse;
        width: 100%;
    }

    td, th {
        border: 1px solid #dddddd;
        text-align: left;
        padding: 8px;
    }

    tr:nth-child(even) {
        background-color: #dddddd;
    }
</style>
<aside class="right-side">
    <section class="content-header">
        <!-- Content Header (Page header) -->
        <ol class="breadcrumb">
            @if (role.ToString() == "1")
            {
                <li><a href="/@Session["firmcode"]/firm/dashboard"><i class="fa fa-dashboard"></i> Home</a></li>
            }
            else if (role.ToString() == "2")
            {
                <li><a href="/@Session["firmcode"]/employee/dashboard"><i class="fa fa-dashboard"></i> Home</a></li>
            }
            <li><a href="/@Session["firmcode"]/firm/Mailbox">Mail Box</a></li>
            <li class="active">Mail Box Setting</li>
        </ol>
        <h1><span class="fa fa-envelope-o"></span>Edit Mail Box Setting</h1>
    </section>
    <script>
          var token = enctypesingle("@ViewBag.token");
        $(document).ready(function () {
            $("#searchdata").on("keyup", function () {
                var value = $("#searchdata").val().toLowerCase();
                $("#mailboxserver tbody tr ").filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });
        });
    </script>
    <section class="content">
        <div id="page-wrapper">
            <div class="container-fluid showcontent" id="showcontent">
                <div class="">
                    <div class="box-header">
                        @*<btn class="btn btn-success pull-right publish" id="publish"><span class="glyphicon glyphicon-plus"></span> Publish Page</btn>*@
                    </div>
                </div>
            </div>
        </div>
    </section>
    <section class="content">
        <form id="fileupload" enctype="multipart/form-data">
            <div class="row">
                <div class="col-lg-12">
                    <div class="row">
                        <div class="col-md-12">
                            <fieldset>
                                <div class="form-group form-horizontal">
                                    <label class="control-label col-md-3">Mail Server Name <span class="required" aria-required="true">*</span></label>
                                    <div class="col-md-4">
                                        <input class="form-control" value="@ViewBag.MailServerName" maxlength="50" type="text" id="mservername" />
                                    </div>
                                </div>
                                <div class="form-group form-horizontal">
                                    <label class="control-label col-md-3">SMTP Server Address <span class="required" aria-required="true">*</span></label>
                                    <div class="col-md-4">
                                        <input class="form-control" value="@ViewBag.SmtpAddress" type="text" id="smtpserver" />
                                    </div>
                                </div>
                                <div class="form-group form-horizontal">
                                    <label class="control-label col-md-3">SMTP Port <span class="required" aria-required="true">*</span></label>
                                    <div class="col-md-4">
                                        <input class="form-control" value="@ViewBag.SmtpPort" maxlength="10" onkeypress="return restrictAlphabets(event)" type="text" id="smtpport" />
                                    </div>
                                </div>
                                <div class="form-group form-horizontal">
                                    <label class="control-label col-md-3">IMAP Server Address <span class="required" aria-required="true">*</span></label>
                                    <div class="col-md-4">
                                        <input class="form-control" value="@ViewBag.ImapAddress" type="text" id="imapserver" />
                                    </div>
                                </div>
                                <div class="form-group form-horizontal">
                                    <label class="control-label col-md-3">IMAP Port <span class="required" aria-required="true">*</span></label>
                                    <div class="col-md-4">
                                        <input class="form-control" value="@ViewBag.ImapPort" maxlength="10" onkeypress="return restrictAlphabets(event)" type="text" id="imapport" />
                                    </div>
                                </div>
                                <div class="form-group form-horizontal">
                                    <label class="control-label col-md-3">POP Server Address <span class="required" aria-required="true">*</span></label>
                                    <div class="col-md-4">
                                        <input class="form-control" value="@ViewBag.PopAddress" type="text" id="popserver" />
                                    </div>
                                </div>
                                <div class="form-group form-horizontal">
                                    <label class="control-label col-md-3">POP Port <span class="required" aria-required="true">*</span></label>
                                    <div class="col-md-4">
                                        <input class="form-control" value="@ViewBag.PopPort" maxlength="10" onkeypress="return restrictAlphabets(event)" type="text" id="popport" />
                                    </div>
                                </div>
                                <div class="form-group form-horizontal">
                                    <label class="control-label col-xs-3"></label>
                                    <div class="col-xs-8">
                                        <button type="button" class="btn btn-success" id="savemailboxsetting">Save</button>
                                    </div>
                                </div>
                            </fieldset>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </section>
</aside>
<div id="myOverlay1" class="overlay">
    <div class="overlay-content">
        <div class="spinner2">
            <div><img src="~/newassets/images/MyKase_Loader.gif" height="59" width="150"></div>
        </div>
    </div>
</div>
