<SCRIPT>
    $(document).ready(function () {
        try {
            var ddlCountry = $('#country');
            $.ajax({
                async: true,
                url: '/api/EmployeeApi/BindCountryDetails',
                type: 'POST',
                dataType: 'json',
                success: function (d) {
                    $.each(d.Data, function (i, country) {
                        ddlCountry.append($("<option></option>").val(country.CountryName).html(country.CountryName));
                    });
                    ddlCountry.append($("<option value='' selected></option>").val('').html('Please Select Country'));
                },
                error: function (d) {
                    alert(d.responseText);
                }
            });
        }
        catch (err) {
            alert(err.message);
        }
        //State details by country id
        $("#country").change(function () {
            var CountryId = $(this).val();
            var ddlState = $('#state');
            ddlState.empty();
            ddlState.append($("<option></option>").val('').html('Please wait ...'));
            $.ajax({
                async: true,
                url: '/api/EmployeeApi/BindStateDetails',
                type: 'POST',
                dataType: 'json',
                headers: { CountryName: CountryId },
                success: function (d) {
                    ddlState.empty();
                    // Clear the please wait
                    if (d.Data != "") {
                        ddlState.append($("<option value='' selected></option>").val('').html('Select the state.'));
                        $.each(d.Data, function (i, states) {
                            ddlState.append($("<option></option>").val(states.StateName).html(states.StateName));
                        });
                        $('#state').show();
                        $('#city').show();
                        $('#txtstate').hide();
                        $('#txtcity').hide();
                    }
                    else {
                        $('#txtstate').show();
                        $('#state').hide();
                        $('#txtcity').show();
                        $('#city').hide();
                    }
                },
                error: function (d) {
                    alert(d.responseText);
                }
            });
        });
        //City Bind By satate id
        $("#state").change(function () {
            var StateId = $(this).val();
            var ddlCity = $('#city');
            ddlCity.append($("<option></option>").val('').html('Please wait ...'));
            debugger;
            $.ajax({
                async: true,
                url: '/api/EmployeeApi/BindCityDetails',
                type: 'POST',
                dataType: 'json',
                headers: { StateName: StateId },
                success: function (d) {
                    ddlCity.empty(); // Clear the plese wait
                    ddlCity.append($("<option value'' selected></option>").val('').html('Select City Name'));
                    $.each(d.Data, function (i, cities) {
                        ddlCity.append($("<option></option>").val(cities.CityName).html(cities.CityName));
                    });
                },
                error: function (d) {
                    alert('Error!'); alert(d.responseText);
                }
            });
        });
    });
</SCRIPT>
<script>
    $(document).ready(function () {
        //get the IP addresses associated with an account
        HomePageData();
    });
    function HomePageData() {
        var pageURL = $(location).attr("href");
        var pathArray = window.location.pathname.split('/');
        var firmcode = pathArray[1];
        $.ajax({
            async: true,
            type: 'POST',
            dataType: 'json',
            headers: { 'firmcode': firmcode },
            url: '/api/WorkFlowNewApi/HomePageData',
            contentType: "application/json; charset=utf-8",
            processData: false,
            success: function (response) {
                if (response.Status == true) {
                    var datas = JSON.stringify(response);
                    var obj = JSON.parse(response.Data);
                    $.each(obj, function (i, val) {
                        $("#heading").html(val.LogoHeading);
                        $("#subheading").html(val.Logotext);
                        $("#aboutus").html(val.Aboutus);
                        $("#services").html(val.Services);
                        $("#lbladdress").text(val.Address);
                        $("#lblphone").text(val.ContactNo);
                        $("#lblemail").text(val.email);
                        $("#website").html(val.website);
                        var imglogopath = "../.." + val.LogoPath;
                        var imglogopath = val.LogoPath;
                        var mykaselogo = "/Manupanel/img/mykase.png";
                        var LogoPosition = val.LogoPosition;
                        if (imglogopath == "") {
                            $("#logo_menu_mobile").hide();
                        }
                        else {
                            $("#logo_menu_mobile").show();
                        }
                        if (String(LogoPosition) == "left") {
                            $("#mykaselogo").attr("src", imglogopath);
                            $("#imglogo").attr("src", mykaselogo);
                            $("#imglogo1").attr("src", mykaselogo);
                        }
                        else {
                            $("#imglogo1").attr("src", imglogopath);
                        }
                        if (val.BackgroundImg == "") { val.BackgroundImg = 1; }
                        var strclass = "/assets/img/c_banner_home" + val.BackgroundImg + ".jpg";
                        document.getElementById("banner").style.backgroundImage = "url(" + strclass + ")";
                    });
                }
                else {
                    alert("not found");
                }
            },
            failure: function (data) {
                alert(data.responseText);
            },
            error: function (data) {
                alert(data.responseText);
            }
        });
    }
</script>
