                                            <th bgcolor="DIMGRAY" width="200px;">Date</th>
                                        </tr>
                                    </thead>
                                    <tbody id="bindalertdata">
                                    </tbody>
                                </table>
                            </div>
                            <div id="footeractivitydata">
                            </div>
                            <center>
                                <button type="button" id="loadmore" dataval="10" style="display: none;margin-top:15px" class="btn btn-default" title="Load more cases">More...</button>
                                <a href="#top" id="gotop" class="label label-default" title="Go to Top" style="float:right;display:none;margin-bottom:20px; margin-top:5px;"><i class="glyphicon glyphicon-arrow-up"></i> Got to Top</a>
                            </center>
                        </div>
                    </div>
                </div>
                <div><center><span id="datastatus"></span></center></div>
                <div class="box-footer clearfix">
                    <ul class="pagination pagination-sm no-margin pull-right"></ul>
                </div>
            </div>
        </div>
    </section>

</aside>
<script src="~/PanelDesign/vendor/bootstrap/js/bootstrap.min.js"></script>
