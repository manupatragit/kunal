@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <title>Extra Party Information</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="~/assets/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500;700&display=swap" rel="stylesheet">
    <link href="~/newassets/css/style.css" rel="stylesheet" />
    <style type="text/css">
        .forprint {
            padding: 10px 0 10px 0;
            font-size: 14px;
            font-weight: 500;
            text-transform: uppercase;
            text-align: center;
        }

        sup {
            font-size: 13px;
            color: red;
            top: -2px;
        }

        .table-panel td {
            font-size: 12px !important;
            font-weight: 400 !important;
            color: #272727 !important;
        }
    </style>
</head>
<body>
    <div class="container showcontent" id="showcontent">
        <div class="row">
            <div style="float:right"><a href="/@Session["firmcode"]/firm/caselist" title="Create new Matter">Go to matters</a> </div>
            <div class="col-md-12">
                <div class="forprint"><u>EXTRA PARTY INFORMATION</u></div>
            </div>
            <div class="col-md-12 table-panel" id="partyinformation">
            </div>
        </div>
    </div>
    <script src="~/assets/js/jquery-2.1.3.min.js"></script>
    <script type="text/javascript">
        function formatDatetoIST(date) {
            if (date == "1900-01-01T00:00:00") {
                return "";
            }
            else {
                const months = ["JAN", "FEB", "MAR", "APR", "MAY", "JUN", "JUL", "AUG", "SEP", "OCT", "NOV", "DEC"];
                let current_datetime = new Date(date)
                let formatted_date = current_datetime.getDate() + " " + months[current_datetime.getMonth()] + " " + current_datetime.getFullYear()
                return formatted_date;
            }
        }
        var caseid = "@ViewBag.token";
    $(document).ready(function () {
        var formData = new FormData();
        formData.append("caseid", caseid);
        $.ajax({
            async: true,
            type: "POST",
            url: "/api/ExtraParty/GetExtraPartyReport",
            dataType: 'json',
            data: formData,
            contentType: false,
            processData: false,
            success: function (response) {
                if (response.Status == true) {
                    var myData = response.Data;
                    var html = "";
                    $.each(myData, function (i, item) {
                        html += "<table class='table table-bordered table-striped' >";
                        html += "<tr>";
                        html += "<td style='width: 3%;' align='center'>1</td>";
                        html += "<td style='width: 17%;'><sup>*</sup>Name of Extra party</td>";
                        html += "<td colspan='4' style='width: %;'>"+item.Name+"</td>";
                        html += "</tr>";
                        html += "<tr>";
                        html += "<td style='width: 3%;' align='center'>2</td>";
                        html += "<td style='width: 17%;'><sup>*</sup>S/o, W/o,D/o</td>";
                        html += "<td colspan='4'>" + item.GuardianName + "</td>";
                        html += "</tr>";
                        html += "<tr>";
                        html += "<td style='width: 3%;' align='center'>3</td>";
                        html += "<td style='width: 17%;'><sup>*</sup>Address</td>";
                        html += "<td colspan='4'>" + item.Address + "</td>";
                        html += "</tr>";
                        html += "<tr>";
                        html += "<td style='width: 3%;' align='center'>4</td>";
                        html += "<td style='width: 17%;'><sup>*</sup>Adhar Card No.</td>";
                        html += "<td colspan='2' style='width: 40%'>" + item.AadharNo + "</td>";
                        html += "<td style='width: 15%;'><sup>*</sup>Gender</td>";
                        html += "<td >" + item.Gender + "</td>";
                        html += "</tr>";
                        html += "<tr>";
                        html += "<td style='width: 3%;' align='center'>5</td>";
                        html += "<td style='width: 17%;'><sup>*</sup>Date of Birth</td>";
                        html += "<td colspan='2' style='width: 40%'>" + formatDatetoIST(item.DOB) + "</td>";
                        html += "<td style='width: 15%;'><sup>*</sup>Nationality</td>";
                        html += "<td colspan='2'>" + item.Nationality + "</td>";
                        html += "</tr>";
                        html += "<tr>";
                        html += "<td style='width: 50px;' align='center'>6</td>";
                        html += "<td style='width: 200px;'><sup>*</sup>MobileNo/<sup>*</sup>Email</td>";
                        html += "<td colspan='2'>" + item.MobileNo + "</td>";
                        html += "<td colspan='2'>" + item.Email + "</td>";
                        html += "</tr>";
                        html += "</table>";
                    });
                    $("#partyinformation").html(html);
                    window.print();
                }
                else {
                    alert("Oops! Something went wrong..");
                }
            },
            failure: function (data) {
                alert(data.responseText);
            },
            error: function (data) {
                alert(data.responseText);
            }
        });
    });
    </script>
</body>
</html>