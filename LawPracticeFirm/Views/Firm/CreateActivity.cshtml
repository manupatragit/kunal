@{
    ViewBag.Title = "Case Subject";
    Layout = null;
}
<!-- Page Content -->
<script src="~/Manupanel/pnotify/pnotify.custom.min.js"></script>
<link href="~/Manupanel/pnotify/pnotify.custom.min.css" rel="stylesheet" />
<script src="~/Manupanel/validation/jquery.validate.js"></script>
<style>
    table {
        font-family: arial, sans-serif;
        border-collapse: collapse;
        width: 100%;
    }

    th {
        border: 1px solid #dddddd;
        text-align: left;
        padding: 8px;
        color: white !important;
        background: rgb(105, 105, 105) !important;
    }

    tr:nth-child(even) {
        background-color: #dddddd;
    }
</style>
<script type="text/javascript">
    function openload() {
        $('#myOverlay').css("display", "unset");
    }
    function closeload() {
        $('#myOverlay').css("display", "none");
    }
    Loadcontacttype();
@*Load contact type details*@
    function Loadcontacttype() {
        var html = '';
        $("#assignuserdata").html("");
        var formData = new FormData();
        //read assign using list
        qty1 = 0;
        openload();
        $.ajax({
            async: true,
            type: "POST",
            url: "/api/CallApi/LoadCustomActivity",
            dataType: 'json',
            data: formData,
            contentType: false,
            processData: false,
            success: function (response1) {
                var datas1 = JSON.stringify(response1);
                var obj = JSON.parse(response1.Data);
                $.each(obj, function (i, a) {
                    qty1 = qty1 + 1;
                    html += '<tr><td class="CustomerId"><span style="display:none">' + a.Id + '</span>' + qty1 + '</td><td class="Name"><span>' + a.ActivityName + '</span> <input type="text" class="form-control" value="' + a.ActivityName + '" style="display:none" /></td><td><a class="Edit btn btn-primary btn-sm" href="javascript:;">Edit</a><a class="Update btn btn-info btn-sm" href="javascript:;" style="display:none">Update</a> <a class="Cancel btn btn-default btn-sm" href="javascript:;" style="display:none">Cancel</a>&nbsp;  <a class="Delete btn btn-danger btn-sm" href="javascript:;">Delete</a></td></tr>';
                });
                $("#assignuserdata").append(html);
                closeload();
                try {
                    bindcontacttype();
                }
                catch (ex) {
                }
            },
            failure: function (data) {
                alert(data.responseText);
                closeload();
            },
            error: function (data) {
                alert(data.responseText);
                closeload();
            }
        });
    }
@*Append row*@
    function AppendRow(row, customerId, name, country) {
        $(".CustomerId", row).find("span").html(customerId);
        $(".Name", row).find("span").html(name);
        $(".Name", row).find("input").val(name);
        row.find(".Edit").show();
        row.find(".Delete").show();
        $("#tblCustomers").append(row);
    };
    //Add event handler.
    $(document).ready(function () {
        $("#btnAdd").click(function () {
            try {
                var formData = new FormData();
                var txtName = $("#txtName").val();
                if (txtName == "") {
                    alert("Please enter activity name");
                    return false;
                }
                formData.append("ActivityName", txtName);
                openload();
                $.ajax({
                    url: '/api/CallApi/InsertCustomActivity',
                    data: formData,
                    contentType: false,
                    processData: false,
                    type: 'POST',
                    success: function (response) {
                        new PNotify({
                            title: 'Success',
                            text: 'Data saved Successfully',
                            type: 'success',
                            delay: 3000
                        });
                        localStorage.setItem("Customactivity1", "1");
                        Loadcontacttype();
                        $("#txtName").val("");
                        closeload();
                        return false;
                    }
                });
            }
            catch (er) {
                alert(er.message);
            }
        });
    });
    //Edit event handler.
    $("body").on("click", "#tblCustomers .Edit", function () {
        var row = $(this).closest("tr");
        $("td", row).each(function () {
            if ($(this).find("input").length > 0) {
                $(this).find("input").show();
                $(this).find("span").hide();
            }
        });
        row.find(".Update").show();
        row.find(".Cancel").show();
        row.find(".Delete").hide();
        $(this).hide();
    });
    //Update event handler.
    $("#tblCustomers").on("click", ".Update", function () {
        var row = $(this).closest("tr");
        $("td", row).each(function () {
            if ($(this).find("input").length > 0) {
                var span = $(this).find("span");
                var input = $(this).find("input");
                span.html(input.val());
                if (row.find(".Name").find("span").html() == "") {
                    return false;
                }
                span.show();
                input.hide();
            }
        });
        if (row.find(".Name").find("span").html() == "") {
            alert("Activity name can not be blank");
            return false;
        }
        row.find(".Edit").show();
        row.find(".Delete").show();
        row.find(".Cancel").hide();
        $(this).hide();
        var formData = new FormData();
        formData.append("id", row.find(".CustomerId").find("span").html());
        formData.append("ActivityName", row.find(".Name").find("span").html());
        openload();
        $.ajax({
            url: '/api/CallApi/UpdateCustomActivity',
            data: formData,
            contentType: false,
            processData: false,
            type: 'POST',
            success: function (response) {
                new PNotify({
                    title: 'Success',
                    text: 'Data Updated Successfully',
                    type: 'success',
                    delay: 3000
                });
                localStorage.setItem("Customactivity1", "1");
                closeload();
                return false;
            }
        });
    });
    //Cancel event handler.
    $("body").on("click", "#tblCustomers .Cancel", function () {
        var row = $(this).closest("tr");
        $("td", row).each(function () {
            if ($(this).find("input").length > 0) {
                var span = $(this).find("span");
                var input = $(this).find("input");
                input.val(span.html());
                span.show();
                input.hide();
            }
        });
        row.find(".Edit").show();
        row.find(".Delete").show();
        row.find(".Update").hide();
        $(this).hide();
    });
    //Delete event handler.
    $("#tblCustomers").on("click", ".Delete", function () {
        if (confirm("Please download data before reset. You may loose your data. Are you sure to remove this activity?")) {
            var row = $(this).closest("tr");
            var customerId = row.find("span").html();
            var formData = new FormData();
            formData.append("id", customerId);
            openload();
            $.ajax({
                url: '/api/CallApi/RemoveCustomActivity',
                data: formData,
                contentType: false,
                processData: false,
                type: 'POST',
                success: function (response) {
                    localStorage.setItem("Customactivity1", "1");
                    Loadcontacttype();
                    closeload();
                }
            });
            return false;
        }
    });
</script>
<div class="modal-header btn-primary">
    <button type="button" class="close" id="closemodel" data-dismiss="modal">&times;</button>
    <h4 class="modal-title">
        Create Custom Activity
    </h4>
</div>
<div class="modal-body ">
    <aside>
        <section class="content">
            <div id="page-wrapper">
                <div class="container-fluid showcontent" id="showcontent">
                    <div class="">
                        <div class="box-header">
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <section class="content">
            <form id="fileupload" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-lg-12" style="overflow-x:auto">
                        <div class="row">
                            <div class="col-md-12">
                                <fieldset>
                                    <legend>Activity Type</legend>
                                    <div class="form-group form-horizontal">
                                        <label class="control-label col-md-3">Activity Name <span class="required" aria-required="true" style="color:red"><b>*</b> </span></label>
                                        <div class="col-md-4">
                                            <input class="form-control" type="text" id="txtName" placeholder="Enter activity name" />
                                        </div>
                                    </div>
                                    <div class="form-group form-horizontal">
                                        <label class="control-label col-xs-3"></label>
                                        <div class="col-xs-8">
                                            <button type="button" class="btn btn-success" id="btnAdd">Save</button>
                                        </div>
                                    </div>
                                </fieldset>
                            </div>
                        </div>
                        <table id="tblCustomers" border="1px solid" class="dataTable table table-bordered table-striped" cellpadding="0" cellspacing="0">
                            <tr>
                                <th style="width:10%">Sl.No </th>
                                <th style="width:60%">Activity Name</th>
                                <th style="width:30%">Action</th>
                            </tr>
                            <tbody id="assignuserdata"></tbody>
                        </table>
                    </div>
                </div>
            </form>
        </section>
    </aside>
    <div class="row">
        <div class="col-md-12">
            <div class="modal-footer">
                <button type="button" id="closemodels" class="btn btn-default" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
