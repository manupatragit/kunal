@{
    /**/
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
}
<style>

    :root {
        --bg: #f6f7fb;
        --card: #fff;
        --accent: #2b66f0;
        --muted: #737a86;
        --border: #e6e8ee;
        --shadow: 0 6px 16px rgba(0,0,0,.06);
    }

    .wrap {
        max-width: 1180px;
        margin: 28px auto;
        padding: 0 16px;
    }

    .grid {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 20px;
    }

    /* ✅ Corrected media query */
    @@media (max-width:900px) {
        .grid {
            grid-template-columns: 1fr;
        }
    }

    /* LEFT: nav */
    .nav {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 12px;
        box-shadow: var(--shadow);
        height: 50%vh;
        height: fit-content;
    }

    .btn1 {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 12px 14px;
        margin: 8px 0;
        border: 1px solid var(--border);
        border-radius: 10px;
        background: linear-gradient(#fff,#fafafa);
        cursor: pointer;
        font-weight: 600;
        color: #1b1f24;
        transition: .2s;
    }

        .btn1:hover {
            box-shadow: 0 3px 10px rgba(0,0,0,.05);
        }

        .btn1.active {
            outline: 2px solid var(--accent);
            border-color: transparent;
        }

        .btn1 .chev {
            margin-left: auto;
            opacity: .6;
            transition: transform .2s;
        }

        .btn1.collapsible.active .chev {
            transform: rotate(90deg);
        }

    .sub {
        margin: 0 0 8px 0;
        padding-left: 10px;
        display: grid;
        grid-template-rows: 0fr;
        transition: grid-template-rows .25s ease;
    }

        .sub.open {
            grid-template-rows: 1fr;
        }

        .sub > div {
            overflow: hidden;
        }

        .sub .subbtn {
            width: 100%;
            text-align: left;
            font-weight: 600;
            color: #2c2f36;
            border: 1px dashed var(--border);
            background: #fff;
            border-radius: 8px;
            padding: 10px 12px;
            margin: 6px 0;
            cursor: pointer;
            transition: .2s;
        }

            .sub .subbtn:hover {
                background: #f3f6ff;
            }
    /*
            .sub .subbtn.active {
                background: #eaf1ff;
                border-color: #cfe0ff;
            }*/

    /* RIGHT: content panel */
    .panel {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 12px;
        box-shadow: var(--shadow);
        padding: 20px 24px;
        min-height: 520px;
    }

        .panel h2 {
            margin: 0 0 6px 0;
            font-size: 28px;
        }

        .panel .meta {
            color: var(--muted);
            font-size: 14px;
            margin-bottom: 12px;
        }

    .hr {
        height: 1px;
        background: var(--border);
        margin: 12px 0 18px;
    }

    .section {
        display: none;
        animation: fade .18s ease;
    }

        .section.show {
            display: block;
        }

    /* ✅ Corrected keyframes */
    @@keyframes fade {
        from {
            opacity: .2;
            transform: translateY(4px);
        }

        to {
            opacity: 1;
            transform: none;
        }
    }

    /* Tiny badge style for “Updated on …” */
    .badge {
        display: inline-block;
        background: #f0f3ff;
        color: #1b3fad;
        border: 1px solid #cfe0ff;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 12px;
    }

    /*   ul {
        margin-top: 8px;
    }*/

    .muted {
        color: var(--muted);
    }

    .case-page div,
    .case-page ul,
    .case-page li,
    .case-page p {
        margin: 0;
        padding: 0;
        padding: 1rem !important;
    }


    /* TOP 4 BUTTONS ROW */
    .top-tabs {
        /* justify-content: center; */
        display: flex;
        /* gap: 10px; */
        margin-bottom: 16px;
        flex-wrap: wrap;
        /* margin-top: 15px; */
    }

    .top-btn {
        border: 1px solid var(--border);
        background: linear-gradient(#fff, #f5f7ff);
        border-radius: 10px;
        padding: 10px 50px;
        font-size: 14px;
        font-weight: 600;
        color: #1b1f24;
        cursor: pointer;
        box-shadow: 0 3px 8px rgba(0,0,0,.04);
        transition: .2s;
    }

        .top-btn:hover {
            box-shadow: 0 5px 14px rgba(0,0,0,.06);
        }

        .top-btn.active {
            background: #0C4A6E;
            color: white;
            /* border-color: var(--accent);*/
        }

    /* each top-level area under a button */
    .top-section {
        display: none;
    }

        .top-section.show {
            display: block;
        }
</style>

<style>
    .top-section {
        display: none;
    }
</style>
