    <script>
        function switchTopTab(tabId, btn) {
            // Hide all tabs
            var tabs = document.getElementsByClassName('top-section');
            for (var i = 0; i < tabs.length; i++) {
                tabs[i].classList.remove('show');
            }

            // Remove active from top buttons
            var topBtns = document.getElementsByClassName('top-btn');
            for (var j = 0; j < topBtns.length; j++) {
                topBtns[j].classList.remove('active');
            }

            // Show selected tab
            var tab = document.getElementById(tabId);
            if (!tab) return;
            tab.classList.add('show');

            // ✅ TOP Billing tab → open Invoice Management
            if (tabId === 'tab5') {
                var billingAccBtn = tab.querySelector("button.btn1[data-target='billing']");
                if (billingAccBtn) {
                    toggleAccordion('billing', billingAccBtn);

                    var invoiceBtn = tab.querySelector("#sub-billing .subbtn");
                    if (invoiceBtn) invoiceBtn.click(); // showSection(...)
                }
            }

            // ✅ TOP AI Tools tab → open Generate Summary
            else if (tabId === 'tab2') {
                var aiAccBtn = tab.querySelector("button.btn1[data-target='ai-tools']");
                if (aiAccBtn) {
                    toggleAccordion('ai-tools', aiAccBtn);

                    var summaryBtn = tab.querySelector("#sub-ai-tools .subbtn[data-target='t3-dashboard']")
                        || tab.querySelector("#sub-ai-tools .subbtn");
                    if (summaryBtn) summaryBtn.click(); // showSection('t3-dashboard', ...)
                }
            }

            // Default (optional)
            else {
                var firstSidebarBtn = tab.querySelector('.btn1, .subbtn');
                if (firstSidebarBtn) firstSidebarBtn.click();
            }

            // Highlight clicked top tab
            if (btn) btn.classList.add('active');
        }

        function showSection(id, btn) {
            var container = btn.closest('.top-section');
            if (!container) return;

            container.querySelectorAll('.section').forEach(function (sec) {
                sec.style.display = 'none';
            });

            container.querySelectorAll('.btn1, .subbtn').forEach(function (b) {
                b.classList.remove('active');
            });

            var el = container.querySelector('#' + id);
            if (el) el.style.display = 'block';

            btn.classList.add('active');
        }

        function toggleAccordion(accId, btn) {
            var container = btn.closest('.top-section') || document;
            var sub = container.querySelector('#sub-' + accId);
            if (!sub) return;

            var isVisible = sub.style.display === 'block';

            // close all accordions in this tab
            container.querySelectorAll('.sub').forEach(function (s) {
                s.style.display = 'none';
            });

            // open/close clicked one
            sub.style.display = isVisible ? 'none' : 'block';
        }

        window.onload = function () {
            var firstTopBtn = document.querySelector('.top-btn[data-top="tab1"]');
            if (firstTopBtn) switchTopTab('tab1', firstTopBtn);
        };
    </script>







