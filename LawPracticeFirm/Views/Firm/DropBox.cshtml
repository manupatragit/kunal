<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "https://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="https://www.w3.org/1999/xhtml">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=iso-8859-1" />
    <title>Untitled Document</title>
    <script type="text/javascript" src="https://www.dropbox.com/static/api/1/dropins.js" id="dropboxjs" data-app-key="6skhvbra48yblki"></script>
    <script src="https://apis.google.com/js/platform.js"></script>
    <script>
        Dropbox.createSaveButton(url, filename, options);
    </script>
    <body>
        <form id=frm name=frm method=post>
            <br>
            <table width="100%" cellpadding="0" cellspacing="0" style="font-family:verdana, arial; font-size:11px; line-height:15px;">
                <tr><td align="left" colspan="2"><b>Save document in:</b></td></tr>
                <tr><td colspan="2"><hr></td></tr>
                <tr>
                    <td><b>Upload document to Cloud Server</b></td>
                    <td align="left">
                        <div>
                            <a href="@ViewBag.token" class="dropbox-saver"></a>
                        </div>
                    </td>
                </tr>
                <tr><td colspan="2">&nbsp;</td></tr>
                <tr>
                    <td><b></b></td>
                    <td align="left" valign="top">
                        <div class="g-savetodrive"
                             data-src="@ViewBag.token"
                             data-filename="@ViewBag.filename"
                             data-sitename="mykase">
                        </div>
                    </td>
                </tr>
            </table>
        </form>
    </body>
</html>