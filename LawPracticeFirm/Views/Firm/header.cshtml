            notification(pageindex);
            $("#myModalNotificationdata ").modal('show');

        });
        //for paging
        $(document).on('click', '#ppaginatenoti', function () {
            ppageindex = $(this).attr("index");
            notification(ppageindex);
        });
        $(document).on('click', '#pgetdatabypagenumnoti', function () {
