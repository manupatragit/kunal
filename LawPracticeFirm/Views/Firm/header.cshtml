<script>
function showConfirm(title, message) {
    return new Promise((resolve) => {
        let confirmed = false; // track if Yes clicked

        $("#confirmTitle").text(title || "Confirmation");
        $("#confirmMessage").text(message || "Are you sure?");

        // remove old handlers
        $("#confirmYes").off("click");
        $("#myModalConfirm").off("hidden.bs.modal");

        // confirm clicked
        $("#confirmYes").on("click", function () {
            confirmed = true;
            $("#myModalConfirm").modal("hide");
            resolve(true);
        });

        // closed without confirm
        $("#myModalConfirm").on("hidden.bs.modal", function () {
            if (!confirmed) {
                resolve(false);
            }
        });

        // show modal
        $("#myModalConfirm").modal("show");
    });
    }


$(document).ready(function () {
    $("#signoutconfirm").click(function () {
        showConfirm("Thank you for using myKase.", "Are you sure you want to Sign Off?")
            .then(function (result) {
                if (result) {
                    try {
                        var formData = new FormData();
                        formData.append("duration", $("#duration2").val());
                        window.clearInterval(window.t11);

                        $.ajax({
                            type: "POST",
                            url: "/api/callApi/PostSaveTimervalue",
                            data: formData,
                            contentType: false,
                            processData: false,
                            success: function (data) {
                                // success handler
                            },
                            failure: function (data) {
                                // failure handler
                            },
                            error: function (data) {
                                // error handler
                            }
                        });
                    } catch (err) {
                        console.error(err);
                    }

                    localStorage.removeItem("causemodal");
                    location.href = "/@firmcode121/Account/LogOut";
                }
            });
    });

    $("#password1").click(function () {
        try {
            openload3();
            var url = "/Client/ChangePassword";
            $('.mymodelscpd').load(url, function () {
                closeload3();
                $('#myModalcpd').modal({ show: true });
            });
        } catch (err) {
            alert(err.message);
        }
    });
});

    function openload3() {
        $('#myOverlay').css("display", "block");
    }

    function closeload3() {
        $('#myOverlay').css("display", "none");
    }
</script>




