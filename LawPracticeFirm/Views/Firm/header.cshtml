        /*Pagination Start*/
        var isRenderPageNotification = false;
        var totalPageRecNotification = "";
        function renderPaginationNotification(pageindex, totdata) {
            let totPages = totdata;
            setPageNo = pageindex;
            totalPageRecNotification = totdata;
            let paginationHtml = '';
            let maxVisible = 4; // Visible page numbers before ellipsis
            if (totdata <= maxVisible + 2) {
                for (let i = 1; i <= totPages; i++) {
                    paginationHtml += `<button class="page-btn-notification ${i === pageindex ? 'active' : ''}" data-page="${i}">${i}</button>`;
                }
            } else {
                if (pageindex <= maxVisible) {
                    for (let i = 1; i <= maxVisible; i++) {
                        paginationHtml += `<button class="page-btn-notification ${i === parseInt(pageindex) ? 'active' : ''}" data-page="${i}">${i}</button>`;
                    }
                    paginationHtml += `<span>.......</span>`;
                    for (let j = totPages - 3; j <= totPages; j++) {
                        paginationHtml += `<button class="page-btn-notification ${j === pageindex ? 'active' : ''}" data-page="${j}">${j}</button>`;
                    }
                }
            }
            $("#pageNumbersNotification").html(paginationHtml);
            $("#prevNotification").toggleClass("disabled", pageindex === 1);
            $("#nextNotification").toggleClass("disabled", pageindex === totdata);
            isRenderPageNotification = true;
        }


        $(document).on("click", ".page-btn-notification", function (event) {
            event.preventDefault();
            let page = $(this).data("page");
            setPageNo = page;
            //if (page) changePage(page);
            loadflag = true;
            isRenderPageNotification = true;
            $("#txtgopageNotification").val("");
            notification(setPageNo, "", "");
            $(".page-btn-notification ").removeClass("active");
            $(".page-btn-notification[data-page='" + setPageNo + "']").addClass("active");
        });

