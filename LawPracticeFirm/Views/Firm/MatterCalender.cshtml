<script>
    var fcode1 = localStorage.getItem("FirmCode");
    function downloadExcel() {
        window.location = encodeURI("/firm/ExportoExcelCalendar");
    }
    function downloadPDF() {
        window.location = encodeURI("/firm/ExportoPDFCalendar");
    }
    function eventlist() {
        window.location = encodeURI("/" + fcode1 + "/firm/CalendarEventList");
    }
    $(document).ready(function () {
        var fcode = localStorage.getItem("FirmCode");
        $(document).on("click", "#transferpageevent", function () {
            var modelid = $(this).attr("type");
            var transferid = $(this).attr("data-date");
            var url = "/firm/ScheduleTask?token=" + encodeURI(transferid);
            $('.mymodels').load(url, function (result) {
                closeload3();
                $('#myModal').modal({ show: true });
            });
        });
        $(document).on("click", "#transferpagecalevent", function () {
            var modelid = $(this).attr("type");
            var transferid = $(this).attr("data-date");
            var url = "/firm/ScheduleCalendarEvent?token=" + encodeURI(transferid);
            $('.mymodels').load(url, function (result) {
                closeload3();
                $('#myModal').modal({ show: true });
            });
        });
        $(document).on("click", "#transferpagemore", function () {
            var modelid = $(this).attr("data-val");
            openload3();
            var url = "/firm/CalendarMoreEvent?status=true&token=" + encodeURI(modelid);
            $('.mymodels').load(url, function (result) {
                closeload3();
                $('#myModal').modal({ show: true });
            });
        });
    });
</script>
