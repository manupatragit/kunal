<script>
    function printDiv(elem) {
        var mywindow = window.open('', 'PRINT', 'height=500,width=500');
        mywindow.document.write('<html><head>');
        mywindow.document.write("<link href=\"/Scripts/Calendar/dhtmlxscheduler.css\" rel=\"stylesheet\"><link href=\"/newassets/css/PrintCalendar.css\" rel=\"stylesheet\"><link href=\"/newassetsw/css/style.css?3.0\" rel=\"stylesheet\"><link href=\"../css/icons.css\" rel=\"stylesheet\">")
        mywindow.document.write('</head><body >');
        mywindow.document.write(document.getElementById('scheduler_here').innerHTML);
        mywindow.document.write('</body></html>');
        mywindow.document.close(); // necessary for IE >= 10
        mywindow.focus(); // necessary for IE >= 10*/
        setTimeout(function () {
            mywindow.print();
            mywindow.close();
        }, 1000)
        return true;
    }
    function printDiv1(id) {
        var printContents = document.getElementById(id).innerHTML;
        var originalContents = document.body.innerHTML;
        document.body.innerHTML = printContents;
        window.print();
        document.body.innerHTML = originalContents;
    }
</script>
