    function formatDate(date) {
        var d = new Date(date),
            month = '' + (d.getMonth() + 1),
            day = '' + d.getDate(),
            year = d.getFullYear();
        if (month.length < 2)
            month = '0' + month;
        if (day.length < 2)
            day = '0' + day;
        return [year, month, day].join('-');
    }
    function execute1(dataObj) {
        return gapi.client.calendar.events.insert({
            "calendarId": "primary",
            "resource": dataObj
        })
