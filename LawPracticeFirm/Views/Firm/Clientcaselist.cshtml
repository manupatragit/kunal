@{
    /**/
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
}
<script>
    var roleids = "@Session["sessionroleid"]";
    var isDelete = "@Session["IsDelete"]";
    var IsCreate = "@Session["IsCreate"]";
    var token = "@ViewBag.Clienttoken";
    var type = 8;
</script>
<script src="~/Scripts/Firm/Pages/ClientCaseList.js?1.9"></script>
<style>
    .trcolor {
        background: #f5c9c9 !important;
    }

        .trcolor td {
            background-color: transparent !important;
        }

    .clSelectCaseUser {
        background-color: #ebebeb !important;
        padding-right: 20px !important;
        border-radius: 20px !important;
        height: 30px !important;
        margin-top: -5px !important;
        -moz-appearance: none;
        -webkit-appearance: none;
        appearance: none;
        padding-left: 15px !important;
        background: #ebebeb url(/newassets/images/selectbox_arrow.png) no-repeat right !important;
        -webkit-appearance: none;
        background-position-x: 99%;
        margin-bottom: 10px !important;
        margin-left: -15px !important;
    }
</style>
<section id="header">
    <div class="container-main" style="display:flex; justify-content:space-between;">
        <div class="text-left">
            <p class="ctitle" id="clientdiv">Client&nbsp;&nbsp;|&nbsp;&nbsp;<span id="ncdclientname" style="cursor:pointer" title="view profile"></span></p>
            <p class="ctitle" id="companydiv" style="display:none">Client&nbsp;&nbsp;|&nbsp;&nbsp;<span id="ncdcompanynames"></span></p>
        </div>
        @if (role.ToString() == "1")
        {
            <a href="/@Session["firmcode"]/firm/CreateCase" class="button4"><img src="/newassets/img/plus-icon.png"> New Matter</a>
        }
        else
        {
            if (Convert.ToInt32(Session["IsCreate"]) == 1)
            {
                <a href="/@Session["firmcode"]/firm/CreateCase" class="button4"><img src="/newassets/img/plus-icon.png"> New Matter</a>
            }
        }

    </div>
</section>
<section>
    <div class="container-main">
        <div class="tabs-and-filters">
            <div class="button-group">
