                                            </select>
                                        </div>
                                    </th>
                                    <th class="casecasedetails">
                                        <div class="thbg">
                                            Court Hearing
                                        </div>
                                    </th>
                                    <th class="casecourtname">
                                        <div class="thbg" style="width:100px;">
                                            <select class="form-control" id="casefiltercourt">
                                                <option value="" selected="">Court</option>
                                                <option value="Supreme Court">Supreme Court</option>
                                                <option value="High Court">High Court</option>
                                                <option value="District Court">District Court</option>
                                                <option value="Tribunals">Tribunals</option>
                                            </select>
                                        </div>
                                    </th>
                                    <th class="casecreatedby">
                                        <div class="thbg">
                                            Created By
                                        </div>
                                    </th>
                                    <th class="caseteammembers">
                                        <div class="thbg">
