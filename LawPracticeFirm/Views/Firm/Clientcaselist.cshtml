                                <li><input type="checkbox" value="MatterTeamLead" class="shcheckbox1 chkdhide" name="caselead" checked><a href="#" class="dropdown-item">Matter Lead</a></li>
                                <li><input type="checkbox" value="ClientContact" class="shcheckbox1 chkdhide" name="caseclientcontact"><a href="#" class="dropdown-item">Client Contact</a></li>
                                <li><input type="checkbox" value="SubjectType" class="shcheckbox1 chkdhide" name="casesubject" checked><a href="#" class="dropdown-item">Subject</a></li>
                                <li><input type="checkbox" value="Status" class="shcheckbox1 chkdhide" name="casestatus" checked><a href="#" class="dropdown-item">Status</a></li>
