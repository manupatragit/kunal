                        <select id="filtercaseuser" class="form-control selctInputFormat">
                            <option value="" selected>Select User </option>
                        </select>
                    }
                    else
                    {
                        <input type="text" class="form-control inputFormat" id="filtercaseuser" style="display:none">
                    }

                </div>
            </div>
            <div style="display:inline-flex">
                <div class="table-header">
                    <div class="actions3">
                        <div class="menuexport" style="position:relative; cursor:pointer;">
