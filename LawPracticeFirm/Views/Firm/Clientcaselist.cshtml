                                <img class="plus-icon" alt="" src="~/newassets/img/upload-icon.png">
                            </div>
                            <ul class="dropdown-menu action-more">
                                <li><div id="oexcel" title="Export to Excel"><span style="padding: 0 10px 0 0;"><img src="/newassets/img/exportexl-icon.png"></span> Export to Excel</div></li>
                                <li><div id="opdf" title="Export data to PDF"><span style="padding: 0 10px 0 0;"><img src="/newassets/img/exportpdf-icon.png"></span> Export to PDF</div></li>
                            </ul>
                        </div>
                        <div class="button13" id="ColumnSelectionopen" title="Column Selection">
