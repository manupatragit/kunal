                                    </th>
                                    <th class="casecasename">
                                        <div class="thbg" style="width:145px;">
                                            <input type="text" id="casefiltercasename" placeholder="Matter Name" class="form-control inputFormat pull-left" style="width:70%;">

                                            <span class="glyphicon glyphicon-search pull-left" id="searchdatas"></span>
                                            <span class="" id="clearnewseach" title="Click here to reset search" style="display:none;float:left;cursor:pointer;">x</span>
                                        </div>
                                    </th>
                                    <th class="caselead">
                                        <div class="thbg">
                                            Matter Team Lead
                                        </div>
                                    </th>
                                    <th class="caseclientcontact">
                                        <div class="thbg">
                                            Client Contact
                                        </div>
                                    </th>
                                    <th class="casesubject">
