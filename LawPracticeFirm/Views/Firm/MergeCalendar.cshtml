<script type="text/javascript">

    var totpage = 1;
    var count = 1;
    var pagesize = 30;
    var dataresbn = null;
    var datacount = 1;

    function calendarsyncdata(currentPage, pageSize, data) {
        const total = data.length;
        const totalPages = Math.ceil(total / pageSize);

        if (currentPage > totalPages) {
            new PNotify({
                title: 'Success!',
                text: 'Google Calendar synchronized successfully',
                type: 'success',
                delay: 2000
            });
            closeload();
            return;
        }

        openload();

        finalcalendarsync(currentPage, pageSize, data)
            .then(() => calendarsyncdata(currentPage + 1, pageSize, data))
            .catch(err => {
                console.error("Error syncing page:", err);
                closeload();
            });
    }

    // LoadMergeNextHearingForDownload

    function calendarsync() {
        var urls3 = "/firm/LoadMergeNextHearingForDownload";

        $.ajax({
            async: true,
            type: "POST",
            url: urls3,
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (data) {
                if (data && data.length > 0) {
                    calendarsyncdata(datacount, count, data);
                    new PNotify({
                        title: 'success',
                        text: 'Google Calendar synchronization in progress please wait.',
                        type: 'success',
                        delay: 10000
                    });
                } else {
                    alert("No data available for calendar.");
                }
            },
            error: function () {
                alert('failed');
            }
        });
    }

    function finalcalendarsync(page, pageSize, data) {
        return new Promise((resolve, reject) => {

            const start = (page - 1) * pageSize;
            const end = Math.min(start + pageSize, data.length);

            let promises = [];

            function cleanText(value, fallback = "") {

                if (value == null) return fallback;

                value = String(value);

                try {

                    // Remove hidden/control chars first
                    value = value
                        .replace(/[\x00-\x08\x0B\x0C\x0E-\x1F\x7F]/g, "")
                        .replace(/[\u200B-\u200D\uFEFF]/g, "");

                    // Attempt mojibake recovery
                    try {

                        const encoded = new TextEncoder().encode(value);

                        const decoded =
                            new TextDecoder("utf-8", {
                                fatal: false
                            }).decode(encoded);

                        // Use recovered text only if Hindi appears
                        if (/[\u0900-\u097F]/.test(decoded)) {
                            value = decoded;
                        }

                    } catch (e) {
                        console.log("Decode skipped");
                    }

                    // Remove replacement symbols
                    value = value
                        .replace(/\uFFFD/g, "")
                        .replace(/[^\u0900-\u097F\w\s().,&:/\-]/g, " ")
                        .replace(/\s+/g, " ")
                        .normalize("NFC")
                        .trim();

                } catch (e) {
                    console.log("cleanText error", e);
                }

                return value || fallback;
            }
            for (let i = start; i < end; i++) {

                const row = data[i];
                if (!row) continue;

                let appealno = "";
                let cdescription = "";

                // Build Title
                if (cleanText(row.Caseyear) === "NA") {
                    appealno =
                        cleanText(row.Casename) ||
                        cleanText(row.Casetype) ||
                        "Case Event";

                    cdescription =
                        cleanText(row.CourseName);

                }
                else if (cleanText(row.Caseyear) !== "") {

                    appealno =
                        `${cleanText(row.Casetype)} ${cleanText(row.CaseNo)}/${cleanText(row.Caseyear)}`
                            .replace(/\s+/g, " ")
                            .trim();

                    cdescription =
                        cleanText(row.CourseName);

                    if (cleanText(row.Advname)) {
                        cdescription +=
                            ", Advocate: " + cleanText(row.Advname);
                    }
                }
                else {

                    appealno =
                        cleanText(row.Casetype) ||
                        cleanText(row.Casename) ||
                        "Case Event";

                    cdescription =
                        cleanText(row.Casetype);
                }
                console.log("Raw Casename:", row.Casename);
                console.log("Raw CourseName:", row.CourseName);
                // Final protection against empty title
                appealno = cleanText(appealno, "Case Event");
                cdescription = cleanText(cdescription);
                console.log("After Fix Title:", appealno);
                console.log("After Fix Desc:", cdescription);
                function createEvent(date) {
                    return {
                        summary: appealno,
                        location: "",
                        description: cdescription,
                        start: {
                            dateTime: date + "T08:00:00+05:30"
                        },
                        end: {
                            dateTime: date + "T09:00:00+05:30"
                        }
                    };
                }

                // Hearing Date
                if (row.Disposeddt) {

                    let hearingDate = formatDate(row.Disposeddt);

                    promises.push(
                        execute1(createEvent(hearingDate))
                            .catch(err => {
                                console.error(
                                    "Insert failed:",
                                    err,
                                    createEvent(hearingDate)
                                );
                            })
                    );
                }

                // Next Hearing
                if (row.NextHearing) {

                    let nextHearingDate = formatDate(row.NextHearing);

                    if (nextHearingDate) {
                        promises.push(
                            execute1(createEvent(nextHearingDate))
                                .catch(err => {
                                    console.error(
                                        "Insert failed:",
                                        err,
                                        createEvent(nextHearingDate)
                                    );
                                })
                        );
                    }
                }
            }

            Promise.all(promises)
                .then(resolve)
                .catch(reject);
        });
    }

    function formatDate(dateStr) {
        var d = new Date(dateStr);
        if (isNaN(d.getTime())) return null;
        var month = ('0' + (d.getMonth() + 1)).slice(-2);
        var day = ('0' + d.getDate()).slice(-2);
        return d.getFullYear() + "-" + month + "-" + day;
    }

    function authenticateAndLoad() {
        return new Promise(function (resolve, reject) {
            if (!window.gapiInited || !window.gisInited || !window.tokenClient) {
                reject("Google API not initialised yet.");
                return;
            }

            window.tokenClient.callback = function (resp) {
                if (resp.error) return reject(resp);
                gapi.client.setToken({ access_token: resp.access_token });
                resolve();
            };

            window.tokenClient.requestAccessToken({ prompt: 'consent' });
        });
    }

    function execute1(dataObj) {
        return gapi.client.calendar.events.insert({
            calendarId: "primary",
            resource: dataObj
        }).then(
            function (res) { console.log("Event created:", res.result.id || res.result.htmlLink); },
            function (err) { console.error("Error creating event:", err); }
        );
    }

    function execute() {
        console.log("Calendar sync completed");
    }

    function calendarsync1() {
        return gapi.client.calendar.events.list({
            calendarId: "primary",
            timeMin: (new Date()).toISOString(),
            singleEvents: true,
            orderBy: "startTime",
            maxResults: 10
        }).then(
            function (res) {
                console.log("Events:", res.result.items);
                calendarsync();
            },
            function (err) {
                console.error("calendarsync error:", err);
            }
        );
    }

    function googleCalendarSyncClick() {
        authenticateAndLoad()
            .then(calendarsync1)
            .then(execute)
            .catch(function (err) {
                console.error("Google Calendar sync error:", err);
                closeload && closeload();
            });
    }
</script>

