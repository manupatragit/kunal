
@{
    ViewBag.Title = "test";
    Layout = null;
}

<button type="button" id="login">signin</button>
<script type="text/javascript">
    // Client ID and API key from the Developer Console
    var CLIENT_ID = '33848583939-t1ahu0lo9gn6gu05k4v6a21pdu5cthpr.apps.googleusercontent.com';

    // Array of API discovery doc URLs for APIs used by the quickstart
    var DISCOVERY_DOCS = ["https://www.googleapis.com/discovery/v1/apis/calendar/v3/rest"];

    // Authorization scopes required by the API; multiple scopes can be
    // included, separated by spaces.
    var SCOPES = "https://www.googleapis.com/auth/calendar";

    var createEventButton = document.getElementById('login');


    function handleClientLoad() {
        alert("hi");
        gapi.load('client:auth2', initClient);
       
    }

    function initClient() {
        alert("hi");
        gapi.client.init({
            discoveryDocs: DISCOVERY_DOCS,
            clientId: CLIENT_ID,
            scope: SCOPES
        }).then(function () {
            // Call the handleCreateEvent function on the click on your desired button.
          
            createEventButton.onclick = handleCreateEvent;
        });
    }

    function updateSigninStatus(isSignedIn) {
        if (isSignedIn) {
            createEvent();
        }
    }

    function handleCreateEvent(event) {
        
        gapi.auth2.getAuthInstance().signIn();
        updateSigninStatus(gapi.auth2.getAuthInstance().isSignedIn.get());
    }

    function createEvent() {
        var event = {
            'summary': 'oktest',
            'location': '800 Howard St., San Francisco, CA 94103',
            'description': 'A chance to hear more about Google\'s developer products.',
            'start': {
                'dateTime': '2018-12-21T09:00:00-07:00',
                'timeZone': 'America/Los_Angeles'
            },
            'end': {
                'dateTime': '2018-12-22T17:00:00-07:00',
                'timeZone': 'America/Los_Angeles'
            }
           
           
        };


        var request = gapi.client.calendar.events.insert({
            'calendarId': 'primary',
            'resource': event
        });

        request.execute(function (event) {
           // window.location.href = event.htmlLink;
        });
    }
</script>

<script async defer src="https://apis.google.com/js/api.js"
        onload="handleClientLoad()"></script>

