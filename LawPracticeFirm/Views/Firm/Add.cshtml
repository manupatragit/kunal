<script>
    var configurationtype = parseInt('@ViewBag.ConfType',10);
    var mode = "VIEW";
    var Id = '@ViewBag.Id';
</script>
<script src="~/Scripts/Firm/Pages/CustomFields.js"></script>
<script src="~/Scripts/Firm/Pages/Add.js"></script>
<div class="">
    <div class="row page-title-row">
        <div class="col-md-12">
            <h3 class="page-title">
                <i class="pp-icon-user"></i> @ViewBag.Header Details
            </h3>
        </div>
    </div>
    <div class="form-section" style="padding:25px 0px;">
        <div id="divCFields" class="form-control" style="padding:25px 0px;min-height:1px;">
            <div id="divUserName" class="form-control" style="padding:25px 0 0 0;display:none;">
                <div class="form-group col-md-12 parallel">
                    <label for="" class="col-md-4 control-label">UserName<i class="fa fa-star" aria-hidden="true"></i></label>
                    <input class="col-md-3 textinput" id="txtusername" pattern="^[a-zA-Z]{1}[a-z0-9A-Z\.]{2,10}$" name="" placeholder="User Name" type="text" value="" maxlength="10" required>
                </div>
                <div class="form-group col-md-12 parallel">
                    <label for="" class="col-md-4 control-label">Password<i class="fa fa-star" aria-hidden="true"></i></label>
                    <input class="col-md-3 textinput" id="txtpassword" pattern="^[a-z0-9A-Z]{6,}$" name="" placeholder="User Name" type="password" value="123456" maxlength="50" required>
                </div>
            </div>
        </div>
    </div>
    <div class="form-section">
        <nav class="navbar" style="background: #ffffff; padding-left:40%;justify-content: unset;">
            <button id="btnSave" class="btn btn-success" style="margin:0 1%;"><i class="fa fa-floppy-o" aria-hidden="true"></i> Add </button>
            <button id="btnCancel" class="btn btn-danger" style="margin:0 1%;"><i class="fa fa-times" aria-hidden="true"></i> Cancel </button>
        </nav>
    </div>
</div>
<!-- The Modal -->
<div class="modal" id="workflow" data-backdrop="false">
    <div class="modal-dialog  modal-lg">
        <div class="modal-content">
            <!-- Modal Header -->
            <div class="modal-header">
                <h4 class="modal-title">Workflow Information</h4>
                <button type="button" class="close" data-dismiss="modal" id="btnClose">&times;</button>
            </div>
            <!-- Modal body -->
            <div class="modal-body">
                <div id="divwfFields" class="form-control" style="padding:25px 0px;min-height:1px;">
                </div>
            </div>
            <!-- Modal footer -->
            <div class="modal-footer">
                <button type="button" class="btn btn-success" data-dismiss="modal" id="btnAddField">Update</button>
            </div>
        </div>
    </div>
</div>
