<script>
    $('#assign').selectize({
        //maxItems: 3
    });
    var $select = $("#assign").selectize();
    if (id != "") {
        setTimeout(function () {
            var formData = new FormData();
            formData.append("token", id);
            $.ajax(
                {
                    type: "POST",
                    url: "/api/callApi/contactAssignUser", // Controller/View
                    data: formData,
                    contentType: false,
                    processData: false,
                    //},
                    success: function (response) {
                        var dataarray = [];
                        $.each(response.Data, function (i, b) {
                            try {
                                var selectize = $select[0].selectize;
                                var selecteduser = b.auser;
                                dataarray.push(selecteduser)
                            }
                            catch (er) {
                                alert(er.message);
                            }
                            selectize.setValue(dataarray)
                        });
                    },
                    failure: function (response) {
                        alert(data.responseText);
                    },
                    error: function (response) {
                        alert(data.responseText);
                    }
                });
        }, 1000);
    }
    else {
        // alert(tokenid);
    }
</script>