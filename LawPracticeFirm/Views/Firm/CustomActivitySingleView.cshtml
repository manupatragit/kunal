                                <div class="col-md-12">
                                    <fieldset>
                                        <legend>Linked to</legend>
                                        <div class="col-lg-9">
                                            <div class="form-group" style="margin-left: -23px !important;">
                                                <label class="control-label col-md-4 "><b>Subject</b> <span class="required" aria-required="true">*</span></label>
                                                <div class="col-md-8 ">
                                                    <span id="subject"></span>
                                                </div>
                                            </div>
                                            <div class="form-group " style="margin-left: -23px !important;">
                                                <label class="control-label col-md-4"><b>Case</b></label>
                                                <div class="col-md-8">
                                                    <span id="case"></span>
                                                </div>
                                            </div>
                                            <div class="form-group " style="margin-left: -23px !important;">
                                                <label class="control-label col-md-4 "><b>Assigned to</b> <span class="required" aria-required="true">*</span></label>
                                                <div class="col-md-8">
                                                    <span id="assignto"></span>
                                                </div>
                                            </div>
                                        </div>
