@{
    ViewBag.Title = "InvoiceSetting";
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
}
<script src="~/CssJsfiles/js/3.3.1/jquery.min.js"></script>
<!-- Page Content -->
<script src="/Manupanel/pnotify/pnotify.custom.min.js"></script>
<link href="/Manupanel/pnotify/pnotify.custom.min.css" rel="stylesheet" />
<script src="~/Scripts/Firm/Pages/SingleDataCustomActivity.js"></script>
<link href="~/Manupanel/validation/screen.css" rel="stylesheet" />
<script src="~/Manupanel/validation/jquery.validate.js"></script>
<script>
    var id = "@ViewBag.aid";
    var token = "@ViewBag.tokenid";
        var filesize =@ViewBag.filesize;
</script>
<script type='text/javascript'>
    if (String(token) != "") {
        localStorage.setItem("contacttoken", token);
    }
    if (String(token) == "") {
        var urls = window.location.href;
        url_redirect({
            url: urls,
            method: "post",
            data: { "token": localStorage.getItem("contacttoken") }
        });
    }
    function goodbye(e) {
        localStorage.setItem("contacttoken", token);
        if (!e) e = window.event;
        //e.cancelBubble is supported by IE - this will kill the bubbling process.
        e.cancelBubble = true;
        //  e.returnValue = 'You sure you want to leave?'; //This is displayed on the dialog
        //e.stopPropagation works in Firefox.
        if (e.stopPropagation) {
            e.stopPropagation();
            e.preventDefault();
        }
    }
    window.onbeforeunload = goodbye;
</script>
<script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
<link href="~/Manupanel/jquerydatetimepicker/jquery.datetimepicker.css" rel="stylesheet" />
<script src="~/Manupanel/jquerydatetimepicker/jquery.datetimepicker.js"></script>
<script src="~/Content/multipleselect/selectize.js"></script>
<script src="~/Content/multipleselect/index.js"></script>
<link href="~/Content/multipleselect/dist/css/selectize.bootstrap2.css" rel="stylesheet" />
<link href="~/Content/multipleselect/dist/css/jquery.magicsearch.min.css" rel="stylesheet" />
<style>
    .selectize-control {
        margin: 0 8px 6px 0;
    }

    .selectize-input {
        width: 94%;
    }

    .selectize-dropdown {
        position: unset !important;
    }
</style>
<script>
    $(document).on("click", "#print1", function () {
        window.print();//  document.body.innerHTML = originalContents;
    });
</script>
<aside class="right-side">
    <section class="content-header">
        @{
            var firmcode = Request.Url.Segments[1];
        }
        <ol class="breadcrumb" id="sectionbrudca">
            @if (role.ToString() == "1")
            {
                <li><a href="/@Session["firmcode"]/firm/dashboard"><i class="fa fa-dashboard"></i> Home</a></li>
                <li><a href="/@Session["firmcode"]/firm/activities/">Activity List</a></li>
            }
            else if (role.ToString() == "2")
            {
                <li><a href="/@Session["firmcode"]/employee/dashboard"><i class="fa fa-dashboard"></i> Home</a></li>
                <li><a href="/@Session["firmcode"]/employee/activities/">Activity List</a></li>
            }
            <li class="active transferpage" title="edit activity"> <a id='transferpage' href="javascript:void()" sno="@ViewBag.tokenid"> <i class="fa fa-pencil-square-o"></i> @ViewBag.activityname</a></li>
            <li>
                <btn class=" " id="print1" title="Print" style="margin-left:15px; cursor:pointer"><span class="glyphicon glyphicon-print" style="color:darkorange"></span> </btn>
            </li>
        </ol>
        <h1><span class="glyphicon glyphicon-th-list"></span> Activity Name => @ViewBag.activityname </h1>
    </section>
    <!-- Main content -->
    <section class="content">
        <div class="row">
            <div class="col-xs-12 col-sm-12 col-md-12">
                <div class="row ">
                    <div class="col-md-12">
                        <form id="savecustomform" enctype="multipart/form-data">
