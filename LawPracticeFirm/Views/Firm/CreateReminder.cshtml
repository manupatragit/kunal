@{
    ViewBag.Title = "CreateReminder";
    var role = Session["sessionroleid"];
    var usertype = "";
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
        usertype = "firm";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
        usertype = "employee";
    }
}
<script>
    var token = "@ViewBag.token";
</script>
<script src="~/CssJsfiles/js/2.02/jquery.min.js"></script>
<script src="~/Scripts/Firm/Pages/CreateReminder.js"></script>
<script src="~/Manupanel/ckeditor/ckeditor.js"></script>
<script src="~/Manupanel/ckeditor/samples/js/sample.js"></script>
<link href="~/Manupanel/ckeditor/samples/toolbarconfigurator/lib/codemirror/neod.css" rel="stylesheet" />
<aside class="right-side">
    <section class="content-header">
        <!-- Content Header (Page header) -->
        <ol class="breadcrumb">
            @if (role.ToString() == "1")
            {
                <li><a href="/@Session["firmcode"]/firm/dashboard"><i class="fa fa-dashboard"></i> Home</a></li>
            }
            else if (role.ToString() == "2")
            {
                <li><a href="/@Session["firmcode"]/employee/dashboard"><i class="fa fa-dashboard"></i> Home</a></li>
            }
            <li class="active"><a href="/@Session["firmcode"]/firm/ReminderList">Event Reminder List </a></li>
        </ol>
        <h1><span class="glyphicon glyphicon-folder-open"></span>  &nbsp;&nbsp;Create/Edit Event Reminder</h1>
    </section>
    <section class="content">
        <div id="page-wrapper">
            <div class="container-fluid showcontent" id="showcontent">
                <div class="box">
                    <div class="box-header" style="padding:5px;">
                        <ul class="btn_panel no-margin pull-right" style="padding:0;" id="sectiontemp"></ul>
                    </div>
                </div>
            </div>
            <!-- Main content -->
            <form id="saveremindform" enctype="multipart/form-data">
                <!-- Start About boxes -->
                <div class="row">
                    <div class="col-md-12">
                        <fieldset>
                            <legend>Event Details</legend>
                            <div class="form-group form-horizontal">
                                <label class="control-label col-md-3">Event Title <span class="required" aria-required="true">*</span> </label>
                                <div class="col-md-5">
                                    <input type="text" class="form-control" id="etitle" name="etitle" placeholder="Enter Event Title">
                                </div>
                            </div>
                            <div class="form-group form-horizontal">
                                <label class="control-label col-md-3">Source  <span class="required" aria-required="true">*</span> </label>
                                <div class="col-md-5">
                                    <select name="source" class="form-control" id="source">
                                        <option value="" selected>Select Source</option>
                                        <option value="Dropped Client">Dropped Client</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-group form-horizontal">
                                <label class="control-label col-md-3">Event Description</label>
                                <div class="col-md-9">
                                    <textarea ID="details" cols="15"></textarea>
                                    <div class="grid-container" style="display:none">
                                        <div id="editor">
                                        </div>
                                        <script>
                                            initSample();
                                            CKEDITOR.replace('details', {
                                                toolbar:
                                                    [
                                                        { name: 'basicstyles', items: ['Bold', 'Italic'] },
                                                        { name: 'paragraph', items: ['NumberedList', 'BulletedList'] },
                                                        { name: 'tools', items: ['Maximize',] }
                                                    ],
                                                height: 80,
                                                width: 420
                                            });
                                        </script>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group form-horizontal">
                                <label class="control-label col-md-3">Event Time </label>
                                <div class="col-md-5">
                                    <input type="time" class="form-control" id="eventstime" name="eventstime" placeholder="Event Time">
                                </div>
                            </div>
                            <div class="form-group form-horizontal">
                                <label class="control-label col-md-3">Event Time End </label>
                                <div class="col-md-5">
                                    <input class="form-control" type="time" id="eventetime" name="eventetime" placeholder="Event End">
                                </div>
                            </div>
                            <div class="form-group form-horizontal" style="margin-top:10px;">
                                <label class="control-label col-md-3">All Day?</label>
                                <div class="col-md-9">
                                    <label class="switch">
                                        <input type="checkbox" id="allday" name="allday" value="1">
                                        <span class="slider round"></span>
                                    </label>
                                </div>
                            </div>
                            <div class="form-group form-horizontal">
                                <label class="control-label col-md-3">Event Date  <span class="required" aria-required="true">*</span> </label>
                                <div class="col-md-5">
                                    <input type="date" class="form-control" id="eventdate" name="eventdate" placeholder="Event Date">
                                </div>
                            </div>
                            <div class="form-group form-horizontal" style="margin-top:10px;">
                                <label class="control-label col-md-3">Recurrence</label>
                                <div class="col-md-9">
                                    <label class="switch">
                                        <input type="checkbox" id="recurrence" name="recurrence" value="1">
                                        <span class="slider round"></span>
                                    </label>
                                </div>
                            </div>
                            <div class="form-group form-horizontal">
                                <label class="control-label col-md-3">Location </label>
                                <div class="col-md-5">
                                    <textarea id="location" cols="15" style="margin: 0px; width: 430px; height: 63px;"></textarea>
                                </div>
                            </div>
                            <div class="form-group form-horizontal">
                                <label class="control-label col-md-3"> </label>
                                <div class="col-md-5">
                                    <input type="button" id="savereminder" class="btn save" value="Save">
                                </div>
                            </div>
                        </fieldset>
                    </div>
                </div>
                <!-- /.content -->
            </form>
        </div>
    </section>
</aside>
<div id="myOverlay" class="overlay">
    <div class="overlay-content">
        <div class="spinner2">
            <div><img src="~/newassets/images/MyKase_Loader.gif" height="59" width="150"></div>
        </div>
    </div>
</div>
<style>
    .overlay {
        height: 100%;
        width: 100%;
        display: none;
        position: fixed;
        z-index: 1;
        top: 0;
        left: 0;
        background-color: rgb(0,0,0);
        background-color: rgba(0,0,0, 0.4);
    }

    .overlay-content {
        position: relative;
        top: 46%;
        width: 80%;
        text-align: center;
        margin-top: 30px;
        margin: auto;
        color: white;
    }

    .overlay .closebtn {
        position: absolute;
        top: 20px;
        right: 45px;
        font-size: 60px;
        cursor: pointer;
        color: white;
    }

        .overlay .closebtn:hover {
            color: #ccc;
        }
</style>
