@{
    Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    var fid = "";
    try
    {
        fid = Request.Url.Segments[4];
        if (fid == "")
        {
            fid = "0";
        }
        else
        {
            fid = Request.Url.Segments[4];
        }
    }
    catch (Exception ex)
    {
    }
}
<script>
    formids = "@fid";
</script>
