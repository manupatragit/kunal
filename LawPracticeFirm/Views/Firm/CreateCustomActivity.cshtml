<aside class="right-side">
    <section class="content-header">
        <!-- Content Header (Page header) -->
        <ol class="breadcrumb">
            <li><a href="/@Session["firmcode"]/firm/dashboard"><i class="fa fa-dashboard"></i> Home</a></li>
            <li class="active"><a href="/@Session["firmcode"]/firm/activities/">Activities</a></li>
            <li class="active">Custom Activity</li>
        </ol>
        <h1><span class="glyphicon glyphicon-list-alt"></span> Create Custom Activity</h1>
    </section>
    <section class="content">
        <div id="page-wrapper">
            <div class="container-fluid showcontent" id="showcontent">
                <div class="box">
                    <div class="box-header" style="padding:5px;">
                        <ul class="btn_panel no-margin pull-right" style="padding:0;">
                            <li>
                                <btn class="btn btn-info  " style="margin-top:0px;" id="addcontacttype" title="Create new Custom Form"><span class="glyphicon glyphicon-plus"></span> New Activity</btn>
                            </li>
                            <li>
                                <select class="form-control pull-left viewc" name="state" tempname="user" id="formtype" style="width:150px !important;">
                                    <option value="" selected>Select Activity</option>
                                </select>
                            </li>
                            <li>
                                <btn class="btn btn-primary publish" id="publish" style="display:none" title="Publish Custom Fields">Publish</btn>
                            </li>
                            <li>
                                @*<btn class="btn btn-danger pull-right publish" id="removecfield" style="margin-right:10px" title="Reset All Custom Fields">Reset Form</btn>*@
                            </li>
                        </ul>
                    </div>
                </div>
            </div><!-- /.box-header -->
            <div id="updatePanel">
                <div class="container">
                    <div class="row ">
                        <div class="col-md-12">
                            <div class="row">
                                <fieldset>
                                    <legend>Custom Activity Master Form</legend>
                                    <div class="col-lg-6" style="clear:both;display:none" id="staticdata1">
                                        <div class="form-group">
                                            <label class="control-label col-lg-4">
                                                Subject <span class="required" aria-required="true" style="display: unset;">*</span>
                                            </label>
                                            <div class="col-lg-8">
                                                <input class="form-control" placeholder="Subject" type="text" value="" id="customSubject" required="" name="subject">
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-lg-6" style="clear:both;display:none" id="staticdata2">
                                        <div class="form-group">
                                            <label class="control-label col-md-4">
                                                Case
                                            </label>
                                            <div class="col-md-8">
                                                <select class="form-control" id="case">
                                                    <option value="">Select Case</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-lg-6" style="clear:both;display:none" id="staticdata4">
                                        <div class="form-group">
                                            <label class="control-label col-md-4">
                                                Assigned to <span class="required" aria-required="true" style="display: unset;">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                <select class="form-control" id="case">
                                                    <option value="">Select Case</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-lg-6" id="content" style="cursor:pointer;clear:both">
                                    </div>
                                    <div class="col-lg-6" style="clear:both;display:none;" id="staticdata3">
                                        <div class="form-group">
                                            <label class="control-label col-md-4">
                                                &nbsp;
                                            </label>
                                            <div class="col-md-8">
                                                <btn class="btn btn-success " id="addcustomfiled" style="margin-top:0px;width:159px" title="Add Custom Fields in Form"><span class="glyphicon glyphicon-plus"></span> New Custom Field</btn>
                                            </div>
                                        </div>
                                    </div>
                                </fieldset>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div><center><span id="datastatus"></span></center></div>
</aside>
<br />
<div id="myOverlay" class="overlay">
    <div class="overlay-content">
        <div class="spinner2">
            <div><img src="~/newassets/images/MyKase_Loader.gif" height="59" width="150"></div>
        </div>
    </div>
</div>
<style>
    .overlay {
        height: 100%;
        width: 100%;
        display: none;
        position: fixed;
        z-index: 1;
        top: 0;
        left: 0;
        background-color: rgb(0,0,0);
        background-color: rgba(0,0,0, 0.4);
    }

    .overlay-content {
        position: relative;
        top: 46%;
        width: 80%;
        text-align: center;
        margin-top: 30px;
        margin: auto;
        color: white;
    }

    .overlay .closebtn {
        position: absolute;
        top: 20px;
        right: 45px;
        font-size: 60px;
        cursor: pointer;
        color: white;
    }

        .overlay .closebtn:hover {
            color: #ccc;
        }
</style>
<div id="myModaltypes" class="modal fade myModal " role="dialog" data-backdrop="static">
    <div class="modal-dialog modal-lg">
        <!-- Modal content-->
        <div class="modal-content mymodelstype1" id="mymodelstype">
        </div>
    </div>
</div>
<div id="myModal2" class="modal fade" role="dialog">
    <div class="modal-dialog ">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header btn-primary">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">
                    Create Custom Form
                </h4>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-lg-12">
                        <div class="alert alert-danger alert-dismissable validpanel">
                            <button type="button" class="close" data-dismiss="alert" class="validpanel" aria-hidden="true">&times;</button>
                            . <a href="#" class="alert-link">Alert Link</a>.
                        </div>
                        <div class="panel panel-default">
                            <div class="panel-body">
                                <div class="row">
                                    <div class="col-lg-12">
                                        <form role="form" id="foldercreate">
                                            <div class="form-group form-horizontal">
                                                <label class="control-label col-md-3">Form Name<span class="required" aria-required="true" style="color:red"><b>*</b></span></label>
                                                <div class="col-md-9">
                                                    <input class="form-control" type="text" value="" id="cdir">
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                    <!-- /.row (nested) -->
                                </div>
                                <!-- /.panel-body -->
                            </div>
                            <!-- /.panel -->
                        </div>
                        <!-- /.col-lg-12 -->
                    </div>
                    <!-- /.row -->
                </div>
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-success" id="CreateDir">Create Form</button>
                <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
<!-- Modal -->
<div id="myModal" class="modal fade" role="dialog">
    <div class="modal-dialog ">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header btn-primary">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">
                    Custom Field
                </h4>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-lg-12">
                        <div class="alert alert-danger alert-dismissable validpanel">
                            <button type="button" class="close" data-dismiss="alert" class="validpanel" aria-hidden="true">&times;</button>
                            . <a href="#" class="alert-link">Alert Link</a>.
                        </div>
                        <div class="panel panel-default">
                            <div class="panel-body">
                                <div class="row">
                                    <div class="col-lg-12" id="addcustomf">
                                        <form role="form" id="form2">
                                            <div class="form-group">
                                                <label class="control-label col-md-4">Custom Field Name <span class="required" aria-required="true" style="color:red"><b>*</b></span></label>
                                                <div class="col-md-8">
                                                    <input class="form-control" type="text" value="" id="txtcustomFieldName">
                                                </div>
                                            </div>
                                            <div class="form-group">
                                                <label class="control-label col-md-4">Custom Field Type <span class="required" aria-required="true" style="color:red"><b>*</b></span></label>
                                                <div class="col-md-8">
                                                    <select class="form-control" id="ctype">
                                                        <option value="0">-Select Any-</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div id="common">
                                                <div class="form-group">
                                                    <label class="control-label col-md-4" id="listid">List options</label>
                                                    <div class="col-md-8">
                                                        <input class="form-control" data-val="true" id="txtcustomFieldvalue" />
                                                        <p style="clear:both">(Add the options you would like to have in the drop down list list, separate values with a comma.)</p>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group" style="clear:both">
                                                <label class="control-label col-md-4">Is Required :</label>
                                                <div class="col-md-8">
                                                    <label class="switch">
                                                        <input type="checkbox" id="chkRequired" name="assign" value="1">
                                                        <span class="slider round"></span>
                                                    </label>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                    <!-- /.row (nested) -->
                                </div>
                                <!-- /.panel-body -->
                            </div>
                            <!-- /.panel -->
                        </div>
                        <!-- /.col-lg-12 -->
                    </div>
                    <!-- /.row -->
                </div>
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-success" id="addfield">Add Field</button>
                <button type="button" class="btn btn-default" data-dismiss="modal" id="closemodal">Close</button>
            </div>
        </div>
    </div>
</div>
    </div>
<!-- /.col-lg-12 -->
<script>
    $(document).on("click", "#mymodal2", function () {
        $(".validpanel").css("display", "none");
        $('#myModal2').modal({ show: true });
    });
    $(document).on("click", "#addcustomfiled", function () {
        $(".validpanel").css("display", "none");
        $('#myModal').modal({ show: true });
    });
</script>
