<script>
    $(document).ready(function () {
        var batchsize = 3;
        var lastlength = 1;
        $("#nxt").click(function () {
            var length = $("#nxt").attr("dataval");
            lastlength = parseInt(length) + 1;
            $("#nxt").attr("dataval", lastlength);
            $("#prv").attr("dataval", length);
            laodcontent(batchsize, lastlength);
        });
        $("#prv").click(function () {
            var length = $("#prv").attr("dataval");
            if (parseInt(length) > 1) {
                lastlength = parseInt(length) - 1;
            }
            else {
                lastlength = parseInt(length);
            }
            $("#prv").attr("dataval", lastlength);
            $("#nxt").attr("dataval", length);
            laodcontent(batchsize, lastlength);
        });
        //////start news and article//////
        laodcontent2(10, 1);
        function laodcontent2(batch, length) {
            var formData = new FormData();
            var classtag = "";
            formData.append("batch", EncodeText(batch));
            formData.append("length", EncodeText(length));
            var html = "";
            try {
                var ajaxTime = new Date().getTime();
                $.ajax({
                    async: true,
                    type: "POST",
                    url: "/api/OcrInvoiceApi/Loadnewsandarticle",
                    dataType: 'json',
                    data: formData,
                    contentType: false,
                    processData: false,
                    success: function (response1) {
                        var totalTime = new Date().getTime() - ajaxTime;
                        console.log("details:" + totalTime);
                        var count = 0;
                        if (String(JSON.stringify(response1)).indexOf("title") == "-1") {
                            $("#nxt").css("display", "none");
                            $("#prv").css("display", "none");
                        }
                        else {
                            html += '<marquee scrolldelay = "150" class="topnews_marquee"  onmouseover = "this.stop();" onmouseout = "this.start();" >'
                            $.each(response1.Data, function (i, a) {
                                count = count + 1;
                                html += '&nbsp;&nbsp;' + a.title + ':' + a.updated + ' &nbsp;&nbsp; ||'
                                // Set the regex string
                            });
                            html += '</marquee >'
                            $("#updatenews3").empty().append(html);
                        }
                    },
                    failure: function (data) {
                        alert(data.responseText);
                    },
                    error: function (data) {
                        alert(data.responseText);
                    }
                });
            }
            catch (err) {
                alert(err.message);
                closeloader();
            }
        }
        laodcontent(batchsize, lastlength);
        function laodcontent(batch, length) {
            var formData = new FormData();
            var classtag = "";
            formData.append("batch", EncodeText(batch));
            formData.append("length", EncodeText(length));
            var html = "";
            try {
                var ajaxTime = new Date().getTime();
                openloader();
                $.ajax({
                    async: true,
                    type: "POST",
                    url: "/api/OcrInvoiceApi/Loadnewsandarticle",
                    dataType: 'json',
                    data: formData,
                    contentType: false,
                    processData: false,
                    success: function (response1) {
                        var totalTime = new Date().getTime() - ajaxTime;
                        console.log("details:" + totalTime);
                        var count = 0;
                        if (String(JSON.stringify(response1)).indexOf("title") == "-1") {
                            $("#nxt").css("display", "none");
                            $("#prv").css("display", "none");
                        }
                        else {
                            $.each(response1.Data, function (i, a) {
                                count = count + 1;
                                var uldlink = window.location.origin + "/home/NewsArticleContent?id=" + String(a.dateid).substring(0, 8) + "&token=" + String(a.dateid).substring(8, 14);
                                var uldlinktwitter = window.location.origin + "/home/NewsArticleContent?id=" + String(a.dateid).substring(0, 8) + "%26token%3d" + String(a.dateid).substring(8, 14);
                                var uldlinklinkedin = window.location.origin + "/home/NewsArticleContent?id%3D" + String(a.dateid).substring(0, 8) + "%26token%3D" + String(a.dateid).substring(8, 14);
                                var facebook = "https://www.facebook.com/sharer/sharer.php?s=100&p[url]=" + uldlink + "&icat=&p[title]=" + a.title + "&p[summary]=";
                                var twitter = "https://twitter.com/intent/tweet?text=" + a.title + "&url=" + uldlinktwitter + "&via=newsroom";
                                var linkedin = "https://www.linkedin.com/shareArticle?mini=true&url=" + window.location.origin + "/home/NewsArticleContent?id=20190903&token=155425&title=" + a.title + "&summary=&source=" + a.link + "";
                                var loclink = window.location.origin + "home/NewsArticleContent?id=" + String(a.dateid).substring(0, 8) + "%26token=" + String(a.dateid).substring(8, 14);
                                html += '<div st="' + a.dateid + '"  style="margin-bottom:15px;margin:auto;margin-top:10px;transition: 0.3s;">'
                                html += '<div class="ec_bg" style="' + classtag + '">'
                                html += '<div class=" row" style="margin-left: -5px;">'
                                html += '<div class="col-md-12">'
                                html += '<span style="font-family:verdana">'
                                html += 'Title:'
                                html += '</span>'
                                html += '<span style="font-weight:bold;font-family:verdana"> '
                                html += '' + a.title + ''
                                html += '</span>'
                                html += '</div>'
                                html += '</div>'
                                html += '<div class=" row" style="padding:3px;margin-left:-8px;">'
                                html += '<div class="col-md-12"><span style="font-family:verdana">Date: </span> <span id="" font-family:verdana>' + a.updated + '</span></div>'
                                html += '</div>'
                                html += '<div class=" row" style="margin-left:-5px;">'
                                html += '<div class="col-md-12" style="font-family:verdana;text-align: justify;"><span><b>Summary:</b></span>'
                                var regex = /(https?:\/\/([-\w\.]+)+(:\d+)?(\/([\w\/_\.]*(\?\S+)?)?)?)/ig
                                // Replace plain text links by hyperlinks
                                var summry = a.summary;
                                summry = summry.replace(regex, "<a href='$1' target='_blank'>$1</a>");
                                html += '<span id="" style="font-size:13px;" >' + summry + '</span>'
                                html += '</div>'
                                html += '</div>'
                                html += '<div class=" row" style="margin-left:-10px; padding:5px;">'
                                html += '<div class="col-md-12">'
                                html += '<span style="font-family:verdana">Link: </span><span><a href="' + a.link + '" title="click here to open link" target="_blank"><span class="sbtbtn" style="font-size:12px;"><i class="glyphicon glyphicon-link"></i> click here</span></a> </span>'
                                html += '</div>'
                                html += '</div>'
                                html += '<div class=" row" style="">'
                                html += '<div class="col-md-12 pull-right">'
                                html += '<span style="font-family:monospace;float:right">Share: '
                                html += '<a id = "socialnetwork" title="post share  to facebook" target="_new" href ="' + facebook + '" class="fa fa-facebook socialnetwork" ></a >'
                                html += '<a id="socialnetwork" title="post share  to twitter" target="_new" href ="' + twitter + '" class="fa fa-twitter socialnetwork" ></a >'
                                html += '<a  id="socialnetwork" title="post share  to linkedin" target="_new" href="' + linkedin + '" class="fa fa-linkedin socialnetwork"></a> '
                                html += '<a id="socialnetwork" style="display:none;float:right" title="post share  to whatsapp"  href="whatsapp://send?text=' + String(a.summary).replace(/"/g, "").replace(/'/g, "").replace(/&/g, "") + '"   data-action="share/whatsapp/share" class="fa fa-whatsapp socialnetwork"> </a > </span>'
                                html += '</div>'
                                html += '</div>'
                                html += '</div>'
                                html += '</div>'
                                // Set the regex string
                            });
                            $("#updatePanel").empty().append(html).hide().fadeIn(1000);
                            $("#nxt").css("display", "block");
                            if (parseInt($("#nxt").attr("dataval")) > 1) {
                                $("#prv").css("display", "block");
                            }
                            else {
                                $("#prv").css("display", "none");
                            }
                            $("#gotop").css("display", "none");
                            closeloader();
                        }
                    },
                    failure: function (data) {
                        alert(data.responseText);
                        closeloader();
                    },
                    error: function (data) {
                        alert(data.responseText);
                        closeloader();
                    }
                });
            }
            catch (err) {
                alert(err.message);
                closeloader();
            }
        }
    });
</script>
