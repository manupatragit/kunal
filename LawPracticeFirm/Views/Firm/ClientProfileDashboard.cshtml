        function loadclientcasenexthearingdata() {
            var html231 = '';
            var formData = new FormData();
            formData.append("token", clientid);
            //read assign using list
            var cn = 0;
            var d5 = $.ajax({
                async: true,
                type: "POST",
                url: "/api/CallApi/CaseNextHearingListbyClientId",
                dataType: 'json',
                data: formData,
                contentType: false,
                processData: false,
                success: function (response2) {
                    try {
                        $.when(
                            $.each(response2.Data, function (q, b) {
                                var tempstrng = "smcase" + b.ID;
                                var tempstrngcourt = "smcourt" + b.ID;
                                var tempstrngctype = "smctype" + b.ID;
                                var tempstrngbench = "smbench" + b.ID;
                                if (tempstrng == $("#smcase" + b.ID).attr("id")) {
                                    if (b.Nexthearing == "") {
                                        $("#smcase" + b.ID).text("NA");
                                    }
                                    else {
                                        $("#smcase" + b.ID).text(b.Nexthearing);
                                    }
                                }
                                if (tempstrngcourt == $("#smcourt" + b.ID).attr("id")) {
                                    $("#smcourt" + b.ID).text(b.vCourt);
                                }
                                if (tempstrngctype == $("#smctype" + b.ID).attr("id")) {
                                    $("#smctype" + b.ID).text(b.casetype);
                                }
                                if (b.benchname != "") {
                                    if (tempstrngbench == $("#smbench" + b.ID).attr("id")) {
                                        $("#smbench" + b.ID).text(b.benchname);
                                    }
                                }
                                else {
                                    $("#smbenchclass" + b.ID).css("display", "none");
                                }
                                $("#smbenchclassnull").css("display", "none");
                            })
                        ).then(function () {
                        });
                    }
                    catch (er) {
                        alert(er.message);
                    }
                },
                failure: function (data) {
                    alert(data.responseText);
                },
                error: function (data) {
                    alert(data.responseText);
                }
            });
            $.when(d5).then(function (data, textStatus, jqXHR) {
                closeload();
            });
        }
