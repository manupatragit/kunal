@{
    /**/
    Layout = null;
}
<!-- Page Content -->
<link href="~/Manupanel/validation/screen.css" rel="stylesheet" />
<script src="~/Manupanel/validation/jquery.validate.js"></script>
<script src="~/Scripts/Firm/Pages/ConfigTimer.js"></script>
<script src="~/Manupanel/ckeditor/ckeditor.js"></script>
<script src="~/Manupanel/ckeditor/samples/js/sample.js"></script>
<link href="~/Manupanel/ckeditor/samples/css/sampltes.css" rel="stylesheet" />
<link href="~/Manupanel/ckeditor/samples/toolbarconfigurator/lib/codemirror/neod.css" rel="stylesheet" />
<div class="modal-header btn-primary">
    <button type="button" class="close" id="closemodel" data-dismiss="modal">&times;</button>
    <h4 class="modal-title">
        New Time Entry
    </h4>
</div>
<div class="modal-body ">
    <!-- Main content -->
    <form id="savecallform" enctype="multipart/form-data">
        <!-- Start About boxes -->
        <div class="row">
            <div class="col-md-12">
                <fieldset>
                    <legend>Linked to</legend>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-xs-3">Client <span class="required" aria-required="true">*</span></label>
                        <div class="col-xs-8">
                            <select name="contact" class="form-control" id="contact" required>
                                <option value="" selected>Select Client...</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-xs-3">Case <span class="required" aria-required="true">*</span></label>
                        <div class="col-xs-8">
                            <select name="matter" class="form-control" id="matter" required>
                                <option value="" selected>Select Case...</option>
                            </select>
                        </div>
                    </div>
                </fieldset>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <fieldset>
                    <legend>New Time Entry</legend>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-xs-3">Item </label>
                        <div class="col-xs-8">
                            <select name="" class="form-control" id="item">
                                <option value="">Select </option>
                                <option value="Item A">Item A </option>
                                <option value="Item B">Item B </option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-xs-3">Date</label>
                        <div class="col-xs-8">
                            <input class="form-control" name="dt" type="date" placeholder="Date" id="dt" />
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-xs-3">Call Duration <span class="required" aria-required="true">*</span></label>
                        <div class="col-xs-8">
                            <input class="form-control" name="duration" type="text" required id="duration" placeholder="Format: 1h 10m 1s" value="0h:0m:0s" />
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-xs-3"> </label>
                        <div class="col-xs-6">
                            <button id="starttimer" type="button" class="btn save" style="float:left; width:200px; margin:0 10px 0 0px;"><span class="glyphicon glyphicon-time"></span>&nbsp;&nbsp;Start Timer</button>
                            <button id="stoptimer" type="button" class="btn save" style="float:left; width:200px; margin:0 10px 0 0px;display:none"><span class="glyphicon glyphicon-pause"></span>&nbsp;&nbsp;Stop Timer</button>
                            <div class="timer pull-left " id="countdown2">0h:0m:0s</div>
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-xs-3">Description</label>
                        <div class="col-xs-8">
                            <textarea id="details" cols="15" class="valid" aria-invalid="false" style="margin: 0px; width: 484px; height: 93px;"></textarea>
                            <div class="grid-container" style="display:none">
                                <div id="editor">
                                </div>
                                <script>
                                    initSample();
                                    CKEDITOR.replace('details', {
                                        toolbar:
                                            [
                                                { name: 'basicstyles', items: ['Bold', 'Italic'] },
                                                { name: 'paragraph', items: ['NumberedList', 'BulletedList'] },
                                                { name: 'tools', items: ['Maximize',] }
                                            ],
                                        height: 80,
                                        width: 385
                                    });
                                </script>
                            </div>
                        </div>
                    </div>
                </fieldset>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <fieldset>
                    <legend>Billing</legend>
                    <div class="form-group form-horizontal" style="margin-top:10px;">
                        <label class="control-label col-xs-3">Billable</label>
                        <div class="col-xs-8">
                            <label class="switch">
                                <input type="checkbox" id="billable" name="billable" value="true">
                                <span class="slider round"></span>
                            </label>
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-xs-3">Billed By:</label>
                        <div class="col-xs-8">
                            <select name="" class="form-control" id="billby">
                                <option value="">Select user...</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-xs-3">Hourly Rate (INR)</label>
                        <div class="col-xs-8">
                            <input class="form-control" name="dt" type="number" placeholder="Rate" id="hrate" />
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-xs-3">Total</label>
                        <div class="col-xs-8">
                            <input class="form-control" name="dt" type="number" placeholder="Rate" id="total" />
                        </div>
                    </div>
                    <div class="form-group form-horizontal">
                        <label class="control-label col-xs-3">Private Notes</label>
                        <div class="col-xs-8">
                            <textarea ID="privnotes" cols="15" style="margin: 0px; width: 387px; height: 89px;"></textarea>
                        </div>
                    </div>
                </fieldset>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="form-actions ">
                    <div class="btn-group">
                        <div class="modal-footer">
                            <input type="submit" id="savecall" class="btn save" value="save">
                            <button type="reset" id="resetform" class="btn btn-default">Reset</button>
                            <button type="button" id="closemodels" class="btn btn-default" data-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- /.content -->
    </form>
</div>
<script src="~/Manupanel/js/bootstrap.min.js"></script>
