@*edit limitation*@
<div class="modal fade" id="modalLimitation" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" data-backdrop="false">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header btn-primary">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true" style="font-size:unset !important">&times;</span></button>
                <div id="divusergroupLabel"><h4 class="modal-title" id="myModalLabel">Set Action - Period of Limitation</h4></div>
            </div>
            <div class="modal-body " style="height:450px; overflow:auto">
                <!-- Main content -->
                <form enctype="multipart/form-data" novalidate="novalidate">
                    <!-- Start About boxes -->
                    <div class="row">
                        <div class="col-md-12">
                            <ul class="nav nav-tabs">
                                <li class="active"><a data-toggle="tab" href="#createlimit">Create</a></li>
                                <li><a data-toggle="tab" href="#viewlimit">View</a></li>
                            </ul>
                            <div class="tab-content">
                                <div id="createlimit" class="tab-pane fade in active">
                                    <fieldset class="ec_bg" style="overflow:scroll">
                                        <div class="form-group ">
                                            <label class="formLabel colorDark col-md-12">Limitation Applicable&nbsp;</label>
                                            <div class="col-md-12">
                                                <input id="LimitationApplicable" name="LimitationApplicable" type="text" class="form-control inputFormat" readonly />
                                            </div>
                                        </div>
                                        <br /><br />
                                        <div class="form-group ">
                                            <label class="formLabel colorDark col-md-12">Provision&nbsp;</label>
                                            <div class="col-md-12">
                                                <input id="Provision" name="Provision" type="text" class="form-control inputFormat" readonly />
                                            </div>
                                        </div>
                                        <div class="form-group ">
                                            <label class="formLabel colorDark col-md-12">Start Date<span class="required" aria-required="true">*</span>&nbsp;</label>
                                            <div class="col-md-12">
                                                <input id="ddate" name="ddate" type="date" class="form-control inputFormat" />
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <label class="formLabel colorDark col-md-12">Due Date<span class="required" aria-required="true">*</span>&nbsp;</label>
                                            <div class="col-md-12">
                                                <input id="duedate" name="duedate" type="text" class="form-control inputFormat" readonly />
                                            </div>
                                        </div>
                                        <div class="form-group ">
                                            <label class="formLabel colorDark col-md-12">Remarks<span class="required" aria-required="true">*</span>&nbsp;</label>
                                            <div class="col-md-12">
                                                <textarea id="Remarks" name="Remarks" maxlength="2000" class="form-control inputFormatTextArea" rows="25" cols="5" style="height:65px !important;"></textarea>
                                            </div>
                                        </div>
                                        <div class="form-group " style="display:none;">
                                            <label class="formLabel colorDark col-md-12">Attachments&nbsp;</label>
                                            <div class="col-md-12">
                                                <input type="file" multiple id="attachmentcase" name="attachmentcase" style="border-bottom:none !important;" class="form-control inputFormat">
                                            </div>
                                        </div>
                                        <div class="form-group ">
                                            <label class="formLabel colorDark col-md-12"> Enter Days<span class="required" aria-required="true">*</span>&nbsp;</label>
                                            <div class="col-md-12">
                                                <input type="text" id="chkdate" onkeypress="return isNumberKey(event)" class="form-control inputFormat" minlength="1" maxlength="2" />
                                            </div>
                                        </div>
                                        <div class="form-group " style="margin-top:5px;clear:both">
                                            <label class="control-label col-md-12">User(s)<span class="required" aria-required="true">*</span>&nbsp;</label>
                                            <div class="col-md-12">
                                                <a href="javascript:void()" class="dropdown-toggle selctInputFormat" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                    <label id="lblTeammemberSelectlimit" style="color: #7c7777;font-size: 12px;font-weight: 500;text-transform:unset;width:200px;">Select</label>
                                                </a>
                                                <ul class="dropdown-menu settingshowhide" id="rUsers" style="width:200px!important;"></ul>
                                            </div>
                                        </div>
                                        <div class="form-group form-horizontal" style="display:none;">
                                            <label class="control-label col-md-3">Set Alert&nbsp;</label>
                                            <div class="col-md-9">
                                                <input id="setalert" name="setalert" type="checkbox" checked class="form-control" />
                                            </div>
                                        </div>
                                    </fieldset>
                                    <input type="hidden" id="hidid">
                                    <input type="hidden" id="hidcaid">
                                    <input type="hidden" id="hidDueDays">
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-primary" id="rSaveLimitation">Save</button>
                                    </div>
                                </div>
                                <div id="viewlimit" class="tab-pane fade">
                                    <div class="table-panel table-responsive" data-example-id="hoverable-table" id="home">
                                        <h2 class="title">Alert Date</h2>
                                        <table class="table">
                                            <thead>
                                                <tr>
                                                    <th><div class="thbg">Due Date</div></th>
                                                    <th><div class="thbg">Alert Date</div></th>
                                                </tr>
                                            </thead>
                                            <tbody id="bindalertdate"></tbody>
                                        </table>
                                        <center><div id="dataalertdatestatus"></div></center>
                                    </div>
                                    <div class="table-panel table-responsive" data-example-id="hoverable-table" id="home">
                                        <h2 class="title">User(s)</h2>
                                        <table class="table ">
                                            <thead>
                                                <tr>
                                                    <th><div class="thbg">Name</div></th>
                                                    <th><div class="thbg">Email</div></th>
                                                    <th><div class="thbg">Mobile</div></th>
                                                </tr>
                                            </thead>
                                            <tbody id="bindalertuser"></tbody>
                                        </table>
                                        <center><div id="dataalertuserstatus"></div></center>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- /.content -->
                </form>
            </div>
        </div>
    </div>
</div>
@*end edit limitation*@
@*set action limitation*@
<div class="modal fade" id="modalactionLimitation" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" data-backdrop="false">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header btn-primary">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true" style="font-size:unset !important">&times;</span></button>
                <div id="divusergroupLabel"><h4 class="modal-title" id="myModalLabel">Set Action - Period of Limitation</h4></div>
            </div>
            <div class="modal-body " style="min-height:300px; overflow:auto">
                <!-- Main content -->
                <form enctype="multipart/form-data" novalidate="novalidate">
                    <!-- Start About boxes -->
                    <div class="row">
                        <div class="col-md-12">
                            <fieldset class="ec_bg" style="overflow: scroll;">
                                <div class="form-group ">
                                    <label class="control-label colorDark  col-md-12">Limitation Applicable&nbsp;</label>
                                    <div class="col-md-12">
                                        <input id="actionLimitationApplicable" name="actionLimitationApplicable" type="text" class="form-control inputFormat " readonly />
                                    </div>
                                </div>
                                <br /><br />
                                <div class="form-group ">
                                    <label class="control-label colorDark   col-md-12">Provision&nbsp;</label>
                                    <div class="col-md-12">
                                        <input id="actionProvision" name="actionProvision" type="text" class="form-control inputFormat" readonly />
                                    </div>
                                </div>
                                <div class="form-group ">
                                    <label class="control-label colorDark  col-md-12">Attachments&nbsp;</label>
                                    <div class="col-md-12">
                                        <input type="file" multiple id="actionattachmentcase" name="actionattachmentcase" style="border-bottom:none !important;top:5px;" class="form-control inputFormat">
                                    </div>
                                </div>
                                <div class="form-group ">
                                    <label class="control-label colorDark  col-md-12">Due Date&nbsp;</label>
                                    <div class="col-md-12">
                                        <input id="dduedate" name="dduedate" type="text" class="form-control inputFormat" readonly />
                                    </div>
                                </div>
                                <div class="form-group ">
                                    <label class="control-label colorDark  col-md-12">Action&nbsp;</label>
                                    <div class="col-md-12">
                                        <select id="actionDone" class="form-control inputFormat">
                                            <option value="0">Pending</option>
                                            <option value="1">Done</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="form-group ">
                                    <label class="control-label colorDark  col-md-12">Remarks</label>
                                    <div class="col-md-12">
                                        <textarea id="sremarks" name="sRemarks" class="form-control" rows="25" cols="5" style="height:65px !important;" maxlength="2000"></textarea>
                                    </div>
                                </div>
                            </fieldset>
                        </div>
                    </div>
                    <!-- /.content -->
                    <input type="hidden" id="hidid">
                    <input type="hidden" id="hidcaid">
                    <div class="modal-footer">
                        <button type="button" class="btn btn-primary" id="actionSaveLimitation">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@*end set action limitation*@
