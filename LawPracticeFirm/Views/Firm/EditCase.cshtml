<style>
    .overlay {
        height: 100%;
        width: 100%;
        display: none;
        position: fixed;
        z-index: 1;
        top: 0;
        left: 0;
        background-color: rgb(0,0,0);
        background-color: rgba(0,0,0, 0.4);
    }

    .overlay-content {
        position: relative;
        top: 46%;
        width: 80%;
        text-align: center;
        margin-top: 30px;
        margin: auto;
        color: white;
    }

    .overlay .closebtn {
        position: absolute;
        top: 20px;
        right: 45px;
        font-size: 60px;
        cursor: pointer;
        color: white;
    }

        .overlay .closebtn:hover {
            color: #ccc;
        }

    .add {
        color: #000000;
        font-size: 14px;
        border: 1px solid #d5d7da;
        border-radius: 0 7px 7px 0px;
        padding: 9px 11px 9px 11px;
        text-align: center;
        margin: 0 0 0 -2px;
        display: flex;
        gap: 2px;
        align-items: center;
        font-weight: 600;
    }

    .selectize-input {
        padding: 3px 5px 0 0 !important;
    }

    .spacer-h {
        min-height: 70px;
    }

    .selectize-input > input {
        font-size: 16px !important;
        width: 100% !important;
    }

    .form-grouph {
        height: 80px;
    }


    .inputFormatTextArea {
        border-radius: 7px !important;
        height: 72px !important;
        margin-top: 0px !important;
        padding: 7px 10px !important;
        border: 1px solid #d5d7da !important;
        background: #ffffff !important;
        font-size: 16px !important;
        font-weight: 400 !important;
    }

    .selectize-control.multi .selectize-input.has-items {
        max-height: 100px;
        overflow-y: auto;
    }

    label {
        display: block;
        margin-bottom: 5px;
    }
</style>
