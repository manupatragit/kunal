<script>
    var roleids = "@Session["sessionroleid"]";
    $(document).on('keypress', '#OppositePartyCounselphone,#fCourtfee', function (event) {
        var regex = new RegExp("^[0-9]+$");
        var key = String.fromCharCode(!event.charCode ? event.which : event.charCode);
        if (!regex.test(key)) {
            event.preventDefault();
            return false;
        }
    });
</script>
<script>
    $(document).on('click', 'div .clientdefault .selectize-input div.item', function (e) {
        var select = $('#clientto').selectize();
        var selectSizeControl = select[0].selectize;
        // 1. Get the value
        var selectedValue = $(this).attr("data-value");
        // 2. Remove the option
        select[0].selectize.removeItem(selectedValue);
        select[0].selectize.refreshItems();
        select[0].selectize.refreshOptions();
        $(".div.selectize-input div.item").css("padding", "7px 10px");
    });
    $(document).on('click', 'div .userdefault .selectize-input div.item', function (e) {
        var select = $('#assignto').selectize();
        var selectSizeControl = select[0].selectize;
        // 1. Get the value
        var selectedValue = $(this).attr("data-value");
        // 2. Remove the option
        select[0].selectize.removeItem(selectedValue);
        select[0].selectize.refreshItems();
        select[0].selectize.refreshOptions();
        $(".div.selectize-input div.item").css("padding", "7px 10px");
    });
</script>
