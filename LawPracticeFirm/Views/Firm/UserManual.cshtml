<script>
    function showSection(id, btn) {
        // Hide all sections
        var sections = document.getElementsByClassName('section');
        for (var i = 0; i < sections.length; i++) {
            sections[i].style.display = 'none';
        }

        // Remove 'active' class from all buttons
        var buttons = document.getElementsByClassName('btn1');
        for (var j = 0; j < buttons.length; j++) {
            buttons[j].className = buttons[j].className.replace(' active', '');
        }

        // Show selected section
        var el = document.getElementById(id);
        if (el) el.style.display = 'block';

        // Mark clicked button as active
        if (btn) btn.className += ' active';

        // 🔹 Only close accordions if NOT a sub-button
        if (!btn.className.includes('subbtn')) {
            var subs = document.getElementsByClassName('sub');
            for (var k = 0; k < subs.length; k++) {
                subs[k].style.display = 'none';
            }
            var collapsibles = document.getElementsByClassName('collapsible');
            for (var l = 0; l < collapsibles.length; l++) {
                collapsibles[l].className = collapsibles[l].className.replace(' active', '');
            }
        }
    }

    function toggleAccordion(accId, btn) {
        var sub = document.getElementById('sub-' + accId);
        if (!sub) return;

        var isVisible = sub.style.display === 'block';

        // Close all other accordions
        var subs = document.getElementsByClassName('sub');
        for (var i = 0; i < subs.length; i++) {
            subs[i].style.display = 'none';
        }

        // Remove 'active' class from all collapsible buttons
        var collapsibles = document.getElementsByClassName('collapsible');
        for (var j = 0; j < collapsibles.length; j++) {
            collapsibles[j].className = collapsibles[j].className.replace(' active', '');
        }

        // Toggle clicked one
        if (!isVisible) {
            sub.style.display = 'block';
            btn.className += ' active';
        } else {
            sub.style.display = 'none';
        }
    }
</script>

<script>
    window.onload = function () {
        showSection('copyright', document.querySelector('.btn1[onclick*="copyright"]'));
    };
</script>


