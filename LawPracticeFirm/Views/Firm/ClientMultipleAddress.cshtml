                    <img src="/newassets/img/delete-notice.png" style="margin:-10px 0px 0 -13px">
                </h4>
            </div>
            <div class="modaltitle" style="margin: -33px 0 0 0; border-bottom: none;">
                <h4 id="ids_deleteTraderequesr">Delete Request</h4>
            </div>
            <div class="modal-body">
                <p id="msgRUSure">Are you sure you want to delete this Address.</p>
            </div>
            <div class="footer_buttons modal-footer">
                <button class="btn btn-secondary" id="" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary" id="deleteListDetails">Confirm</button>
            </div>
        </div>
    </div>
</div>
