@{
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
}
<script src="~/Scripts/Firm/Pages/ClientMultipleAddress.js?1.9"></script>
<style>
    .form-group {
        padding-top: 10px;
    }
</style>
<section class="wrapper">
    <div class="container-main">
        <section id="header">
            <div class="container-main">
                <div class="text-left">
                    <a class="goback" id="goBack" href="/@Session["firmcode"]/Firm/ContactsList"><img src="/newassets/img/backarrow.svg" alt="">Go Back</a>
                    <h3 style="margin-top:0px;">Client Multiple Address</h3>

                </div>
            </div>
        </section>
        <section class="content_wrapper">
            <div class="form_wrapper_main">

                <form class="row ec_bg" id="savemultipleaddress">
                    @*<div class="col-md-3">
                            <label class="formLabel colorDark">Contact Type<span class="required" aria-required="true">*</span> </label>
                            <select id="Clistctypeaddress" name="Clistctypeaddress" class=" dropdown-toggle form-control selctInputFormat" style="background-color: white !important;"></select>
                        </div>*@
                    <div class="col-md-4" style="display:none" id="Propectdiv">
                        <div class="form-group">
                            <label class="formLabel colorDark">Select Contact<span class="required" aria-required="true">*</span> </label>
                            <select class="form-control selctInputFormat" style="background-color: white !important;" id="multipleAddressContact"></select>

                        </div>

                    </div>
                    <div class="col-md-4" id="clientdiv">
                        <div class="form-group">
                            <label class="formLabel colorDark">Select Client<span class="required" aria-required="true">*</span> </label>
                            <select class="form-control selctInputFormat" style="background-color: white !important;" id="multipleAddressClient"></select>
                        </div>

                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="formLabel colorDark">Select Country<span class="required" aria-required="true">*</span> </label>
                            <select class="form-control selctInputFormat" style="background-color: white !important;" id="aCountry">
                                <option value="">Select</option>
                            </select>
                        </div>

                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="formLabel colorDark">Select State<span class="required" aria-required="true">*</span> </label>
                            <select class="form-control selctInputFormat" style="background-color: white !important;" id="aState">
                                <option value="">Select</option>
                            </select>
                        </div>

                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="formLabel colorDark">Select City<span class="required" aria-required="true">*</span> </label>
                            <select class="form-control selctInputFormat" style="background-color: white !important;" id="aCity">
                                <option value="">Select</option>
                            </select>
                        </div>

                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="formLabel colorDark ">Pincode <span class="required" aria-required="true">*</span> </label>
                            <input type="text" class="form-control inputFormat" id="aPincode" name="aPincode" onkeypress="return isNumberKey(event)" placeholder="Enter Pincode" maxlength="6" minlength="6">
                        </div>

                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="formLabel colorDark">GST No.  </label>
                            <input type="text" class="form-control inputFormat" id="aGST" name="aGST" placeholder="Enter GST No." maxlength="15">
                        </div>

                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="formLabel colorDark " minlength="10">PAN No.  </label>
                            <input type="text" class="form-control inputFormat" id="aPAN" name="aPAN" placeholder="Enter PAN No." maxlength="10">
                        </div>

                    </div>
                    <div class="col-md-8">
                        <div class="form-group">
                            <label class="formLabel colorDark">Address <span class="required" aria-required="true">*</span> </label>
                            <textarea class="form-control1 form-control inputFormatTextArea" rows="3" id="mAddress" name="mAddress" placeholder="Enter Address"></textarea>
                        </div>

                    </div>
                    <div class="col-md-12">
                        <div class="form-group">
                            <button type="button" class="btn btn-primary" id="savecontactaddress">Save</button>
                        </div>
                    </div>

                </form>
                <input type="hidden" id="hiddenAddIt">
            </div>

