@if (ViewBag.HierarchyCustomtype != null && ViewBag.HierarchyCustomtype.ToString() == "HierarchyCustomtype")
{
<script>
    $(document).ready(function () {
        var lvlNames = ['', 'CP', 'Zonal', 'Range', 'District', 'Sub-District', 'PS'];
        var allUsers = [];

        function getUsersByLevel(level, parentId) {
            return $.grep(allUsers, function (u) {
                var ul = parseInt(u.UserLevel) || 0;
                if (ul !== level) return false;
                if (parentId !== undefined && parentId !== null && parentId !== '') {
                    return String(u.ParentUserId) === String(parentId);
                }
                return true;
            });
        }

        function populateDropdown($dd, level, parentId, placeholder) {
            var users = getUsersByLevel(level, parentId);
            $dd.empty();
            $dd.append('<option value="">' + (placeholder || 'Select ' + lvlNames[level]) + '</option>');
            var added = 0;
            $.each(users, function (i, u) {
                $dd.append('<option value="' + u.Id + '" data-level="' + u.UserLevel + '">' +
                    u.UserFullName + ' (' + lvlNames[level] + ')</option>');
                added++;
            });
            if (added === 0) {
                $dd.html('<option value="">No ' + lvlNames[level] + ' users yet</option>');
                return 0;
            }
            if (added === 1) {
                $dd.find('option:eq(1)').prop('selected', true);
                $dd.trigger('change');
            }
            return added;
        }

        // Build cascade: levels 2 through N-1 (last one IS the Reports To)
        function buildCascadeUI(newUserLevel) {
            var cascadeHtml = '';
            for (var lvl = 2; lvl <= newUserLevel - 1; lvl++) {
                var selectId = 'hierarchyCascadeLvl' + lvl;
                var isLast = (lvl === newUserLevel - 1);
                var labelText = 'Select ' + lvlNames[lvl] + (isLast ? ' (Reports To)' : '');
                cascadeHtml += '<div class="form-group col-md-3">' +
                    '<label>' + labelText + ' <span class="required"><b>*</b></span></label>' +
                    '<select id="' + selectId + '" class="form-control selctInputFormat hierarchyCascade" data-level="' + lvl + '">' +
                    '<option value="">-- Loading --</option></select></div>';
            }
            $('#hierarchyCascadeContainer').html(
                cascadeHtml ? '<div id="hierarchyCascadeRows" class="row">' + cascadeHtml + '</div>' : ''
            );
        }

        // Filter Reports To hint
        function updateHint(newUserLevel) {
            var sel = $('#hierarchyParentUser').find('option:selected');
            var parentLevel = parseInt(sel.data('level') || '0');
            if (parentLevel > 0 && newUserLevel > 0) {
                $('#hierarchyParentHint').text(
                    'New: Lvl ' + newUserLevel + ' (' + lvlNames[newUserLevel] +
                    ') → reports to Lvl ' + parentLevel + ' (' + lvlNames[parentLevel] + ')'
                );
            }
        }

        // --- MAIN ---
        $('#hierarchyNewUserLevel').off('change').on('change', function () {
            var newUserLevel = parseInt($(this).val() || '0');
            $('#hdnNewUserLevel').val(newUserLevel);
            $('#hierarchyCascadeContainer').html('');
            $('#hierarchyParentUser').val('');

            // Level 1 (CP) cannot be created
            if (newUserLevel === 2) {
                // Zonal → Reports To = CP, no cascade
                $('#reportsToGroup').show();
                $('#hierarchyParentUser').html('<option value="' + loggedInUserId + '" data-level="1" selected>CP (Auto - You)</option>');
                $('#hierarchyParentHint').text('Zonal always reports to CP');
                return;
            }

            if (newUserLevel >= 3) {
                // Hide the original Reports To — it will appear inside the cascade
                $('#reportsToGroup').hide();
                $('#hierarchyParentUser').html('<option value="">Loading...</option>');

                $.ajax({
                    type: "POST",
                    url: "/api/CallApi/LoadHierarchyParentUsers",
                    contentType: false,
                    processData: false,
                    success: function (response) {
                        var users = response.Data;
                        if (users && typeof users === 'object' && !Array.isArray(users) && users.Data !== undefined)
                            users = users.Data;
                        if (typeof users === 'string')
                            try { users = JSON.parse(users); } catch(e) { users = []; }

                        if (!users || !users.length) {
                            $('#hierarchyParentUser').html('<option value="">No users found</option>');
                            return;
                        }
                        allUsers = users;

                        // Build cascade UI including Reports To level (2 through N-1)
                        buildCascadeUI(newUserLevel);

                        // Wire events BEFORE population so auto-select cascades work
                        wireCascadeEvents(newUserLevel);

                        // Populate top level (Zonal = level 2) — cascade flows down from here
                        var $topDD = $('#hierarchyCascadeLvl2');
                        if ($topDD.length) {
                            populateDropdown($topDD, 2, null);
                        }
                    },
                    error: function () {
                        $('#hierarchyParentUser').html('<option value="">API unavailable</option>');
                    }
                });
            } else {
                $('#reportsToGroup').show();
                $('#hierarchyParentUser').html('<option value="">-- First select New User Level --</option>');
                $('#hierarchyParentHint').text('');
            }
        });

        function wireCascadeEvents(newUserLevel) {
            var deepestLevel = newUserLevel - 1;  // Reports To level
            for (var lvl = 2; lvl <= deepestLevel; lvl++) {
                (function (currentLevel) {
                    $('#hierarchyCascadeLvl' + currentLevel).off('change').on('change', function () {
                        var selectedId = $(this).val();
                        var nextLevel = currentLevel + 1;

                        if (nextLevel <= deepestLevel) {
                            // Filter next cascade dropdown
                            var $nextDD = $('#hierarchyCascadeLvl' + nextLevel);
                            if ($nextDD.length) {
                                var label = lvlNames[nextLevel] + (nextLevel === deepestLevel ? ' (Reports To)' : '');
                                populateDropdown($nextDD, nextLevel, selectedId || null, 'Select ' + label);
                            }
                        }

                        // If deepest level changed, set hidden hierarchyParentUser value
                        if (currentLevel === deepestLevel) {
                            // Must set innerHTML (not .val()) because the select has no matching option
                            $('#hierarchyParentUser').html(
                                '<option value="' + selectedId + '" selected data-level="' + currentLevel + '"></option>'
                            );
                            $('#hierarchyParentHint').text(
                                'New: Lvl ' + newUserLevel + ' (' + lvlNames[newUserLevel] +
                                ') → reports to Lvl ' + currentLevel + ' (' + lvlNames[currentLevel] + ')'
                            );
                        }
                    });
                })(lvl);
            }
        }
    });
</script>
}