<script>
    $(document).ready(function () {
        if (stfUser > 0) {
            $("#StfHide").hide();
            $("#stfFirmFiled").hide();
        } else {
            $("#StfHide").show();
            $("#stfFirmFiled").show();

        }

        var $select = $("#firmexperience");
        $select.append($('<option ></option>').val("").html("Select"));
        for (i = 1; i <= 25; i++) {
            $select.append($('<option></option>').val(i).html(i))
        }
        try {
            var ddlCountry = $('#cocountry');
            $.ajax({
                async: true,
                url: '/api/EmployeeApi/BindCountryDetails',
                type: 'POST',
                dataType: 'json',
                success: function (d) {
                    $.each(d.Data, function (i, country) {
                        ddlCountry.append($("<option selected></option>").val(country.CountryName).html(country.CountryName));
                    });
                },
                error: function (d) {
                    alert(d.responseText);
                }
            });
        }
        catch (err) {
            alert(err.message);
        }
        //auto state
        try {
            var CountryId = "India";
            var ddlState = $('#costate');
            ddlState.empty();
            ddlState.append($("<option></option>").val('').html('Please wait ...'));
            var ddCity = $('#cocity');
            ddCity.empty();
            ddCity.append($("<option value='' selected ></option>").val('').html('Select'));
            $.ajax({
                async: true,
                url: '/api/EmployeeApi/BindStateDetails',
                type: 'POST',
                dataType: 'json',
                headers: { CountryName: CountryId },
                success: function (d) {
                    ddlState.empty();
                    // Clear the please wait
                    ddlState.append($("<option value='' selected ></option>").val('').html('Select'));
                    $.each(d.Data, function (i, states) {
                        ddlState.append($("<option></option>").val(states.StateName).html(states.StateName));
                    });
                },
                error: function (d) {
                    alert(d.responseText);
                }
            });
        }
        catch (err) {
            alert(err.message);
        }
        //State details by country id
        $("#cocountry").change(function () {
            var CountryId = $(this).val();
            if (CountryId != "India") {
                $("#ostate").css("display", "unset");
                $("#ocity").css("display", "unset");
                $("#lstate").css("display", "none");
                $("#lcity").css("display", "none");
                return false;
            }
            else {
                $("#ostate").css("display", "none");
                $("#ocity").css("display", "none");
                $("#lstate").css("display", "unset");
                $("#lcity").css("display", "unset");
            }
            var ddlState = $('#costate');
            ddlState.empty();
            ddlState.append($("<option></option>").val('').html('Please wait ...'));
            var ddCity = $('#cocity');
            ddCity.empty();
            ddCity.append($("<option value='' selected ></option>").val('').html('Select City'));
            $.ajax({
                async: true,
                url: '/api/EmployeeApi/BindStateDetails',
                type: 'POST',
                dataType: 'json',
                headers: { CountryName: CountryId },
                success: function (d) {
                    ddlState.empty();
                    // Clear the please wait
                    ddlState.append($("<option value='' selected ></option>").val('').html('Select'));
                    $.each(d.Data, function (i, states) {
                        ddlState.append($("<option></option>").val(states.StateName).html(states.StateName));
                    });
                },
                error: function (d) {
                    alert(d.responseText);
                }
            });
        });
        //City Bind By satate id
        $("#costate").change(function () {
            var StateId = $(this).val();
            var ddlCity = $('#cocity');
            ddlCity.append($("<option></option>").val('').html('Please wait ...'));
            $.ajax({
                async: true,
                url: '/api/EmployeeApi/BindCityDetails',
                type: 'POST',
                dataType: 'json',
                headers: { StateName: StateId },
                success: function (d) {
                    ddlCity.empty(); // Clear the plese wait
                    ddlCity.append($("<option value'' selected></option>").val('').html('Select'));
                    $.each(d.Data, function (i, cities) {
                        ddlCity.append($("<option></option>").val(cities.CityName).html(cities.CityName));
                    });
                },
                error: function (d) {
                    alert('Error!'); alert(d.responseText);
                }
            });
        });

        window.addEventListener('DOMContentLoaded', () => {
            const firstHeader = document.querySelector('.section-header');
            if (firstHeader) {
                toggleSection(firstHeader);
            }
        });


    });
    function toggleSection(header) {
        const allSections = document.querySelectorAll('.section-content');
        const allIcons = document.querySelectorAll('.toggle-icon');

        const content = header.nextElementSibling;
        const icon = header.querySelector('.toggle-icon');

        allSections.forEach(sec => {
            if (sec !== content) sec.style.display = 'none';
        });

        allIcons.forEach(ic => {
            if (ic !== icon) ic.classList.remove('rotate');
        });

        const isOpen = content.style.display === 'block';
        content.style.display = isOpen ? 'none' : 'block';
        icon.classList.toggle('rotate', !isOpen);
    }
</script>
