</aside>
<script>
    $('#select-user').selectize({
    });
    var $select = $("#select-user").selectize();
    if (token != "") {
        setTimeout(function () {
            var formData = new FormData();
            formData.append("token", token);
            $.ajax(
                {
                    type: "POST",
                    url: "/api/callApi/CustomActivtiyAssignUser", // Controller/View
                    data: formData,
                    contentType: false,
                    processData: false,
                    success: function (response) {
                        var dataarray = [];
                        $.each(response.Data, function (i, b) {
                            try {
                                var selectize = $select[0].selectize;
                                var selecteduser = b.auserid;
                                dataarray.push(selecteduser)
                            }
                            catch (er) {
                                alert(er.message);
                            }
                            selectize.setValue(dataarray)
                        });
                    },
                    failure: function (response) {
                        alert(data.responseText);
                    },
                    error: function (response) {
                        alert(data.responseText);
                    }
                });
        }, 1000);
    }
    else {
    }
</script>
