@{
    /**/
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
    var userid = Session["sessionuserid"];
}
<script>
     var newfilesize = 20480;
    var roleids = "@Session["sessionroleid"]";
</script>
<script src="~/Scripts/Firm/Pages/PdfDocConverter.js?1.3"></script>
<section class="wrapper">
    <div class="pdf_convertor">
        <div class="container_convertor showcontent" id="showcontent">
            <div class="conInner_wrapper"
                 style="font-family: 'Inter', sans-serif; background: #FAFAFA; width: 612px; height: 436px; border: 1px solid #E9EAEB; border-radius: 12px; padding: 40px 48px; box-sizing: border-box; margin: 100px auto;">

                <h4 style="margin: 0 0 24px 0; font-size: 20px; font-weight: 600; color: #111827;">Convert PDF to Doc</h4>

                <div class="ec_bg"
                     style="width: 100%; height: 260px; border: 1px solid #E5E7EB; border-radius: 12px; background: #FFFFFF; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; cursor: pointer;">

                    <div class="form-group" style="display: none;">

                        <label style="font-size: 14px; color: #374151;">Conversion Type</label>
                        <select class="form-control" id="conversion"
                                style="margin-top: 8px; padding: 8px; border-radius: 8px; border: 1px solid #D1D5DB;">
                            <option value="PDFTOW" selected>PDF to word</option>
                        </select>
                    </div>

                    <div class="form-group" style="display: flex; flex-direction: column; align-items: center;">
                        <label class="formLabel colorDark" style="display: none;">Select Document</label>

                        <div class="upload-icon"
                             style="width: 40px; height: 40px; background: #F9FAFB; border-radius: 8px; display: flex; align-items: center; justify-content: center; margin-bottom: 12px; border: 1px solid #E5E7EB;">
                            <img src="/newassets/img/upload-cloud.svg" alt="Upload Icon" style="width: 24px; height: 24px;">
                        </div>


                        <input type="file" id="attachment" class="form-control inputformat" value="AA" style="display: none;">

                        <label for="attachment"
                               style="display: inline-block; cursor: pointer; color: #0369A1; font-weight: 500; font-size: 14px;">
                            Click to upload

                            <span style="font-size: 14px; color: #4B5563;"> or drag and drop</span>
                        </label>

                        <p style="margin: 4px 0 12px; font-size: 12px; color: #9CA3AF;">PDF (max. 5mb)</p>

                        @*<input type="file" id="attachment" class="form-control inputformat" value="AA" style="display: none;">*@
                    </div>
                    <div id="fileListDocs" style="margin-top:10px;"></div>
                    <div class="doc_download" style="margin-top: 16px;">
                        <div class="form-group" style="text-align: center;">
                            <button type="button" class="btn btn-primary" id="savecasefilenew"
                                    style="padding: 8px 16px; border-radius: 8px; background-color: #0369A1; border: none; color: white; font-size: 14px; cursor: pointer;">
                                Convert to Doc
                            </button>
                        </div>
                        <div class="form-group">
                            <div id="container"></div>
                        </div>
                    </div>

                </div>
            </div>
    </div>
</section>
<div id="myOverlay" class="overlay">
    <div class="overlay-content">
        <div class="spinner2">
            <div><img src="~/newassets/images/MyKase_Loader.gif" height="59" width="150"></div>
        </div>
    </div>
</div>
<style>
    .overlay {
        height: 100%;
        width: 100%;
        display: none;
        position: fixed;
        z-index: 1;
        top: 0;
        left: 0;
        background-color: rgb(0,0,0);
        background-color: rgba(0,0,0, 0.4);
    }

    .overlay-content {
        position: relative;
        top: 46%;
        width: 80%;
        text-align: center;
        margin-top: 30px;
        margin: auto;
        color: white;
    }

    .overlay .closebtn {
        position: absolute;
        top: 20px;
        right: 45px;
        font-size: 60px;
        cursor: pointer;
        color: white;
    }

        .overlay .closebtn:hover {
            color: #ccc;
        }
</style>
