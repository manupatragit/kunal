@{
    /**/
    ViewBag.Title = "BrowseDocument";
    var role = Session["sessionroleid"];
    if (role.ToString() == "1")
    {
        Layout = "~/Views/Shared/_ManuPanelPartial.cshtml";
    }
    else if (role.ToString() == "2")
    {
        Layout = "~/Views/Shared/_ManuPanelPartialUser.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_ManuPanelPartialClient.cshtml";
    }
}
@using System.Web.Configuration;
@{
    string BaseDomainURL = WebConfigurationManager.AppSettings["BaseDomainURL"].ToString();
}
<script>
    var BaseDomainURL = "@BaseDomainURL";
</script>
<script src="~/Scripts/Firm/Pages/BrowseDocument.js?1.1" type="text/javascript"></script>
<style>
    .bd_title {
        margin: 0;
        padding: 2px 4px;
        border-bottom: 1px solid #8fd500;
        color: #0059c1;
        font-size: 16px;
        font-weight: 400;
        text-transform: lowercase;
    }

    .bd_docpanel1 {
        width: 100%;
        clear: both;
        padding: 4px;
        overflow-y: scroll;
        height: 426px;
        border-bottom: 1px solid #dedede;
    }

    .bd_docpanel2 {
        width: 100%;
        clear: both;
        padding: 4px;
        overflow-y: scroll;
        height: 453px;
        border-bottom: 1px solid #dedede;
    }

    .bd_datepicker {
        width: 100%;
        clear: both;
        padding: 4px;
        overflow-y: scroll;
        height: 424px;
    }

    .bd_submit {
        width: 100%;
        clear: both;
        text-align: right;
        padding: 4px;
        border-top: 1px solid #8fd500;
    }

    .bd_wrapper {
        margin: 0 0 12px 0;
        padding: 0;
        overflow: hidden;
    }
</style>
<section class="wrapper">
    <div class="container">
        <h2 class="title">Compare Document </h2>
        <div class="row">
            <div class="col-md-6">
                <div class="bd_container">
                    <div class="bd_filepanel">
                        <label for="myfile">Select a file:</label>
                        <input type="file" id="attachmentone" name="attachmentone">
                    </div>
                    <div class="bd_title">Title</div>
                    <div class="bd_docpanel1">
                        <iframe src="" frameborder="0" width="100%" height="100%" id=""></iframe>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="bd_container">
                    <div class="bd_filepanel">
                        <label for="myfile">Select Date</label>
                    </div>
                    <div class="bd_datepicker">
                        <div class="bd_wrapper">
                            <div class="col-md-8"><input type="text" id="" class="form-control" style="border-bottom: 1px solid #ccc !important;"></div>
                            <div class="col-md-4"><input type="date" id="" class="form-control" style="border-bottom: 1px solid #ccc !important;"></div>
                        </div>
                        <div class="bd_wrapper">
                            <div class="col-md-8"><input type="text" id="" class="form-control" style="border-bottom: 1px solid #ccc !important;"></div>
                            <div class="col-md-4"><input type="date" id="" class="form-control" style="border-bottom: 1px solid #ccc !important;"></div>
                        </div>
                        <div class="bd_wrapper">
                            <div class="col-md-8"><input type="text" id="" class="form-control" style="border-bottom: 1px solid #ccc !important;"></div>
                            <div class="col-md-4"><input type="date" id="" class="form-control" style="border-bottom: 1px solid #ccc !important;"></div>
                        </div>
                        <div class="bd_wrapper">
                            <div class="col-md-8"><input type="text" id="" class="form-control" style="border-bottom: 1px solid #ccc !important;"></div>
                            <div class="col-md-4"><input type="date" id="" class="form-control" style="border-bottom: 1px solid #ccc !important;"></div>
                        </div>
                        <div class="bd_wrapper">
                            <div class="col-md-8"><input type="text" id="" class="form-control" style="border-bottom: 1px solid #ccc !important;"></div>
                            <div class="col-md-4"><input type="date" id="" class="form-control" style="border-bottom: 1px solid #ccc !important;"></div>
                        </div>
                    </div>
                    <div class="bd_submit">
                        <button style="padding:4px 14px !important;" type="button" class="sbtbtn" id="">Submit</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
