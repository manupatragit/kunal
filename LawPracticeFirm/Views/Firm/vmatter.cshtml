                            for (i = 0; i < tr.length; i++) {
                                td = tr[i].getElementsByClassName("cstatus");
                                td1 = tr[i].getElementsByClassName("auserto");
                                for (j = 0; j < td.length; j++) {
                                    if (td[j].textContent.toUpperCase().indexOf(filter) > -1 && td1[j].textContent.toUpperCase().indexOf(filter1) > -1) {
                                        found = true;
                                    }
                                }
                                if (found) {
                                    tr[i].style.display = "";
                                    found = false;
                                } else {
                                    tr[i].style.display = "none";
                                }
                            }
                        }
