@{
    Layout = null;
}
<i class="pp-icon-user"></i>
<!-- Page Content -->
@{
    var filetype = @ViewBag.type;
    var fid = @ViewBag.data;
    var mode = @ViewBag.mode;
    var role = Session["sessionroleid"];
}
<style>
    .glyphicon-download-alt {
        color: black !important;
    }
</style>
<div class="modal-header btn-primary">
    <button type="button" class="close" id="closemodel" data-dismiss="modal">&times;</button>
    <h4 class="modal-title">
        <img src="/newassets/img/notice-icon.png" style="margin:-15px 0px 0 -15px">
    </h4>
</div>
<div class="modaltitle" style="margin: -35px 0 15px 0; border: none;">
    <h4>Document List</h4>
</div>
<div class="modal-body">
    <aside class="">
        <!-- /.box-header -->
        <!-- /.panel-heading -->
        <!-- Main content -->
        <!-- Main content -->
        <section>
            <div id="contentdata" style="height:370px; overflow-y:auto">
                <table id="example123" class="table-panel">
                    <thead>
                        <tr>
                            <th width="50px" class="Activity"><div class="thbg">Sl. No.</div></th>
                            <th class="Status"><div class="thbg">File Name</div></th>
                            <th width="90px" class="Date"><div class="thbg">Download</div></th>
                        </tr>
                    </thead>
                    <tbody id="savefildedata">
                        @{
                            int qty = 0;
                            string string1 = "";
                            string string2 = "";
                        }
                        @foreach (var item in ViewBag.filedata)
                        {
                            qty = qty + 1;
                            var dfilename = @item.fname;
                            var ftoken = "/DownloadFile.ashx?module=NoticeManagement&ftype=" + filetype + "&fid=" + item.Id;
                            <tr>
                                <td>@qty</td>
                                <td>@dfilename</td>
                                <td><a href="@ftoken" title="Download File"><img src="~/newassets/img/download-icon.png" /></a></td>
                            </tr>
                        }
                    </tbody>
                </table>
                <span class="filefound124"><center>No Document Found !</center></span>
            </div>
        </section>
        <!-- /.content -->
        <!-- /.content -->
    </aside>
   
    <!-- /.container-fluid -->
</div>
<script>
    $("a").bind("click", function () {
        validnavigation = true;
        window.onbeforeunload = null;
    })
      function removefiledata(dataid,r) {
          try {
              var result = confirm("Are you sure to remove this file?");
              if (result) {
                  var i = r.parentNode.parentNode.rowIndex;
                  document.getElementById("example123").deleteRow(i);
                  //Logic to delete the item
                  $.ajax({
                      async: true,
                      type: "POST",
                      url: "/api/CallApi/RemoveMultipleFile",
                      headers: {
                          'dataid': dataid,
                          'ftype': '@ViewBag.type'
                      },
                      contentType: "application/json; charset=utf-8",
                      dataType: "json",
                      success: function (data1) {
                          new PNotify({
                              title: 'Success!',
                              text: ' File removed Successfully',
                              type: 'success',
                              delay: 3000
                          });
                      },
                      failure: function (data) {
                          alert(data.responseText);
                      },
                      error: function (data) {
                          alert(data.responseText);
                      }
                  });
              }
          }
          catch (er) {
              alert(er.message);
          }
        }
    $(document).ready(function () {
        var modes = "@mode";
        if (modes == "view") {
        }
        var rowCount1 = $('#example123 >tbody>tr').length;
        if (String(rowCount1) == "0") {
            $(".filefound124").css("display", "unset");
        }
        else {
            $(".filefound124").css("display", "none");
        }
    });
</script>
