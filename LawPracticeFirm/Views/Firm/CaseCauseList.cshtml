<i class="pp-icon-user"></i>
<!-- Page Content -->
<script>
    var tokencauelist = "@(ViewBag.token ?? "")" || "";
    var IsRera = "@(ViewBag.IsRera ?? "")" || "";
    var courtTypeId = "@(ViewBag.CourtTypeId ?? "")" || "";
    var courtName = "@(ViewBag.courtName ?? "")" || "";
    var janpadName = "@(ViewBag.janpadName ?? "")" || "";
    var tahsilName = "@(ViewBag.tahsilName ?? "")" || "";
    var caseNo = "@(ViewBag.caseNo ?? "")" || "";
    var vJudCourt = "@(ViewBag.vJudCourt ?? "")" || "";
</script>
<script>
    $(document).ready(function () {

        function openload() {
            $("#myOverlay").css("display", "block");
        }

        function closeload() {
            $("#myOverlay").css("display", "none");
        }

        loadcauselist();

        function loadcauselist() {
            let $table = $('<table width="100%" class="table table-panel table-responsive" style="overflow-x:auto;"></table>');
            let $header = $('<thead></thead>');
            let formData = new FormData();

            formData.append("id", tokencauelist);
            formData.append("IsReracauselist", IsRera);
            formData.append("courtTypeId", courtTypeId);

            // Build table header based on court type
            if (courtTypeId === 'RERH') {
                formData.append("courtName", encodeURIComponent(courtName));
                formData.append("janpadName", encodeURIComponent(janpadName));
                formData.append("tahsilName", encodeURIComponent(tahsilName));
                formData.append("AppealNo", encodeURIComponent(caseNo));
                formData.append("vJudCourt", encodeURIComponent(vJudCourt));

                $header.append(`
                    <tr>
                        <th width="12%" class="Activity"><div class="thbg">SL No.</div></th>
                        <th class="Status"><div class="thbg">CauseList Details</div></th>
                        <th class="Date" style="width:200px;"><div class="thbg">Matter</div></th>
                        <th class="Date"><div class="thbg">Court</div></th>
                        <th class="Date"><div class="thbg">CauseList Date</div></th>
                    </tr>
                `);
            } else {  // used for all other courts except RERH
                $header.append(`
                    <tr>
                        <th width="12%" class="Activity"><div class="thbg">SL No.</div></th>
                        <th class="Status"><div class="thbg">CauseList Details</div></th>
                        <th class="Date" style="width:200px;"><div class="thbg">Matter</div></th>
                        <th class="Date"><div class="thbg">Court</div></th>
                        <th class="Date"><div class="thbg">Bench Name</div></th>
                        <th class="Date"><div class="thbg">CauseList Date</div></th>
                    </tr>
                `);
            }

            $table.append($header);
            $('#contentdata').empty().append($table);

            openload();

            $.ajax({
                type: "POST",
                url: "/Firm/LoadCauseList",
                dataType: 'json',
                data: formData,
                contentType: false,
                processData: false,
                success: function (data) {
                    if (!data || data.length === 0) {
                        $('#causeliststatus').text("There are no Cause List Details available for this date.");
                        closeload();
                        return;
                    }

                    data.forEach((a, index) => {
                        let $row = $('<tr />');
                        $row.append(`<td class="s"><span>${index + 1}</span></td>`);

                        if (courtTypeId === 'RERH') {
                            $row.append(`<td class="s"><span>${a.Appres}</span></td>`);
                            $row.append(`<td class="s"><span>${a.vCaseno}</span></td>`);
                            $row.append(`<td class="s"><span>${a.vCourt == 'RERH' ? 'Revenue(Rajasthan)' : ''}</span></td>`);
                            $row.append(`<td class="s"><span>${a.Causelistdate}</span></td>`);
                        } else {
                            $row.append(`<td class="s"><span>${a.Filetext}</span></td>`);
                            $row.append(`<td class="s"><span>${a.Casename}</span></td>`);
                            $row.append(`<td class="s"><span>${a.CourtId}</span></td>`);
                            $row.append(`<td class="s"><span>${a.Bench}</span></td>`);
                            $row.append(`<td class="s"><span>${a.Causelistdate}</span></td>`);
                        }

                        $table.append($row);
                    });

                    closeload();
                },
                error: function (xhr) {
                    alert(xhr.responseText);
                    closeload();
                }
            });
        }
    });
</script>

