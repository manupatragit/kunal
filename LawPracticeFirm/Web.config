		<add key="RegistrationToAdminSubject" value="Registration details on myKase" />
		<add key="RegistrationMailToAdminBody" value="&lt;table width='700' border='0' cellspacing='0' cellpadding='0' align='center' bgcolor='#FFFFFF' style='border:1px #bbbbbb solid;'&gt;         &lt;tr&gt;&lt;td align='left'&gt;&lt;a href='https://lms.mykase.in/' target='_blank'&gt;&lt;img src='https://lms.mykase.in/newassets/images/automail_logo.jpg' title='MyKase' width='700' height='73' /&gt;&lt;/a&gt;&lt;/td&gt;         &lt;/tr&gt;&lt;tr&gt;&lt;td align='center'&gt;                 &lt;table cellpadding='0' cellspacing='0' border='0' align='center' style='width:95%; font-family: Arial, Helvetica, sans-serif; font-size:13px; color:#000000;'&gt;                     &lt;tr&gt;                         &lt;td&gt;                             &lt;p&gt;&lt;strong&gt;Dear #NAME#,&lt;/strong&gt;&lt;/p&gt;                             &lt;p&gt;We are pleased to inform you that you have  successfully registered on &lt;a style='color: blue !important; margin: 0px;' target='_blank' href='http://www.mykase.in/'&gt;www.mykase.in&lt;/a&gt;&lt;/p&gt;                             &lt;p&gt;                                 Your login credentials are as follows:                             &lt;/p&gt;                             &lt;p&gt;Username : #USERID#&lt;/p&gt;                             &lt;p&gt;Password : #PASSWORD#&lt;/p&gt;                                                        &lt;p&gt;Regards,&lt;br /&gt;&lt;strong&gt;Team Mykase&lt;/strong&gt;                              &lt;br/&gt;                              &lt;br/&gt;&lt;em&gt;Streamline your operations with myKase!&lt;/em&gt;&lt;/p&gt;                         &lt;/td&gt;                     &lt;/tr&gt;                 &lt;/table&gt;             &lt;/td&gt;         &lt;/tr&gt;" />
		<add key="forgetPasswordSubject" value="Mykase Password Reset Link" />
		<add key="ForgotPasswordBody" value="&lt;div align=center&gt;&lt;table class=MsoNormalTable border=1 cellspacing=0 cellpadding=0 width=650  style='width:487.5pt;background:#F0F0F0;border:solid #010628 1.0pt'&gt;&lt;tr&gt;   &lt;td style='border:none;padding:0cm 0cm 0cm 0cm'&gt;   &lt;p class='MsoNormal align=center' style='text-align:center'&gt;&lt;img src='http://10.60.1.47:8075/Manupanel/img/top-logo.jpg'&gt;&lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;  &lt;tr&gt;&lt;td style='border:none;padding:0cm 0cm 0cm 0cm'&gt;&lt;div align='center'&gt;   &lt;table class='MsoNormalTable' border='0' cellspacing='0' cellpadding='0' width='628'style='width:471.0pt'&gt;&lt;tr&gt;     &lt;td style='padding:0cm 0cm 0cm 0cm'&gt;     &lt;p class='MsoNormal' style='margin-bottom:12.0pt'&gt;&lt;span style='font-size:10.5pt;font-family:'Arial','sans-serif';color:black'&gt;&lt;/span&gt;&lt;/p&gt;     &lt;br&gt;&lt;br&gt;     &lt;p&gt;&lt;span style='font-family:'Arial','sans-serif';color:black'&gt; Dear  #USERNAME#,&lt;br&gt;&lt;br&gt;We received a request to reset the password associated with this email address.&lt;br&gt;&lt;br&gt;Click the link below to reset your password: &lt;br&gt;&lt;br&gt;#RESETLINK# &lt;br&gt;&lt;br&gt;&lt;br&gt;Above link can also be copied and pasted into the browser. &lt;br&gt;&lt;br&gt;The link is valid for the next 24 hours and can only be used once. &lt;br&gt;&lt;br&gt;If you did not request a new password change, please ignore this email. &lt;/span&gt;&lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;     &lt;td style='padding:0cm 0cm 0cm 0cm'&gt; &lt;p style='mso-margin-top-alt:22.5pt;margin-right:0cm;margin-bottom:12.0pt;     margin-left:0cm'&gt;&lt;span style='font-size:10.5pt;font-family:'Arial','sans-serif';color:black'&gt;&lt;o:p&gt;&lt;/o:p&gt;&lt;/span&gt;&lt;/p&gt;     &lt;p&gt;&lt;span style='font-size:10.5pt;font-family:'Arial','sans-serif';color:black'&gt;&lt;br&gt;&lt;br&gt;Thank You!&lt;br&gt;     &lt;br&gt;Team MyKase&lt;o:p&gt;&lt;/o:p&gt;&lt;/span&gt;&lt;/p&gt;     &lt;p class=MsoNormal style='margin-bottom:12.0pt'&gt;&lt;span style='font-size:10.5pt;font-family:'Arial','sans-serif';color:black'&gt;&lt;a href='https://www.mykase.in/'&gt;https://www.mykase.in&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;     &lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/div&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/div&gt;   " />
		<add key="bottomlinkref" value="https://mykase.manupatra.com/" />
		<add key="basicmailtemplate" value="&lt;table border='0' cellspacing='0' cellpadding='0' width='700' style='border:1px #bbbbbb solid;'&gt;  &lt;tr&gt; &lt;td&gt; &lt;a href='https://lms.mykase.in/' target='_blank'&gt;&lt;img src='https://lms.mykase.in/newassets/images/automail_logo.jpg' title='MyKase' width='700' height='73' /&gt;&lt;/a&gt;&lt;/td&gt;&lt;/tr&gt;  &lt;tr&gt;&lt;td&gt;  &lt;table border='0' cellspacing='0' cellpadding='0' width='95%' align='center'&gt;&lt;tr&gt;    &lt;td&gt;  &lt;p&gt; #CONTENT#&lt;/p&gt;&lt;/td&gt;  &lt;/tr&gt;  &lt;tr&gt;    &lt;td&gt;   &lt;p&gt;Regards,&lt;br /&gt;&lt;strong&gt;Team Mykase&lt;/strong&gt;                              &lt;br/&gt;                              &lt;br/&gt;  &lt;p&gt;&lt;i&gt;Streamline your operations with myKase!&lt;i&gt;&lt;/p&gt;&lt;br&gt;      &lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;    ">
		</add>
		<add key="WorkflowMailToAdminSubject" value="Information About Workflow " />
		<add key="ClientRegistrationSubject" value="Sub: Your registration details on myKase – Unified platform for Practice Management" />
		<add key="ClientRegistrationBody" value="Dear User,&lt;br&gt;Welcome to myKase – A single unified platform which integrates everything you need to manage your practice and business. #SubscriberName has created an account for you on www.mykase.in.  &lt;br&gt;Your login credentials to access myKase:&lt;br&gt;Username: #USERNAME&lt;br&gt;Password: #PASSWORD &lt;br&gt;myKase is the digital interface between you and #SubscriberName, providing you 24/7, real time access to case dashboard, case status,billing details, archived projects, files and documents.&lt;br&gt;myKase is thrilled to be facilitating this client collaboration and is committed to deliver a state of the art experience. &lt;br&gt;Looking forward to a long term association and assuring you of the best of our services.&lt;br&gt;If you need any assistance, please don’t hesitate to write us back (contact@mykase.in) or call (0120-4014433)&lt;br&gt;" />
		<add key="TrialRegistrationSubject" value="myKase Firm Registration Detail" />
		<add key="TrialRegistrationBody" value="&lt;table width='700' border='0' cellspacing='0' cellpadding='0' align='center' bgcolor='#FFFFFF' style='border:1px #bbbbbb solid;'&gt;         &lt;tr&gt;&lt;td align='left'&gt;&lt;a href='https://mykase.manupatra.com/' target='_blank'&gt;&lt;img src='https://mykase.manupatra.com/newassets/images/automail_logo.jpg' title='MyKase' width='700' height='73' /&gt;&lt;/a&gt;&lt;/td&gt;         &lt;/tr&gt;&lt;tr&gt;&lt;td align='center'&gt;                 &lt;table cellpadding='0' cellspacing='0' border='0' align='center' style='width:95%; font-family: Arial, Helvetica, sans-serif; font-size:13px; color:#000000;'&gt;                     &lt;tr&gt;                         &lt;td&gt;                             &lt;p&gt;&lt;strong&gt;Hello #NAME#,&lt;/strong&gt;&lt;/p&gt;                              &lt;p&gt;                                 We appreciate your decision in investing your valuable time to try out myKase.&lt;br /&gt;                                 Following are your account details to access myKase during the trial period.                             &lt;/p&gt;                             &lt;p&gt;Username : #Username#&lt;/p&gt;                             &lt;p&gt;Password : #Password#&lt;/p&gt;                             &lt;p&gt;                                 &lt;a href='https://mykase.manupatra.com/'&gt;Click here&lt;/a&gt; to access myKase&lt;br /&gt;                                 Set up a demo at your convenience to have a myKase representative guide you through the platform.                             &lt;/p&gt;                             &lt;p&gt;We look forward to incorporate myKase into your operations! &lt;/p&gt;                             &lt;p&gt;&lt;em&gt;Stay efficient with myKase&lt;/em&gt;&lt;/p&gt;                             &lt;p&gt;&lt;strong&gt;Thank You&lt;/strong&gt;&lt;br /&gt;Team MyKase&lt;/p&gt;                         &lt;/td&gt;                     &lt;/tr&gt;                                    &lt;/table&gt;             &lt;/td&gt;         &lt;/tr&gt;     &lt;/table&gt;" />
		<add key="RegistrationSubject" value="myKase Firm Registration Detail" />
		<add key="RegistrationBody" value="&lt;table width='700' border='0' cellspacing='0' cellpadding='0' align='center' bgcolor='#FFFFFF' style='border:1px #bbbbbb solid;'&gt;         &lt;tr&gt;&lt;td align='left'&gt;&lt;a href='https://lms.mykase.in/' target='_blank'&gt;&lt;img src='https://lms.mykase.in/newassets/images/automail_logo.jpg' title='MyKase' width='700' height='73' /&gt;&lt;/a&gt;&lt;/td&gt;         &lt;/tr&gt;&lt;tr&gt;&lt;td align='center'&gt;                 &lt;table cellpadding='0' cellspacing='0' border='0' align='center' style='width:95%; font-family: Arial, Helvetica, sans-serif; font-size:13px; color:#000000;'&gt;                     &lt;tr&gt;                         &lt;td&gt;                             &lt;p&gt;&lt;br&gt;&lt;strong&gt;Dear #NAME#,&lt;/strong&gt;&lt;br /&gt;&lt;br /&gt;                             We are pleased to inform you that you have  successfully been registered on &lt;a style='color: blue !important; margin: 0px;' target='_blank' href='http://www.mykase.in/'&gt;www.mykase.in&lt;/a&gt;&lt;br /&gt;&lt;br /&gt;                             Your login credentials are as follows:&lt;br /&gt;&lt;br /&gt;                             Username: #Username#&lt;br /&gt;                             Password: #Password#&lt;br /&gt;&lt;br /&gt;&lt;br /&gt;                             Regards,&lt;br /&gt;&lt;strong&gt;Team Mykase&lt;/strong&gt;&lt;br /&gt;&lt;br /&gt;                             &lt;em&gt;Streamline your operations with myKase!&lt;/em&gt;&lt;br /&gt;&lt;br /&gt;&lt;/p&gt;                         &lt;/td&gt;                     &lt;/tr&gt;                                   &lt;/table&gt;             &lt;/td&gt;         &lt;/tr&gt;     &lt;/table&gt;" />
		<add key="DemoMail" value="&lt;table width='700' border='0' cellspacing='0' cellpadding='0' align='center' bgcolor='#FFFFFF' style='border:1px #bbbbbb solid;'&gt; &lt;tr&gt;&lt;td align='left'&gt;&lt;a href='https://mykase.manupatra.com/' target='_blank'&gt;&lt;img src='https://mykase.manupatra.com/newassets/images/automail_logo.jpg' title='MyKase' width='700' height='73' /&gt;&lt;/a&gt;&lt;/td&gt; &lt;/tr&gt;&lt;tr&gt;&lt;td align='center'&gt;&lt;table cellpadding='0' cellspacing='0' border='0' align='center' style='width:95%; font-family: Arial, Helvetica, sans-serif; font-size:13px; color:#000000;'&gt; &lt;tr&gt; &lt;td&gt;&lt;br/&gt; &lt;p&gt;&lt;strong&gt;Dear #NAME#,&lt;/strong&gt;&lt;/p&gt; &lt;p&gt;Thank you for showing interest in myKase.&lt;br /&gt;&lt;br/&gt; We have &lt;strong&gt;received your request for a Demo,&lt;/strong&gt; and &lt;strong&gt;will share the Online Demo link shortly.&lt;/strong&gt;&lt;br /&gt; &lt;/p&gt; &lt;p&gt;We look forward to enabling hassle free Case and Document Management experience for your firm / organization.&lt;/p&gt; &lt;br/&gt; &lt;p&gt;&lt;strong&gt;Thank You,&lt;/strong&gt;&lt;br /&gt;&lt;br/&gt;Team MyKase&lt;/p&gt; &lt;p&gt;&lt;i&gt;&lt;u&gt;Connect with us:&lt;/u&gt; Phone 0120-4014433; WhatsApp @8800106683&lt;/i&gt;&lt;/p&gt; &lt;br /&gt; &lt;/td&gt; &lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;table style='font-family: Arial, Helvetica, sans-serif; font-size:13px; color:#000000;'&gt;&lt;tr&gt;&lt;td&gt;Follow us on :&lt;/td&gt;&lt;td&gt;&lt;a href='https://www.linkedin.com/showcase/mykasemanupatra/' target='_blank'&gt;&lt;img src='https://mykase.manupatra.com/NewDesign/images/sl.png' class='img-responsive' &gt;&lt;/a&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/tr&gt; &lt;/table&gt;&lt;br /&gt; &lt;/td&gt; &lt;/tr&gt; &lt;/table&gt;" />
		<!--Email Body IPR Details-->
		<add key="EmailIPRPropDetails" value="&lt;div align=center&gt;&lt;table class=MsoNormalTable border=1 cellspacing=0 cellpadding=0 width=650 style='width:487.5pt;background:#F0F0F0;border:solid #010628 1.0pt'&gt;&lt;tr&gt;&lt;td style='border:none;padding:0cm 0cm 0cm 0cm'&gt;&lt;p class='MsoNormal align=center' style='text-align:center'&gt;&lt;img src='https://mykase.manupatra.com/Manupanel/img/top-logo.jpg'&gt;&lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='border:none;padding:0cm 0cm 0cm 0cm'&gt;&lt;div align='center'&gt;&lt;table class='MsoNormalTable' border='0' cellspacing='0' cellpadding='0' width='628' style='width:471.0pt'&gt;&lt;tr&gt;&lt;td style='padding:0cm 0cm 0cm 0cm'&gt;&lt;p class='MsoNormal' style='margin-bottom:12.0pt'&gt;&lt;span style='font-size:10.5pt;font-family:'' Arial'',''sans-serif'';color:black'&gt;&lt;/span&gt;&lt;b&gt;&lt;p&gt;Dear #User#,&lt;/p&gt;&lt;/b&gt;&lt;p&gt;Greetings!&lt;/p&gt;&lt;/p&gt;&lt;p&gt;&lt;span style='font-size:10.5pt;font-family:'' Arial'',''sans-serif'';color:black'&gt;Please find the requested #Mark# information attached in this e-mail&lt;tr&gt;&lt;td&gt;&lt;br&gt;&lt;br&gt;Please &lt;a href='https://www.mykase.in/'&gt;login&lt;/a&gt; and check!&lt;/td&gt;&lt;/tr&gt;&lt;br&gt;&lt;tr&gt;&lt;td style='padding:0cm 0cm 0cm 0cm'&gt;&lt;p style='mso-margin-top-alt:22.5pt;margin-right:0cm;margin-bottom:12.0pt;margin-left:0cm'&gt;&lt;span style='font-size:10.5pt;font-family:'' Arial'',''sans-serif'';color:black'&gt;&lt;o:p&gt;&lt;/o:p&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style='font-size:10.5pt;font-family:'' Arial'',''sans-serif'';color:black'&gt;&lt;br&gt;Thank You! &lt;br&gt;&lt;br&gt;Team MyKase &lt;o:p&gt;&lt;/o:p&gt;&lt;/span&gt;&lt;/p&gt;&lt;p class=MsoNormal style='margin-bottom:12.0pt'&gt;&lt;span style='font-size:10.5pt;font-family:'' Arial'',''sans-serif'';color:black'&gt;&lt;/span&gt;&lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/div&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/div&gt;" />
