		<add key="WorkflowMailToAdminBody" value="&lt;div align=center&gt;&lt;table class=MsoNormalTable border=1 cellspacing=0 cellpadding=0 width=650  style='width:487.5pt;background:#F0F0F0;border:solid #010628 1.0pt'&gt;&lt;tr&gt;   &lt;td style='border:none;padding:0cm 0cm 0cm 0cm'&gt;   &lt;p class='MsoNormal align=center' style='text-align:center'&gt;&lt;img src='https://mykase.manupatra.com/Manupanel/img/top-logo.jpg'&gt;&lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;  &lt;tr&gt;&lt;td style='border:none;padding:0cm 0cm 0cm 0cm'&gt;&lt;div align='center'&gt;   &lt;table class='MsoNormalTable' border='0' cellspacing='0' cellpadding='0' width='628'style='width:471.0pt'&gt;&lt;tr&gt;     &lt;td style='padding:0cm 0cm 0cm 0cm'&gt;     &lt;p class='MsoNormal' style='margin-bottom:12.0pt'&gt;&lt;span style='font-size:10.5pt;font-family:'Arial','sans-serif';color:black'&gt;&lt;/span&gt;&lt;/p&gt;     &lt;br&gt;&lt;br&gt;     &lt;p&gt;&lt;b&gt;&lt;span style='font-size:10.5pt;font-family:'Arial','sans-serif';color:black'&gt;Stage #Stage#&lt;/span&gt;&lt;/b&gt;&lt;span style='font-size:10.5pt;     font-family:'Arial','sans-serif';color:black'&gt; of Task: &lt;b&gt;#TaskName#&lt;/b&gt; has been completed by     &lt;b&gt;#User#&lt;/b&gt; &lt;/span&gt;&lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;     &lt;td style='padding:0cm 0cm 0cm 0cm'&gt; &lt;p style='mso-margin-top-alt:22.5pt;margin-right:0cm;margin-bottom:12.0pt;     margin-left:0cm'&gt;&lt;span style='font-size:10.5pt;font-family:'Arial','sans-serif';color:black'&gt;&lt;o:p&gt;&lt;/o:p&gt;&lt;/span&gt;&lt;/p&gt;     &lt;p&gt;&lt;span style='font-size:10.5pt;font-family:'Arial','sans-serif';color:black'&gt;&lt;br&gt;&lt;br&gt;Thank You!&lt;br&gt;     &lt;br&gt;Team MyKase&lt;o:p&gt;&lt;/o:p&gt;&lt;/span&gt;&lt;/p&gt;     &lt;p class=MsoNormal style='margin-bottom:12.0pt'&gt;&lt;span style='font-size:10.5pt;font-family:'Arial','sans-serif';color:black'&gt;&lt;a href='https://www.mykase.in/'&gt;https://www.mykase.in&lt;/a&gt;&lt;/span&gt;&