		<add key="ReAssignMatterTeamLeadSubject" value="Re-assign Matter Team Lead" />
		<add key="ReAssignMatterTeamLeadBody" value="&lt;table width='700' border='0' cellspacing='0' cellpadding='0' align='center' bgcolor='#FFFFFF' style='border:1px #bbbbbb solid;'&gt;  &lt;tr&gt;&lt;td align='left'&gt;&lt;a href='https://mykase.manupatra.com/' target='_blank'&gt; &lt;img src='https://mykase.manupatra.com/newassets/images/automail_logo.jpg' title='MyKase' width='700' height='73' /&gt;&lt;/a&gt;&lt;/td&gt;         &lt;/tr&gt; &lt;tr&gt;&lt;td align='center'&gt;  &lt;table cellpadding='0' cellspacing='0' border='0' align='center' style='width:95%; font-family: Arial, Helvetica, sans-serif; font-size:13px; color:#000000;'&gt; &lt;tr&gt;&lt;td&gt;&lt;p&gt;&lt;strong&gt;Dear User,&lt;/strong&gt;&lt;/p&gt;  &lt;p&gt;Your request for adding user #UserName# as matter Team Lead in Matter #MatterName# has been rejected by his partner #PartnerName#.&lt;br /&gt;   &lt;br /&gt;So Kindly reassign Matter Team Lead for the Matter.&lt;/p&gt;  &lt;p&gt;&lt;strong&gt;Thank You&lt;/strong&gt;&lt;br /&gt;&lt;br /&gt;Team MyKase&lt;br /&gt; &lt;em&gt;Stay efficient with myKase&lt;/em&gt;&lt;/p&gt; &lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" />
		<add key="TaskAssigneeAlertSubject" value="#mailSubject#" />
		<add key="TaskAssigneeAlertBody" value="&lt;table width='700' border='0' cellspacing='0' cellpadding='0' align='center' bgcolor='#FFFFFF' style='border:1px #bbbbbb solid;'&gt; &lt;tr&gt; &lt;td align='left'&gt;&lt;a href='https://www.mykase.in/' target='_blank'&gt;&lt;img src='https://ipr.mykase.in/assets/img/mykase_logo.png' title='myKase' /&gt;&lt;/a&gt;&lt;/td&gt; &lt;/tr&gt;&lt;tr&gt; &lt;td align='center'&gt; &lt;table cellpadding='0' cellspacing='0' border='0' align='center' style='width:95%; font-family: Arial, Helvetica, sans-serif; font-size:13px; color:#000000;'&gt; &lt;tr&gt; &lt;td&gt;&lt;br /&lt;&lt;p&gt;&lt;strong&gt;Dear #User#,&lt;/strong&gt;&lt;/p&gt; #TextMessage#&lt;/p&gt; &lt;p&gt;#TextRemark#&lt;/p&gt; &lt;p&gt; &lt;p&gt;#MatterName#&lt;/p&gt; &lt;p&gt;&lt;strong&gt;Task :&lt;/strong&gt; #TaskName#.&lt;/p&gt; #SubjectName# &lt;p&gt;#DueDate#&lt;/p&gt; #TaskNote#  #FooterLine# &lt;p&gt;&lt;strong&gt;Thank You,&lt;/strong&gt;&lt;/p&gt; &lt;p&gt;Team myKase&lt;/p&gt; &lt;/td&gt; &lt;/tr&gt; &lt;tr&gt;&lt;td height='12px;'&gt;&lt;/td&gt;&lt;/tr&gt; &lt;tr&gt; &lt;td&gt; &lt;i&gt;Stay efficient with myKase!&lt;/i&gt;&lt;br /&gt;&lt;br /&gt; &lt;/td&gt; &lt;/tr&gt; &lt;/table&gt; &lt;/td&gt; &lt;/tr&gt; &lt;/table&gt;" />
		<add key="NotificationEmailTemplate" value="&lt;div align=center&gt;&lt;table class=MsoNormalTable border=1 cellspacing=0 cellpadding=0 width=650  style='width:487.5pt;background:#F0F0F0;border:solid #010628 1.0pt'&gt;&lt;tr&gt;   &lt;td style='border:none;padding:0cm 0cm 0cm 0cm'&gt;   &lt;p class='MsoNormal align=center' style='text-align:center'&gt;&lt;img src='https://mykase.manupatra.com/newassets/images/automail_logo.jpg'&gt;&lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;  &lt;tr&gt;&lt;td style='border:none;padding:0cm 0cm 0cm 0cm'&gt;&lt;div align='center'&gt;   &lt;table class='MsoNormalTable' border='0' cellspacing='0' cellpadding='0' width='628'style='width:471.0pt'&gt;&lt;tr&gt;     &lt;td style='padding:0cm 0cm 0cm 0cm'&gt;     &lt;p class='MsoNormal' style='margin-bottom:12.0pt'&gt;&lt;span style='font-size:10.5pt;font-family:'Arial','sans-serif';color:black'&gt;&lt;/span&gt;&lt;/p&gt;     &lt;br&gt;&lt;br&gt;     &lt;p&gt;&lt;span style='font-family:'Arial','sans-serif';color:black'&gt; #CONTENT#&lt;/span&gt;&lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;     &lt;td style='padding:0cm 0cm 0cm 0cm'&gt; &lt;p style='mso-margin-top-alt:22.5pt;margin-right:0cm;margin-bottom:12.0pt;     margin-left:0cm'&gt;&lt;span style='font-size:10.5pt;font-family:'Arial','sans-serif';color:black'&gt;&lt;o:p&gt;&lt;/o:p&gt;&lt;/span&gt;&lt;/p&gt;     &lt;p&gt;&lt;span style='font-size:10.5pt;font-family:'Arial','sans-serif';color:black'&gt;&lt;br&gt;&lt;br&gt;Thank You!&lt;br&gt;     &lt;br&gt;#SenderAddress#&lt;o:p&gt;&lt;/o:p&gt;&lt;/span&gt;&lt;/p&gt;     &lt;p class=MsoNormal style='margin-bottom:12.0pt'&gt;&lt;span style='font-size:10.5pt;font-family:'Arial','sans-serif';color:black'&gt;&lt;i&gt;Stay efficient with myKase!&lt;i&gt;&lt;/span&gt;&lt;/p&gt;     &lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/div&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/div&gt;" />
