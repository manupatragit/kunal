		<add key="ResetPasswordLinkForCommon" value="&lt;table width='700' border='0' cellspacing='0' cellpadding='0' align='center' bgcolor='#FFFFFF' style='border:1px #bbbbbb solid;'&gt;&lt;tr&gt;        &lt;td align=center&gt;&lt;a href='https://www.mykase.in' target='_blank'&gt;&lt;img src='https://ipr.mykase.in/assets/img/mykase_logo.png' width='128' height='50' /&gt;&lt;/a&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td align='center'&gt;&lt;table cellpadding='0' cellspacing='0' border='0' align='center' style='width:95%; font-family: Arial, Helvetica, sans-serif; color:#000000;'&gt;             &lt;tr&gt;&lt;td&gt;&lt;p&gt;&lt;br /&gt;&lt;strong&gt;Dear Sir/Madam,&lt;/strong&gt;&lt;/p&gt;             &lt;p&gt;Greetings from Mykase!&lt;/p&gt;             &lt;p&gt;            Please click  #Here# to reset your password.&lt;br /&gt;            &lt;p&gt;Link will expire in 24 hours.&lt;/p&gt;                         &lt;p&gt;Please ignore this email if you did not request to reset your password.&lt;/p&gt;            &lt;br /&gt;&lt;br /&gt;                        &lt;br /&gt;&lt;strong&gt;Thank You,&lt;/strong&gt;&lt;br&gt;            Team myKase            &lt;/p&gt;                &lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;           &lt;td align='center'&gt;&lt;br /&gt;&lt;br /&gt;&lt;table cellpadding='0' cellspacing='0' width='100%' style='font-family: Arial, Helvetica, sans-serif; font-size:12px;'&gt;               &lt;tr&gt; &lt;td align='left' width='70%'&gt;&lt;div&gt;&lt;i&gt;The information provided above has been obtained from the e-Courts websites.&lt;/i&gt;&lt;/div&gt;&lt;/td&gt;                 &lt;td align='right'&gt;&lt;div&gt; &lt;a href=https://www.mykase.in target='_blank' style = 'color:#0000ff; font-weight:bold;'&gt;Login to View More..&lt;/a&gt; &lt;/div&gt;&lt;/td&gt;               &lt;/tr&gt;&lt;/table&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td align='center'&gt;&lt;table cellpadding='0' cellspacing='0' width='100%' style='font-family: Arial, Helvetica, sans-serif; font-size:12px; margin-top:10px;'&gt;&lt;tr&gt;                 &lt;td align='left' width='30%'&gt;&lt;div&gt;&lt;a href='https://www.mykase.in/Home/Disclaimer' target='_blank' style = 'color:#000000;text-decoration:none;'&gt;&lt;img src='https://ipr.mykase.in/assets/img/disclaimer_icon.png'  /&gt;&lt;strong&gt;Disclaimer&lt;/strong&gt;&lt;/a&gt;&lt;/div&gt;&lt;/td&gt;                 &lt;td align='right'&gt;&lt;div&gt; &lt;a href='https://www.mykase.in/' target='_blank' style='color:#000000;text-decoration:none;'&gt;www.mykase.in&lt;/a&gt; | &lt;a href='mailto:contact@mykase.in' style='color:#000000; text-decoration:none;'&gt;contact@mykase.in&lt;/a&gt; | 91-120-4014603 &lt;/div&gt;&lt;/td&gt;               &lt;/tr&gt;             &lt;/table&gt;&lt;br /&gt;&lt;/td&gt;         &lt;/tr&gt;          &lt;/table&gt;          &lt;/td&gt;    &lt;/tr&gt; &lt;/table&gt;" />
		<add key="EmailOTPTemplate" value="&lt;table width='700' border='0' cellspacing='0' cellpadding='0' align='center' bgcolor='#FFFFFF' style='border:1px #bbbbbb solid; font-family: Arial, sans-serif; padding:25px;'&gt;   &lt;tr&gt;&lt;td align='center' style='padding-bottom:20px;'&gt;     &lt;a href='https://www.mykase.in/' target='_blank'&gt;       &lt;img src='https://ipr.mykase.in/assets/img/mykase_logo.png' alt='mykase.in' style='height:auto;' /&gt;     &lt;/a&gt;   &lt;/td&gt;&lt;/tr&gt;   &lt;tr&gt;&lt;td style='font-size:15px; color:#444; padding-bottom:10px;'&gt;     Dear User,   &lt;/td&gt;&lt;/tr&gt;   &lt;tr&gt;&lt;td style='font-size:15px; color:#444; padding-bottom:20px;'&gt;     Use the One-Time Password (OTP) below to verify your E-mail. It is valid for &lt;strong&gt;{ValidMinutes} minutes&lt;/strong&gt;.   &lt;/td&gt;&lt;/tr&gt;   &lt;tr&gt;&lt;td align='center' style='padding:20px 0;'&gt;     &lt;span style='display:inline-block; padding:16px 28px; font-size:24px; letter-spacing:4px; background-color:#f0f4f8; border-radius:4px; color:#333;'&gt;       &lt;strong&gt;{OTP}&lt;/strong&gt;     &lt;/span&gt;   &lt;/td&gt;&lt;/tr&gt;   &lt;tr&gt;&lt;td style='font-size:13px; color:#666; padding-bottom:20px;'&gt;     If you did not request this, you can safely ignore this email.   &lt;/td&gt;&lt;/tr&gt;   &lt;tr&gt;&lt;td style='font-size:15px; color:#444; padding-bottom:20px;'&gt;     Regards,&lt;br /&gt;&lt;br /&gt;     Team Manupatra&lt;br /&gt;&lt;br /&gt;     &lt;a href='https://www.mykase.in/'&gt;Mykase.in&lt;/a&gt;&lt;br /&gt;     &lt;span style='margin:16px 0; font-size:14px; line-height:1.6; color:#444444; font-style:italic;'&gt;&lt;/span&gt;   &lt;/td&gt;&lt;/tr&gt;   &lt;tr&gt;&lt;td&gt;&lt;hr style='border:none; border-top:1px solid #eee; margin:20px 0;' /&gt;&lt;/td&gt;&lt;/tr&gt; &lt;/table&gt;" />
		<add key="SendReceivedNoticeTemplate" value="&lt;div align=center&gt;&lt;table class=MsoNormalTable border=1 cellspacing=0 cellpadding=0 width=650 style='width:487.5pt;background:#F0F0F0;border:solid #010628 1.0pt'&gt; &lt;tr&gt;&lt;td style='border:none;padding:0cm 0cm 0cm 0cm'&gt;&lt;p class='MsoNormal align=center' style='text-align:center'&gt;&lt;img src='https://ipr.mykase.in/assets/img/mykase_logo.png'&gt;       &lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='border:none;padding:0cm 0cm 0cm 0cm'&gt;       &lt;div align='center'&gt;&lt;table width='95%'&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;Dear #UserName#,&lt;/strong&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;                &lt;td&gt;Following Notice is added by #CreatedUserName#&lt;/td&gt;&lt;/tr&gt;&lt;td&gt;&lt;table width='95%'&gt;                   &lt;tbody&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;Sender's Name:&lt;/b&gt;&lt;/td&gt;&lt;td&gt;#SenderName#&lt;/td&gt;                      &lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;Receiver's Name:&lt;/b&gt;&lt;/td&gt;&lt;td&gt;#ReceiverName#&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;                         &lt;td&gt;&lt;b&gt;Date of Notice:&lt;/b&gt;&lt;/td&gt;&lt;td&gt;#DateOfNotice#&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;Notice Title:&lt;/b&gt;                         &lt;/td&gt;&lt;td&gt;#TitleOfNotice#&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;Notice Subject:&lt;/b&gt;&lt;/td&gt;                         &lt;td&gt;#SubjectOfNotice#&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;Notice Due Date:&lt;/b&gt;&lt;/td&gt;&lt;td&gt;#DueDateOfNotice#&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;p&gt;&lt;br/&gt;&lt;br/&gt;Please login to &lt;a href='https://www.mykase.in/'&gt;myKase&lt;/a&gt; account and share your feedback (if any).&lt;/p&gt;                &lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;p&gt;&lt;br/&gt; &lt;br/&gt;&lt;strong&gt;Thank You,&lt;/strong&gt;&lt;br/&gt;&lt;br/&gt;Team myKase&lt;br/&gt; &lt;em&gt;Stay efficient with myKase!&lt;/em&gt;&lt;br/&gt;                   &lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" />
