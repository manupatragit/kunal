@Scripts.Render("~/Bundles/UserProfileScripts")
@{
    Layout = "~/Views/Shared/_BaseView.cshtml";
}
<div class="container-fluid panel-white" style="padding-left:20px;">
    <div class="row">
        <div class="col-md-12 text-right" style="margin-top: 10px;">
            <a style="cursor:pointer;padding:10px 5px;" data-toggle="modal" id="lnkChangePassword">Change Password</a>
        </div>
        <div class="col-md-6 col-md-offset-2 divProfile">
            <div class="form-group">
                <div class="row">
                    <div class="col-md-5 text-right margin-top-5">Email Address:</div>
                    <div class="col-md-7">
                        @Html.Kendo().TextBox().Name("Email").HtmlAttributes(new { @type = "email", @required = "required", @maxlength = "50", @class = "form-control", @placeholder = "e.g.  sample@example.com", @disabled = "disabled" })
                    </div>
                </div>
            </div>
            <div class="form-group">
                <div class="row">
                    <div class="col-md-5 text-right margin-top-5">First Name:</div>
                    <div class="col-md-7">
                        @Html.Kendo().TextBox().Name("FirstName").HtmlAttributes(new { @placeholder = "First Name", @maxlength = "16", @disabled = "disabled", @class = "form-control" })
                    </div>
                </div>
            </div>
            <div class="form-group">
                <div class="row">
                    <div class="col-md-5 text-right margin-top-5">Last Name:</div>
                    <div class="col-md-7">
                        @Html.Kendo().TextBox().Name("LastName").HtmlAttributes(new { @placeholder = "Last Name", @maxlength = "16", @disabled = "disabled", @class = "form-control" })
                    </div>
                </div>
            </div>
            <div class="form-group">
                <div class="row">
                    <div class="col-md-5 text-right margin-top-5">New Username:</div>
                    <div class="col-md-7">
                        @Html.Kendo().TextBox().Name("FPUsername").HtmlAttributes(new { @placeholder = "New Username", @disabled = "disabled", @minlength = "6", @maxlength = "16", @class = "form-control" })
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Model PopUp For Change Password -->

    <div id="chngPassword" class="modal fade " tabindex="-1" data-keyboard="false" role="dialog">
        <div class="modal-dialog" style="margin-top: 8%;">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" id="closeChangePass" data-dismiss="modal">&times;</button>
                    <h4 class="modal-title text-info">Change Password</h4>
                </div>
                <div class="modal-body divChangePassword">
                    <div class="row form-group">
                        <div class="col-md-4 col-md-offset-1 text-right margin-top-5">
                            <span>Old Password</span><sup class="text-danger">*</sup>
                        </div>
                        <div class="col-md-6">
                            @Html.Kendo().TextBox().Name("oldPassword").HtmlAttributes(new { @placeholder = "Old Password", @maxlength = "16", @onpaste = "return false;", @type = "password", @class = "form-control" })
                        </div>
                    </div>
                    <div class="row form-group">
                        <div class="col-md-4 col-md-offset-1 text-right margin-top-5">
                            <span>New Password</span><sup class="text-danger">*</sup>
                        </div>
                        <div class="col-md-6">
                            @Html.Kendo().TextBox().Name("newPassword").HtmlAttributes(new { @placeholder = "New Password", @type = "password", @onpaste = "return false;", @maxlength = "16", @class = "form-control" })
                        </div>
                    </div>
                    <div class="row form-group">
                        <div class="col-md-4 col-md-offset-1 text-right margin-top-5">
                            <span>Confirm New Password</span><sup class="text-danger">*</sup>
                        </div>
                        <div class="col-md-6">
                            @Html.Kendo().TextBox().Name("conPassword").HtmlAttributes(new { @placeholder = "Confirm New Password", @type = "password", @onpaste = "return false;", @maxlength = "16", @class = "form-control" })
                        </div>
                    </div>
                    <div class="row form-group" style="padding-bottom: 30px;">
                        <div class="col-sm-11 text-right">
                            <button type="button" class="btn btn-danger" id="changePassword">Submit</button>
                        </div>
                    </div>
                    <hr>
                    <div class="row">
                        <div class="col-md-12">
                            <p class="text-info">
                                <strong> Valid passwords must meet the following criteria</strong>
                            </p>
                            <ul>
                                <li>
                                    Must have at least 7 characters
                                </li>
                                <li>
                                    Must have no more than 16 characters
                                </li>
                                <li>
                                    Must contain at least 1 digit
                                </li>
                                <li>
                                    Must contain at least 1 capital letter
                                </li>
                                <li>
                                    Must contain at least 1 lowercase letter
                                </li>
                                <li>
                                    Must contain only letters and digits (no symbols)
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
                <hr class="margin-0" />
                <div class="modal-footer">
                    <footer id="copyright">&copy; Copyright @DateTime.Now.Year RetailData LLC . All Rights Reserved</footer>
                </div>
            </div>
        </div>
    </div>

    <!-- Model PopUp For Change Password -->
</div>
