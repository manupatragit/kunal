
@{
    ViewBag.Title = "Registration";
    Layout = "~/Views/Shared/_ApplicationLayout.cshtml";
}


<script src="~/Scripts/AES.js"></script>
<script src="~/Scripts/Application/FirmRegister.js"></script>
<section class="clearfix" id="registration" style="background-color: #077bce;height:99vh;">

    <div class="container-login100">
        <div class="wrap-login100 p-t-30 p-b-50">
            <span class="login100-form-title p-b-41">
                Registration
            </span>
            <div class="">
                <div class="wrap-input100 validate-input" data-validate="Enter name">
                    <input class="input100" type="text" name="firmname" placeholder="Name" id="firmname" style="text-transform:uppercase;">
                </div>
                <div class="wrap-input100 validate-input" data-validate="Enter name">
                    <input class="input100" type="text" name="firmCode" placeholder="Short Code" id="firmCode" style="text-transform:uppercase;">
                </div>

                <div class="wrap-input100 validate-input" data-validate="Enter name">
                    <input class="input100" type="text" name="firmTitle" placeholder="Application Title" id="firmTitle" style="text-transform:uppercase;">
                </div>

                <div class="wrap-input100 validate-input" data-validate="Enter name">
                    <input class="input100" type="text" name="firmAdminUserName" placeholder="Admin User Name" id="firmAdminUserName" style="text-transform:uppercase;">
                </div>

                <div class="wrap-input100 validate-input" data-validate="Enter name">
                    <input class="input100" type="email" name="firmAdminEmail" placeholder="Admin Email Address" id="firmAdminEmail" style="text-transform:uppercase;">
                </div>

                <div class="wrap-input100 validate-input" data-validate="Enter password">
                    <input class="input100" type="password" name="pass" placeholder="Password" id="password" pattern="^[a-zA-Z1-9]{6,}$">
                </div>

                <div class="wrap-input100 validate-input" data-validate="Enter password">
                    <input class="input100" type="password" name="confirmpassword" placeholder="Confirm Password" id="confirmpassword" pattern="^[a-zA-Z1-9]{6,}$">
                </div>

                <div class="container-login100-form-btn m-t-32">
                    <button class="login100-form-btn" id="btnRegister">
                        Register
                    </button>
                </div>
            </div>
        </div>
    </div>

</section>